/* Connector descriptor */
import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/resources/concepts_nls.page"

ds_generic_hr_csv_NLS = NLS {
  title [ en "Generic HR - File" fr "RH Générique - fichier"]
  description [
   en "Retrieves people, organisation and manager information from CSV files. The HR repository name will be the file name."
   fr "Extrait les personnes, organisations et informations de management de fichiers CSV. Le nom du référentiel RH est celui du fichier."]
   cfg.label_repo_code [ en "HR Repository code" fr "Clé du référentiel RH"]
   cfg.label_repo_label  [ en "HR Repository label" fr "Nom du référentiel RH"]
}

ds_generic_hr_csv = Page {
	title: $ds_generic_hr_csv_NLS.title
	tags: "bwds_connector" 
	description: $ds_generic_hr_csv_NLS.description
	icon: "bw_dsm/L/bw_genericapp.png"
	large-icon: "bw_dsm/XL/bw_genericapp.png"
	metadata: (  
	 category -> "identity", 
	 collector -> "bwdsm_generic_hr",
	 destPathVar -> "bw_generic_hr_sourceFolder", 
	 filePattern -> "*.csv",
	 multiFile -> True  ,
	 hasMapping -> True,
    imodelcolumns -> "hrcode;givenname;surname;altname;fullname;titlecode;mail;phone;mobile;internal;employeetype;arrivaldate;departuredate;active;jobtitlecode;jobtitledisplayname;organisationcode;organisationshortname;organisationdisplayname;organisationtype;parentorganisationcode;linemanagerhrcode;linemanagerfullname;managedorgcode",
    imodelcolumnsmandatory ->"False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False;False",
	 imodelcolumnsdescription -> "Employee ID number;First name;Last name;Alternative or maiden name;Complete name;Civil title;Email address;Home phone;Cell phone;Employee? (true for Employee false for Contractor);Type of employee or contract;Hire date;Departure date;Is the employee still in the company? (T/F);Job function code;Job function display name;Department code;Department short name;Display name of job function;Department display name;Parent department code;Manager’s employee ID number;Manager’s employee fullname;Manager’s department code",
	 imodelcolumnsexample -> "ID0000183;Denis;GEOFFRAY;JACOB;Denis GEOFFRAY;Mr;DGEOFFRAY@gmail.com;+1 212-330-3296;+1 212-879-4401;true;CDD;20200121000000;20210530000000;true;TecQu;Qualification;STECQU;STECQU;Quality Assurance;Service;DTECPR;ID0000121;John DOE;STECRD",
	 imodelcolumnstype -> "String;String;String;String;String;String;String;String;String;Boolean;String;Date;Date;Boolean;String;String;String;String;String;String;String;String;String;String"
   )	
}



