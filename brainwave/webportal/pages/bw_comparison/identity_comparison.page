bwc_readonly_identity_comparison = Page {
	title: $bwc_identity_comparisonNLS.title
	dynamic-title: $bwc_identity_comparisonNLS.dyntitle(refidentity.fullname, otheridentity.fullname)
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	enter-event:Set [] to identityperimeter, MultivaluedAdd uid to identityperimeter, MultivaluedAdd otheruid to identityperimeter
	
	mixins: simpleReport
	
	/* Parameters here */
	uid = Parameter {
		label:$bwc_identity_comparisonNLS.refidentity
		multivalued:False
		type:String
		hidden:True
		mandatory:True
	}
	
	uids = Parameter {
		label:$bwc_identity_comparisonNLS.identitiestocomparewith
		multivalued:True
		type:String
		hidden:True
		mandatory:True
	}
	
	/* Variables here */
	selectedRepository = Variable
	selectedShare = Variable
	identityperimeter = Variable {multivalued:True}
	otheruid = Variable
	
	// 0: application
	// 1: permission
	// 2: account
	// 3: group
	// 4: share
	// 5: folder
	selectedTab = Variable {initial:Constant BWC_SELECTEDTAB_APPLICATION type:Integer}
	
	/* Datasets and records here */
	identities = Dataset {
		view:br_identity
	}
	
	refidentity = Record {
		view:br_identityDetail with uid to uid
	}
	refidentityorgs = Dataset {
		view:bwc_identityorgs with uid to uid
	}

	otheridentity = Record {
		view:br_identityDetail with otheruid to uid
	}
	otheridentityorgs = Dataset {
		view:bwc_identityorgs with otheruid to uid
	}

	selectedIdentities = Dataset {
		view:bwc_identities with uids to uids
	}

	// ---------------------------------------
	// application
	appref = Dataset {
		view:bwc_identity_applications with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_APPLICATION then True }
	}
	
	appother = Dataset {
		view:bwc_identity_applications with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_APPLICATION then True }
	}
	
	joinapps = Dataset {
		join:Join {
			primary-dataset:appref
			secondary-dataset:appother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refapps = Dataset {
		join:Join {
			primary-dataset:appref
			secondary-dataset:appother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherapps = Dataset {
		join:Join {
			primary-dataset:appother
			secondary-dataset:appref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}


	// ---------------------------------------
	// permission

	permref = Dataset {
		view:bwc_identity_permissions with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_PERMISSION then True }
	}
	
	permother = Dataset {
		view:bwc_identity_permissions with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_PERMISSION then True }
	}
	
	joinperms = Dataset {
		join:Join {
			primary-dataset:permref
			secondary-dataset:permother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refperms = Dataset {
		join:Join {
			primary-dataset:permref
			secondary-dataset:permother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherperms = Dataset {
		join:Join {
			primary-dataset:permother
			secondary-dataset:permref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// ACCOUNT

	repref = Dataset {
		view:bwc_identity_repositories with uid to uid
		disabled:IntPredicate(selectedTab) { when !=  Constant BWC_SELECTEDTAB_ACCOUNT then True }
	}
	
	repother = Dataset {
		view:bwc_identity_repositories with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_ACCOUNT then True }
	}
	
	joinrep = Dataset {
		join:Join {
			primary-dataset:repref
			secondary-dataset:repother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refrep = Dataset {
		join:Join {
			primary-dataset:repref
			secondary-dataset:repother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherrep = Dataset {
		join:Join {
			primary-dataset:repother
			secondary-dataset:repref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}


	// ---------------------------------------
	// group

	groups = Dataset {
		view:bwc_repositorieswithgroups with identityperimeter to uids
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_GROUP then True }
	}

	groupref = Dataset {
		view:bwc_identity_groups with uid to uid, selectedRepository to repositoryuid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_GROUP then True }
	}
	
	groupother = Dataset {
		view:bwc_identity_groups with otheruid to uid, selectedRepository to repositoryuid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_GROUP then True }
	}
	
	joingroup = Dataset {
		join:Join {
			primary-dataset:groupref
			secondary-dataset:groupother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refgroup = Dataset {
		join:Join {
			primary-dataset:groupref
			secondary-dataset:groupother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	othergroup = Dataset {
		join:Join {
			primary-dataset:groupother
			secondary-dataset:groupref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// share

	shareref = Dataset {
		view:bwc_identity_shares with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_SHARE then True }
	}
	
	shareother = Dataset {
		view:bwc_identity_shares with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_SHARE then True }
	}
	
	joinshares = Dataset {
		join:Join {
			primary-dataset:shareref
			secondary-dataset:shareother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refshares = Dataset {
		join:Join {
			primary-dataset:shareref
			secondary-dataset:shareother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	othershares = Dataset {
		join:Join {
			primary-dataset:shareother
			secondary-dataset:shareref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// shared folder

	sharesincommon = Dataset {
		view:bwc_joinshares with identityperimeter to uids
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_FOLDER then True }
	}

	folderref = Dataset {
		view:bwc_identity_sharedfolders with uid to uid, selectedShare to shareuid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_FOLDER then True }
	}
	
	folderother = Dataset {
		view:bwc_identity_sharedfolders with otheruid to uid, selectedShare to shareuid
		disabled:IntPredicate(selectedTab) { when != Constant BWC_SELECTEDTAB_FOLDER then True }
	}
	
	joinfolders = Dataset {
		join:Join {
			primary-dataset:folderref
			secondary-dataset:folderother
			primary-column:key
			secondary-column:key
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	reffolders = Dataset {
		join:Join {
			primary-dataset:folderref
			secondary-dataset:folderother
			primary-column:key
			secondary-column:key
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherfolders = Dataset {
		join:Join {
			primary-dataset:folderother
			secondary-dataset:folderref
			primary-column:key
			secondary-column:key
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// Page content
	
	SetNavigator {
		data:selectedIdentities
		column:uid
		selection:otheruid
		label:Current fullname
		label-width:320
		show-count:True
		selection-changed-event:Set [] to identityperimeter, MultivaluedAdd uid to identityperimeter, MultivaluedAdd otheruid to identityperimeter
		show-first:True
		show-last:True
		dropdown:Dropdown {
			height:300
			text:Current fullname
		}
		hidden:IntPredicate(Count selectedIdentities) { when <=1 then True }
	}
	
	Grid {
		columns:GridColumn{width:64 align:leading},GridColumn{width:grow group:a  align:leading},GridColumn{width:64},GridColumn{width:grow group:a}
		layout:Layout {grab:horizontal True vertical False hint:height 120}
		
		GridRow {
			GridCell {
				Image {
					image:"/various/photo.jpg"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:refidentity.fullname
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center hint:width 320}
				}
				Text {
					value:refidentity.mail
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:Transform refidentity.internal using bwc_identity_status
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					iterate-on:refidentityorgs
					value:$bwc_identity_comparisonNLS.identityorg(Current jobtitledisplayname, Current displayname)
					compact:True
					styling:detailsText
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
					align:Left
				}
			}
			GridCell {
				Image {
					image:"/various/photo.jpg"				
				}
			}
			GridCell {
				Text {
					value:otheridentity.fullname
					compact:True
					styling:bigTitleStyle
