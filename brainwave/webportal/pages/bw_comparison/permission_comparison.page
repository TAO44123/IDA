/* Import other pages here */
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/bw_htmlwidgets/charts.page"

/* Nationalized labels here */
bwc_permission_comparisonNLS = NLS {
	title [en "Permission comparison" fr "Comparaison de permissions"]
	dyntitle [en "comparing {0} with {1}" fr "comparaison de {0} avec {1}"]

	refaccounts [en "only for {0}" fr "seulement pour {0}"]
	joinaccounts [en "in common" fr "en commun"]
	otheraccounts [en "only for {0}" fr "seulement pour {0}"]

	accountlevel [en "Account level" fr "Comptes"]
	
	internal [en "internal" fr "interne"]
	contractor [en "contractor" fr "prestataire"]

	reference [en "reference profile" fr "profil de référence"]
	other [en "comparison profile" fr "profil de comparaison"]
	
	refprofile [en "reference profile" fr "profil de référence"]
	profilestocomparewith [en "profiles to compare with" fr "profils à comparer"]

	dataviz [en "Data visualisation" fr "Analyse graphique"]
	tooltipSuffix [en "accounts" fr "comptes"]
	tooltipnSuffix [en "accounts in common" fr "comptes en commun"]
}

BWCG_SELECTEDTAB_ACCOUNT 		= Constant { type:Integer value:0}
BWCG_SELECTEDTAB_DATAVIZ 		= Constant { type:Integer value:1}

bwc_permission_status = BooleanMapping {
	when True then $bwc_permission_comparisonNLS.internal
	when False then $bwc_permission_comparisonNLS.contractor
}

bwc_permission_comparison_search = Page {
	title: $bwc_permission_comparisonNLS.title
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
//	tags:"permission", "byuids"
	feature:bwc_groupcomparisonsearchanalytics
	conditional-redirect:ConditionalRedirect{condition:True target:Page bwc_permission_comparison with uids to uids }
	
	uids = Parameter {
		multivalued:True
		mandatory:True
	}
	
}

/**
 * <span style="white-space: pre-line">
 * Compare two permission direct members
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>first group</li>
 * <li><b>inuids </b>second group</li>
 * </ul>
 * </span>
 */
bwc_permission_comparison_fragment = PageFragment {
	enter-event:Set [] to groupperimeter, MultivaluedAdd inuid to groupperimeter, MultivaluedAdd otheruid to groupperimeter
	
	mixins: simpleReport
	/*
	dock-left: Dock {
		collapsed:True
		collapsible:True
		width:300
		
		ParametersEdition {
			parameters:uids inline
		}
	}
	*/
	/* Parameters here */
	inuid = Variable {
		type:String
	}
	
	inuids = Variable {
		multivalued:True
		type:String
	}
	
	/* Variables here */
	selectedRepository = Variable
	selectedShare = Variable
	groupperimeter = Variable {multivalued:True}
	otheruid = Variable
	
	// 0: account
	selectedTab = Variable {initial:Constant BWCG_SELECTEDTAB_ACCOUNT type:Integer}
	
	/* Datasets and records here */
	permissions = Dataset {
		view:bwc_permissionslist
	}
	
	refpermission = Record {
		view:br_permissionDetail with inuid to uid
	}
	otherpermission = Record {
		view:br_permissionDetail with otheruid to uid
	}

	selectedPermissions = Dataset {
		view:bwc_permissions with inuids to uids
	}

	// ---------------------------------------
	// application
	permissionref = Dataset {
		view:bwc_permission_accounts with inuid to uid
		disabled:
			AndPredicate {
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
			}		
	}
	
	permissionother = Dataset {
		view:bwc_permission_accounts with otheruid to uid
		disabled:
			AndPredicate {
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
			}		
	}
	
	joinaccounts = Dataset {
		join:Join {
			primary-dataset:permissionref
			secondary-dataset:permissionother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refaccounts = Dataset {
		join:Join {
			primary-dataset:permissionref
			secondary-dataset:permissionother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current otheridentifier) { when IsEmpty then False otherwise True }
	}

	otheraccounts = Dataset {
		join:Join {
			primary-dataset:permissionother
			secondary-dataset:permissionref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refidentifier) { when IsEmpty then False otherwise True }
	}

	unionaccounts = Dataset {
		union: Union {
			datasets:permissionref discriminator $bwc_permission_comparisonNLS.reference, permissionother discriminator $bwc_permission_comparisonNLS.other
			discriminator-column:discr 
		}
		disabled:IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
	}


	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// Page content

	SetNavigator {
		data:selectedPermissions
		column:uid
		selection:otheruid
		label:Concat(Current displayname, ' / ', Current applicationdisplayname)
		label-width:320
		show-count:True
		selection-changed-event:Set [] to groupperimeter, MultivaluedAdd inuid to groupperimeter, MultivaluedAdd otheruid to groupperimeter
		show-first:True
		show-last:True
		dropdown:Dropdown {
			height:300
			text:Concat(Current displayname, ' / ', Current applicationdisplayname)
		}
		hidden:IntPredicate(Count selectedPermissions) { when <=1 then True }
	}
	
	Grid {
		columns:GridColumn{width:64 align:leading},GridColumn{width:grow group:a  align:leading},GridColumn{width:64},GridColumn{width:grow group:a}
		layout:Layout {grab:horizontal True vertical False hint:height 120}
		
		GridRow {
			GridCell {
				Image {
					image:"/48/audit/permission_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:refpermission.displayname
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False  hint:width 320}
				}
				Text {
					value:refpermission.code
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refpermission.description
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refpermission.application_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
			GridCell {
				Image {
					image:"/48/audit/permission_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:otherpermission.displayname
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint:width 320}
				}
				Text {
					value:otherpermission.code
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:otherpermission.description
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:otherpermission.application_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
		}
	}

