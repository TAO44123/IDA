bwc_permission_comparison_dialog = Dialog {
	title: $bwc_permission_comparisonNLS.title
	width:1366
	height:720
	buttons:OkButton
	
	inuid = Variable
	inotheruid = Variable
	
	
	IncludeFragment (bwc_permission_comparison_fragment with value-of inuid to inuid, value-of inotheruid to inuids)
}

bwc_permission_comparison = Page {
	title: $bwc_permission_comparisonNLS.title
//	dynamic-title: $bwc_permission_comparisonNLS.dyntitle(Concat(refpermission.displayname,'/',refpermission.application_displayname) , Concat(otherpermission.displayname,'/',otherpermission.application_displayname))
//	tags: "permission" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwc_groupcomparisonpage
	
	mixins: simpleReport
	/*
	dock-left: Dock {
		collapsed:True
		collapsible:True
		width:300
		
		ParametersEdition {
			parameters:uids inline
		}
	}
	*/
	/* Parameters here */
	uid = Parameter {
		label:$bwc_permission_comparisonNLS.refprofile
		multivalued:False
		type:String
		constraint:Picker {picker:groupPicker returning outUid display:Display { value: Concat(Current displayname, ' (',Current applicationdisplayname,')') data: permissions match uid  } }
		mandatory:True
		hidden:True
	}
	
	uids = Parameter {
		label:$bwc_permission_comparisonNLS.profilestocomparewith
		multivalued:True
		type:String
		constraint:Picker {picker:groupPicker returning outUid display:Display { value: Concat(Current displayname, ' (',Current applicationdisplayname,')') data: permissions match uid  } }
		mandatory:True
		hidden:True
	}

	permissions = Dataset {
		view:bwc_permissionslist
	}

	IncludeFragment (bwc_permission_comparison_fragment with value-of uid to inuid, value-of uids to inuids)  	
}


