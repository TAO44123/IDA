/* Import other pages here */
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pickers.page"

/* Nationalized labels here */
bwc_account_comparisonNLS = NLS {
	title [en "Account comparison" fr "Comparaison de comptes"]
	dyntitle [en "comparing {0} with {1}" fr "comparaison de {0} avec {1}"]

	refapps [en "only for {0}" fr "seulement pour {0}"]
	joinapps [en "in common" fr "en commun"]
	otherapps [en "only for {0}" fr "seulement pour {0}"]

	refperms [en "only for {0}" fr "seulement pour {0}"]
	joinperms [en "in common" fr "en commun"]
	otherperms [en "only for {0}" fr "seulement pour {0}"]

	refgroup [en "only for {0}" fr "seulement pour {0}"]
	joingroup [en "in common" fr "en commun"]
	othergroup [en "only for {0}" fr "seulement pour {0}"]

	refshare [en "only for {0}" fr "seulement pour {0}"]
	joinshare [en "in common" fr "en commun"]
	othershare [en "only for {0}" fr "seulement pour {0}"]

	reffolder [en "only for {0}" fr "seulement pour {0}"]
	joinfolder [en "in common" fr "en commun"]
	otherfolder [en "only for {0}" fr "seulement pour {0}"]
	
	identityorg [en "{0} in {1}" fr "{0} dans {1}"]
	
	rights [en "Rights" fr "Droits"] 
	folder [en "Folder" fr "Répertoire"]
	share [en "Share" fr "Partage"]
	
	applicationlevel [en "Application level" fr "Applications"]
	permissionlevel [en "Permission level" fr "Permissions"]
	accountlevel [en "Account level" fr "Comptes"]
	grouplevel [en "Group level" fr "groupes"]
	sharelevel [en "Share level" fr "Partages"]
	folderlevel [en "Folder level" fr "Répertoires"]
	
	internal [en "internal" fr "interne"]
	contractor [en "contractor" fr "prestataire"]
	
	refaccount [en "reference account" fr "compte de référence"]
	accountstocomparewith [en "accounts to compare with" fr "comptes à comparer"]
	
	selectedrepository [en "selected repository" fr "référentiel sélectionné"]
	selectedshare [en "selected share" fr "partage sélectionné"]

	filterto [en "Filtered to {0}" fr "Filtré sur {0}"]
}

BWCA_SELECTEDTAB_APPLICATION 	= Constant { type:Integer value:0}
BWCA_SELECTEDTAB_PERMISSION 		= Constant { type:Integer value:1}
BWCA_SELECTEDTAB_ACCOUNT 		= Constant { type:Integer value:2}
BWCA_SELECTEDTAB_GROUP 			= Constant { type:Integer value:3}
BWCA_SELECTEDTAB_SHARE 			= Constant { type:Integer value:4}
BWCA_SELECTEDTAB_FOLDER 			= Constant { type:Integer value:5}

bwc_account_status = BooleanMapping {
	when True then $bwc_account_comparisonNLS.internal
	when False then $bwc_account_comparisonNLS.contractor
}

bwc_account_comparison_search = Page {
	title: $bwc_account_comparisonNLS.title
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
//	tags:"account", "byuids"
	feature:bwc_accountcomparisonsearchanalytics
	conditional-redirect:ConditionalRedirect{condition:True target:Page bwc_account_comparison with uids to uids }
	
	uids = Parameter {
		multivalued:True
		mandatory:True
	}
	
}

bwc_account_comparison = Page {
	title: $bwc_account_comparisonNLS.title
	dynamic-title: $bwc_account_comparisonNLS.dyntitle(Concat(refaccount.login,'/',refaccount.repository_displayname) , Concat(otheraccount.login,'/',otheraccount.repository_displayname))
//	tags: "account" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwc_accountcomparisonpage
	enter-event:Set [] to accountperimeter, MultivaluedAdd uid to accountperimeter, MultivaluedAdd otheruid to accountperimeter
	
	mixins: simpleReport
	/*
	dock-left: Dock {
		collapsed:True
		collapsible:True
		width:300
		
		ParametersEdition {
			parameters:uids inline
		}
	}
	*/
	
	/* Parameters here */
	uid = Parameter {
		label:$bwc_account_comparisonNLS.refaccount
		multivalued:False
		type:String
		constraint:Picker {picker:accountPicker returning outUid display:Display { value: Concat(Current login, ' (',Current username, ' / ',Current repositorydisplayname,')') data: accounts match uid  } }
		mandatory:True
		hidden:True
	}
	
	uids = Parameter {
		label:$bwc_account_comparisonNLS.accountstocomparewith
		multivalued:True
		type:String
		constraint:Picker {picker:accountPicker returning outUid display:Display { value: Concat(Current login, ' (',Current username, ' / ',Current repositorydisplayname,')') data: accounts match uid  } }
		mandatory:True
		hidden:True
	}
	
	inshowapplication = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inshowpermission = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inshowaccount = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inshowgroup = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inshowshare = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inshowfolder = Parameter {
		default:True
		type:Boolean
		mandatory:False
		hidden:True
	}
	inapplicationuid = Parameter { // filter results for a given application
		type:String
		mandatory:False
		hidden:True
	}
	insharenuid = Parameter { // filter results for a given share
		type:String
		mandatory:False
		hidden:True
	}

	
	/* Variables here */
	selectedRepository = Variable
	selectedShare = Variable
	accountperimeter = Variable {multivalued:True}
	otheruid = Variable
	
	// 0: application
	// 1: permission
	// 2: account
	// 3: group
	// 4: share
	// 5: folder
	selectedTab = Variable {initial:Constant BWCA_SELECTEDTAB_APPLICATION type:Integer}
	
	/* Datasets and records here */
	accounts = Dataset {
		view:bwc_accountslist
	}
	
	refaccount = Record {
		view:br_accountDetail with uid to uid
	}
	otheraccount = Record {
		view:br_accountDetail with otheruid to uid
	}

	selectedAccounts = Dataset {
		view:bwc_accounts with uids to uids
	}

	// ---------------------------------------
	// application
	appref = Dataset {
		view:bwc_account_applications with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_APPLICATION then True }
	}
	
	appother = Dataset {
		view:bwc_account_applications with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_APPLICATION then True }
	}
	
	joinapps = Dataset {
		join:Join {
			primary-dataset:appref
			secondary-dataset:appother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refapps = Dataset {
		join:Join {
			primary-dataset:appref
			secondary-dataset:appother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherapps = Dataset {
		join:Join {
			primary-dataset:appother
			secondary-dataset:appref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}


	// ---------------------------------------
	// permission

	application = Record {
		view:br_applicationDetail with inapplicationuid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_PERMISSION then True }
	}
	permref = Dataset {
		view:bwc_account_permissions with uid to uid, inapplicationuid to applicationuid unless-empty
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_PERMISSION then True }
	}
	
	permother = Dataset {
		view:bwc_account_permissions with otheruid to uid, inapplicationuid to applicationuid unless-empty
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_PERMISSION then True }
	}
	
	joinperms = Dataset {
		join:Join {
			primary-dataset:permref
			secondary-dataset:permother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refperms = Dataset {
		join:Join {
			primary-dataset:permref
			secondary-dataset:permother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherperms = Dataset {
		join:Join {
			primary-dataset:permother
			secondary-dataset:permref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// group

	groups = Dataset {
		view:bwc_accountrepositorieswithgroups with accountperimeter to uids
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_GROUP then True }
	}

	groupref = Dataset {
		view:bwc_account_groups with uid to uid, selectedRepository to repositoryuid unless-empty
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_GROUP then True }
	}
	
	groupother = Dataset {
		view:bwc_account_groups with otheruid to uid, selectedRepository to repositoryuid unless-empty
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_GROUP then True }
	}
	
	joingroup = Dataset {
		join:Join {
			primary-dataset:groupref
			secondary-dataset:groupother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refgroup = Dataset {
		join:Join {
			primary-dataset:groupref
			secondary-dataset:groupother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	othergroup = Dataset {
		join:Join {
			primary-dataset:groupother
			secondary-dataset:groupref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// share

	shareref = Dataset {
		view:bwc_account_shares with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_SHARE then True }
	}
	
	shareother = Dataset {
		view:bwc_account_shares with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_SHARE then True }
	}
	
	joinshares = Dataset {
		join:Join {
			primary-dataset:shareref
			secondary-dataset:shareother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refshares = Dataset {
		join:Join {
			primary-dataset:shareref
			secondary-dataset:shareother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	othershares = Dataset {
		join:Join {
			primary-dataset:shareother
			secondary-dataset:shareref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ---------------------------------------
	// shared folder

	sharesincommon = Dataset {
		view:bwc_accountjoinshares with accountperimeter to uids, insharenuid to shareuid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_FOLDER then True }
	}

	folderref = Dataset {
		view:bwc_account_sharedfolders with uid to uid, selectedShare to shareuid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_FOLDER then True }
	}
	
	folderother = Dataset {
		view:bwc_account_sharedfolders with otheruid to uid, selectedShare to shareuid
		disabled:IntPredicate(selectedTab) { when != Constant BWCA_SELECTEDTAB_FOLDER then True }
	}
	
	joinfolders = Dataset {
		join:Join {
			primary-dataset:folderref
			secondary-dataset:folderother
			primary-column:key
			secondary-column:key
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	reffolders = Dataset {
		join:Join {
			primary-dataset:folderref
			secondary-dataset:folderother
			primary-column:key
			secondary-column:key
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current othercode) { when IsEmpty then False otherwise True }
	}

	otherfolders = Dataset {
		join:Join {
			primary-dataset:folderother
			secondary-dataset:folderref
			primary-column:key
			secondary-column:key
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refcode) { when IsEmpty then False otherwise True }
	}

	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// Page content
	
	SetNavigator {
		data:selectedAccounts
		column:uid
		selection:otheruid
		label:Concat(Current login, ' / ', Current repositorydisplayname)
		label-width:320
		show-count:True
		selection-changed-event:Set [] to accountperimeter, MultivaluedAdd uid to accountperimeter, MultivaluedAdd otheruid to accountperimeter
		show-first:True
		show-last:True
		dropdown:Dropdown {
			height:300
			text:Concat(Current login, ' / ', Current repositorydisplayname)
		}
		hidden:IntPredicate(Count selectedAccounts) { when <=1 then True }
	}
	
	Grid {
		columns:GridColumn{width:64 align:leading},GridColumn{width:grow group:a  align:leading},GridColumn{width:64},GridColumn{width:grow group:a}
		layout:Layout {grab:horizontal True vertical False hint:height 120}
		
		GridRow {
			GridCell {
				Image {
					image:"/48/audit/account_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:refaccount.login
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint:width 320}
					//target:Activity Account Detail with uid to paramAccountUid
				}
				Text {
					value:refaccount.username
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refaccount.mail
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refaccount.repository_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
			GridCell {
				Image {
					image:"/48/audit/account_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:otheraccount.login
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint:width 320}
					// target:Activity Account Detail with otheruid to paramAccountUid
				}
				Text {
					value:otheraccount.username
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:otheraccount.mail
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:otheraccount.repository_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
		}
	}

	TabFolder {
		TabItem {
			text:$bwc_account_comparisonNLS.applicationlevel
			icon:"/16/audit/application_16.png"
			hidden:Not BooleanPredicate(inshowapplication)
			activation-event:Set  Constant BWCA_SELECTEDTAB_APPLICATION to selectedTab

			Grid {
				columns:GridColumn,GridColumn,GridColumn
				
				GridRow {
					GridCell {
						Text {
							value:@srv_truncatestring($bwc_account_comparisonNLS.refapps(refaccount.login) to string, 30 to maxlength)
							tooltip:$bwc_account_comparisonNLS.refapps(refaccount.login)
							compact:True
						}
						Table {
							data:refapps
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
					GridCell {
						Text {
							value:$bwc_account_comparisonNLS.joinapps
							compact:True
						}
						Table {
							data:joinapps
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
					GridCell {
						Text {
							value:@srv_truncatestring($bwc_account_comparisonNLS.otherapps(otheraccount.login) to string, 30 to maxlength)
							tooltip:$bwc_account_comparisonNLS.otherapps(otheraccount.login)
							compact:True
						}
						Table {
							data:otherapps
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
				}
			}
		}
		TabItem {
			text:$bwc_account_comparisonNLS.permissionlevel
			icon:"/16/audit/permission_16.png"
			hidden:Not BooleanPredicate(inshowpermission)
			activation-event:Set  Constant BWCA_SELECTEDTAB_PERMISSION to selectedTab
		
			Header {
				value:$bwc_account_comparisonNLS.filterto(application.displayname)
				hidden:StringPredicate(inapplicationuid) { when IsEmpty then True otherwise False }
			}
			Grid {
				columns:GridColumn,GridColumn,GridColumn
				
				GridRow {
					GridCell {
						Text {
							value:@srv_truncatestring($bwc_account_comparisonNLS.refperms(refaccount.login) to string, 30 to maxlength)
							tooltip:$bwc_account_comparisonNLS.refperms(refaccount.login)
							compact:True
						}
						Table {
							data:refperms
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								header:$permission.code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$permission.concept
								width:100%
							}
							Column {
								sortable:True
								column:description
								filterable:True
								width:100%
								initially-masked:True
							}
							Column {
								sortable:True
								column:applicationdisplayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
					GridCell {
						Text {
							value:$bwc_account_comparisonNLS.joinperms
							compact:True
						}
						Table {
							data:joinperms
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								header:$permission.code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$permission.concept
								width:100%
							}
							Column {
								sortable:True
								column:description
								filterable:True
								width:100%
								initially-masked:True
							}
							Column {
								sortable:True
								column:applicationdisplayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
					GridCell {
						Text {
							value:@srv_truncatestring($bwc_account_comparisonNLS.otherperms(otheraccount.login) to string, 30 to maxlength)
							tooltip:$bwc_account_comparisonNLS.otherperms(otheraccount.login)
							compact:True
						}
						Table {
							data:otherperms
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							persist-configuration:True
							show-count:True
							show-filter:True
						
							Column {
								sortable:True
								column:code
								header:$permission.code
								initially-masked:True
							}
							Column {
								sortable:True
								column:displayname
								filterable:True
								header:$permission.concept
								width:100%
							}
							Column {
								sortable:True
								column:description
								filterable:True
								width:100%
								initially-masked:True
							}
							Column {
								sortable:True
								column:applicationdisplayname
								filterable:True
								header:$application.concept
								width:100%
							}
						}
					}				
				}
			}
		}
		TabItem {
			text:$bwc_account_comparisonNLS.grouplevel
			icon:"/16/audit/group_16.png"
			hidden:Not BooleanPredicate(inshowgroup)
			activation-event:Set  Constant BWCA_SELECTEDTAB_GROUP to selectedTab
		
			Combo {
				options:Dynamic {
					data:groups
					text:Current displayname
					value:Current uid
				}
				variable:selectedRepository
				label:$bwc_account_comparisonNLS.selectedrepository
