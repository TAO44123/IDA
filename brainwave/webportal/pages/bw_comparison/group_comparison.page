							tooltip:$bwc_group_comparisonNLS.refaccounts(refgroup.displayname)
							compact:True
						}
						Table {
							data:refaccounts
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							show-count:True
							show-filter:True
							persist-configuration:True
						
							Column {
								column:identifier
								filterable:True
								sortable:True
								width:100px
								header:$account.identifier
								initially-masked:True
							}
							Column {
								column:login
								filterable:True
								sortable:True
								width:100px
								header:$account.login
							}
							Column {
								column:username
								filterable:True
								sortable:True
								width:160px
								header:$account.username
							}
							Column {
								column:mail
								filterable:True
								sortable:True
								width:160px
								header:$account.mail
								initially-masked:True
							}
							Column {
								column:creationdate
								filterable:True
								sortable:True
								width:100px
								header:$account.creationdate
								initially-masked:True
							}
							Column {
								column:lastlogindate
								filterable:True
								sortable:True
								width:100px
								header:$account.lastlogindate
								initially-masked:True
							}
							Column {
								column:repositorydisplayname
								filterable:True
								sortable:True
								width:100px
								header:$repository.concept
							}
							Column {
								column:service
								filterable:True
								sortable:True
								width:100px
								header:$account.service
								initially-masked:True
							}
							Column {
								column:identityhrcode
								filterable:True
								sortable:True
								width:100px
								header:$pidentity.hrcode
								initially-masked:True
							}
							Column {
								column:identityfullname
								filterable:True
								sortable:True
								width:160px
								header:$pidentity.fullname
								initially-masked:True
							}
							Column {
								column:identitymail
								filterable:True
								sortable:True
								width:160px
								header:$pidentity.mail
								initially-masked:True
							}
						}
					}				
					GridCell {
						Text {
							value:$bwc_group_comparisonNLS.joinaccounts
							compact:True
						}
						Table {
							data:joinaccounts
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							show-count:True
							show-filter:True
							persist-configuration:True
						
							Column {
								column:identifier
								filterable:True
								sortable:True
								width:100px
								header:$account.identifier
								initially-masked:True
							}
							Column {
								column:login
								filterable:True
								sortable:True
								width:100px
								header:$account.login
							}
							Column {
								column:username
								filterable:True
								sortable:True
								width:160px
								header:$account.username
							}
							Column {
								column:mail
								filterable:True
								sortable:True
								width:160px
								header:$account.mail
								initially-masked:True
							}
							Column {
								column:creationdate
								filterable:True
								sortable:True
								width:100px
								header:$account.creationdate
								initially-masked:True
							}
							Column {
								column:lastlogindate
								filterable:True
								sortable:True
								width:100px
								header:$account.lastlogindate
								initially-masked:True
							}
							Column {
								column:repositorydisplayname
								filterable:True
								sortable:True
								width:100px
								header:$repository.concept
							}
							Column {
								column:service
								filterable:True
								sortable:True
								width:100px
								header:$account.service
								initially-masked:True
							}
							Column {
								column:identityhrcode
								filterable:True
								sortable:True
								width:100px
								header:$pidentity.hrcode
								initially-masked:True
							}
							Column {
								column:identityfullname
								filterable:True
								sortable:True
								width:160px
								header:$pidentity.fullname
								initially-masked:True
							}
							Column {
								column:identitymail
								filterable:True
								sortable:True
								width:160px
								header:$pidentity.mail
								initially-masked:True
							}
						}
					}				
					GridCell {
						Text {
							value:@srv_truncatestring($bwc_group_comparisonNLS.otheraccounts(othergroup.displayname) to string, 30 to maxlength)
							tooltip:$bwc_group_comparisonNLS.otheraccounts(othergroup.displayname)
							compact:True
						}
						Table {
							data:otheraccounts
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							show-count:True
							show-filter:True
							persist-configuration:True
						
							Column {
								column:identifier
								filterable:True
								sortable:True
								width:100px
								header:$account.identifier
								initially-masked:True
							}
							Column {
								column:login
