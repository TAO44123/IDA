bwc_group_comparison_dialog = Dialog {
	title: $bwc_group_comparisonNLS.title
	width:1366
	height:720
	buttons:OkButton
	
	inuid = Variable
	inotheruid = Variable
	
	
	IncludeFragment (bwc_group_comparison_fragment with value-of inuid to inuid, value-of inotheruid to inotheruid)
}

bwc_group_comparison = Page {
	title: $bwc_group_comparisonNLS.title
	dynamic-title: $bwc_group_comparisonNLS.dyntitle(Concat(refgroup.displayname,'/',refgroup.repository_displayname) , Concat(othergroup.displayname,'/',othergroup.repository_displayname))
//	tags: "group" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwc_groupcomparisonpage
	enter-event:Set [] to groupperimeter, MultivaluedAdd uid to groupperimeter, MultivaluedAdd otheruid to groupperimeter
	
	mixins: simpleReport
	/*
	dock-left: Dock {
		collapsed:True
		collapsible:True
		width:300
		
		ParametersEdition {
			parameters:uids inline
		}
	}
	*/
	/* Parameters here */
	uid = Parameter {
		label:$bwc_group_comparisonNLS.refgroup
		multivalued:False
		type:String
		constraint:Picker {picker:groupPicker returning outUid display:Display { value: Concat(Current displayname, ' (',Current repositorydisplayname,')') data: groups match uid  } }
		mandatory:True
		hidden:True
	}
	
	uids = Parameter {
		label:$bwc_group_comparisonNLS.groupstocomparewith
		multivalued:True
		type:String
		constraint:Picker {picker:groupPicker returning outUid display:Display { value: Concat(Current displayname, ' (',Current repositorydisplayname,')') data: groups match uid  } }
		mandatory:True
		hidden:True
	}
	
	/* Variables here */
	selectedRepository = Variable
	selectedShare = Variable
	groupperimeter = Variable {multivalued:True}
	otheruid = Variable
	
	// 0: account
	selectedTab = Variable {initial:Constant BWCG_SELECTEDTAB_ACCOUNT type:Integer}
	
	/* Datasets and records here */
	groups = Dataset {
		view:bwc_groupslist
	}
	
	refgroup = Record {
		view:br_groupDetail with uid to uid
	}
	othergroup = Record {
		view:br_groupDetail with otheruid to uid
	}

	selectedGroups = Dataset {
		view:bwc_groups with uids to uids
	}

	// ---------------------------------------
	// application
	accountref = Dataset {
		view:bwc_group_accounts with uid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
	}
	
	accountother = Dataset {
		view:bwc_group_accounts with otheruid to uid
		disabled:IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
	}
	
	joinaccounts = Dataset {
		join:Join {
			primary-dataset:accountref
			secondary-dataset:accountother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refaccounts = Dataset {
		join:Join {
			primary-dataset:accountref
			secondary-dataset:accountother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current otheridentifier) { when IsEmpty then False otherwise True }
	}

	otheraccounts = Dataset {
		join:Join {
			primary-dataset:accountother
			secondary-dataset:accountref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refidentifier) { when IsEmpty then False otherwise True }
	}



	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// ------------------------------------------------------------------------------------------------------------------------------
	// Page content
	
	SetNavigator {
		data:selectedGroups
		column:uid
		selection:otheruid
		label:Concat(Current displayname, ' / ', Current repositorydisplayname)
		label-width:320
		show-count:True
		selection-changed-event:Set [] to groupperimeter, MultivaluedAdd uid to groupperimeter, MultivaluedAdd otheruid to groupperimeter
		show-first:True
		show-last:True
		dropdown:Dropdown {
			height:300
			text:Concat(Current displayname, ' / ', Current repositorydisplayname)
		}
		hidden:IntPredicate(Count selectedGroups) { when <=1 then True }
	}
	
	
	IncludeFragment (bwc_group_comparison_fragment with value-of uid to inuid, otheruid binds-to inotheruid) 
}


