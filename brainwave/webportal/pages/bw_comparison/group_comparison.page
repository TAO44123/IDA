/* Import other pages here */
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/bw_htmlwidgets/charts.page"

/* Nationalized labels here */
bwc_group_comparisonNLS = NLS {
	title [en "Group comparison" fr "Comparaison de groupes"]
	dyntitle [en "comparing {0} with {1}" fr "comparaison de {0} avec {1}"]

	refaccounts [en "only for {0}" fr "seulement pour {0}"]
	joinaccounts [en "in common" fr "en commun"]
	otheraccounts [en "only for {0}" fr "seulement pour {0}"]

	accountlevel [en "Account level" fr "Comptes"]
	
	internal [en "internal" fr "interne"]
	contractor [en "contractor" fr "prestataire"]
	
	refgroup [en "reference group" fr "groupe de référence"]
	groupstocomparewith [en "groups to compare with" fr "groupes à comparer"]
	
	reference [en "reference group" fr "groupe de référence"]
	other [en "comparison group" fr "groupe de comparaison"]
	
	dataviz [en "Data visualisation" fr "Analyse graphique"]
	tooltipSuffix [en "accounts" fr "comptes"]
	tooltipnSuffix [en "accounts in common" fr "comptes en commun"]
}

BWCG_SELECTEDTAB_ACCOUNT 		= Constant { type:Integer value:0}
BWCG_SELECTEDTAB_DATAVIZ		= Constant { type:Integer value:1}

bwc_group_status = BooleanMapping {
	when True then $bwc_group_comparisonNLS.internal
	when False then $bwc_group_comparisonNLS.contractor
}

bwc_group_comparison_search = Page {
	title: $bwc_group_comparisonNLS.title
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
//	tags:"group", "byuids"
	feature:bwc_groupcomparisonsearchanalytics
	conditional-redirect:ConditionalRedirect{condition:True target:Page bwc_group_comparison with uids to uids }
	
	uids = Parameter {
		multivalued:True
		mandatory:True
	}
	
}

/**
 * <span style="white-space: pre-line">
 * Compare two group direct members
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>first group</li>
 * <li><b>inotheruid </b>second group</li>
 * </ul>
 * </span>
 */
bwc_group_comparison_fragment = PageFragment {
	mixins: simpleReport

	inuid = Variable
	inotheruid = Variable
	

	// 0: account
	selectedTab = Variable {initial:Constant BWCG_SELECTEDTAB_ACCOUNT type:Integer}
	
	/* Datasets and records here */
	refgroup = Record {
		view:br_groupDetail with inuid to uid
	}
	othergroup = Record {
		view:br_groupDetail with inotheruid to uid
	}

	// ---------------------------------------
	// application
	accountref = Dataset {
		view:bwc_group_accounts with inuid to uid
		disabled:
			AndPredicate {
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
			}		
	}
	
	accountother = Dataset {
		view:bwc_group_accounts with inotheruid to uid
		disabled:
			AndPredicate {
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_ACCOUNT then True }
				IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
			}		
	}
	
	joinaccounts = Dataset {
		join:Join {
			primary-dataset:accountref
			secondary-dataset:accountother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:mandatory
		}
	}

	refaccounts = Dataset {
		join:Join {
			primary-dataset:accountref
			secondary-dataset:accountother
			primary-column:uid
			secondary-column:uid
			secondary-prefix:other
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current otheridentifier) { when IsEmpty then False otherwise True }
	}

	otheraccounts = Dataset {
		join:Join {
			primary-dataset:accountother
			secondary-dataset:accountref
			primary-column:uid
			secondary-column:uid
			secondary-prefix:ref
			primary-optional:False
			secondary-cardinality:optional
		}
		excludes:StringPredicate(Current refidentifier) { when IsEmpty then False otherwise True }
	}

	unionaccounts = Dataset {
		union: Union {
			datasets:accountref discriminator $bwc_group_comparisonNLS.reference, accountother discriminator $bwc_group_comparisonNLS.other
			discriminator-column:discr 
		}
		disabled:IntPredicate(selectedTab) { when != Constant BWCG_SELECTEDTAB_DATAVIZ then True }
	}


	Grid {
		columns:GridColumn{width:64 align:leading},GridColumn{width:grow group:a  align:leading},GridColumn{width:64},GridColumn{width:grow group:a}
		layout:Layout {grab:horizontal True vertical False hint:height 120}
		
		GridRow {
			GridCell {
				Image {
					image:"/48/audit/group_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:refgroup.displayname
					tooltip:refgroup.displayname
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False  hint:width 320}
					//target:Activity Account Detail with uid to paramAccountUid
				}
				Text {
					value:refgroup.code
					tooltip:refgroup.code
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refgroup.comment
					tooltip:refgroup.comment
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:refgroup.repository_displayname
					tooltip:refgroup.repository_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
			GridCell {
				Image {
					image:"/48/audit/group_48.png"				
				}
			}
			GridCell {
				align:leading
				Text {
					value:othergroup.displayname
					tooltip:othergroup.displayname
					compact:True
					styling:bigTitleStyle
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint:width 320}
					//target:Activity Account Detail with otheruid to paramAccountUid
				}
				Text {
					value:othergroup.code
					tooltip:othergroup.code
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:othergroup.comment
					tooltip:othergroup.comment
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
				Text {
					value:othergroup.repository_displayname
					tooltip:othergroup.repository_displayname
					compact:True
					styling:detailsText
					align:Left
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False hint: height 16 width 320}
				}
			}
		}
	}

	TabFolder {
		TabItem {
			text:$bwc_group_comparisonNLS.accountlevel
			icon:"/16/audit/account_16.png"
			activation-event:Set  Constant BWCG_SELECTEDTAB_ACCOUNT to selectedTab

			Grid {
				columns:GridColumn,GridColumn,GridColumn
				
				GridRow {
					GridCell {
						Text {
