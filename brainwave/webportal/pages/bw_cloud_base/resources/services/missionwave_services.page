
// MissionWaves

listMissionWaves = DatasetService {
	reference: cloud
	selection: listMissionWaves
	
	recordUid = Column {
		type: Integer
	}
	name = Column
	endpointName = Column
	timeslotUid = Column
	hidden = Column
}

getMissionWave = EventService {
	reference: cloud
	selection: getMissionWave
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	
	name = Output
	description = Output
	endpointId = Output {
		type: Integer
	}
	timeslotUid = Output
	hidden = Output {
		type: Boolean
	}
	error = Output
}

saveMissionWave = EventService {
	reference: cloud
	selection: saveMissionWave
	
	recordUid = Input {
		type: Integer
	}
	name = Input
	description = Input
	endpointId = Input {
		type: Integer
	}
	
	error = Output
}

deleteMissionWave = EventService {
	reference: cloud
	selection: deleteMissionWave
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	
	error = Output
}

hideMissionWave = EventService {
	reference: cloud
	selection: hideMissionWave
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	hide = Input {
		type: Boolean
		default: True
	}
	
	error = Output
}

resetMissionWaveTimeslot = EventService {
	reference: cloud
	selection: resetMissionWaveTimeslot
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	
	error = Output
}

duplicateMissionWave = EventService {
	reference: cloud
	selection: duplicateMissionWave
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	newName = Input {
		type: String
		mandatory: True
	}
	newDescription = Input
	
	error = Output
}

// MissionWaveStages

listMissionWaveStages = DatasetService {
	reference: cloud
	selection: listMissionWaveStages
	
	missionWaveId = Input {
		type: Integer
		mandatory: True
	}
	language = Input
	
	recordUid = Column {
		type: Integer
	}
	order = Column {
		type: Integer
	}
	type = Column
	key = Column
	val = Column
	label = Column
	available = Column {
		type: Boolean
	}
	completed = Column {
		type: Boolean
	}
}

getMissionWaveStage = EventService {
	reference: cloud
	selection: getMissionWaveStage
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	language = Input
	
	order = Output {
		type: Integer
	}
	type = Output
	key = Output
	val = Output
	label = Output
	labelsLang = Output {
		type: String
		multivalued: True
	}
	labelsVal = Output {
		type: String
		multivalued: True
	}
	available = Output {
		type: Boolean
	}
	completed = Output {
		type: Boolean
	}
	error = Output
}

saveMissionWaveStage = EventService {
	reference: cloud
	selection: saveMissionWaveStage
	
	recordUid = Input {
		type: Integer
	}
	missionWaveId = Input {
		type: Integer
	}
	order = Input {
		type: Integer
		default: 0
	}
	type = Input {
		type: String
		mandatory: True
	}
	key = Input {
		type: String
		mandatory: True
	}
	val = Input {
		type: String
		mandatory: True
	}
	labelsLang = Input {
		type: String
		multivalued: True
	}
	labelsVal = Input {
		type: String
		multivalued: True
	}
	
	error = Output
}

deleteMissionWaveStage = EventService {
	reference: cloud
	selection: deleteMissionWaveStage
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	
	error = Output
}

setMissionWaveStageAvailable = EventService {
	reference: cloud
	selection: setMissionWaveStageAvailable
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	available = Input {
		type: Boolean
		default: True
	}
	
	error = Output
}

setMissionWaveStageCompleted = EventService {
	reference: cloud
	selection: setMissionWaveStageCompleted
	
	recordUid = Input {
		type: Integer
		mandatory: True
	}
	completed = Input {
		type: Boolean
		default: True
	}
	
	error = Output
}
