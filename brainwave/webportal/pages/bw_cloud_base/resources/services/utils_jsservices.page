stringConcatQuoted = StringService {
  javascript-file:"/webportal/pages/bw_cloud_base/resources/services/utils_jsservices.javascript"
	javascript-method: concatQuotedStrings
	strings = Input { multivalued: True mandatory: True}
	quote = Input { default: "\"" }
	separator = Input { default: ","}	
}

b64_sha1 = StringService {
  javascript-file:"/webportal/pages/bw_cloud_base/resources/services/utils_jsservices.javascript"
	javascript-method: b64_sha1
	string = Input { mandatory: True}
}

/* test page  */

test_utils_services = Page {
  title: "test_utils_services"
  //homepage-for: All
  
  stringsEmpty = Variable {}
  strings1 = Variable { multivalued: True initial: "ABC"}
  strings3 = Variable { multivalued: True initial: ["ABC", "DEF", "GHI"] }
    
  
  Text {
    label: "quotedEmpty"
    value: @stringConcatQuoted( stringsEmpty to strings)
  }
  
   Text {
    label: "quoted1"
    value: @stringConcatQuoted( strings1 to strings)
  }
  
   Text {
    label: "quoted3"
    value: @stringConcatQuoted( strings3 to strings)
  }
  

 
} 