/**
 *  stepsdata: provides data for each step:
 * - id : mandatory unique id for the step 
 * - label: mandatory title of the step
 * - description: optional description (help) for the step
 * - iconclass: css icon class for the icon to display in front of the step. 
 *   valid icon css classes are listed in static/bw_cloud_rolemining/widgets/stepper/icons.css. You can add more icons if needed...
 * - avaialble: true if the step is not locked
 * - done : true|false  
 * - status (optional) when done is true , optional status for "done" steps:
 *     - "error" will display an error icon
 *     - "warning" will display a warning icon
 *     - anything else will display a "check" icon 
 * 
 *  currentStep: set this variable to the id of the step to make current
 * 
 * options:
 * orientation:  for now, only "vertical" is supported
 * popupHelp:  in this mode, hovering a step show the description ( except for the current step)
 * showIcons: display icons for steps, from the icon columnn of dataset, if false will show circled numbers (default false)
 *
 * 
 */

bw_stepper = JsWidgetTemplate {
	source-directory: "static/bw_cloud_base/widgets/stepper_js" 
		datasets: stepsdata ( id as String , label as String, description as String, icon as Image , order as Integer, available as Boolean, done as Boolean, hidden as Boolean, status as String) 
		bindings:
			orientation as in String,
			popupHelp as in Boolean,
			showIcons as in Boolean,
			showState as in Boolean,
			debugLinks as in Boolean,
			sort as in Boolean,
			currentStep as in String
		widget-events:
			onlabelclick ( id as String, index as Integer)
}
