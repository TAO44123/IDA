/* Import other pages here */


/* Nationalized labels here */
RKT_NLS = NLS {
	RKT000.title [en "WARNING - reconciliation is under 80%" ]
	RKT000.description [en "This risk is displayed only if the reconciliation rate is under 80%"]
	RKT000.rating.r1 [ en "Not cool at all!" ]
	RKT000.rating.r2 [ en "Not very cool" ]
	RKT000.rating.r3 [ en "OK" ]
	RKT000.rating.r4 [ en "Good" ]
	RKT000.rating.r5 [ en "Great!" ]
	
	RKT001.title [en "WARNING - this is a risk without a link" ]
	RKT001.description [en "And its also displayed all the time"]
	RKT001.rating.r1 [ en "1" ]
	RKT001.rating.r2 [ en "2" ]
	RKT001.rating.r3 [ en "3" ]
	RKT001.rating.r4 [ en "4" ]
	RKT001.rating.r5 [ en "5" ]
}

RKT000_goto = Page {
	title: $RKT_NLS.RKT000.title
	description: $RKT_NLS.RKT000.description
	tags: "risk", "waitingforcube", "creatingcube"
	conditional-redirect: ConditionalRedirect {
		condition: True
		target: HomePage
	}
	// condition to display the risk ( view businessview bwcrm_conditionalrisks )
}
RKT000_rating_1 = Page { title: "RKT000_goto" tags: "riskratinginfo1" description:  $RKT_NLS.RKT000.rating.r1 }
RKT000_rating_2 = Page { title: "RKT000_goto" tags: "riskratinginfo2" description:  $RKT_NLS.RKT000.rating.r2 }
