RKT000_rating_4 = Page { title: "RKT000_goto" tags: "riskratinginfo4" description:  $RKT_NLS.RKT000.rating.r4 }
RKT000_rating_5 = Page { title: "RKT000_goto" tags: "riskratinginfo5" description:  $RKT_NLS.RKT000.rating.r5 }

