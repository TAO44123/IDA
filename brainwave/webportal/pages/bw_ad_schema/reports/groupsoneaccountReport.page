/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"
import "/webportal/pages/bw_ad_schema/resources/dbstyle.page"

import "/webportal/pages/bw_ad_schema/reports/accountsReport.page"
import "/webportal/pages/bw_ad_schema/reports/groupsReport.page"
import "/webportal/pages/bw_ad_schema/reports/allreports.page"

bw_adschema_groupsoneaccountReportNLS = NLS {
	master [en "Groups" fr "Groupes"]
	detail [en "Corresponding accounts" fr "Comptes correspondants"]
}

/* Nationalized labels here */
bw_adschema_groupsoneaccountReport = Page {
	title: $bw_adschema_groupsReportNLS.title
	dynamic-title:$bw_adschema_groupsReportNLS.dyntitle(title)
	
	tags: "ADreports"
		
	/* Parameters here */
	title = Parameter {type:String hidden:True mandatory:False}
	domainuid = Parameter {type:String hidden:True mandatory:False multivalued:True}
	
	importaction = Parameter {type:String hidden:True mandatory:False}
	deletedaction = Parameter {type:String hidden:True mandatory:False}
	
	/* Variables here */
	vtitle = Variable {type:String initial:$bw_adschema_groupsReportNLS.title}
	selectedGroup = Variable
	selectedAccount = Variable
	
	/* Datasets and records here */
	groups = Dataset {
		view:br_ad_groups_oneaccount with domainuid to domainuid
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:False
			join-column:uid
			value-column:^value
			status-column-name:status	
			timeslot:FromPage(-1)
		}
	}
	
	groupmembers = Dataset {
		view:br_ad_groupmembers with selectedGroup to uid

		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:False
			join-column:uid
			value-column:^value
			status-column-name:status	
			timeslot:FromPage(-1)
		}
	}
	
	/* Page content */
	Splitter {
		disposition:Horizontal	
	
		Group {
			title:$bw_adschema_groupsoneaccountReportNLS.master
			
				Grid {
				columns: GridColumn { width: grow }, GridColumn { width: 50px }
				GridRow {
					GridCell {
					
			Table {
				data:groups
				layout:Layout {grab:horizontal True vertical True}
				show-filter:True
				show-count:True
				configurable:True
				double-click:GoTo Activity Group Detail with Current uid to paramGroupUid
				
				Column {column:status header:"New" text:"" sortable:True width:32px image:StringImageSelection(Current status) {when "New" then "16/famfamfam_silk_icons_v013/add.png"}}
		
				Column {column:repositoryrecorduid hidden:True}
				Column {column:repositoryuid hidden:True}
				Column {column:repositorycode header:$pdomain.code sortable:True filterable:True}
				Column {column:repositorydisplayname header:$pdomain.displayname sortable:True filterable:True initially-masked:True}
				Column {column:repositoryextractDate header:$pdomain.extractdate sortable:True filterable:True initially-masked:True}
		
				Column {column:recorduid hidden:True}
				Column {column:uid hidden:True selection:selectedGroup}
		
				Column {column:code header:$group.code sortable:True filterable:True}
				Column {column:sid header:$bw_adschema_groupsReportNLS.sid sortable:True filterable:True initially-masked:True}
				Column {column:guid header:$bw_adschema_groupsReportNLS.guid sortable:True filterable:True initially-masked:True}
				Column {column:displayname header:$group.displayname sortable:True filterable:True}
				Column {column:comment header:$group.comment sortable:True filterable:True}
				Column {column:grouptype header:$group.grouptype sortable:True filterable:True initially-masked:True}
				Column {column:dynamic header:$group.dynamic sortable:True filterable:True initially-masked:True}
				Column {column:filter header:$group.filter sortable:True filterable:True initially-masked:True}
				Column {column:creationdate header:$group.creationdate sortable:True filterable:True}
				Column {column:modificationdate header:$group.modificationdate sortable:True filterable:True}
		
				Column {column:custom1 header:$group.custom1 sortable:True filterable:True initially-masked:True}
				Column {column:custom2 header:$group.custom2 sortable:True filterable:True initially-masked:True}
				Column {column:custom3 header:$group.custom3 sortable:True filterable:True initially-masked:True}
				Column {column:custom4 header:$group.custom4 sortable:True filterable:True initially-masked:True}
				Column {column:custom5 header:$group.custom5 sortable:True filterable:True initially-masked:True}
				Column {column:custom6 header:$group.custom6 sortable:True filterable:True initially-masked:True}
				Column {column:custom7 header:$group.custom7 sortable:True filterable:True initially-masked:True}
				Column {column:custom8 header:$group.custom8 sortable:True filterable:True initially-masked:True}
				Column {column:custom9 header:$group.custom9 sortable:True filterable:True initially-masked:True}
			}
			
				}
					GridCell {
						Button {
							layout: Layout { indent: horizontal 0 vertical 30 }
							actions: GoTo Report bw_adschema_groupsoneaccountReport_print
								with 	domainuid to domainuid,
										
										title to title
							presentation: Link
							image: "32/details/printable_32_gray.png"
						}
					}
				}
			}
			
		}
		Group {
			title:$bw_adschema_groupsoneaccountReportNLS.detail
			Table {
				data:groupmembers
				layout:Layout {grab:horizontal True vertical True}
				show-filter:True
				show-count:True
				configurable:True
				double-click:GoTo Activity Account Detail with Current uid to paramAccountUid
				
				Column {column:status header:"New" text:"" sortable:True width:32px image:StringImageSelection(Current status) {when "New" then "16/famfamfam_silk_icons_v013/add.png"}}
	
				Column {column:repositoryrecorduid hidden:True}
				Column {column:repositoryuid hidden:True}
				Column {column:repositorycode header:$pdomain.code sortable:True filterable:True  initially-masked:True}
				Column {column:repositorydisplayname header:$pdomain.displayname sortable:True filterable:True initially-masked:True}
				Column {column:repositoryextractDate header:$pdomain.extractdate sortable:True filterable:True initially-masked:True}
		
				Column {column:recorduid hidden:True selection:selectedAccount}
				Column {column:uid hidden:True}
				Column {column:identifier header:$bw_adschema_accountsReportNLS.dn sortable:True filterable:True initially-masked:True}
				Column {column:login header:$account.login sortable:True filterable:True}
				Column {column:sid header:$account.sid sortable:True filterable:True initially-masked:True}
				Column {column:guid header:$account.guid sortable:True filterable:True initially-masked:True}
				Column {column:profile header:$account.profile sortable:True filterable:True initially-masked:True}
				Column {column:givenname header:$account.givenname sortable:True filterable:True initially-masked:True}
				Column {column:surname header:$account.surname sortable:True filterable:True initially-masked:True}
				Column {column:username header:$account.username sortable:True filterable:True}
				Column {column:employeenumber header:$account.employeenumber sortable:True filterable:True initially-masked:True}
				Column {column:mail header:$account.mail sortable:True filterable:True}
				Column {column:managerdata header:$account.managerdata sortable:True filterable:True initially-masked:True}
				Column {column:creationdate header:$account.creationdate sortable:True filterable:True}
				Column {column:lastlogindate header:$account.lastlogindate sortable:True filterable:True}
				Column {column:passwordlastsetdate header:$account.passwordlastsetdate sortable:True filterable:True}
				Column {column:expiredate header:$account.expiredate sortable:True filterable:True}
				Column {column:nextpwdchangedate header:$account.nextpwdchangedate sortable:True filterable:True}
				Column {column:service header:$account.service sortable:True filterable:True initially-masked:True}
				Column {column:disabled header:$account.disabled sortable:True filterable:True}
				Column {column:logincount header:$account.logincount sortable:True filterable:True initially-masked:True}
				Column {column:badpasswordcount header:$account.badpasswordcount sortable:True filterable:True initially-masked:True}
				Column {column:passwordnotrequired header:$account.passwordnotrequired sortable:True filterable:True}
				Column {column:passwordcantchange header:$account.passwordcantchange sortable:True filterable:True}
				Column {column:notnormalaccount header:$account.notnormalaccount sortable:True filterable:True initially-masked:True}
				Column {column:dontexpirepassword header:$account.dontexpirepassword sortable:True filterable:True}
				Column {column:passwordexpired header:$account.passwordexpired sortable:True filterable:True}
				Column {column:smartcardrequired header:$account.smartcardrequired sortable:True filterable:True}
				Column {column:groupchanged header:$account.groupchanged sortable:True filterable:True initially-masked:True}
				Column {column:custom1 header:$account.custom1 sortable:True filterable:True initially-masked:True}
				Column {column:custom2 header:$account.custom2 sortable:True filterable:True initially-masked:True}
				Column {column:custom3 header:$account.custom3 sortable:True filterable:True initially-masked:True}
				Column {column:custom4 header:$account.custom4 sortable:True filterable:True initially-masked:True}
				Column {column:custom5 header:$account.custom5 sortable:True filterable:True initially-masked:True}
				Column {column:custom6 header:$account.custom6 sortable:True filterable:True initially-masked:True}
				Column {column:custom7 header:$account.custom7 sortable:True filterable:True initially-masked:True}
				Column {column:custom8 header:$account.custom8 sortable:True filterable:True initially-masked:True}
				Column {column:custom9 header:$account.custom9 sortable:True filterable:True initially-masked:True}
			}
		}
	} 
}
