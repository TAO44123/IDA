/* Import other pages here */
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_ad_schema/resources/basestyles.page"
import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"
import "/webportal/pages/bw_ad_schema/resources/dbstyle.page"
import "/webportal/pages/bw_ad_schema/resources/resources.page"
import "/webportal/pages/bw_ad_schema/resources/concepts_nls.page"

/* Nationalized labels here */
ad_subgroups_treeNLS = NLS {
	title [en "Browse Subgroups" fr "Parcourir les sous-groupes"]
}

notZero = IntMapping {
	when =0 then ""
	otherwise current
}

rootStyle = Style {
	background: Color RGB (245,245,245)
}

accountIcon16 = IntImageTemplate {
	when <=0 then  ""
	when >0 then  "bw_ad_schema/indicators/explorer/key_16.png"
}

ad_subgroups_tree = Page {
	title: $ad_subgroups_treeNLS.title
// DISABLE REPORT AS IT IS NOW PART OF IAS
//	tags: "group" priority 200, "byuid" , "browsing", "ADreports"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	
	mixins: base_pageMixin
	
	/* Parameters here */
	initialTimeSlotUid = Parameter { default: PageTimeslot.UID hidden: True }
	uid = Parameter {
		type:String
	}
	
	/* Variables here */
	selectedTab = Variable { type: Integer initial: 0 }
	selectedGroupUid = Variable { type: String }
	selectedGroupRecorduid = Variable { type: String }

	/* Second tab vars */
	selectAll = Variable { type: Integer initial: 0 }
	selectedAccountUid = Variable { type: String }
	selectedIdentityUid = Variable { type: String }
	uids =  Variable {type:String multivalued:True}
	selectedTimeSlotUid = Variable { type: String }
	timeNavigatorEnabled = Variable { type: Boolean initial: False }
	
	
	/* Datasets and records here */
	groupTree = HierarchicalData {
		roots-view: ad_groups_self_uid with uid to groupuid
		children-view: ad_groups_children
		parameter: parentrecorduid
		attribute: recorduid
	}
	
	selectedGroup = Record {
		view: ad_group_select with selectedGroupRecorduid to recorduid 
	}
	
	directIdentities = Dataset {
		view: ad_group_identitiesdirect with selectedGroupUid to uid
		timeslot: selectedTimeSlotUid
		trend: Trend { 
			join-column: account_uid
			exclude-new: False
			include-removed: False
			exclude-same: False
			status-column-name:status
			timeslot: FromPage (-1) // TODO : should be selectedtimeslot - 1 
			value-column: trend
		}
	}
	
	indirectIdentities = Dataset {
		view: ad_group_identitiesindirect with selectedGroupUid to uid
		timeslot: selectedTimeSlotUid 
		trend: Trend { 
			join-column: account_uid
			exclude-new: False
			include-removed: False
			exclude-same: False
			status-column-name:status
			timeslot: FromPage (-1)
			value-column: trend
		}
	}
	
	allIdentities = Dataset {
		union: Union {
			datasets: directIdentities discriminator "direct", indirectIdentities discriminator "indirect"
			discriminator-column: type
		}
	}
	
	timeslots = Dataset { view: explorergettimeslots }
	
	
	// Dataset for identity Reports
	identityanalytics = Dataset {
		pages: Pages{tags: "identity" and "byuids" }
		disabled: IntPredicate(selectedTab) { when =2 then False otherwise True }  // activate only in selectedTab = 2
	}
	// Dataset for account Reports
	accountanalytics = Dataset {
		pages: Pages{tags: "account" and "byuids" }
		disabled: IntPredicate(selectedTab) { when =2 then False otherwise True }  // activate only in selectedTab = 2
	}
	analytics = Dataset {
		union:Union{ datasets:identityanalytics discriminator "identity", accountanalytics discriminator "account" discriminator-column: id }
		disabled: IntPredicate(selectedTab) { when =2 then False otherwise True }  // activate only in selectedTab = 2
	}
	
	selectionChanged= NamedAction (
		IntCase ( selectedGroupRecorduid ) {
			when > 0 then [ 
				IntCase ( selectedTab ) { 
					when =0 then [ 
						Set 1 to selectedTab 
					]	 
				} 
			]
		}
	)
	
	
	/* Page content */
	
	Splitter {
		disposition: Horizontal 
		size: 25%
	
		Group {
		
			Tree {
				data: groupTree 
				layout: Layout { grab: horizontal True vertical True indent: horizontal 10 vertical 4}
				expand-level: All
				hide-header: True
				selection-changed-event: ExecuteNamedAction selectionChanged
				
				Column {
					column: displayname
					image: "bw_ad_schema/16/container_16.png"
					width: 100%
					text: Concat ( "  ", Current displayname )
					
					styling: StringStyling ( Current parent_recorduid ) { when IsEmpty then rootStyle  }
				}
				
				Column {
					column: total_accounts
					text: Transform Current total_accounts using notZero
					width: 40px
					align: Right
					styling: StringStyling ( Current parent_recorduid ) { when IsEmpty then rootStyle  }
				}
				
				Column {
					column: total_accounts
					image: TemplateImageSelection ( Current total_accounts ) using accountIcon16
					width: 25px
					align: Right
					text: ""
					styling: StringStyling ( Current parent_recorduid ) { when IsEmpty then rootStyle  }
					
				}
				
				
				Column {
					column: uid
					hidden: True
					selection: selectedGroupUid
				}
				
				Column {
					column: recorduid
					hidden: True
					selection: selectedGroupRecorduid
				}
				
			}
		}
		Group{
			
			/*********** START OF THE RIGHT SIDE ************/
			
			/********* TABS BORDER AND CONTAINER *******/
			Group {
				background: Color RGB(180, 180, 180)
				layout: Layout { grab: horizontal True vertical True}
				margins: All 1
				Group {
					background: Color RGB ( 249 , 247 , 246)
					layout: Layout { grab: horizontal True vertical True}
					
					/*********** TABS TITLES  **********/
					mixins: tabsStyle
					Grid {
						layout: Layout { grab: horizontal True vertical False }
						columns: GridColumn { width: 300px }, GridColumn { width: 300px }, GridColumn { width: grow }
						GridRow{
							height: 40 px 
							
							GridCell {
								Button {
									actions: Set 1 to selectedTab
									text: $adschema_group_explorer.tabs.allidentities.title
									image:  IntImageSelection ( selectedTab ) { when =1 then "bw_ad_schema/32/menu_32_red.png" otherwise "bw_ad_schema/32/menu_32_grey.png"  }
									disabled: IntPredicate (selectedGroupRecorduid) { when > 0 then False otherwise True }
								}
							}
							
							GridCell {
								Button {
									actions: Set 2 to selectedTab
									text: $adschema_group_explorer.tabs.directidentities.title
									image:  IntImageSelection ( selectedTab ) { when =2 then "bw_ad_schema/32/menu_32_red.png" otherwise "bw_ad_schema/32/menu_32_grey.png"  }
									disabled: IntPredicate (selectedGroupRecorduid) { when > 0 then False otherwise True }
								}
							}
										
						}
					}
					Separator {}
					
					/********* TAB NUMBER 0 *********/
					Group {
						layout: Layout { grab: horizontal True vertical True }
						margins: All 20
						background: Color white
						hidden: IntPredicate ( selectedTab) { when !=0 then True}
						
						Image {
							layout: Layout { indent: vertical 100 horizontal 0 } 
							image: "bw_ad_schema/32/menu_32_red.png"
							align: Center
						}
						Text {
							align: Center
							value: $adschema_group_explorer.tabs.emptytab.message
							styling: smallLabel
						}
					}
					
					
					
					
					/********** TAB NUMBER 1 *********/
					Group {
						layout: Layout { grab: horizontal True vertical True }
						margins: All 20
						background: Color white
						hidden: IntPredicate ( selectedTab) { when !=1 then True}
						
						Group {
							layout: Layout { grab: horizontal True vertical False }
							hidden: Not BooleanPredicate ( timeNavigatorEnabled )
							Text { 
								value: $adschema_group_explorer.tabs.identities.timenavitagor styling: redSmallLabel layout: Layout { indent: horizontal 0 vertical 5}
							}
									SetNavigator {
										data: timeslots 
										column: uid 
										align: Center
										selection: selectedTimeSlotUid  
										label: Current displayname
										label-width: 350
										dropdown: Dropdown { text: Current displayname } 
										initial: initialTimeSlotUid
										show-last:True
									}
									Spacer { height: 5 }
						}
						Button {
							hidden: BooleanPredicate ( timeNavigatorEnabled )
							layout: Layout { hint: height 30 align: horizontal End vertical Beginning }
							align: Right
							actions: Set True to timeNavigatorEnabled,  Set 0 to selectAll , ReloadData ( allIdentities ) text: $adschema_group_explorer.labels.checktimeslots
							styling: xSmallTextStyle
						}			
						
						Grid {
							columns: GridColumn { width: grow } , GridColumn { width:minimum 60 maximum 60 ( prefered 60) } , GridColumn{}
							
							GridRow {
								height:grow
								GridCell {
									Table {
										data: allIdentities
										layout: Layout { grab: horizontal True vertical True indent: horizontal 0 vertical 5 }
										show-count: True 
										
										Column {
											column: status
											header: $adschema_group_explorer.tabs.identities.headers.status
											width: 80px
											text: Transform Current status using statusMapping
											image: TemplateImageSelection(Current status) using newItemTemplate
											sortable: True
											styling: IntStyling(selectAll) { when =1 then selectedRow} 
										}
				
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70% column: type text: Transform Current type using typeMap header: $adschema_group_explorer.tabs.identities.headers.type }
										
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70% column: type 
											// isDirect ? displayname : child_displayname
											text: $adschema_group_explorer.tabs.identities.labels.group( Transform Current type using isDirect , Current displayname, Current child_displayname )  
											header: $group.concept }
										
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70% column: account_login header: $account.login }
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70%  column: id_fullname header: $pidentity.fullname  text: Transform Current id_fullname using optionStringMapping }
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 50%  column: org_shortname header: $organisation.concept text: Transform Current org_shortname using optionStringMapping  }
										
										Column { column: account_uid hidden: True selection: selectedAccountUid }		
										Column { column: id_uid hidden: True selection: selectedIdentityUid }		
									}
								}
								/* Action icons */
								GridCell {
									Group{
										layout: Layout { grab: horizontal True vertical True align: horizontal Center vertical Beginning}
										
										Spacer {
											height: 10
										}
										Button {
											actions:  Set 1 to selectAll , ReloadData ( allIdentities )
											image: "bw_ad_schema/48/red/analytics.png"
											presentation: Link
											disabled: IntPredicate ( Count allIdentities ) { when =0 then True }
											hidden: IntPredicate ( selectAll ) { when =1 then True }
										}
										Button {
											actions:  Set 0 to selectAll , ReloadData ( allIdentities )
											image: "bw_ad_schema/48/red/back.png"
											presentation: Link
											disabled: IntPredicate ( Count allIdentities ) { when =0 then True }
											hidden: IntPredicate ( selectAll ) { when =0 then True }
										}
										Button {
											actions: GoTo Activity Account Detail with selectedAccountUid to paramAccountUid
											image: "48/red/account.png"
											presentation: Link
											disabled: IntPredicate (  Sum ( Transform selectedAccountUid using isEmptyMapping, selectAll ) ) { when > 0 then True}
										}
										Button {
											actions: GoTo Activity Identity Detail with selectedIdentityUid to paramIdentityUid
											image: "48/red/identity.png"
											presentation: Link
											disabled: IntPredicate (  Sum ( Transform selectedIdentityUid using isEmptyMapping, selectAll ) ) { when > 0 then True}
										}
									}
								}
								/* Analytics Section */
								GridCell {
								
									Group {
										hidden: IntPredicate ( selectAll ) { when =0 then True}
										layout:Layout{hint:width 320}
							
										TemplateTable {
											data:analytics
											layout:Layout{grab: horizontal True vertical True}
											row-height:82
											initial-sort:^priority
											pagination:6
											disabled:IntPredicate(Count allIdentities) {when =0 then True}
											show-filter:True			
											double-click:
														StringCase(Current id) {
															when "identity" then [TransferData allIdentities(id_uid) to (uids)]
															when "account" then [TransferData allIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
											
											ImageCell {
												image:Current largeIcon
												top:0
												height:48
												left:136
												width:48
												on-click:
														StringCase(Current id) {
															when "identity" then [TransferData allIdentities(id_uid) to (uids)]
															when "account" then [TransferData allIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
												}
											TextCell {
												column:title
												top:50
												height:32
												left:0
												width:320
												horizontal-align:Center
												filterable:True
												on-click:
														StringCase(Current id) {
															when "identity" then [TransferData allIdentities(id_uid) to (uids)]
															when "account" then [TransferData allIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
											
											}
										}
									}
								}
							}
						}
					}
					
					/********** TAB NUMBER 2 *********/
					Group {
						layout: Layout { grab: horizontal True vertical True }
						margins: All 20
						background: Color white
						hidden: IntPredicate ( selectedTab) { when !=2 then True}
						
						Group {
							layout: Layout { grab: horizontal True vertical False }
							hidden: Not BooleanPredicate ( timeNavigatorEnabled )
							Text { 
								value: $adschema_group_explorer.tabs.identities.timenavitagor styling: redSmallLabel layout: Layout { indent: horizontal 0 vertical 5}
							}
									SetNavigator {
										data: timeslots 
										column: uid 
										align: Center
										selection: selectedTimeSlotUid  
										label: Current displayname
										label-width: 350
										dropdown: Dropdown { text: Current displayname } 
										initial: initialTimeSlotUid
										show-last:True
									}
									Spacer { height: 5 }
						}
						Button {
							hidden: BooleanPredicate ( timeNavigatorEnabled )
							layout: Layout { hint: height 30 align: horizontal End vertical Beginning }
							align: Right
							actions: Set True to timeNavigatorEnabled,  Set 0 to selectAll , ReloadData ( directIdentities ) text: $adschema_group_explorer.labels.checktimeslots
							styling: xSmallTextStyle
						}			
						
						Grid {
							columns: GridColumn { width: grow } , GridColumn { width:minimum 60 maximum 60 ( prefered 60) } , GridColumn{}
							
							GridRow {
								height:grow
								GridCell {
									Table {
										data: directIdentities
										layout: Layout { grab: horizontal True vertical True indent: horizontal 0 vertical 5 }
										show-count: True 
										
										Column {
											column: status
											header: $adschema_group_explorer.tabs.identities.headers.status
											width: 80px
											text: Transform Current status using statusMapping
											image: TemplateImageSelection(Current status) using newItemTemplate
											sortable: True
											styling: IntStyling(selectAll) { when =1 then selectedRow} 
										}
										
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70% column: account_login header: $account.login }
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 70%  column: id_fullname header: $pidentity.fullname  text: Transform Current id_fullname using optionStringMapping }
										Column {styling: IntStyling(selectAll) { when =1 then selectedRow}  width: 50%  column: org_shortname header: $organisation.concept text: Transform Current org_shortname using optionStringMapping  }
										
										Column { column: account_uid hidden: True selection: selectedAccountUid }		
										Column { column: id_uid hidden: True selection: selectedIdentityUid }		
									}
								}
								/* Action icons */
								GridCell {
									Group{
										layout: Layout { grab: horizontal True vertical True align: horizontal Center vertical Beginning}
										
										Spacer {
											height: 10
										}
										Button {
											actions:  Set 1 to selectAll , ReloadData ( directIdentities )
											image: "bw_ad_schema/48/red/analytics.png"
											presentation: Link
											disabled: IntPredicate ( Count directIdentities ) { when =0 then True }
											hidden: IntPredicate ( selectAll ) { when =1 then True }
										}
										Button {
											actions:  Set 0 to selectAll , ReloadData ( directIdentities )
											image: "bw_ad_schema/48/red/back.png"
											presentation: Link
											disabled: IntPredicate ( Count directIdentities ) { when =0 then True }
											hidden: IntPredicate ( selectAll ) { when =0 then True }
										}
										Button {
											actions: GoTo Activity Account Detail with selectedAccountUid to paramAccountUid
											image: "48/red/account.png"
											presentation: Link
											disabled: IntPredicate (  Sum ( Transform selectedAccountUid using isEmptyMapping, selectAll ) ) { when > 0 then True}
										}
										Button {
											actions: GoTo Activity Identity Detail with selectedIdentityUid to paramIdentityUid
											image: "48/red/identity.png"
											presentation: Link
											disabled: IntPredicate (  Sum ( Transform selectedIdentityUid using isEmptyMapping, selectAll ) ) { when > 0 then True}
										}
									}
								}
								/* Analytics Section */
								GridCell {
								
									Group {
										hidden: IntPredicate ( selectAll ) { when =0 then True}
										layout:Layout{hint:width 320}
							
										TemplateTable {
											data:analytics
											layout:Layout{grab: horizontal True vertical True}
											row-height:82
											initial-sort:^priority
											pagination:6
											disabled:IntPredicate(Count directIdentities) {when =0 then True}
											show-filter:True			
											double-click:
														StringCase(Current id) {
															when "identity" then [TransferData directIdentities(id_uid) to (uids)]
															when "account" then [TransferData directIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
											
											ImageCell {
												image:Current largeIcon
												top:0
												height:48
												left:136
												width:48
												on-click:
														StringCase(Current id) {
															when "identity" then [TransferData directIdentities(id_uid) to (uids)]
															when "account" then [TransferData directIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
												}
											TextCell {
												column:title
												top:50
												height:32
												left:0
												width:320
												horizontal-align:Center
												filterable:True
												on-click:
														StringCase(Current id) {
															when "identity" then [TransferData directIdentities(id_uid) to (uids)]
															when "account" then [TransferData directIdentities(account_uid) to (uids)]
														},													
														MultivaluedDistinct uids, MultivaluedRemove all '' from uids,
															IntCase(SizeOf uids) { 
																//when =0 then [Message $search_page.analyticsreportnoentries]
																when <2001 then [GoTo Dynamic (Current type, Current name) with uids to uids] //MAX AS OF SQL SERVER : 2100 parameters in Hibernate request
																//otherwise [Message $search_page.analyticsreporttoomanyentries]
															}
											
											}
										}
									}
								}
							}
						}
					}
					
				}
			}
		
		
		}
	}	
}
