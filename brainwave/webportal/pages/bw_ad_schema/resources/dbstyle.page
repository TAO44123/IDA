/* Mixins and styles used in dashboard-like pages, or in dahsboard panels of pages  */

import "/webportal/pages/bw_ad_schema/resources/basestyles.page"
// MIXINS 
dashboardPageMixin =  Mixin {  
	Text 	{ compact: True }
	Grid 	{ fill: Both gap: 0 insets: 0 background: Color  RGB ( 255, 251,251)}	
}

dashboardTransparentMixin =  Mixin {
	Text 	{ compact: True }
	Grid 	{ fill: Both gap: 0 insets: 0  }	
}

whiteGridMixin = Mixin {
   This Grid 	{ fill: Both gap: 0 insets: 0 background: Color  RGB ( 255, 251,251)  
   
   layout: Layout { indent: horizontal 0 vertical 20} }	
}

headersMixins = Mixin {

	Text 	{ align: Center styling: bigNumber layout: Layout {align: horizontal Fill vertical Center  indent: horizontal 0 vertical 0} }
	Link 	{ align: Center styling: bigNumber layout: Layout { indent: horizontal 0 vertical 0} }
	Button 	{ align: Center styling: bigNumber layout: Layout { indent: horizontal 0 vertical 0} }
}

filterBar = Mixin {
   This Grid {
      	layout: Layout { hint: height 60  indent: horizontal 0 vertical 20}
       background: Color RGB ( 134,154,178)
		fill: Both
		
   }
	Text { align: Center styling: whiteLabel layout: Layout { hint: height 20}}	
	Button { presentation: Link  }
	Checkbox {
		styling: smallWhiteText
	}	
}

separatorBar = Mixin {
   This Grid {
      	layout: Layout { grab: horizontal True vertical False  hint: height 45  indent: horizontal 0 vertical 10 }
       background: Color RGB ( 134,154,178)
		
   }
}

buttonHeader = Style(textBase) {
   foreground: RGB(128, 128, 128)
}

buttonSelectedHeader = Style(textBase) {
   foreground: RGB(240, 240, 240)
}

leftSelectionBar = Mixin {
	Button {
		layout: Layout { hint: height 40 }
		presentation: Link
		styling: buttonHeader
	}

}

data = Mixin {
	Grid{
		fill: Both
		insets:5
		gap:5
		
		GridRow{
			height: 60px
		}
	}
	Text {
		align: Center
		styling: textStyle
		layout: Layout { grab: horizontal True vertical  True }
	}
	Image {
    	layout: Layout { align: horizontal Center vertical Center grab: horizontal True vertical True}
	}
	Button {
		layout: Layout { indent: horizontal 0 vertical 5 }
		presentation: Link 
   	}
   	Group {
		layout: Layout { hint: height 70 width 235 align: vertical Beginning horizontal Center indent: horizontal 0 vertical 15}
		background: Color RGB ( 255, 251,251)
	}
}


xsmallNumber = Style {
	font: "Anton,Impact,Arial Black,Gadget,sans-serif"
	size: 14px
	foreground: RGB ( 98,98,98 )
}

smallerNumber = Style {
	font: "Anton,Impact,Arial Black,Gadget,sans-serif"
	size: 16px
	foreground: RGB ( 98,98,98 )
}

xsmallNumberMixinLeft = Mixin {
	Text {
		styling: xsmallNumber
		compact: True 
		align: Left	
	}
}

bigNumberMixinLeft = Mixin {
   Link {
     styling: bigNumber
     align: Left
     compact: True
   }

}

smallerNumberMixin = Mixin {
	Button {
		styling: smallerNumber
		align: Right
		layout: Layout{ align: vertical Beginning horizontal End}
	}
}

bigNumberMixin = Mixin {
  Text {
     styling: bigNumber
     align: Right
     compact: True
   }
   Link {
     styling: bigNumber
     align: Right
     compact: True
     layout: Layout { align: horizontal End vertical Center}
   }
   Button {
	styling: bigNumber
	align: Right
	layout: Layout{ align: vertical Center horizontal End}
   }
}

bigNumberCenterMixin = Mixin {
  Text {
     styling: bigNumber
     align: Center
     compact: True
     layout: Layout{  hint: height 40 }
   }
   Link {
     styling: bigNumber
     align: Center
     compact: True
     layout: Layout{ hint: height 40}
   }
}

bigNumberVCenterMixin = Mixin {
  Text {
     align: Center
     styling: bigNumber
     layout: Layout{  grab: horizontal True vertical True align: horizontal Center vertical Center }
   }
   Link {
     styling: bigNumber
     layout: Layout{ grab: horizontal True vertical True align: horizontal Center vertical Center}
   }
}


moreInfo = Mixin {
   This Group {
      	border: True
		layout: Layout {
		    grab: horizontal False vertical False  
		   align: horizontal End vertical Beginning
		     indent: horizontal 20 vertical 20  }
		background: Color RGB ( 255, 251,251)
		margins: Bottom 30 Top 30 Left 80 Right 80		
   }
   
   Text {
		align: Center
		styling: textStyle
		layout: Layout { grab: horizontal True vertical  True}
	}
   Button {
		layout: Layout { hint: height 20 indent: horizontal 50 vertical 0}
		styling: smallTextStyle 
		align: Left
		presentation: Link 
	}
}

databox = Mixin {
	Text {
		layout:  Layout { indent: horizontal -12 vertical 0}
	}
	
	Button { 
		styling: bigNumber
	}
}

detailedDatabox = Mixin {
	Text {
		layout:  	Layout { hint: height 25 width 220 align: horizontal Beginning vertical Beginning indent: horizontal 50 vertical 0}
		align: Left 
	}
	
	Button { 
		styling: textStyle
		layout:  	Layout { hint: height 25 width 220 align: horizontal Beginning vertical Beginning indent: horizontal 5 vertical 0}
		align: Left 
	}
}

tableTopicMixin = Mixin {
  Text {
    align: Right
    compact: True
    styling: bigLabel
    layout:Layout { indent: vertical 12 horizontal 0}
  }
}

whiteCenteredHeaderMixin = Mixin {
   Text {
     styling: whiteHeader
     align: Center
     compact: True
     layout: Layout{ hint: height 28}
   }
}

grayCenteredHeaderMixin = Mixin {
   Text {
     styling: grayHeader
     align: Center
     compact: True
     layout: Layout{ hint: height 28}
   }
}

grayIndentedHeaderMixin = Mixin {
   Text {
     styling: grayHeader
     align: Left
     compact: True
     layout: Layout{ hint: height 28 indent: horizontal 30 vertical 0}
   }
}

//STYLES 

bigNumberBase = Style {
  	font: "Anton,Impact,Arial Black,Gadget,sans-serif"
  	size: 32px
}

smallNumberBase = Style {
  	font: "Anton,Impact,Arial Black,Gadget,sans-serif"
  	size: 18px
}

headerBase = Style {
    font: "Oswald,'open-sans',sans-serif"
    size: 16px
}


textStyle = Style(textBase) {
}

smallTextStyle = Style (textBase) {
	size: 14px
}

xSmallTextStyle = Style (textBase) {
	size: 12px
}

smallTextStyleTable = Style (textBase) {
	background: Color white
}

bigLabel = Style(textBase) {
  size: 18px
  foreground: RGB(128, 128, 128)
}

bigBoldLabel = Style(bigLabel) {
	bold: True
	foreground: RGB ( 98,98,98 )
}

smallNumber = Style(smallNumberBase) {
 	foreground: RGB ( 98,98,98 )
}

bigNumber = Style(bigNumberBase) {
 	foreground: RGB ( 98,98,98 )
}
bigNumberB = Style(bigNumberBase) {
  foreground: HEX(#3498DB) // A5  blue
}

bigNumberC = Style(bigNumberBase)  {
   foreground: HEX(#8E44AD) // A12 purple
}

bigNumberD = Style(bigNumberBase)  {
   foreground: HEX(#CA2C68)  // A10 pink
}

bigNumberWhite = Style(bigNumberBase)  {
   foreground: white
}

smallWhiteText = Style(textBase) {
	size: 12px
	foreground: white
}

whiteLabel = Style(textBase) {
	size: 14px
	foreground: white
}

grayHeader = Style(headerBase) {
   foreground: RGB(128, 128, 128)
}

whiteHeader = Style(headerBase) {
   foreground: white
}

bigGrayHeader = Style(headerBase) {
   foreground: RGB(128, 128, 128)
   size: 18px
   
}

alertinfo = Style ( uiBase ) {
	foreground: RGB ( 49 , 112, 143 )
}

alertlink = Style ( uiBase ) {
	foreground: RGB ( 0 , 0, 238 )
}

alertinfotitle = Style ( uiBase ) {
	bold: True
	foreground: RGB ( 49 , 112, 143 )
}

alertInfoGroup = Mixin {
	This Group {
		layout: Layout { hint: width 300 height 300 }
		background: Color RGB ( 188 , 232 , 241 ) 	// Border color
		margins: All 2 // Border size
	}
	Group {
		//margins: All 10
		background:  Color RGB ( 217 , 237 , 247  ) // Background color
	}
	Header {
		styling: alertinfotitle
		layout: Layout { hint: indent: vertical 0 horizontal 5  }
	}
	Text {
		styling: alertinfo
		layout: Layout { hint: indent: vertical 5 horizontal 0 grab: horizontal True vertical True }
	}
	OpenURL {
		styling: alertlink
		underline: Always
	}
	Link {
		styling: alertlink
		underline: Always
	}
	// Close button
	Button {
		presentation: Link
		align: Right
		styling: alertinfotitle
		layout: Layout { hint: height 16 width 25 align: horizontal End vertical Beginning }
	}
}



