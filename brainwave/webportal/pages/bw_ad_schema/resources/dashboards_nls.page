	                            ]
	
	access.edit_admin [ en "Are AD accounts that with at least one of the following AD privileges: \n\n - WriteDacl \n - WriteOwner \n - AccessSystemSecurity"
					    fr "Comptes AD avec au moins l'un des privilèges suivants: \n\n - WriteDacl \n - WriteOwner \n - AccessSystemSecurity"
					  ]
	access.edit_admin.link [ en "Please refer to MSDN library for more information."
						     fr "Veuillez consulter la bibliothèque MSDN pour plus d'informations."
						   ]
	access.edit_admin.linkurl [ en "https://msdn.microsoft.com/library/system.directoryservices.activedirectoryrights.aspx"
							  	fr "https://msdn.microsoft.com/library/system.directoryservices.activedirectoryrights.aspx"
							  ]
	
	access.reset_pass [ en "Are AD accounts that have been assigned the following extended rights : \n\n User-Force-Change-Password  \n\n This extended right allows the user to change the password of other accounts."
					    fr "Comptes AD avec les privilèges étendus suivants : \n\n User-Force-Change-Password  \n\n Ce droit étendu permet à l'utilisateur de changer le mot de passe des autres comptes."
					  ]
	access.reset_pass.link [ en "Please refer to MSDN library for more information."
						   	 fr "Veuillez consulter la bibliothèque MSDN pour plus d'informations."
						   ]
	access.reset_pass.linkurl [ en "https://msdn.microsoft.com/library/ms684414.aspx"
							    fr "https://msdn.microsoft.com/library/ms684414.aspx"
							  ]
	
	access.edit_usercontrol [ en "Are AD accounts with the privilege to modify the userAccountControl property of other accounts. \n\n The userAccountControl property of each account defines for example: \n\n - If the account is disabled \n - If a password is required"
							  fr "Comptes AD avec le privilège de modifier la propriété userAccountControl. \n\n La propriété userAccountControl définit par exemple : \n\n - Si un compte est désactivé \n - Si un mot de passe est requis"
							]
