ad_dashboard_accessNLS = NLS {
	title [en "Active Directory Privileged Account Dashboard" fr "Tableau de bord des comptes à privilèges Active Directory"]
	dyntitle [en "{0} Active Directory Privileged Account Dashboard" fr "Tableau de bord des comptes à privilèges Active Directory {0}"]
	description [en "This dashboard presents the most common controls on Active Directory privileged accounts. It is possible to drill-down the the control results for in-depth analysis"
				 fr "Ce tableau de bord présente les contrôles Active Directory les plus courants sur les comptes à privilèges. Il est possible de zoomer sur les résultats de contrôle pour mener des analyses plus poussées"]
	
	subtitle [en "AD Privileged Account Dashboard" fr "Tableau de bord comptes à privilèges d'AD"]
	
	objects.domains [en "Domains" fr "Domaines"]
	
	kpi.label.account_adminright [ en "Accounts With Admin Rights" fr "Comptes à hauts privilèges" ]
	kpi.label.account_adminrightdyn [ en "{0} Accounts With Admin Rights" fr "Comptes à hauts privilèges {0}" ]
	kpi.label.account_editadmin [ en "Accounts That Can Modify Admin Rights" fr "Comptes qui peuvent modifier les privilèges" ]
	kpi.label.account_editadmindyn [ en "{0} accounts That Can Modify Admin Rights" fr "Comptes qui peuvent modifier les privilèges {0}" ]
	kpi.label.account_resetpass [ en "Accounts That Can Reset Passwords" fr "Comptes qui peuvent réinitialiser les mots de passe"]
	kpi.label.account_resetpassdyn [ en "{0} accounts That Can Reset Passwords" fr "Comptes qui peuvent réinitialiser les mots de passe {0}"]
	kpi.label.account_usercontrol [ en "Accounts That Can Edit the UserAccountControl" fr "Comptes qui peuvent modifier les userAccountControl" ]
	kpi.label.account_usercontroldyn [ en "{0} Accounts That Can Edit the UserAccountControl" fr "Comptes qui peuvent modifier les userAccountControl {0}" ]

	kpi.headers.total [en "Total" fr "Total"]
	kpi.headers.recentlyused [en "Used In The Last 3 Months" fr "Utilisé au cours des 3 derniers mois" ]

	kpi.label.global.totalaccounts [ en "Total of Accounts" fr "total des comptes" ]
	kpi.label.global.totalgroups [ en "Total of Groups" fr "total des groupes"]
	kpi.label.global.activeaccounts [ en "Active Accounts" fr "comptes actifs" ]
	
	filter.managed_only.text [ en "Only consider privileges on sensitive objects" fr "Considérer uniquement les privilèges sur les objets sensibles"]
	filter.managed_only.tooltip.activate [en "Activate Filter" fr "Activer le filtre"]
	filter.managed_only.tooltip.deactivate [en "Deactivate Filter" fr "Désactiver le filtre" ]
	
}

