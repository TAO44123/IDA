								 ]
	access.edit_usercontrol.linkurl [ en "https://msdn.microsoft.com/library/ms680832.aspx"
									  fr "https://msdn.microsoft.com/library/ms680832.aspx"
									]
									
	access.managed_filter [ en "Filtering on sensitive objects will display only the numbers of account that have privileges on AD objects marked as critical or sensitive. \n\nUse the sensitive object explorer to see or modify the list of sensitive objects."
							fr "Le filtrage sur les objets sensibles affiche uniquement les comptes qui ont des privilèges sur les objets AD marqués comme critiques ou sensibles. \n\nUtiliser l'explorateur d'objets sensibles pour afficher ou modifier la liste des objets sensibles"
	]
	
	access.managed_explorer_link [	en "Sensitive Object Explorer"
									fr "Explorateur d'objets sensibles"
	]
	
	access.managed_filter_title [ en "Sensitive Object Filter"
								  fr "Filtre d'objets sensibles"
	]
}


