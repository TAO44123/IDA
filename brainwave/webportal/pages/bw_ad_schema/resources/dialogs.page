dialogACEDetails = Dialog {
	title: $adschema_dialogs.acedetails.title
	width: 720
	height: 400
	mixins: base_dialogMixin
	enter-event: 
	StringCase ( accountAceUid ) {
		when IsEmpty then [
			Set groupAce.domain_displayname to principalDomain,
			Set groupAce.group_displayname to principalId,
			Set groupAce.dn to soDistinguishedname,
			Set groupAce.perimeterdisplayname to aceScope,
			Set groupAce.ADS_RIGHT_DELETE to rightT, Set groupAce.ADS_RIGHT_READ_CONTROL to rightC, Set groupAce.ADS_RIGHT_WRITE_DAC to rightM , 
			Set groupAce.ADS_RIGHT_WRITE_OWNER to rightO, Set groupAce.ADS_RIGHT_SYNCHRONIZE to rightY , Set groupAce.ADS_RIGHT_ACCESS_SYSTEM_SECURITY to rightU,
			Set groupAce.ADS_RIGHT_DS_CREATE_CHILD to rightA, Set groupAce.ADS_RIGHT_DS_DELETE_CHILD to rightD, Set groupAce.ADS_RIGHT_ACTRL_DS_LIST to rightL,
			Set groupAce.ADS_RIGHT_DS_SELF to rightS, Set groupAce.ADS_RIGHT_DS_READ_PROP to rightR, Set groupAce.ADS_RIGHT_DS_WRITE_PROP to rightW,
			Set groupAce.ADS_RIGHT_DS_DELETE_TREE to rightE, Set groupAce.ADS_RIGHT_DS_LIST_OBJECT to rightI, Set groupAce.ADS_RIGHT_DS_CONTROL_ACCESS to rightX,
			
			Set $group.concept to soType
			
		]
		otherwise [
			Set accountAce.domain_displayname to principalDomain,
			Set accountAce.account_login to principalId,
			Set accountAce.dn to soDistinguishedname,
			Set accountAce.perimeterdisplayname to aceScope,
			
			Set accountAce.ADS_RIGHT_DELETE to rightT, Set accountAce.ADS_RIGHT_READ_CONTROL to rightC, Set accountAce.ADS_RIGHT_WRITE_DAC to rightM , 
			Set accountAce.ADS_RIGHT_WRITE_OWNER to rightO, Set accountAce.ADS_RIGHT_SYNCHRONIZE to rightY , Set accountAce.ADS_RIGHT_ACCESS_SYSTEM_SECURITY to rightU,
			Set accountAce.ADS_RIGHT_DS_CREATE_CHILD to rightA, Set accountAce.ADS_RIGHT_DS_DELETE_CHILD to rightD, Set accountAce.ADS_RIGHT_ACTRL_DS_LIST to rightL,
			Set accountAce.ADS_RIGHT_DS_SELF to rightS, Set accountAce.ADS_RIGHT_DS_READ_PROP to rightR, Set accountAce.ADS_RIGHT_DS_WRITE_PROP to rightW,
			Set accountAce.ADS_RIGHT_DS_DELETE_TREE to rightE, Set accountAce.ADS_RIGHT_DS_LIST_OBJECT to rightI, Set accountAce.ADS_RIGHT_DS_CONTROL_ACCESS to rightX,
			
			Set $account.concept to soType
		]
	}
	
	accountAceUid = Variable { type: String }
	
	groupAceGroupUid = Variable { type: String }
	groupAcePermUid = Variable { type: String }
	groupAcePerimUid = Variable { type: String }
	
	// Data to display
	principalDomain = Variable { type: String }
	principalId = Variable { type: String }
	soType = Variable { type: String }
	soDistinguishedname = Variable { type: String }
	aceScope = Variable { type: String }
	rightA = Variable { type: Integer }
	rightD = Variable { type: Integer }
	rightL = Variable { type: Integer }
	rightS = Variable { type: Integer }
	rightR = Variable { type: Integer }
	rightW = Variable { type: Integer }
	rightE = Variable { type: Integer }
	rightI = Variable { type: Integer }
	rightX = Variable { type: Integer }
	rightT = Variable { type: Integer }
	rightC = Variable { type: Integer }
	rightM = Variable { type: Integer }
	rightO = Variable { type: Integer }
	rightY = Variable { type: Integer }
	rightU = Variable { type: Integer }
	
	
	accountAce = Record { view: adacl_accountace with accountAceUid to uid }
	groupAce = Record { view: adacl_groupace with groupAceGroupUid to group_uid , groupAcePerimUid to perimeter_uid, groupAcePermUid to permission_uid }
	
	Grid {
		columns: GridColumn { width: grow }, GridColumn { width: 150 }, GridColumn { width: 150 }
		
		GridRow {
			GridCell{
				
				Text { value: $dialogsdetailsACL.labels.securityprincipal styling: redSmallLabel }
				Group {
					layout: Layout { indent: horizontal 20 vertical 0 }
					Text { label: $ad_domain.concept value: principalDomain }
					Text { label: $dialogsdetailsACL.labels.id value: principalId }
				}
				Text { value: $dialogsdetailsACL.labels.securableobject styling: redSmallLabel }
				Group {
					layout: Layout { indent: horizontal 20 vertical 0 }
					Text { label: $dialogsdetailsACL.labels.type value: soType }
					Text { label: $dialogsdetailsACL.labels.dn value: soDistinguishedname  lines: 2 layout: Layout { hint: height 30 }}
				}
				Text { value: $dialogsdetailsACL.labels.additional styling: redSmallLabel  }
				Group {
					layout: Layout { indent: horizontal 20 vertical 0 }
					Text { label: $dialogsdetailsACL.labels.scope value: aceScope }
				}
			
			
			}
			
			GridCell{
				Text { value: $dialogsdetailsACL.labels.rights styling: redSmallLabel  }
				Group {
				
					layout: Layout { indent: horizontal 10 vertical 0 }
					
					Text { value: $ad_rights.svalue.R  tooltip: $ad_rights.explained.R decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightR ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.W  tooltip: $ad_rights.explained.W decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightW ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.L  tooltip: $ad_rights.explained.L decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightL ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.A  tooltip: $ad_rights.explained.A decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightA ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.D  tooltip: $ad_rights.explained.D decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightD ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.S  tooltip: $ad_rights.explained.S decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightS ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.E  tooltip: $ad_rights.explained.E decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightE ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.I  tooltip: $ad_rights.explained.I decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightI ) using rightTemplate width:18 } width: 140  } }
					
					
					
				}
			
			}
			
			GridCell {
				Group {
					layout: Layout { indent: horizontal 0 vertical 26 }
					
					Text { value: $ad_rights.svalue.X  tooltip: $ad_rights.explained.X decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightX ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.T  tooltip: $ad_rights.explained.T decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightT ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.C  tooltip: $ad_rights.explained.C decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightC ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.M  tooltip: $ad_rights.explained.M decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightM ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.O  tooltip: $ad_rights.explained.O decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightO ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.Y  tooltip: $ad_rights.explained.Y decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightY ) using rightTemplate width:18 } width: 140  } }
					Text { value: $ad_rights.svalue.U  tooltip: $ad_rights.explained.U decorator: Decorator { before: Image {  image: TemplateImageSelection ( rightU ) using rightTemplate width:18 } width: 140  } }
				}
			}
		
		}
	}
	
	
	

}