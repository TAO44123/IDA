import "/webportal/pages/bw_ad_schema/resources/concepts_nls.page"
import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"
import "/webportal/pages/bw_ad_schema/resources/basestyles.page"
import "/webportal/pages/bw_ad_schema/resources/resources.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"

isgroupACE = StringMapping {
	when "group" then 1
	otherwise 0
}

groupOrgAccountACE = NLS {
	displayname [en "{0,choice,0# Account ACE |1#{1}}" ]
}

inverseManaged = IntMapping {
	when =0 then 1
	when =1 then 0
	otherwise 1
}

intToBooleanMapping = IntMapping {
	when =0 then False
	when =1 then True
}

objectMetadata_Dialog = Dialog {
	title: $adschema_dialogs.objectmetadata.title
	width: 700
	height: 280
	enter-event:
		Set selectedPermission.managed to managed,
		Set selectedPermission.description to description,
		IntCase ( autoSet ) { when =0 then [ Set 0 to managed, Set 1 to changed ] when =1 then [ Set 1 to managed, Set 1 to changed ] }
		
	buttons: [
	
		OkButton {
			disabled:StringPredicate(changed) {when '1' then False otherwise True}
			actions: Set description to task.description,
			Set Transform managed using intToBooleanMapping to task.managed,
			Set paramPermissionUid to task.object,
			TaskComplete task wait,
			Flash $adschema_dialogs.objectmetadata.messages.done
			
		}
		
		CancelButton
		
	] 
	
	// Parameter
	paramPermissionUid = Variable {type:String multivalued:False}
	autoSet = Variable { type: Integer initial: -1 }
	
	// Variables to edit
	description = Variable
	managed = Variable
	
	changed = Variable{type:String initial:'0'}
	
	// Datasets and Records
	selectedPermission = Record { view: ad_object_detail with paramPermissionUid to uid }
	
	task = TaskRecord ( create "updateobjectmetadata" )
	
	
	Header {
		value: $adschema_dialogs.objectmetadata.description ( selectedPermission.displayname )
	}
	
	Spacer {
		height: 10
	}
	
	
	Combo {
		variable: managed
		label: $adschema_dialogs.objectmetadata.labels.managed
		modify-event:
			Set '1' to changed
		options:Static{
			Option{text: $global.no value:'0'}
			Option{text: $global.yes value:'1'}
		}
	}
	
	Edit {
		variable:description
		label:$adschema_dialogs.objectmetadata.labels.description
		multi-lines:True
		layout:Layout{grab: horizontal True vertical False hint:height 64}
		modify-event:Set '1' to changed
	}	
	
	

}

dialogGroupMembers = Dialog {
	title: $adschema_dialogs.groupmembers.title
	width: 700
	height: 400
	
	// Parameter
	groupUid = Variable { type: String }
	
	selectedGroup = Record { view: ad_group_select_uid with groupUid to uid}
	
	directIdentities = Dataset {
		view: ad_group_identitiesdirect with groupUid to uid
	}
	
	indirectIdentities = Dataset {
		view: ad_group_identitiesindirect with groupUid to uid
	}
	
	allIdentities = Dataset {
		union: Union {
			datasets: directIdentities discriminator "direct", indirectIdentities discriminator "indirect"
			discriminator-column: type
		}
	}
	
	Text { 
		value: $adschema_dialogs.groupmembers.subtitle (selectedGroup.displayname )
		styling: redSmallLabel
		compact: True 
	}
									
	Table {
		data: allIdentities
		layout: Layout { grab: horizontal True vertical True indent: horizontal 0 vertical 5  hint: width 650 }
		show-count: True 
		show-filter: True
		
		Column {width: 70% column: type text: Transform Current type using typeMap header: $adschema_group_explorer.tabs.identities.headers.type }
		
		Column { width: 70% column: type 
			// isDirect ? displayname : child_displayname
			text: $adschema_group_explorer.tabs.identities.labels.group( Transform Current type using isDirect , Current displayname, Current child_displayname )  
			header: $group.concept 
			filterable: True
			}
		
		Column {width: 70% column: account_login header: $account.login filterable: True }
		Column {width: 70%  column: id_fullname header: $pidentity.fullname  text: Transform Current id_fullname using optionStringMapping filterable: True }
		Column {width: 50%  column: org_shortname header: $organisation.concept text: Transform Current org_shortname using optionStringMapping  filterable: True }		
	}

}

dialogACLDetails = Dialog {
	title: $adschema_dialogs.acldetails.title
	width: 780
	height: 500
	mixins: base_dialogMixin
	enter-event: TransferData groups(uid) to (accountInGroups)
	
	// Input variables
	accountUid = Variable { type: String }
	adObjectUid = Variable { type: String }
	
	// Other variables
	accountInGroups = Variable { type: String multivalued: True }
	initialTimeSlotUid = Variable { initial:PageTimeslot.UID }
	selectedTimeSlotUid = Variable { type: String }
	selectedACEUid = Variable  { type: String }
	selectedACEType = Variable { type: String }
	selectedGroupUid = Variable {type: String }
	selectedPerimeterUid = Variable { type: String }
	
	// Datasets
	account = Record { view: br_accountDetail with accountUid to uid }
	adObject = Record { view: adobject_Detail_Uid with adObjectUid to uid  }
	groups = Dataset { view: groups_byaccount with accountUid to uid }
	
	
	// Datasets to get ACLS ( same used in the explorer ) 
	groupAcls = Dataset {
		view: adacl_groupacls with adObjectUid to uid , accountInGroups to groupUids
		timeslot: selectedTimeSlotUid 
	}
	accountAcls = Dataset {
		view: adacl_accountacls with adObjectUid to uid , accountUid to accountUids
		timeslot: selectedTimeSlotUid 
	}
	
	allACEs = Dataset {
		union: Union {
			datasets: accountAcls discriminator "account", groupAcls discriminator "group"
			discriminator-column: type
		}
	}
	
	/* timeslots */
	timeslots = Dataset { view: explorergettimeslots }
	
	Group {
		layout: Layout { grab: horizontal True  vertical False }
		Grid{ columns: GridColumn { width: grow 1 } , GridColumn { width: grow 2 } 
			GridRow {
				GridCell {
					Text {
						label: $ad_account.pdomain
						value: account.repository_displayname
					}
					Text {
						label: $paccount.login
						value: account.login 
					}
				}
				GridCell {
					Text {
						label: $ad_object.concept 
						value: adObject.displayname
					}
					Text {
						layout: Layout { hint: height 40 grab: horizontal True vertical False }
						label: Label { value: $ad_object.dn  layout: Layout { align: horizontal Beginning vertical Beginning }}
						value: adObject.custom1
						lines: 2
					}
				}
			}
		}
	}
	
	/*SetNavigator {
		data: timeslots 
		column: uid 
		align: Center
		selection: selectedTimeSlotUid  
		label: Current displayname
		label-width: 350
		dropdown: Dropdown { text: Current displayname } 
		show-last:True
		initial: 
	}*/
	
	
	Table {
		data: allACEs
		layout: Layout { grab: horizontal True vertical True }
		double-click: StringCase ( selectedACEType ) {
			when "account" then [ Dialog dialogACEDetails( selectedACEUid to accountAceUid ) ]
			when "group" then [ Dialog dialogACEDetails( selectedGroupUid to groupAceGroupUid , adObjectUid to groupAcePermUid, selectedPerimeterUid to groupAcePerimUid ) ]
		
		}
		commands:Commands{position:After orientation:Vertical presentation:Icon Command{actions: Dialog dialogACLHelp icon:"16/famfamfam_silk_icons_v013/help.png" tooltip: $adschema_dialogs.aclhelp.tooltip.button}  Command{actions:Message "" icon:"" disabled:True}}
							
		
		
		Column { column: type  hidden: True selection: selectedACEType }
		Column { width: 60% column: group_displayname text: $groupOrgAccountACE.displayname ( Transform Current type using isgroupACE , Concat ( Current domain_displayname , "\\", Current group_displayname))    header: $group.concept }
		Column { width: 25px column: ADS_RIGHT_DS_READ_PROP header: "R"  image: TemplateImageSelection (Current ADS_RIGHT_DS_READ_PROP) using rightTemplate text: ""  }
		Column { width: 25px column: ADS_RIGHT_DS_WRITE_PROP header: "W"  image: TemplateImageSelection (Current ADS_RIGHT_DS_WRITE_PROP) using rightTemplate text: "" }
		Column { width: 25px column: ADS_RIGHT_ACTRL_DS_LIST header: "L"  image: TemplateImageSelection (Current ADS_RIGHT_ACTRL_DS_LIST) using rightTemplate text: "" }
		Column { width: 25px column: ADS_RIGHT_DS_CREATE_CHILD header: "A" image: TemplateImageSelection (Current ADS_RIGHT_DS_CREATE_CHILD) using rightTemplate text: "" }
		Column { width: 25px column: ADS_RIGHT_DS_DELETE_CHILD header: "D" image: TemplateImageSelection (Current ADS_RIGHT_DS_DELETE_CHILD) using rightTemplate text: "" }
		Column { width: 25px column: SPECIAL header: "+" image: TemplateImageSelection (Current SPECIAL) using rightTemplate text: ""}
		
		Column { width: 100% column: perimeterdisplayname  header: $ad_perimeter.displayname  }
		Column { width: 56px column: isdefault header: $adschema_explorer.headers.defaultright text: Transform Current isdefault using booleanDisplayMapping }
		
		Column { column: uid hidden: True selection: selectedACEUid}
		Column { column: group_uid hidden: True selection: selectedGroupUid}
		Column { column: perimeteruid hidden: True selection: selectedPerimeterUid }	
	}
}

