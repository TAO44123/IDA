import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"

typeMap = StringMapping {
	when "direct" then $adschema_group_explorer.tabs.identities.labels.type.direct
	when "indirect" then $adschema_group_explorer.tabs.identities.labels.type.indirect
}

isDirect = StringMapping {
	when "direct" then 1
	otherwise 0
}



rightTemplate = StringImageTemplate {
	when "2" then "16/famfamfam_silk_icons_v013/cross.png"
	when "1" then "16/famfamfam_silk_icons_v013/tick.png"
}


// Evolution icons

evolutionWarningIcons = IntImageTemplate {
	when < 0  then "bw_ad_schema/arrows/green/down_16.png"
	when = 0  then "bw_ad_schema/arrows/blue/neutro_16.png"
	when > 0  then "bw_ad_schema/arrows/red/up_16.png"
}

evolutionInverseWarningIcons = IntImageTemplate {
	when < 0  then "bw_ad_schema/arrows/red/down_16.png"
	when = 0  then "bw_ad_schema/arrows/blue/neutro_16.png"
	when > 0  then "bw_ad_schema/arrows/green/up_16.png"
}

evolutionIssueIcons = IntImageTemplate {
	when < 0  then "bw_ad_schema/arrows/green/down_16.png"
	when = 0  then "bw_ad_schema/arrows/blue/neutro_16.png"
	when > 0  then "bw_ad_schema/arrows/red/up_16.png"
}

evolutionNeutroIcons = IntImageTemplate {
	when < 0  then "bw_ad_schema/arrows/blue/down_16.png"
	when = 0  then "bw_ad_schema/arrows/blue/neutro_16.png"
	when > 0  then "bw_ad_schema/arrows/blue/up_16.png"
}

newItemTemplate = StringImageTemplate {
	when "New" then "16/famfamfam_silk_icons_v013/add.png"
	when "Modified" then "16/indicators/flipflop.png"
}

diffItemTemplate = StringImageTemplate {
	when "New" then "16/famfamfam_silk_icons_v013/add.png"
	when "Modified" then "16/indicators/flipflop.png"
	when "Deleted" then "16/famfamfam_silk_icons_v013/delete.png"
}

statusMapping = StringMapping {
	when "New" then "New" prefix " "
	when "Modified" then "Modified" prefix " "
	when "Deleted" then "Deleted" prefix " "
	when "Invalid" then "No change" prefix " "
}
