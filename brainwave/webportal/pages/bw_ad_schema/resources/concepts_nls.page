ad_rights = NLS {
	
	svalue.A [en "CreateChild" fr "CreateChild"]
	svalue.D [en "DeleteChild" fr "DeleteChild"]
	svalue.L [en "ListChildren" fr "ListChildren"]
	svalue.S [en "Self" fr "Self"]
	svalue.R [en "ReadProperty" fr "ReadProperty"]
	svalue.W [en "WriteProperty" fr "WriteProperty"]
	svalue.E [en "DeleteTree" fr "DeleteTree"]
	svalue.I [en "ListObject" fr "ListObject"]
	svalue.X [en "ExtendedRight" fr "ExtendedRight"]
	svalue.T [en "Delete" fr "Delete"]
	svalue.C [en "ReadControl" fr "ReadControl"]
	svalue.M [en "WriteDacl" fr "WriteDacl"]
	svalue.O [en "WriteOwner" fr "WriteOwner"]
	svalue.Y [en "Synchronize" fr "Synchronize"]
	svalue.U [en "AccessSystemSecurity" fr "AccessSystemSecurity"]
	
	explained.A [en "The right to create children of the object." fr "Le droit de créer des objets fils."]
	explained.D [en "The right to delete children of the object." fr "Le droit de supprimer des objects fils."]
	explained.L [en "The right to list children of this object." fr "Le droit de lister les objets fils."]
	explained.S [en "The right to perform an operation that is controlled by a validated write access right." fr "Le droit d'effectuer une opération qui est contrôlée par un droit d'accès en écriture."]
	explained.R [en "The right to read properties of the object." fr "Le droit de lire les propriétés de l'objet."]
	explained.W [en "The right to write properties of the object." fr "Le droit d'écrire les propriétes de l'objet."]
	explained.E [en "The right to delete all children of this object, regardless of the permissions of the children." fr "Le droit de supprimer tous les objets fils indépendamment des permissions des objets fils."]
	explained.I [en "The right to list a particular object." fr "Le droit de lister un objet particulier."]
	explained.X [en "A customized control access right." fr "Un droit de contrôle personnalisé."]
	explained.T [en "The right to delete the object." fr "Le droit de supprimer l'objet."]
	explained.C [en "The right to read data from the security descriptor of the object, not including the data in the SACL." fr "Le droit de lire les donnés dans le descripteur de sécurité de l'objet, sans inclure les donnés dans la SACL."]
	explained.M [en "The right to modify the DACL in the object security descriptor." fr "Le droit de modifier la DACL dans le descripteur de sécurité de l'objet."]
	explained.O [en "The right to assume ownership of the object. " fr "Le droit de devenir le propiétaire de l'objet."]
	explained.Y [en "The right to use the object for synchronization." fr "Le droit d'utiliser l'objet pour la synchronisation."]
	explained.U [en "The right to get or set the SACL in the object security descriptor." fr "Le droit d'obtenir ou de définir la SACL dans le descripteur de sécurité de l'objet."]

}

