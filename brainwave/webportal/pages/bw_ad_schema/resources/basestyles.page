/* Base styles and mixins */
base_pageMixin = Mixin {
   Text {
     compact: True
   }
}

base_dialogMixin = Mixin {
   Text {
     compact: True
   }
}

fileExplorer = Mixin {
	Tree {
		hide-header: True
		hide-lines: True
		layout: Layout { grab: horizontal True vertical True indent: horizontal 0 vertical 0 }
	}
	
	Table {
		hide-header: True
		hide-lines: True
		layout: Layout { grab: horizontal True vertical True indent: horizontal 0 vertical 0  }
	}
	
	Button {
		layout: Layout { indent: horizontal 12 vertical 0 hint: height 50}
		presentation: Link
		styling: buttonStyle
	}
		
}

fileExplorerLabel = Mixin {

	Label {
		styling: label
		layout: Layout { indent: horizontal 12 vertical 0}
	}
	
	Combo{
		styling: label
	}
	
	Edit {
		styling: label
	}
	
	Checkbox{
		layout: Layout { align: horizontal End vertical Beginning}
	}
}

base_pageHeaderMixin = Mixin {
   Header {
     styling: titleLevel1       
     layout: Layout{ grab: horizontal True vertical False align: horizontal Fill vertical Beginning  hint: height 35 indent: horizontal 0 vertical 0}
  }
  
   This Group {
       	layout: Layout{grab: horizontal True vertical False indent: horizontal 0 vertical 0 align: horizontal Fill vertical End  }
	//	 background: Color HEX(#ECE9E8)
		 border: False
		 margins: Left 0 Top 0 Bottom 20
		 compact: True
   }
   
     // if used with buttons 
    This Grid {
	     layout: Layout{grab: horizontal True vertical False indent: horizontal 0 vertical 0 align: horizontal Fill vertical Beginning  }
		// background: Color HEX(#ECE9E8) // gris clair
		 insets: 5		
		 gap: 20 
	 }	
   
	  Text {
	     styling: titleLevel1
	     compact: True
	     layout: Layout{ hint: height 35 grab: horizontal True vertical False align: horizontal Fill vertical Beginning
	      indent: horizontal 0 vertical 0}
	  }
}


/* description text for page or section */
base_titleDescriptionMixin = Mixin {
  	Text 	{ styling: titleDescriptionText  compact: True  layout: Layout { hint: indent: horizontal -10 vertical -3} }
}

base_sectionTitleMixin = Mixin {
   Text {
     styling: titleLevel2
     align: Left
     compact: True
     layout: Layout{ hint:  indent: horizontal 0 vertical 20  }    
   }    
}

base_componentLabelMixin = Mixin {
   Text {
      styling: titleLevel3
      compact: True
   }
   Label {
     break: True
     styling: titleLevel3
   }
}

base_sideBarPane = Mixin {
	Text { compact: True  styling: simpleLabel }
	Group { margins: All 10 }
	Grid {
		fill: Both 
		gap:0 
		insets:0
		layout: Layout { grab: horizontal True vertical True }
	}
	Button {
		align: Center
		presentation: Link
		layout: Layout { hint: height 60 width 60 }
	}
}

base_quickViewPane = Mixin {
	Text 	{ styling: normalText   layout: Layout { hint: indent: horizontal 0 vertical 10} }
	Label 	{ layout: Layout { hint: indent: horizontal 0 vertical 10}}
	Table {
		layout: Layout { grab: vertical True horizontal True indent: horizontal -15 vertical 0}
	}
}

tabsStyle = Mixin {
	Grid {
		fill: Both
		gap:0
		insets:0
	}
	
	ButtonGroup {
	  margins: Left 5 Bottom 10
	   spacing: 20
	   uniform: False	   
	}
	
	Button {
		presentation: Link
		align: Center
		layout: Layout { grab: horizontal True vertical True align: horizontal Center vertical Center}
		styling: tab			
	}
}


