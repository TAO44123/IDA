deDetailsHeaders = PageFragment {
	firstHeader = Variable
	secondHeader = Variable
	thirdHeader = Variable
	
	ConditionalGroup {
		StringCondition ( thirdHeader ) {
			when Not IsEmpty then [
			
				Grid {
					layout: Layout { hint: height 80}
					columns: GridColumn { width: 400px }, GridColumn{ width: 80px },GridColumn{ width: 16px },GridColumn{ width: 100px }, GridColumn{ width: 90px }, GridColumn{ width:5px } , GridColumn{ width: 80px } , GridColumn{ width: 30px } , GridColumn{ width:5px }, GridColumn{ width: 80px } , GridColumn{ width: 30px } , GridColumn{ width:5px }, GridColumn{ width: 50px }, GridColumn { width: grow }
					mixins: data
					
					GridRow {
						GridCell {}
						GridCell {   
							span: 3
							Text {
								align: Center
								layout: Layout { hint: height 80 width 80 align: horizontal Center vertical Center}
								value: firstHeader mixins: grayCenteredHeaderMixin
							}
						}
						GridCell {}
						GridCell {}
						GridCell { 
							span: 3
							Text {
								align: Center
								layout: Layout { hint: height 80 width 80 align: horizontal Center vertical Center}
								value: secondHeader mixins: grayCenteredHeaderMixin
							}
						}
						GridCell {}
						GridCell {   
							span: 3
							Text {
								align: Center
								layout: Layout { hint: height 80 width 100 align: horizontal Center vertical Center}
								value: thirdHeader mixins: grayCenteredHeaderMixin
								lines: 3
							}
						}
					}
				}
			
			]
			
			otherwise [
				ConditionalGroup{
					StringCondition ( secondHeader ){
						when IsEmpty then [
			
							Grid {
								layout: Layout { hint: height 65 }
								columns: GridColumn { width: 400px }, GridColumn{ width: 80px },GridColumn{ width: 16px },GridColumn{ width: 100px }, GridColumn{ width: 90px } ,GridColumn{ width:5px }, GridColumn{ width: 50px }, GridColumn { width: grow }
								mixins: data
								
								GridRow {
									GridCell{}
									GridCell {   
										span: 4
										Text {
											align: Center
											layout: Layout { hint: height 60 width 80 align: horizontal Center vertical Center}
											value: firstHeader mixins: grayCenteredHeaderMixin
										}
									}
								}
							}
						]
						otherwise [
						
							Grid {
								layout: Layout { hint: height 80}
								columns: GridColumn { width: 400px }, GridColumn{ width: 80px },GridColumn{ width: 16px },GridColumn{ width: 100px }, GridColumn{ width: 90px } , GridColumn{ width:5px } , GridColumn{ width: 80px } , GridColumn{ width: 30px } , GridColumn{ width:5px }, GridColumn{ width: 50px }, GridColumn { width: grow }
								mixins: data
								
								GridRow {
									GridCell {}
									GridCell {   
										span: 4
										Text {
											align: Center
											layout: Layout { hint: height 80 width 80 align: horizontal Center vertical Center}
											value: firstHeader mixins: grayCenteredHeaderMixin
										}
									}
									GridCell { span: 2}
									GridCell {
										span: 3
										Text {
											align: Center
											layout: Layout { hint: height 80 width 100 align: horizontal Center vertical Center}
											value: secondHeader mixins: grayCenteredHeaderMixin
											lines: 3
										}
									}
								}
							}
						
						]
					
					}
				}
			
			]
		}
	}
	
	
}


