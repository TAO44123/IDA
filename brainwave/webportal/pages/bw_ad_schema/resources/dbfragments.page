domainSelectorCombo = PageFragment {
	mixins: dashboardTransparentMixin
	
	currentSelection = Variable
	
	selectedRecorduid = Variable
	selectedTreeCode = Variable
	selectedUID = Variable
	domainsCriteria = Variable { multivalued: True }
	domainperimeter = Variable { multivalued: True }
	
	getRecorduid = Record { view: ad_domaindetails with selectedUID to uid }
	
	/* datasets for the domain browser */
	domainperimeterdataset = Dataset { view: ad_domainperimeter }
	alldomainSelection = Dataset { values: [ ( uid->"", displayname ->$adschema_filters.domains.alldomains) ]}
	domainsFromdataset = Dataset {
		view: ad_alldomains  with domainperimeter to domains
	}
	loadedDomains = Dataset {
		union: Union {
			datasets: alldomainSelection, domainsFromdataset
			discriminator-column: source
		}
	}
	
	Group {
		layout: Layout { grab: horizontal True vertical True }
		
		Combo {
			variable: currentSelection
			layout: Layout { hint: width 200 }
			modify-event: 
				StringCase ( currentSelection ) {
					when IsEmpty then [
						Unset selectedRecorduid, Unset selectedTreeCode, Unset selectedUID, Unset domainsCriteria, TransferData domainperimeterdataset ( uid ) to ( domainsCriteria ) , FireFragmentEvent "selectionChanged"
					]
					otherwise [
						Set currentSelection to selectedUID, Set getRecorduid.recorduid to selectedRecorduid, Set getRecorduid.adtreecode to selectedTreeCode, Unset domainsCriteria, MultivaluedAdd selectedUID to domainsCriteria, FireFragmentEvent "selectionChanged"
					]
				}
			allow-none: False
			options: Dynamic { 
				data: loadedDomains
				text: Current displayname
				value: Current uid
			}
		}
	}
	
}

domainSelector = PageFragment {
	mixins: dashboardTransparentMixin
	enter-event: IntCase ( SizeOf domainsCriteria) { when =1 then [ Set ElementAt 1 of domainsCriteria to selectedUID, Set getRecorduid.adtreecode to selectedTreeCode] }, TransferData domainperimeterdataset ( uid ) to ( domainperimeter )
	
	selectedRecorduid = Variable
	selectedTreeCode = Variable
	selectedUID = Variable
	domainsCriteria = Variable { multivalued: True }
	domainperimeter = Variable { multivalued: True }
	
	getRecorduid = Record { view: ad_domaindetails with selectedUID to uid }
	
	/* datasets for the domain browser */
	domainperimeterdataset = Dataset { view: ad_domainperimeter }
	loadedDomains = Dataset {
		view: ad_alldomains  with domainperimeter to domains
		limit: 8
	}
	
	Grid {
		mixins: leftSelectionBar
		columns: GridColumn {}
		
		GridRow { height: 10 GridCell {} }
		GridRow {
			hidden: IntPredicate ( getRecorduid.recorduid ) { when != 0 then True otherwise False}
			GridCell {
				background: Color RGB ( 134,154,178)
				Button {
					hidden: IntPredicate ( getRecorduid.recorduid ) { when != 0 then True otherwise False}
					actions: Unset selectedRecorduid, Unset selectedTreeCode, Unset selectedUID, Unset domainsCriteria, TransferData domainperimeterdataset ( uid ) to ( domainsCriteria ) , FireFragmentEvent "selectionChanged"
					text: $adschema_filters.domains.alldomains
					styling: buttonSelectedHeader
				}
			}
		}
		GridRow {
			hidden: IntPredicate ( getRecorduid.recorduid ) { when != 0 then False otherwise True }
			GridCell {
				Button {
					hidden: IntPredicate ( getRecorduid.recorduid ) { when != 0 then False otherwise True }
					actions: Unset selectedRecorduid, Unset selectedTreeCode, Unset selectedUID, Unset domainsCriteria, TransferData domainperimeterdataset ( uid ) to ( domainsCriteria ) , FireFragmentEvent "selectionChanged"
					text: $adschema_filters.domains.alldomains
				}
			}
		}
		GridRowGroup {
			iterate-on: loadedDomains
			
			GridRow {
				hidden: IntPredicate ( Difference( Current recorduid, getRecorduid.recorduid ) ) { when != 0 then True otherwise False } 
				GridCell {
					background: Color RGB ( 134,154,178)
					Button {
						hidden: IntPredicate ( Difference( Current recorduid, getRecorduid.recorduid ) ) { when != 0 then True otherwise False } 
						actions: Set Current recorduid to selectedRecorduid, Set Current adtreecode to selectedTreeCode, Set Current uid to selectedUID , Unset domainsCriteria, MultivaluedAdd selectedUID to domainsCriteria, FireFragmentEvent "selectionChanged"
						text: Current displayname
						styling: buttonSelectedHeader
					}
				}
			}
			
			GridRow {
				hidden: IntPredicate ( Difference( Current recorduid, getRecorduid.recorduid ) ) { when != 0 then False otherwise True } 
				GridCell {
					Button {
						hidden: IntPredicate ( Difference( Current recorduid, getRecorduid.recorduid ) ) { when != 0 then False otherwise True } 
						actions: Set Current recorduid to selectedRecorduid, Set Current adtreecode to selectedTreeCode, Set Current uid to selectedUID , Unset domainsCriteria, MultivaluedAdd selectedUID to domainsCriteria, FireFragmentEvent "selectionChanged"
						text: Current displayname
					}
				}
			}
		}
		
		GridRow {
			height: grow
		}
	}
	
}


