/* Import other pages here */
import "/webportal/pages/bw_ad_schema/resources/resources.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_ad_schema/resources/concepts_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_ad_schema/resources/basestyles.page"
import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"
import "/webportal/pages/bw_ad_schema/resources/dashboards_nls.page"
import "/webportal/pages/bw_ad_schema/resources/analytics_nls.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"


analytics_group_almostpublic = Page {
	title: $ad_dashboard_riskNLS.kpi.label.group_almostpublic
	mixins: base_pageMixin
	tags: "ADreports"
	
	/* Parameters here */
	domainFilter = Parameter { type: String hidden:True }
	
	/* Variables here */
	domainperimeter = Variable { multivalued: True }
    domainsCriteria = Variable { type: String multivalued: True initial:domainFilter}
	filterByDomain = Variable { type: String multivalued: True }
	
	selectedGroupUid = Variable { type: String }
	selectedGroupRecorduid = Variable { type: Integer }
	
	/* Datasets and records here */
	domainperimeterdataset = Dataset { view: ad_domainperimeter }
	groupAlmostPublic = Dataset { view: ad_group_almostpublic  with domainsCriteria to domains unless-empty
		trend: Trend { 
					join-column: uid
					exclude-new: False
					include-removed: False
					exclude-same: False
					status-column-name:status
					timeslot: FromPage (-1)
					value-column: trend
				}
	}
	
	
	allDomains = Dataset {
		view: getdomains with domainperimeter to domains
	}
	
	clearDomainCriteria = NamedAction (
        Unset domainsCriteria,
        TransferData domainperimeterdataset(uid) to ( domainsCriteria )
    )
	
	clearAll = NamedAction (
		Unset selectedGroupUid, Unset selectedGroupRecorduid
	)
	
	showGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog (
			selectedGroupUid to inuid,
			True to inshowaccounts,
			True to inshowapplications,
			True to inshowcontrols,
			True to inshowdecisionhistory,
			True to inshowperjob,
			True to inshowperorg,
			True to inshowshares
		)
	)
	
	Splitter {
		disposition: Horizontal
		size: 70%
		Group {
			Table {
				layout:  Layout  { grab: horizontal True vertical True }
				data: groupAlmostPublic
				show-count: True
				show-filter: True
				configurable: True 
				
				Column {
					column: status
					header: $analytics_results_pages.table.headers.status
					width: 80px
					text: Transform Current status using statusMapping
					image: TemplateImageSelection(Current status) using newItemTemplate
					sortable: True
				}
				Column { column: domain_displayname header: $ad_domain.concept width: 100% sortable: True filterable:True}
				Column { column: displayname header: $group.displayname width: 100% sortable: True filterable:True actions:ExecuteNamedAction showGroupDetails}
				Column { column: code header: $group.code width: 100% initially-masked: True sortable: True filterable:True actions:ExecuteNamedAction showGroupDetails}
				Column { column: nbaccount text:Concat(Current nbaccount, ' / ',Current domain_totalnbaccount) header: $account.concept width: 100% sortable: True}
			
				Column { column: uid hidden: True selection: selectedGroupUid }
				Column { column: recorduid hidden: True selection: selectedGroupRecorduid }	
			}
		}
		Group {
			
		}
	}	
}
