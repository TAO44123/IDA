/* Import other pages here */
import "/webportal/pages/bw_ad_schema/resources/resources.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_ad_schema/resources/concepts_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_ad_schema/resources/basestyles.page"
import "/webportal/pages/bw_ad_schema/resources/dbfragments.page"
import "/webportal/pages/bw_ad_schema/resources/pages_nls.page"
import "/webportal/pages/bw_ad_schema/resources/dashboards_nls.page"
import "/webportal/pages/bw_ad_schema/resources/analytics_nls.page"


analytics_gpo_passwords = Page {
	title: $analytics_gpo_passwordsNLS.title
	dynamic-title: $analytics_gpo_passwordsNLS.dyntitle(repository.displayname)
	description: $analytics_gpo_passwordsNLS.description
	mixins: base_pageMixin

    tags: "byuid", "analytics", "repositoryext", "AD"
    icon: %adschema_icons.windows_32 large-icon: %adschema_icons.windows_48

	enter-event: Set uid to domainsCriteria
	
	/* Parameters here */
    uid = Parameter { type: String hidden: True }	
	filterByDomains = Parameter {
		type: String
		multivalued: True
		hidden:True
	}
	
	/* Variables here */
	domainperimeter = Variable { multivalued: True }
	
	domainsCriteria = Variable { type: String multivalued: True }
	
	selectedPolicyUid = Variable { type: String }
	
	/* Datasets and records here */
	repository = Record {
		view:br_repositoryDetail with uid to uid	
	}
	passwordPolicies = Dataset { view: ad_password_policies  with domainsCriteria to domains unless-empty
		trend: Trend { 
					join-column: uid
					exclude-new: False
					include-removed: False
					exclude-same: False
					status-column-name:status
					timeslot: FromPage (-1)
					value-column: trend
				}
	}
	
	allDomains = Dataset {
		view: getdomains with domainperimeter to domains
	}
	
	domainperimeterdataset = Dataset { view: ad_domainperimeter }
	
	clearDomainCriteria = NamedAction (
		Unset domainsCriteria,
		TransferData domainperimeterdataset(uid) to ( domainsCriteria )
	)
	
	clearAll = NamedAction (
		Unset selectedPolicyUid
	)
	
	Splitter {
		disposition: Horizontal
		size: 70%
		Group {
			Table {
				layout:  Layout  { grab: horizontal True vertical True }
				data: passwordPolicies
				show-count: True
				show-filter: True
				configurable: True 
				
				Column {
					column: status
					header: $analytics_results_pages.table.headers.status
					width: 95px
					text: Transform Current status using statusMapping
					image: TemplateImageSelection(Current status) using newItemTemplate
					sortable: True
					filterable:True
				}
				Column { column: displayname width: 70% header: $analytics_moredetailsNLS.headers.policies.names filterable:True}
				Column { column: domaindisplayname width: 30% header: $analytics_moredetailsNLS.headers.policies.domain filterable:True}				
				Column { column: uid hidden: True selection: selectedPolicyUid }
			}
			
		}
		
		Group {
			
			IncludeFragment {
				fragment: passwordPoliciesDetails with
					selectedPolicyUid binds-to selectedGPOuid
			}	
		
			Spacer { height: 16}
		}
	}
}
