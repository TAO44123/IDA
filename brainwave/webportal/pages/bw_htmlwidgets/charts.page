/**
 * <span style="white-space: pre-line">
 * A venn Diagram Chart
 * overlapping is computed based on the number of elements in common between codes (buckets from 2 to 6)
 * WARNING: the venn diagram compute the results based on raw data on the client side. As a result the amount of data to send to the browser
 * can be huge, ie: the diagram will take some time to compute. Be careful when designing your datasets
 * Dataset size is limited to 50000 lines (see NBMAXLINES in the javascript file) which approximately corresponds to 5mb over the network
 * Nb of displayed entities is limited to 10 (see NBMAXENTITY in the javascript file)
 *  
 * <u>Dataset: chartdata</u>
 * <b>label (String)</b> the object label as displayed in the widget
 * <b>code (String)</b> the object unique id
 * <b>element (Integer)</b> the object associated value as a string element
 * 
 * <u>Parameters:</u><ul>
 * <li><b>tooltipPrefix (String)</b>  Optional a string to append at the beginning of the tooltip value</li>
 * <li><b>tooltipSuffix (String)</b>  Optional a string to append at the end of the tooltip value</li>
 * <li><b>tooltipnPrefix (String)</b>  Optional a string to append at the beginning of the tooltip value when the area is an intersection</li>
 * <li><b>tooltipnSuffix (String)</b>  Optional a string to append at the end of the tooltip value when the area is an intersection</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>onclick</b> fired when the user click on an item.</li>
 * </ul>
 * </span>
 */
vennDiagramChart = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/venn/venn.html"
	datasets: chartdata ( code as String, label as String, element as String ) /* Mandatory */
	bindings: 
		tooltipPrefix as in String, /* Optional String */ 
		tooltipSuffix as in String,  /* Optional String */ 
		tooltipnPrefix as in String, /* Optional String */ 
		tooltipnSuffix as in String  /* Optional String */ 
	widget-events:
		// in case of several circle overlaping with each other the order is the most restrictive first
		onclick (nbofitems as Integer, 
				code1 as String, label1 as String, 
				code2 as String, label2 as String, 
				code3 as String, label3 as String, 
				code4 as String, label4 as String, 
				code5 as String, label5 as String, 
				code6 as String, label6 as String, 
				count as Integer )
}

