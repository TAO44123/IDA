/**
 * <span style="white-space: pre-line">
 * A doughnut chart
 * 
 * <u>Dataset: chartdata</u>
 * <b>label (String)</b> the item label displayed in the widget
 * <b>code (String)</b> the item unique code
 * <b>count (Integer)</b> the item value
 * <b>color (String)</b> optional - the item background color such as #FF0045
 * 
 * <u>Parameters:</u><ul>
 * <li><b>title (String)</b>  Optional the title of the chart</li>
 * <li><b>titlePosition (String)</b>  Optional the title position (top, bottom, left, right)</li>
 * <li><b>titleFontSize (Integer)</b>  Optional the title font size</li>
 * <li><b>showLegend (Boolean)</b>  Optional true to show the legend</li>
 * <li><b>showLegend (Boolean)</b>  Optional true to show the legend</li>
 * <li><b>showHalfOnly (Boolean)</b>  Optional show only the upper side of the graph</li>
 * <li><b>cutoutPercentage (Integer)</b>  Optional inner radius (in percentage)</li>
 * <li><b>tooltipShowPercent (Boolean)</b>  Optional true to also show the value as a percent in the tooltip</li>
 * <li><b>nbMaxElements (Integer)</b> max number of elements to display</li>
 * <li><b>showOther (Boolean)</b> in case nbMaxElements reached, consolidate the other elements in a pie</li>
 * <li><b>otherColor (String)</b> color of the 'other' pie such as '#999999'</li>
 * <li><b>otherCode (String)</b> returned code of the 'other' pie (when clicked)</li>
 * <li><b>otherLabel (String)</b> returned label of the 'other' pie (when clicked)</li>
 * <li><b>customColors (String)</b> Optional Provide a custom palette as a string ("#fcc3a7,#f5aa85,#ef8d5d")</li>
 * <li><b>backgroundColor (String)</b> Canvas background color (defaults to '#FFFFFF')</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>onclick</b> fired when the user click on an item.</li>
 * <li><b>onlegendclick</b> fired when the user click on an item in the legend panel.</li>
 * </ul>
 * </span>
 */
doughnutChart = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/doughnut.html"
	datasets: chartdata ( label as String /* Mandatory */, code as String/* Mandatory */, count as Integer/* Mandatory */, color as String /* Optional */) /* Mandatory */
	bindings: 
		title as in String, /* Optional */ 
		titlePosition as in String, /* Optional top, bottom, left, right*/
		titleFontSize as in Integer, /* Optional */
		showLegend as in Boolean, /* Optional */ 
		showHalfOnly as in Boolean, /* Optional */ 
		cutoutPercentage as in Integer, /* Optional */ 
		legendPosition as in String, /* Optional top, bottom, left, right*/
		nbMaxElements as in Integer, /* Optional integer*/
		showOther as in Boolean, /* Optional Boolean */
		backgroundColor as in String, /* Background Color (defaults to #FFFFFF) */
		otherColor as in String, /* Optional Color */
		otherCode as in String, /* Optional String */
		otherLabel as in String, /* Optional String */
		tooltipShowPercent as in Boolean, /* Optional Boolean */
		customColors as in String /* Optional Colors such as: "#fcc3a7,#f5aa85,#ef8d5d" */
	widget-events:
		onclick ( code as String, label as String, count as Integer ),
		onlegendclick ( code as String, label as String )
}


