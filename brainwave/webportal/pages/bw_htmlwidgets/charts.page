	source-file: "static/bw_htmlwidgets/charts/line.html"
	datasets: chartdata ( label as String , code as String, count as Integer , description as String/*optional*/) /* Mandatory */
	bindings: 
		title as in String, /* Optional */ 
		titlePosition as in String, /* Optional top, bottom, left, right*/
		titleFontSize as in Integer, /* Optional */
		tooltipPrefix as in String, /* Optional String */ 
		tooltipSuffix as in String, /* Optional String */ 
		tooltipShowPercent as in Boolean, /* Optional Boolean */
		xlabel as in String, /* Optional String */ 
		ylabel as in String, /* Optional String */ 
		xAxesdisplay as in Boolean, /* Optional Boolean */ 
		yAxesdisplay as in Boolean, /* Optional Boolean */ 
		reverseXorder as in Boolean, /* Optional Boolean */ 
		reverseYorder as in Boolean, /* Optional Boolean */ 
		showxAxesGrid as in Boolean, /* Optional Boolean */ 
		showyAxesGrid as in Boolean, /* Optional Boolean */ 
		fill as in String, /* Optional String: false, origin, start, end */ 
		beginAtZero as in Boolean, /* Optional (boolean) */
		showLine as in Boolean, /* Optional Boolean */ 
		curvedLine as in Boolean, /* Optional Boolean */ 
		maintainAspectRatio as in Boolean, /* Optional (boolean) */
		backgroundColor as in String, /* Background Color (defaults to #FFFFFF) */
		lineColor as in String, /* Optional String (color) */
		lineWidth as in Integer, /* Optional Integer */
		lineDashed as in String, /* Optional String: style1,style2,style3,style4*/
		pointStyle as in String, /* Optional String: circle, cross, crossRot, dash, line, rect, rectRounded, rectRot, star, triangle */ 
		pointRadius as in Integer, /* Optional Integer */ 
		pointColor as in String, /* Optional String (color) */
		pointHoverColor as in String, /* Optional String (color) */
		fillColor as in String, /* Optional String (color) */ 
		animation as in Boolean, /* Optional Boolean, default true */ 
		datasetMinSize as in Integer /* Optional Integer */ 
	widget-events:
		onclick ( code as String, label as String, count as Integer )
}

