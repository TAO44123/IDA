				layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
				template: multilineChart
				datasets: topOrgsIntern ( uid, shortname, internal, status, count ) to chartdata ( code, label, categorycode , category, count )
				bindings: 
					value-of "Stacked100 Multi Line Chart" to title,
					value-of "Start" to fill,
					value-of 1 to pointRadius,
					value-of True to isStacked,
					value-of True to stacked100
				widget-events: {
					when onclick then [
						Flash Concat ("Clicked on Code/Label/Category Code/Category/Count: ", Current code," ", Current label," ", Current categorycode," ", Current category," ", Current count ) 
					]
					when oncategoryclick then [
						Flash Concat ("Clicked on Category Code/Category: ", Current categorycode, " ", Current category ) 
					]
				}
			}
			IncludeHTMLWidget {
				layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
				template: heatmapChart
				datasets: topOrgsRisks ( uid, shortname, risklevel, risklevellabel, count ) to chartdata ( code , label, categorycode, category, count )
				bindings: 
					value-of False to rounded,
					value-of "Palette" to colorInterpolation,
					value-of Constant higherTheWorstPalette to customColors
				widget-events: {
					when onclick then [
						Flash Concat ("Clicked on Code/Label/Category Code/Category/Count: ", Current code," ", Current label," ", Current categorycode," ", Current category," ", Current count ) 
					]
				}
			}
			IncludeHTMLWidget {
				layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
				template: vennDiagramChart
				datasets: testvenn (uid, fullname, recorduid) to chartdata (code,label,element)
				bindings: 
					value-of "Permissions" to tooltipSuffix,
					value-of "Permissions in Common" to tooltipnSuffix
				widget-events: {
					when onclick then [
						Flash Concat ("Clicked on nbofitems/code1/label1/code2/label2/value: ", Current nbofitems," ", Current code1 , " ", Current label1 , " ", Current code2, " ", Current label2, " ", Current count) 
					]
				}
			}
		}
