					value-of True to curvedLine,
					value-of "Style4" to lineDashed
				widget-events: {
					when onclick then [
						Flash Concat ("Clicked on Code/Label/Category Code/Category/Count: ", Current code," ", Current label," ", Current categorycode," ", Current category," ", Current count ) 
					]
					when oncategoryclick then [
						Flash Concat ("Clicked on Category Code/Category: ", Current categorycode, " ", Current category ) 
					]
				}
			}
			Combo {
				variable:sizeStrg
				label:Label{break:True value:"TreeMap Size Strategy" layout:Layout {align:horizontal Center vertical End}}
				layout:Layout {hint: width 300 align:horizontal Center vertical End}
				options:Static {
					Option {text:"Count" value:"Count"}
					Option {text:"Reversecount" value:"Reversecount"}
					Option {text:"Same" value:"Same"}
				}
			}
			IncludeHTMLWidget {
				layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
				template: treemapChart
				datasets: allOrgs ( displayname, uid, count ) to chartdata ( label, code , count )
