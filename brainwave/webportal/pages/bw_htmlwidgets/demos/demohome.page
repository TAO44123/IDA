					value-of 'Top' to legendPosition,
					value-of Constant indicatorsPalette to customColors
				widget-events: {
					when onclick then [
						Flash Concat ("Clicked on Code/Label/Category Code/Category/Count: ", Current code," ", Current label," ", Current categorycode," ", Current category," ", Current count ) 
