				template: multilineChart
				datasets: topOrgsIntern ( uid, shortname, internal, status, count ) to chartdata ( code, label, categorycode , category, count )
				bindings: 
					value-of "Multi Line Chart" to title,
					value-of 'Top' to legendPosition,
