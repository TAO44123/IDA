/**
 * <span style="white-space: pre-line">
 * A Pages timer driven by a client (browser) timer.
 * This timer can be used to refresh data/UIs at a regular time.
 * The advantage is that this timer is driven by the web browser, thus, if the link is broken/the browser is unexpectly closed, the timer is closed as well.
 * 
 * <u>Parameters:</u><ul>
 * <li><b>interval (Integer)</b>  timer interval in ms (milliseconds) </li>
 * <li><b>active (String)</b>  set to true to activate the timer, false to disable it</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>timer</b> timer event, add any kind of action within the event depending on your needs such as ReloadData for instance.</li>
 * </ul>
 * </span>
 */

clientTimer = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/utils/clienttimer.html"
	bindings:
		interval as in Integer,
		active as in Boolean
	widget-events: timer
}
