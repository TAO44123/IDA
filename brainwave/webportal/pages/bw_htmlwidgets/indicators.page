/**
 * <span style="white-space: pre-line">
 * A liquid gauge indicator
 * Minimum layout size is 150x150
 * 
 * <u>Parameters:</u><ul>
 * <li><b>count</b> the gauge current value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>minValue(0)</b> the gauge minimum value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>maxValue(100)</b> the gauge maximum value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>identifier</b> A value to send back when the user click on the gauge (onclick event).</li>
 * <li><b>circleThickness (0.05)</b> The outer circle thickness as a percentage of it's radius.</li>
 * <li><b>circleFillGap (0.05)</b> The size of the gap between the outer circle and wave circle as a percentage of the outer circles radius.</li>
 * <li><b>circleColor (#178BCA)</b> The color of the outer circle.</li>
 * <li><b>waveHeight (0.05)</b> The wave height as a percentage of the radius of the wave circle.</li>
 * <li><b>waveCount (1)</b> The number of full waves per width of the wave circle.</li>
 * <li><b>waveRiseTime (1000)</b> The amount of time in milliseconds for the wave to rise from 0 to it's final height.</li>
 * <li><b>waveAnimateTime (18000)</b> The amount of time in milliseconds for a full wave to enter the wave circle.</li>
 * <li><b>waveRise (true)</b> Control if the wave should rise from 0 to it's full height; or start at it's full height.</li>
 * <li><b>waveHeightScaling (true)</b> Controls wave size scaling at low and high fill percentages. When true; wave height reaches it's maximum at 50% fill; and minimum at 0% and 100% fill. This helps to prevent the wave from making the wave circle from appear totally full or empty when near it's minimum or maximum fill.</li>
 * <li><b>waveAnimate (true)</b> Controls if the wave scrolls or is static.</li>
 * <li><b>waveColor (#178BCA)</b> The color of the fill wave.</li>
 * <li><b>waveOffset (0)</b> The amount to initially offset the wave. 0 = no offset. 1 = offset of one full wave.</li>
 * <li><b>textVertPosition (.5)</b> The height at which to display the percentage text withing the wave circle. 0 = bottom; 1 = top.</li>
 * <li><b>textSize (1)</b> The relative height of the text to display in the wave circle. 1 = 50%</li>
 * <li><b>valueCountUp (true)</b> If true; the displayed value counts up from 0 to it's final value upon loading. If false; the final value is displayed.</li>
 * <li><b>displayPercent (true)</b> If true; value is displayed as a percent based on minValue, maxValue and count</li>
 * <li><b>textColor (#045681)</b> The color of the value text when the wave does not overlap it.</li>
 * <li><b>waveTextColor (#A4DBf8)</b> The color of the value text when the wave overlaps it.</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>onclick</b> fired when the user click on the indicator.</li>
 * </ul>
 * </span>
 */
liquidGaugeIndicator = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/indicator/liquidgauge.html"
	bindings: 
		count as in Integer, /* Mandatory Integer */ 
		identifier as in String,
		minValue as in Integer,
		maxValue as in Integer,
		circleThickness as in String,
		circleFillGap as in String,
		circleColor as in String,
		waveHeight as in String,
		waveCount as in Integer,
		waveRiseTime as in Integer,
		waveAnimateTime as in Integer,
		waveRise as in Boolean,
		waveHeightScaling as in Boolean,
		waveAnimate as in Boolean,
		waveColor as in String,
		waveOffset as in String,
		textVertPosition as in String,
		textSize as in String,
		valueCountUp as in Boolean,
		displayPercent as in Boolean,
		textColor as in String,
		waveTextColor as in String
	widget-events:
		onclick (identifier as String, count as Integer, minValue as Integer, maxValue as Integer )
}


/**
 * <span style="white-space: pre-line">
 * A mashup gauge indicator
 * This indicator mimics the look&feel of the mashup dashboard indicator
 * Minimum layout size is 100x100 for radial and numeric
 * Minimum layout size is 200x40 for row
 * 
 * <u>Parameters:</u><ul>
 * <li><b>mode</b> the gauge mode, can be either: radial, numeric, row. set to radial by default</li>
 * <li><b>count</b> MANDATORY the gauge current value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>trendValue</b> the gauge trend value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>maxValue</b> the gauge maximum value, can be binded to a variable, the content will update accordingly</li>
 * <li><b>identifier</b> A value to send back when the user click on the gauge (onclick event).</li>
 * <li><b>title</b> The title of the gauge, displayed under the gauge</li>
 * <li><b>hasLink</b> Boolean, indicate whether of not the gauge has a onclick action configured</li>
 * <li><b>gaugeColor</b> The gauge color (CSS color such as #1774FF)</li>
 * <li><b>hasThresholds</b> True if thresholds are configured and must be displayed in the gauge</li>
 * <li><b>thresholdType</b> can be either set to 'high' or 'low' for high threshold type or low threshold type</li>
 * <li><b>warningThreshold</b> warning threshold value</li>
 * <li><b>criticalThreshold</b> critical threshold value</li>
 * <li><b>warningColor</b> warning threshold color such as #FFE4B3</li>
 * <li><b>criticalColor</b> critical threshold color such as #FFB3B3</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>onclick</b> fired when the user click on the indicator.</li>
 * </ul>
 * </span>
 */
mashupGaugeIndicator = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/mashupgauge/gauge.html"
	bindings: 
		count as in Integer, /* Mandatory Integer */ 
		identifier as in String,
		trendValue as in Integer,
		maxValue as in Integer,
		title as in String,
		hasLink as in Boolean,
		mode as in String, // radial, numeric, row
		gaugeColor as in String, // #1774FF
		hasThresholds as in Boolean,
		warningThreshold as in Integer,
		criticalThreshold as in Integer,
		thresholdType as in String, //low, high
		warningColor as in String,
		criticalColor as in String,
		animation as in Boolean
	widget-events:
		onclick (identifier as String, count as Integer, trendValue as Integer, maxValue as Integer )
}

/**
 * <span style="white-space: pre-line">
 * A mashup multiple gauge indicator. It displays as many indicators as there are lines in the dataset.
 * This indicator mimics the look&feel of the mashup dashboard indicator
 * Minimum layout size is 100x100 for radial and numeric
 * Minimum layout size is 200x40 for row
 * 
 * <u>Dataset: gaugedata</u>
 * <b>count (Integer)</b> MANDATORY the gauge current value, can be binded to a variable, the content will update accordingly
 * <b>trendValue (Integer)</b> the gauge trend value, can be binded to a variable, the content will update accordingly
 * <b>maxValue (Integer)</b> the gauge maximum value, can be binded to a variable, the content will update accordingly
 * <b>identifier (String)</b> A value to send back when the user click on the gauge (onclick event).
 * <b>title (String)</b> The title of the gauge, displayed under the gauge
 * <b>hasLink (Boolean)</b> Boolean, indicate whether of not the gauge has a onclick action configured
 * <b>hasThresholds (Boolean)</b> True if thresholds are configured and must be displayed in the gauge
 * <b>thresholdType (String)</b> can be either set to 'high' or 'low' for high threshold type or low threshold type
 * <b>warningThreshold (Integer)</b> warning threshold value
 * <b>criticalThreshold (Integer)</b> critical threshold value
 * 
 * <u>Parameters:</u><ul>
 * <li><b>mode</b> the gauge mode, can be either: radial, numeric, row. set to radial by default</li>
 * <li><b>gaugeColor</b> The gauge color (CSS color such as #1774FF)</li>
 * <li><b>warningColor</b> warning threshold color such as #FFE4B3</li>
 * <li><b>criticalColor</b> critical threshold color such as #FFB3B3</li>
 * </ul>
 * 
 * <u>Events:</u><ul>
 * <li><b>onclick</b> fired when the user click on the indicator.</li>
 * </ul>
 * </span>
 */
mashupMultiGaugeIndicator = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/mashupgauge/multigauge.html"
	datasets:gaugedata(	count as Integer, /* Mandatory Integer */
						trendvalue as Integer, 
						maxvalue as Integer, 
						identifier as String, 
						title as String, 
						hasLinks as Boolean,
						hasThresholds as Boolean, 
						warningThreshold as Integer, 
						criticalThreshold as Integer, 
						thresholdType as String)
	bindings: 
		mode as in String, // radial, numeric, row
		gaugeColor as in String, // #1774FF
		warningColor as in String,
		criticalColor as in String
	widget-events:
		onclick (identifier as String, count as Integer, trendValue as Integer, maxValue as Integer )
}
/**
 * <span style="white-space: pre-line">
 * An indicator with a "count" effect
 *  
 * <u>Parameters:</u><ul>
 * <li><b>count (Integer)</b>  the value to display, this parameter can be binded, the indicator will update accordingly</li>
 * <li><b>start (Integer)</b>  Optional the start value</li>
 * <li><b>delay (Integer)</b>  Optional the initial delay before displaying the value (in 10th of seconds)</li>
 * <li><b>duration (Integer)</b>  Optional the animation duration (in 10th of seconds)</li>
 * <li><b>separator (String)</b>  Optional the 1000' separator character</li>
 * <li><b>grouping (Boolean)</b>  Optional group by 1000' </li>
 * <li><b>prefix1 (String)</b>  Optional text prefix </li>
 * <li><b>suffix1 (String)</b>  Optional text suffix</li>
 * <li><b>backgroundColor (String)</b>  Optional Color the background color</li>
 * <li><b>fontColor (String)</b>  Optional Color the font color</li>
 * <li><b>fontSize (Integer)</b>  Optional Integer the font size in px</li>
 * <li><b>font (String)</b>  Optional String the font (same naming convention as in a CSS file)</li>
 * <li><b>textAlign (String)</b>  Optional text alignment: left, center, right</li>
 * </ul>
 * </span>
 */
countUpIndicator = HTMLWidgetTemplate {
	source-file: "static/bw_htmlwidgets/charts/indicator/countUp.html"
	bindings: 
		count as in Integer, /* Integer */ 
		start as in Integer, /* Optional Integer */ 
		delay as in Integer, /* Optional Integer (10th of seconds) */ 
		duration as in Integer, /* Optional Integer (10th of seconds) */ 
		separator as in String, /* Optional String */ 
		easing as in Boolean, /* Optional Boolean */
		grouping as in Boolean, /* Optional Boolean */
		prefix1 as in String, /* Optional String */
		suffix1 as in String, /* Optional String */
		backgroundColor as in String, /* Optional String */
		fontColor as in String, /* Optional String */
		fontSize as in Integer, /* Optional Integer */
		font as in String, /* Optional String */
		textAlign as in String  /* Optional String - left, center, right */
}