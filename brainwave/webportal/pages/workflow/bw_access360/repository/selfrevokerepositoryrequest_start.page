/* Import other pages here */
import "/webportal/pages/mixins/workflow_mixins.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/resources/workflow_pickers.page"

/* Nationalized labels here */
selfrevokerepositoryrequest_startNLS = NLS {
	mandatoryfields [en "*: mandatory fields" fr "* : champs obligatoires"]
	actionsection [en "Actions" fr "Actions"]
	cancel.buttontext [en "Cancel" fr "Annuler"]
	cancel.confirm [en "Cancel process creation ?" fr "Annuler la création du processus ?"]
	complete.buttontext [en "Start process" fr "Initier le processus"]
	complete.confirm [en "Start process ?" fr "Démarrer le processus ?"]
	complete.flashmessage [en "Process started" fr "Processus démarré"]
	title [en "Start" fr "Start"]
	_repository [en "repository" fr "Référentiel"]
}


selfrevokerepositoryrequest_start = Page {
	title: $selfrevokerepositoryrequest_startNLS.title
	mixins: workflowDefaultMixin
	
	/* Parameters here */
	
	/* variables here */
	
	
	/* Datasets and records here */
	task = TaskRecord (create "revoke_access_repo_request")
	
	
	/* Page content */
	
	
	repositoryDataset = Dataset {
		view: workflow_repositorydisplayname_all
	}
	
	
	/* Page content */
	MultiEdit {
		label: $selfrevokerepositoryrequest_startNLS._repository
		
		add-dialog: repositoryPicker(task.repository to inExcludedUidList) returning outUid
		Element {
			variable: task.repository
			filterable: True
			display: Display {
				data: repositoryDataset match uid
				value: Current displayname
			}
		}
	}
	
	Group {
		title: $selfrevokerepositoryrequest_startNLS.actionsection
		mixins: workflowActionsMixin
		
		ButtonGroup {
			Button { 
				text: $selfrevokerepositoryrequest_startNLS.cancel.buttontext
				actions: Confirm $selfrevokerepositoryrequest_startNLS.cancel.confirm, TaskCancel task, GoTo HomePage
			}
			Button { 
				disabled: False
				
				text: $selfrevokerepositoryrequest_startNLS.complete.buttontext
				actions: StringCase (TaskValidation task) { 
					when IsNull then [ 
					Confirm $selfrevokerepositoryrequest_startNLS.complete.confirm, TaskComplete task, Flash Information $selfrevokerepositoryrequest_startNLS.complete.flashmessage, GoTo HomePage
					]
					otherwise [
					Message Error TaskValidation task
					]
				}
			}
		}
	}
}

