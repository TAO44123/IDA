// Name localisation for a few standard roles
roleMapping_NLS = NLS {
	user [en "End-User" fr "Simple Utilisateur"]
	admin [en "Administrator" fr "Administrateur"]
	organisationmanager [en "Organisation Manager" fr "Responsable organisationnel"]
	applicationmanager [en "Application Manager" fr "Responsable applicatif"]
	workflowtechadmin [en "Workflow Administrator" fr "Administrateur de workflows"]
	igrc_administrator [en "Brainwave Adminisrtator" fr "Administrateur Brainwave"]
}

// Name localisation for a few standard processes
processMapping_NLS = NLS {
	identityreview [en "Identity review" fr "Revue des identités"]
	accountreview [en "Account review" fr "Revue des comptes d'accès"]
	permissionreview [en "Permission review" fr "Revue des permissions d'accès"]
}

detailsLink = Style {
	foreground: black
	size: 12px
	bold:False
}

detailItem = Mixin {
	Text {
		compact: True
		layout: Layout { indent: horizontal 10 vertical 5  }
	}
	Label {
		layout: Layout { indent: horizontal 10 vertical 5 align: horizontal End vertical Beginning }
	}
	Link {
		compact: True
		layout: Layout { indent: horizontal 10 vertical 5  }
		styling:detailsLink
	}
	Button {
		layout: Layout { hint: width 120  indent: horizontal 0 vertical 0}
	}
}

endDateMapping = StringMapping {
	when IsEmpty then $delegations_NLS.delegation_noenddate
	otherwise current
}

// Mappings for role names in the delegation creation / update pages
roleMapping = StringMapping {
	when Constant USERROLE then $roleMapping_NLS.user
	when "admin" then $roleMapping_NLS.admin
	when "organisationmanager" then $roleMapping_NLS.organisationmanager
	when "applicationmanager" then $roleMapping_NLS.applicationmanager
	when "workflowtechadmin" then $roleMapping_NLS.workflowtechadmin
	when "igrc_administrator" then $roleMapping_NLS.igrc_administrator
 }

//  Mappings for process names in the delegation creation / update pages
// if no mapping found, it returns the original string.
processMapping = StringMapping {
	when "identityreview" then $processMapping_NLS.identityreview
	when "accountreview" then $processMapping_NLS.accountreview
	when "permissionreview" then $processMapping_NLS.permissionreview
}

// 'Active' boolean display as enabled/disabled
delegationStatus = StringMapping {
	when "true" then $delegations_NLS.status.enabled
	when "True" then $delegations_NLS.status.enabled
	when "1" then $delegations_NLS.status.enabled
	when "false" then $delegations_NLS.status.disabled
	when "False" then $delegations_NLS.status.disabled
	when "0" then $delegations_NLS.status.disabled
	when IsEmpty then ""
	otherwise current	
}