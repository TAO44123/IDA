import "/webportal/pages/mixins/workflow_mixins.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/workflow/bw_delegations/delegationsAdminList.page"
import "/webportal/pages/workflow/bw_delegations/delegationSharedResources.page"


createDelegation = Page {
	title: $createDelegation_NLS.title
	feature: delegation_admin_create
	enter-event:
		Set Constant USERROLE to selectedRoles,
		TransferData availableProcDef (processDefinitionKey) to (task.processDefinitions)
		
	valid = Variable { type: Boolean initial: True }
	selectedRoles = Variable { type: String multivalued: True }
	showDelegatorRoles = Variable { type: Boolean initial: True }
	
	task = TaskRecord (create "br_createDelegation")

	delegateeRecord = Record ( workflow_identitydisplayname with task.delegate to uid )
	delegatorRecord = Record ( workflow_identitydisplayname with task.delegator to uid )	
	
	availableRoles = Dataset {
		roles:
			Roles {
				project-roles: True
			} 
		excludes:
			StringPredicate ( Current role ) {
				when Constant TSEXTENDEDACCESSROLE then True
			}
	}
	
	delegatorRoles = Dataset {
		view: getroles with
			task.delegator to identityuid
		excludes:
			StringPredicate ( Current role ) {
				when Constant TSEXTENDEDACCESSROLE then True
			}
		disabled:
			StringPredicate ( task.delegator ) {
				when IsEmpty then True
			}
	}
	
	availableProcDef = Dataset {
		process-definitions: ProcessDefinitionFilter {
			all-definitions: True
			show-technical: False
			show-not-browsable: True
		}
	}
	
	Text {
		label: Label {
			value: Concat($delegations_NLS.delegator_title,"*")
			layout: Layout {hint: width 120}
		}
		value: delegatorRecord.displayname
		mixins: workflowTextWithCommandMixin
		tooltip: $delegations_NLS.delegator_tooltip
		commands:
			Command { 
				actions:
					Dialog  identityPicker ( task.delegator from outUid ),
					Set Constant USERROLE to selectedRoles 
				icon: "16/audit/identity_16.png"
		}
	}	
	Text {
		label: Concat($delegations_NLS.delegate_title,"*")
		value: delegateeRecord.displayname
		mixins: workflowTextWithCommandMixin
		tooltip:  $delegations_NLS.delegate_tooltip
		commands:
			Command { 
				actions:
					Dialog  identityPicker (
						task.delegate from outUid,
						task.delegate_fullname from outDisplayname
					) 
				icon: "16/audit/identity_16.png"
		}
	}
	Edit {
		label: $delegations_NLS.label
		variable: task.label
		tooltip: $delegations_NLS.labelTt
		not-empty: True			
	}
	DateTime {
		type: Date
		label: Concat($delegations_NLS.delegation_startdate,"*")
		variable: task.beginDate
		format: "yyyyMMddHHmmss"
		date-before: Date(task.endDate, Constant DATEFORMAT)
		validity: valid
	}
	DateTime {
		type: Date
		label: $delegations_NLS.delegation_enddate
		variable: task.endDate
		format: "yyyyMMddHHmmss"
		allow-none: True
		date-after: Date(task.beginDate, Constant DATEFORMAT)
		validity: valid
	}
	Edit {
		label: $delegations_NLS.comment
		variable: task.comment
		multi-lines: True
		layout: Layout {
			grab: horizontal True vertical False
			hint: height 150
		}
		tooltip: $delegations_NLS.comment_tooltip
	}
	Header {
		value: $delegations_NLS.mandatoryfields
	}	
	Header {
		value:$delegations_NLS.scope_header
		styling: bigTitleStyle
		layout: Layout {indent: horizontal 0 vertical 30 }
	}
	Grid {
		insets: 0 0 0 0
		columns: GridColumn { width: 0px },
		GridColumn {
			fill: True
			width: grow		
			group: col
		}, GridColumn {
			fill: True
			width: grow
			group: col
		}
		layout: Layout {
			grab: horizontal True vertical False
		}
		GridRow {
			GridCell {}
			GridCell {
				Checkbox {
					variable: showDelegatorRoles 
					text: $delegations_NLS.roles.showonlydelegatorroles
					modify-event:
						Unset selectedRoles,
						Set Constant USERROLE to selectedRoles
				}
				ConditionalGroup{
					BooleanCondition (showDelegatorRoles) { 
						when True then [ 
							Table {
								data: delegatorRoles
								checkboxes: role to selectedRoles
								hide-header: True
								hide-lines: True
								label: Label {
									value: $delegations_NLS.roles
									layout: Layout {hint: width 115}					
									tooltip: $delegations_NLS.roles_tooltip
								}
								layout: Layout {
									grab: horizontal True vertical False
									hint: height 200
								}
								Column {
									column: role
									text: Transform [Current role] using roleMapping
									width: 100%
								}
							}
						]
						when False then [
							Table {
								data: availableRoles
								checkboxes: role to selectedRoles
								hide-header: True
								hide-lines: True
								label: Label {
									value: $delegations_NLS.roles
									layout: Layout {hint: width 115}					
									tooltip: $delegations_NLS.roles_tooltip
								}
								layout: Layout {
									grab: horizontal True vertical False
									hint: height 200
								}
								Column {
									column: role
									text: Transform [Current role] using roleMapping
									width: 100%
								}
							}
						]
					}
				}
			}
		}
	} // Grid
	Group {
		title: $delegations_NLS.actionsection
		mixins: workflowActionsMixin
		ButtonGroup {
			Button { 
				disabled:
					OrPredicate {
						StringPredicate ( task.delegate ) {
							when IsEmpty then True
						}
						IntPredicate Size ( selectedRoles ) {
							when = 0 then True
						}
						Not BooleanPredicate ( valid )
						// The delegatee must be different from delegator
						SameValuePredicate ( task.delegator, task.delegate )
					}
				text: $createDelegation_NLS.complete.buttontext
				actions:
					Confirm $createDelegation_NLS.complete.confirm, 
					Unset task.roles,
					MultivaluedAdd selectedRoles to task.roles,
					TaskComplete task wait-end timeout-seconds 30,
					Flash Information $createDelegation_NLS.complete.flashmessage,
					GoTo Page adminDelegations
			}
			Button { 
				text: $createDelegation_NLS.cancel.buttontext
				actions:
					TaskCancel task,
					GoTo Page adminDelegations
			}
		}
	}
}