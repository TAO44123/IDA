import "/webportal/pages/resources/concepts_nls.page"

/* Nationalized labels here */
controlexception = NLS {

	concept 	[ en "Control exception" fr "Exception de contrôle"]
	concept.header 	[ en "Control \nexception" fr "Exception \nde contrôle"]
	issuername 	[ en "Issuer" fr "Emetteur"]
	element 	[ en "Element" fr "Elément"]
	context 	[ en "Context" fr "Contexte"]
	creation	[ en "Creation" fr "Création"]
	expiration	[ en "Expiration" fr "Expiration"]
	control		[ en "Control" fr "Contrôle"]
	elementtype	[ en "Element type" fr "Type d'élément"]
	fromdate 	[ en "Valid from" fr "Valide depuis"]
	untildate	[ en "Valid until" fr "Valide jusqu'à"]
	^reason		[ en "Reason" fr "Raison"]
	
	// For the modify dialog
	modify.title 			[ en "Modify exception" fr "Modifier l'exception"]
	modify.label.^reason 	[en "Reason" fr "Raison"]
	modify.label.enddate 	[en "Valid until" fr "Valide jusqu'à"]
	modify.label.files 		[ en "Attachments" fr "Pièces jointes"]
	modify.done 			[ en "Exception modified" fr "Exception modifiée"]
	
	// For the add dialog
	add.title 			[ en "Create an exception" fr "Créer une exception"]
	add.label.^reason 	[en "Reason" fr "Raison"]
	add.label.enddate 	[ en "Valid until" fr "Valide jusqu'à"]
	add.label.files 	[ en "Attachments" fr "Pièces jointes"]
	add.done 			[ en "Exception created" fr "Eception créée"]
	
	// For the delete dialog
	delete.confirm 	[ en "Are you sure you want to delete this exception ?" fr "Etes-vous sûr de bien vouloir supprimer cette exception?"]
	delete.title 	[ en "Delete exception" fr "Supprimer une exception"]
	delete.done 	[ en "Exception deleted" fr "Exception supprimée"]
	
	// For the management page
	page.title 		[ en "Control Exception Management" fr "Gestionnaire d'exceptions de contrôle"]
	editor.header.control 		[ en "Control" fr "Contrôle"]
	editor.header.expiration 	[ en "Expiration" fr "Expiration"]
	editor.header.creation 		[ en "Creation" fr "Création"]
	editor.header.type 			[ en "Type" fr "Type"]
	editor.header.element 		[ en "Element" fr "Elément"]
	editor.header.context 		[ en "Context" fr "Contexte"]
	
	event.title 		[ en "Changelog" fr "Journal des modifications"]
	event.created		[ en "Create" fr "Créée"]
	event.modified		[ en "Modify" fr "Modifiée"]
	event.deleted		[ en "Delete" fr "Supprimée"]
	event.nothing		[ en "None" fr "Aucune"]
	event.header.date 	[ en "Date" fr "Date"]
	event.header.issuer	[ en "User" fr "Utilisateur"]
	event.header.action	[ en "Action" fr "Action"]
	
	attachments.title [ en "Attachments" fr "Pièces jointes"]
	novalue [en "No value" fr "Donnée non précisée"]
	
	selectFirst [en "Select an Exception" fr "Sélectionnez une exception"]
	no.exception [ en "No exception" fr "Aucune exception"]
	date.short [en "MM/dd/yyyy" fr "dd/MM/yyyy"]
}

changeEventMapping = StringMapping {
	when "C" then $controlexception.event.created
	when "U" then $controlexception.event.modified
	when "D" then $controlexception.event.deleted
	when "N" then $controlexception.event.nothing
}

targetTypeMapping = StringMapping {
	when "C" then $account.concept
	when "A" then $application.concept
	when "S" then $asset.concept
	when "G" then $group.concept
	when "I" then $identity.concept
	when "O" then $organisation.concept
	when "P" then $permission.concept
	when "R" then $repository.concept
	
	when "Account" then $account.concept
	when "Application" then $application.concept
	when "Asset" then $asset.concept
	when "Group" then $group.concept
	when "Identity" then $identity.concept
	when "Organisation" then $organisation.concept
	when "Permission" then $permission.concept
	when "Repository" then $repository.concept
}

noValueMapping = StringMapping {
	when IsEmpty then $controlexception.novalue
	otherwise current
}