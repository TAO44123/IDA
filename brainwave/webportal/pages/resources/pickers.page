/**
 * <span style="white-space: pre-line">
 * Identity picker for workflows (ensure we are on the latest timeslot, not the one from the campaign)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inUidList </b>OPTIONAL inclusion filter</li>
 * <li><b>inExcludedUidList </b>OPTIONAL exclusion filter</li>
 * <li><b>inAllowMe </b>DEPRECATED</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outRecordUid </b>selected identity recorduid</li>
 * <li><b>outUid </b>selected identity uid</li>
 * <li><b>outDisplayname </b>selected identity displayname</li>
 * <li><b>outMail </b>selected identity mail</li>
 * <li><b>outHRCode </b>selected identity hr code</li>
 * </ul>
 * </span>
 */
wf_identityPicker = Dialog {

	title: $picker.identity.title
	width: 750
	height: 650
	mixins: pickerMixin

	buttons: [
		OkButton {
			disabled:
				StringPredicate ( outRecordUid ) {
					when IsEmpty then True
				}
		}
		CancelButton
	]

	// input variable : list of uids to restrict scope (if null, no restriction is applied)
	inUidList = Variable { type: String multivalued: True }
	// input variable : list of excluded uids to restrict scope (if null, no restriction is applied)
	inExcludedUidList = Variable { type: String multivalued: True }
	inAllowMe = Variable { type: Boolean initial: False }
	// output variables (recordUid, uid and displayname)
	outRecordUid = Variable { type: Integer }
	outUid = Variable { type: String }
	outDisplayname = Variable { type: String }
	outMail = Variable { type: String }
	outHRCode = Variable { type: String }
	initialIndex = Variable { type: Integer }
	// Local variables for search criteria
	hrcode = Variable { type: String }
	givenname = Variable { type: String }
	surname = Variable { type: String }
	mail = Variable { type: String }
	orgshortname = Variable { type: String }
	orgname = Variable { type: String }
	// Variables to pass to the view
	filterHrcode = Variable { type: String }
	filterGivenname = Variable { type: String }
	filterSurname = Variable { type: String }
	filterMail = Variable { type: String }
	filterOrgshortname = Variable { type: String }
	filterOrgname = Variable { type: String }
	// Do not list all identities by default
	enableSearch = Variable { type: Boolean initial: False }
	
	lastTimeslot = Record {
		view: bw_latestTimeslot
	}
	
	identityData = Dataset {
		view: br_identity_searchpoint_picker with
			inUidList to paramUid unless-empty,
			inExcludedUidList to paramNotUid unless-empty,
			filterHrcode to hrcode unless-empty,
			filterGivenname to givenname unless-empty,
			filterSurname to surname unless-empty,
			filterMail to mail unless-empty,
			filterOrgshortname to orgshortname unless-empty,
			filterOrgname to orgname unless-empty
		timeslot: NonEmpty ( lastTimeslot.uid, PortalTimeslot.UID )
		disabled:
			Not BooleanPredicate ( enableSearch )
	}

	Grid {
		columns: GridColumn { width: grow }, GridColumn
		GridRow {
			GridCell {
				// Search section
				Grid {
					layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
