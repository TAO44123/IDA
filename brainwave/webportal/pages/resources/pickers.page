			grab: horizontal True vertical True
		}
		double-click: CloseDialog Ok
		show-count: True

		Column {
			column: recorduid
			selection: outRecordUid
			hidden: True
		}
		Column {
			column: uid
			selection: outUid
			hidden: True
		}
		Column {
			column: code
