								variable: hrcode
								label: $identity.hrcode
								proposal: Identity.hrcode
							}
							Edit {
								variable: givenname
								label: $identity.givenname
								proposal: Identity.givenname
							}
							Edit {
								variable: orgshortname
								label: $porganisation.shortname
								proposal: Organisation.shortname
							}
						}
						GridCell {
							Edit {
								variable: mail
								label: $identity.mail
								proposal: Identity.mail
							}
							Edit {
								variable: surname
								label: $identity.surname
								proposal: Identity.surname
							}
							Edit {
								variable: orgname
								label: $porganisation.displayname
								proposal: Organisation.displayname
							}
						}
						GridCell {
							width: 20
							Spacer {
								height: 50
							}
							Button {
								image: "16/more/grey/search2_16.png"
								hide-text: True
								presentation: Link
								layout: Layout { grab: horizontal False vertical False }
								actions:
									Set hrcode to filterHrcode,
									Set surname to filterSurname,
									Set givenname to filterGivenname,
									Set mail to filterMail,
									Set orgshortname to filterOrgshortname,
									Set orgname to filterOrgname,
									Set True to enableSearch
							}
						}
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical True }
					Table {
						data: identityData
						show-count: True
						show-filter: True
						layout: Layout { grab: horizontal True vertical True }
						configurable: True
						double-click:
							CloseDialog Ok
						Column {
							column: recorduid
							hidden: True
							selection: outRecordUid
						}
						Column {
							column: uid
							hidden: True
							selection: outUid
						}
						Column {
							column: hrcode
							header: $identity.hrcode
							selection: outHRCode
							width: 100%
							initially-masked: False
							filterable: True
							sortable: True
						}
						Column {
							column: givenname
							header: $identity.givenname
							width: 100%
							initially-masked: True
							filterable: True
							sortable: True
						}
						Column {
							column: surname
							header: $identity.surname
							width: 100%
							initially-masked: True
							filterable: True
							sortable: True
						}
						Column {
							column: fullname
							header: $identity.fullname
							width: 100%
							selection:outDisplayname
							initially-masked: False
							filterable: True
							sortable: True
						}
						Column {
							column: nickname
							header: $identity.nickname
							width: 100%
							initially-masked: True
							filterable: True
							sortable: True
						}
						Column {
							column: middlename
							header: $identity.middlename
							width: 100%
							initially-masked: True
							filterable: True
							sortable: True
						}
						Column {
							column: altname
							header: $identity.altname
							width: 100%
							initially-masked: True
							filterable: True
							sortable: True
						}
						Column {
							column: mail
							header: $identity.mail
