import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_cloud_base/resources/styles.page"
import "/webportal/pages/bw_ledger_admin/resources/mappings.page"
import "/webportal/pages/bw_ledger_admin/resources/pages_nls.page"
import "/webportal/pages/bw_ledger_admin/resources/services.page"
import "/webportal/pages/bw_ledger_admin/timeslot_rename_dialog.page"
import "/webportal/pages/bw_ledger_admin/timeslot_changes.page"
import "/webportal/pages/bw_ledger_admin/manage_timeslot.page"


timeslot_statistics= Page {
	title:$menusAndTitles.timeslotStatistics
	enter-event: StringCase(timeslotuidParam) {when Not IsNull then[Set timeslotuidParam to currentTimeslotuid] } 

	timeslotuidParam  = Parameter {
		mandatory: False
		hidden: True
		type: String			
	}
	
	
	currentTimeslotuid = Variable{type:String }
	
	timeslots = Dataset {
		view:br_timeslotlist}


	identities_stat = Dataset {
		service: srv_identities_statistics with PortalTimeslot.UID to timeslotUid
		}

	data_stat = Dataset {
		service: srv_data_statistics with currentTimeslotuid to timeslotUid
		}

	org_stat = Dataset {
		service: srv_org_statistics with currentTimeslotuid to timeslotUid
		}

	asset_stat = Dataset {
		service: srv_asset_statistics with currentTimeslotuid to timeslotUid
		}
		
	repository_stat = Dataset {
		service: srv_repository_statistics with currentTimeslotuid to timeslotUid
		}
		
	repository_stat_tree = HierarchicalData {	
		service: srv_repository_statistics with currentTimeslotuid to timeslotUid
		connect:parent repository_ to child parent_ 
		initial:parent_ = "racine"
	}
	
	/*
	timeslot = Record {
		view:br_timeslotlist with currentTimeslotuid to timeslot_uid
	}
 */

  Group {
  	styling:cssPageDashboard
  
  	Group {
  		styling:cssRound
  		layout:Layout { grab:horizontal True vertical False hint: height 52 }
	    Grid {
	      columns: GridColumn { width: 100px}, GridColumn { width: 300px}, GridColumn { width: 100px}, GridColumn { width: 100px}, GridColumn{ width: grow}
	      layout: Layout { 
	        grab: horizontal False vertical False
	      }
	      GridRow {
	        GridCell {
		      Button {
		        text: $menusAndTitles.timeslots
		        image: "16/bw_ledger_admin/archive.png"
		        actions: GoTo Page manage_timeslot 	
		        tooltip:$navigation.gotoTimeslot	       
		      }
	        }
	        GridCell {
	          Combo {
					variable: currentTimeslotuid
					modify-event:ReloadData (identities_stat),ReloadData (data_stat),ReloadData (org_stat),ReloadData (asset_stat),ReloadData (repository_stat),ReloadData (repository_stat_tree)									
					label: $menusAndTitles.selectTimeslot						
					allow-none: False
					options: Dynamic {
						data: timeslots
						value: Current uid
						text: Current displayname							
					}
	          }
	        }
	        GridCell {
	           Button {
		        text: $menusAndTitles.statistics
		        image: "16/bw_ledger_admin/chart_bar.png"
		        actions: GoTo Page timeslot_statistics with currentTimeslotuid to timeslotuidParam 
		        tooltip:$navigation.gotoStatistics
		        disabled: True
		      }
	        }
	        GridCell {
	           Button {
		        text: $menusAndTitles.changes
		        image: "16/bw_ledger_admin/lightning.png"
		        actions: GoTo Page timeslot_changes with currentTimeslotuid to timeslotuidParam 
		        tooltip:$navigation.gotoAction
		      }
	        }
	        
	      }
	    }
	}
	
	Group {
	//title: $menusAndTitles.statistics
	styling:cssRound
	Splitter
	{
		disposition:Horizontal
		size:50%		
		Group {
		    
						Table {	   
								layout:Layout{grab: horizontal True vertical True}
								data:identities_stat								
								Column {
									header: $statiscticTabLabel.identityDisplayname
									column:identities_
									image: Transform Current identities_ using statiscticIdentitiesIcons	
									text: Transform Current identities_ using statiscticIdentities												
									width: 50%									
									
								}
								Column {
									header:$statiscticTabLabel.importNumber	
									column:import_									
									width: 25%								
									
								}
								Column {
									header:$statiscticTabLabel.activeNumber
									column:current_
									width: 25%																		
								}
							}
							
							Table {	   
								layout:Layout{grab: horizontal True vertical True}
								data:data_stat								
								Column {
									header: $statiscticTabLabel.dataDisplayname	
									column:data_
									image: Transform Current data_ using statiscticDataIcons
									text: Transform Current data_ using statiscticData								
									width: 50%									
									
								}
								Column {
									header:$statiscticTabLabel.importNumber	
									column:import_
									width: 25%								
									
								}
								Column {
									header:$statiscticTabLabel.activeNumber
									column:current_
									width: 25%																		
								}
							}	
							
	
								Table {	   
							
								layout:Layout{grab: horizontal True vertical True}
								data: org_stat								
								Column {
									header: $statiscticTabLabel.organizationsDisplayname	
									column:organization_
									image: Transform Current organization_ using statiscticOrgIcons
									text: Transform Current organization_ using statiscticOrg																
									width: 50%									
									
								}
								Column {
									header:$statiscticTabLabel.importNumber	
									column:import_
									width: 25%								
									
								}
								Column {
									header:$statiscticTabLabel.activeNumber
									column:current_
									width: 25%																		
								}
							}					
											
		}


		Group {		
			Splitter
				{
					disposition:Vertical
					size:35%		
					
						Group {	
							    layout:Layout{grab: horizontal True vertical True}
								Table {	   
									layout:Layout{grab: horizontal True vertical True}
									data:asset_stat								
									Column {
										header: $statiscticTabLabel.assetsDisplayname	
										column:assets_								
										image: Transform Current assets_ using statiscticAssetsIcons
										text: Transform Current assets_ using statiscticAssets		
										width: 50%									
										
									}
									Column {
										header:$statiscticTabLabel.importNumber	
										column:import_
										width: 25%								
										
									}
									Column {
										header:$statiscticTabLabel.activeNumber
										column:current_
										width: 25%																		
									}
								}					
							}
							
						Group {	
								layout:Layout{grab: horizontal True vertical True}							
								Tree {
								    layout:Layout{grab: horizontal True vertical True}				
									data: repository_stat_tree	
									Column {
									    header: $statiscticTabLabel.repositoryDisplayname
										column:repository_	
										image: Transform Current repository_ using statiscticRepositoryIcons
										text: Transform Current repository_ using statiscticRepository												
										width:50%							
																		
									}					
									Column {
										header:$statiscticTabLabel.importNumber
										column:import_		
										width:25%
									}
									Column {
										header:$statiscticTabLabel.activeNumber
										column:current_			
										width:25%
									}
				
									
								}
							}
						}
											
																		
				}		
							
		  }	
		
	}
  }
  
}

