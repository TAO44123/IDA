manage_timeslot= Page {
	enter-event: StringCase(timeslotuidParam) {when Not IsNull then[Set timeslotuidParam to currentTimeslotuid] }
	title: $menusAndTitles.manageLedger
	large-icon: '48/red/repository.png'
	feature: ledgeradmin_showtimeslots
	tags: "admin"
	
timeslotuidParam  = Parameter {
		mandatory: False
		hidden: True
		type: String			
	}
	

	currentTimeslot = Variable{type:String }
	currentTimeslotuid = Variable{type:String}
	timeslotRename = Variable{type:String}

	organisationCount = Variable{type:Integer}

	timeslots = Dataset {
		view:br_timeslotlist
		}


	stat = Dataset {
		service: srv_timeslot_count_diff with timeslot.uid to timeslotUid
		}

	
	timeslot = Record {
		view:br_timeslotlist with currentTimeslotuid to timeslot_uid
	}
	
	timeslotBatchDone = Record {
		view: timeslot_batchdone with timeslot.uid to timeslot_uid
	}

	statichierarchicaldataset = HierarchicalData {
		service: srv_timeslot_count_diff with timeslot.uid to timeslotUid
		connect:parent identity to child identity 
		initial:identity IsNull
	}

	
	validationRequests = Dataset {
		processes: ProcessFilter { 
			definition: "virtual_timeslot"
			show-completed: False
			show-error: False
			show-suspended: False
			workflow-variable:
				Constraint {
					variable: action_code
					operator: "equals"
					value: "validate"
				}, 
				Constraint {
					variable: timeslot_uid
					operator: "equals"
					value: timeslot.uid
				}
		}	
	}	
  	
  	referenceRequests = Dataset {
  		processes: ProcessFilter {
  			definition: "reference_timeslot"
  			show-completed: False
			show-error: False
			show-suspended: False
			workflow-variable: 
				Constraint {
					variable: timeslot_uid
					operator: "equals"
					value: timeslot.uid
				}
  		}
  	}
  	
  	canUnhideTS = Record {
  		view: timeslot_hierarchy_bv with timeslot.uid to uid
  	}
  	
	Splitter
	{
		disposition:Horizontal
		size:70%		
		Group {
			title:$menusAndTitles.timeslots			
			Table {				
				double-click:GoTo Page timeslot_statistics with currentTimeslotuid to timeslotuidParam
				selection-changed-event:ReloadData (stat)				
				mixins: resultGridMixin	    
				data:timeslots				
				layout:Layout{grab: horizontal True vertical True}
				Column {
					header:$timeslotTableHeader.timeslotDescription
					image: Transform Current status using timeslotIcons
					column:displayname
					selection:currentTimeslot	
					filterable:True				
					width: 30%
					
				}
				Column {
					header:$timeslotTableHeader.timeslotCreationDate	
					column:importdate
					filterable:True
					sortable:True
					width: 25%
				}
				Column {
					header:$timeslotTableHeader.timeslotCommitDate
					column:commitdate
					filterable:True
					sortable:True
					width: 25%
				}
				Column {
					header:$timeslotTableHeader.timeslotStatus
					column:status 
					text: Transform Current status using timeslotStatus
					filterable:True
					sortable:True
					width: 20%					
				}
				Column {
					header:$timeslotTableHeader.timeslotReference
					column: reference
					text: Transform Current reference using mayBeNullMapping
					filterable:True
					sortable:True
					width: 20%
				}		
				Column {					
					column:uid
					selection:currentTimeslotuid					
					hidden:True				
				}				
						
			}
		}


		Group {		
				//layout:Layout{grab: horizontal True vertical False}				
				
					Group {
						layout:Layout{grab: horizontal True vertical False}						
						title: $menusAndTitles.informationTitle		
						Text {
							label: $timeslotTableHeader.timeslotDescription
							value:timeslot.displayname
							compact:True
						}
						Text {
							label:$timeslotTableHeader.timeslotStatus
							value: Transform timeslot.status  using timeslotFullStatus	  
							compact:True
						}
																				
					}
					
					Group {
						title: $menusAndTitles.timeslotreference
						feature: ledgeradmin_editreferences
						layout:Layout{grab: horizontal True vertical False}
						
						Button {
							presentation:Link
							actions: Dialog referenceTimeslotRequest ( timeslot.uid to timeslotUid, timeslot.reference to timeslotReference ), Message $timeslotActions.timeslotrequestsent, ReloadData ( timeslots ), ReloadData(referenceRequests)
							text: $timeslotActions.timeslotReference
							image:"16/bw_ledger_admin/tag_blue.png"
							align:Left		
							disabled:  
								OrPredicate {	
									Not IntPredicate( Count referenceRequests ) { when > 0 then False otherwise True } 		
									IntPredicate( timeslotBatchDone.done ) { when >= 1 then False otherwise True }
								}		
						}
						
						Button {
							presentation:Link
							actions: Dialog pendingReferenceRequests ( timeslot.uid to timeslotUID ), ReloadData ( timeslots ), ReloadData(referenceRequests)
							text: $timeslotActions.timeslotReferencePending
							align:Left		
							layout: Layout { indent: horizontal 25 vertical 0 }
							hidden: IntPredicate( Count referenceRequests ) { when > 0 then False otherwise True }			
						}
						
					}
					
					Group {
					  title: $menusAndTitles.allowedActionsTitle
					  feature: ledgeradmin_modifytimeslots
					  layout:Layout{grab: horizontal True vertical False}	
					  Button {
								presentation:Link
								actions: Dialog validateTimeslotRequest ( timeslot.uid to timeslotUid ) , Flash Information $timeslotActions.timeslotrequestsent, GoTo HomePage
								text: $timeslotActions.timeslotValidate
								image:"16/bw_ledger_admin/activate.png"
								align:Left		
								hidden:StringPredicate(timeslot.status) { when Not "W" then True}				
								disabled:  
									OrPredicate {
										IntPredicate( Count validationRequests ) { when > 0 then True otherwise False }				
										IntPredicate( timeslotBatchDone.done ) { when >= 1 then False otherwise True }
									}
							}
								
							Button {
								presentation:Link
								actions: Dialog pendingValidationRequests ( timeslot.uid to timeslotUID ), ReloadData ( validationRequests )
								text: $timeslotActions.timeslotValidationPending
								align:Left		
								layout: Layout { indent: horizontal 25 vertical 0 }
								hidden: OrPredicate {
									StringPredicate(timeslot.status) { when Not "W" then True}
									IntPredicate( Count validationRequests ) { when > 0 then False otherwise True }
								}				
							}
							
						Button {
								presentation:Link
								actions: Dialog timeslotActionConfirmAndExecute ( timeslot.uid to timeslotUid, "show" to actionCode, $timeslotActions.confirm.timeslotShow to confirmMessage ), Flash Information $timeslotActions.timeslotrequestsent, GoTo HomePage
								text:$timeslotActions.timeslotShow	
								image:"16/bw_ledger_admin/publish.png"
								align:Left	
								hidden:
									OrPredicate {
										StringPredicate(timeslot.status) { when Not "D" then True}
										StringPredicate(canUnhideTS.TS_uid) { when IsEmpty then False otherwise True }
									}
							}
			
						Button {
								presentation:Link
								actions: Dialog timeslotActionConfirmAndExecute ( timeslot.uid to timeslotUid, "hide" to actionCode, $timeslotActions.confirm.timeslotHide to confirmMessage ), Flash Information $timeslotActions.timeslotrequestsent, GoTo HomePage		
								text:$timeslotActions.timeslotHide	
								image:"16/bw_ledger_admin/hide.png"
								align:Left	
								hidden:AndPredicate{ 
											StringPredicate(timeslot.status) { when Not"A" then True}
											StringPredicate(timeslot.status) { when Not "C" then True}
											}	
								disabled:  
									OrPredicate {			
										IntPredicate( timeslotBatchDone.done ) { when >= 1 then False otherwise True }
									}
												
							}
							
						Button {			
								presentation:Link
								actions: Dialog timeslotActionConfirmAndExecute ( timeslot.uid to timeslotUid, "delete" to actionCode, $timeslotActions.confirm.timeslotDelete to confirmMessage ), Flash Information $timeslotActions.timeslotrequestsent, GoTo HomePage
								text:$timeslotActions.timeslotDelete	
								image:"16/bw_ledger_admin/delete.png"
								align:Left
								hidden:StringPredicate(timeslot.status) { when Not "W" then True}					
								disabled:  
									OrPredicate {
										IntPredicate( Count validationRequests ) { when > 0 then True otherwise False }			
										IntPredicate( timeslotBatchDone.done ) { when >= 1 then False otherwise True }
									}
										
							}
							
						Button {			
								presentation:Link
								actions: Dialog renameTimeSlotDialog ( timeslot.uid to timeslotUid, currentTimeslot to timeslot_name ),Flash Information $timeslotActions.timeslotrequestsent, GoTo HomePage	
								text:$timeslotActions.timeslotRename	
								image:"16/bw_ledger_admin/rename.png"
								align:Left										 		
								disabled:  
									OrPredicate {
										IntPredicate( Count validationRequests ) { when > 0 then True otherwise False }		
										IntPredicate( timeslotBatchDone.done ) { when >= 1 then False otherwise True }
									}
							}
					}	
					
					Group {
						//layout:Layout{grab: horizontal True vertical False}					
						title: $menusAndTitles.countsTitle
						feature: ledgeradmin_modifytimeslots
						
						  ButtonGroup {
						      
						      Button {
						        text: $menusAndTitles.statistics
						        image: "16/bw_ledger_admin/chart_bar.png"
						        actions: GoTo Page timeslot_statistics
						        tooltip:$navigation.gotoStatistics 
						      }
						      
						      Button {
						        text: $menusAndTitles.changes
						        image: "16/bw_ledger_admin/lightning.png"
						        actions: GoTo Page timeslot_changes
						        tooltip:$navigation.gotoAction
						      }     
						      
						    }
			
									
						Table {	   
							layout:Layout{grab: horizontal True vertical True}
							label: Label {
							  break: True
							}
							data:stat								
							Column {
								header:$timeslotCountTab.timeslotEntities	
								column:entity						
								image: Transform Current entity using timeslotCountTabIcons
								text:Transform Current entity using timeslotCountTabLabel									 
								width: 50%
							}
							Column {
								header:$timeslotCountTab.timeslotCount	
								column:count
								width: 25%
							}
							Column {
								header:$timeslotCountTab.timeslotDifferences
								column:diff
								width: 25%																		
							}
						}
						
						Text {		
						 		label: $timeslotCountTab.timeslotParent 				
								value: Transform timeslot.parent_timeslot using timeslotNA
								compact: True
						}					
																		
					}		
							
			}		
		
	}
	}

