}

validateTimeslotRequest_NLS = NLS {
	title [ en "Timeslot Validation Request" fr "Demande de validation de la période d'analyse"]
	options.validatenow [ en "Validate the Timeslot Immediately" fr "Valider la période d'analyse immédiatement"]
	options.schedulevalidation [ en "Schedule Timeslot Validation" fr "Programmer la demande de validation de la période d'analyse" ]
	actions.send [en "Send" fr "Envoyer"]
}

referenceTimeslotRequest_NLS = NLS {
	title [ en "Reference Timeslot" fr "Période d'analyse de référence" ]
	actions.send [en "Send" fr "Envoyer"]
	labels.reference [en "Timeslot Reference" fr "Référence"]
	options.newreference [ en "<New Reference>" fr "<Nouvelle référence>"]
	options.seelist [ en "See list" fr "Voir la liste"]
	options.delete [ en "Delete Reference" fr "Supprimer la référence"]
}

getBrowserTimestamp = HTMLWidgetTemplate {
	source-file: "static/bw_ledger_admin/browsertimestamp.html"
	widget-events: localtimestampfound ( timestamp as String )
}

newReferenceOptionMapping = StringMapping {
	when "¶" then $referenceTimeslotRequest_NLS.options.newreference
	otherwise current
}

referenceTimeslotRequest = Dialog {
	title: $referenceTimeslotRequest_NLS.title
	enter-event: IntCase ( Count allreferences ) { when = 0 then [ Unset timeslotReference, Set True to freeTextMode ] }, Set timeslotReference to timeslotReferenceList
	height: 260
	width: 600
	buttons: [
		ActionButton {
			actions: Set timeslotUid to task.timeslot_uid, Set timeslotReference to task.timeslot_reference, TaskComplete task wait
			text: $referenceTimeslotRequest_NLS.actions.send
			status: Ok
			close: True
		}
		CancelButton
	]
	
	timeslotUid =  Variable
	timeslotReference = Variable 
	timeslotReferenceList = Variable
	freeTextMode = Variable { type: Boolean  initial: False }
	task = TaskRecord ( create "reference_timeslot" )
	
	timeslot = Record {
		view:br_timeslotlist with timeslotUid to timeslot_uid
	}
	
	allreferences = Dataset {
		view: br_timeslots_references
	}
	
	newreference = Dataset { values: [ ( reference-> "¶" )] }
	
	alloptions = Dataset {
		union: Union {
			datasets: newreference, allreferences
			discriminator-column: source
		}
	}
	
	Group {
		layout: Layout { indent: horizontal 40 vertical 20 }
		Grid {
			columns: GridColumn { width: 160 }, GridColumn { width: grow }, GridColumn { width: 200 }
			fill: Both
			layout: Layout { grab: horizontal True vertical True }
			GridRow {
				height: 30
				GridCell {
					Text {
						value: $timeslotTableHeader.timeslotDescription
						compact: True
						styling: labelStyle
					}
				}
				GridCell {
					span: 2
					Text {
						value:timeslot.displayname
						compact:True
					}	
				}
			}
			GridRow {
				height: 30
				GridCell {
					Text {
						value: $timeslotTableHeader.timeslotStatus
						compact: True
						styling: labelStyle
					}
				}
				GridCell {
					span: 2
					Text {
						value: Transform timeslot.status  using timeslotFullStatus
						compact:True
					}	
				}
			}
			GridRow {
				height: 30
				GridCell {
					Text {
						value: $referenceTimeslotRequest_NLS.labels.reference
						compact: True
						styling: labelStyle
					}
				}
				GridCell {
					Edit {
						layout: Layout { grab: horizontal True vertical False }
						variable: timeslotReference
						hidden: Not BooleanPredicate ( freeTextMode )
					}
					
					Combo {
						layout: Layout { grab: horizontal True vertical False }
						variable: timeslotReferenceList
						allow-none: True
						modify-event: 
							StringCase( timeslotReferenceList ) { 
								when "¶" then [ Unset timeslotReference , Unset timeslotReferenceList, Set True to freeTextMode ]
								otherwise [ Set timeslotReferenceList to timeslotReference ]
							}
						hidden: BooleanPredicate ( freeTextMode )
						options: Dynamic {
							data: alloptions
							text: Transform Current reference using newReferenceOptionMapping
							value: Current reference
						} 
					}
				}
				GridCell {
					ButtonGroup {
						Button {
							presentation: Link
							image: "16/bw_ledger_admin/text_list_bullets.png"
							actions: Unset timeslotReference , Set False to freeTextMode
							hidden: OrPredicate {
								Not BooleanPredicate ( freeTextMode )
								IntPredicate ( Count allreferences ) { when =0 then True when InvalidInteger then True otherwise False }
							}
							tooltip: $referenceTimeslotRequest_NLS.options.seelist
						}
						Button {
							presentation: Link
							image: "16/bw_ledger_admin/delete.png"
							actions: Unset timeslotReference , Unset timeslotReferenceList, Set False to freeTextMode
							tooltip: $referenceTimeslotRequest_NLS.options.delete
							disabled: StringPredicate ( timeslotReference ) { when IsEmpty then True otherwise False }
						}
					}
				}
			}
			GridRow {
				height: grow
			}
		}		
	}
}

pendingReferenceRequests_NLS = NLS {
	title [ en "Pending References Modifications Requests" en "Demandes de modification de référence en cours" ]
	creationdate [ en "Request creation date" fr "Date de création de la demande"]
	createdby [en "Created by" fr "Crée par"]
}

pendingReferenceRequests = Dialog {
	title: $pendingReferenceRequests_NLS.title
	height: 240
	width: 600
	buttons: OkButton
	
	timeslotUID = Variable 
	processID = Variable
	
	referenceRequests = Dataset {
  		processes: ProcessFilter {
  			definition: "reference_timeslot"
  			show-completed: False
			show-error: False
			show-suspended: False
			workflow-variable: 
				Constraint {
					variable: timeslot_uid
					operator: "equals"
					value: timeslotUID
				}
  		}
  	}
	
	Group {
		layout: Layout { indent: horizontal 0 vertical 20 }
		Table {
			data: referenceRequests
			layout: Layout { grab: horizontal True vertical True }
			commands: 
				Commands {
					orientation: Vertical
					position: After
					presentation: Icon
					
					Command {
						actions: ProcessTerminate process-id processID, ReloadData ( referenceRequests )
						icon: "16/bw_ledger_admin/delete.png"
						disabled: StringPredicate ( processID ) { when IsEmpty then True otherwise False }
					}
				}
			Column {
				column: processCreationDate
				text: DateLDAP(Current processCreationDate).value
				header: $pendingReferenceRequests_NLS.creationdate
				width: 100%
			}
			
			Column {
				column: processCreatorName
				header: $pendingReferenceRequests_NLS.creationdate
				width: 100%
			}
			
			Column {
				column: processId
				selection: processID
				hidden: True 
			}
		}
	}
}

validateTimeslotRequest = Dialog {
	title: $validateTimeslotRequest_NLS.title
	height: 260
	width: 600
	buttons: [
		ActionButton {
			disabled: Not BooleanPredicate ( targetDateTimeValid )
			text: $validateTimeslotRequest_NLS.actions.send
			close: True
			status: Ok
			actions:
				BooleanCase ( schedule ) {
					when True then [ Set Date(targetDateTime).value("yyyyMMddHHmmss.'000'Z") to targetDateTimeLDAP ]
					when False then [ Unset targetDateTimeLDAP ]
				},
				Set timeslotUid to task.timeslot_uid, Set "validate" to task.action_code,
				Set targetDateTimeLDAP to task.execute_timestamp, 
				Set userDateTimeLDAP to task.user_timestamp,
				TaskComplete task wait
		}
		CancelButton 
	]
	
	timeslotUid = Variable
	schedule = Variable { initial: True }
	targetDateTime = Variable { multivalued: False type: Date  initial: Date.value }
	targetDateTimeValid = Variable { type: Boolean }
	targetDateTimeLDAP= Variable { type: String }
	userDateTimeLDAP= Variable { type: String initial: Date.value("yyyyMMddHHmmss.'000'Z") }
	task = TaskRecord (create "virtual_timeslot")
	
	IncludeHTMLWidget {
		layout: Layout { grab: horizontal True vertical False hint: height 20  }
		template: getBrowserTimestamp
		widget-events: {
			when localtimestampfound then [
				StringCase ( Current timestamp ){
					when Not IsEmpty then [
						Set Current timestamp to userDateTimeLDAP,
						Set DateLDAP( Current timestamp ).offset(1 hours).value to targetDateTime
					]
				}
			]
		}
	}
	Group {
		RadioButtons {
			variable: schedule
			layout: Layout { indent: horizontal 40 vertical 0 }
			Option { text: $validateTimeslotRequest_NLS.options.validatenow value: False }
			Option { text: $validateTimeslotRequest_NLS.options.schedulevalidation value: True }
		}
		DateTime {
			variable: targetDateTime
			allow-none: False
			type: DateTime
			validity: targetDateTimeValid date-after: DateLDAP(userDateTimeLDAP)  
			layout: Layout { indent: horizontal 140 vertical 20 }
			disabled: Not BooleanPredicate ( schedule )
		}
	}
}

