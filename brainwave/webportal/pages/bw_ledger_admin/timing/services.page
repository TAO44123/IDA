
fromatMs = StringService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
    javascript-method: fromatMs
    inMs = Input { type: Integer }
    includeMs = Input { type: Boolean default: False }
}

elapsedTime = StringService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
	javascript-method: elapsedTime
	timeslotUid = Input { type: String }
	step = Input { type: String }
	formatTime = Input { type: Boolean default: True }
}

produceJSON = StringService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
	javascript-method: produceJSON
	uids = Input { type: String multivalued: True }
	step = Input { type: String mandatory: False multivalued: False }
}

timeslotsChecksum = EventService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
	javascript-method: timeslotsChecksum
	timeslotsUid = Input { type: String multivalued: True }
	selectedFields = Input { type: String multivalued: True }
	
	uid = Output { type: String multivalued: True }
	checksum = Output { type: String multivalued: True }
	parent_uid = Output { type: String multivalued: True }
	parent_checksum = Output { type: String multivalued: True }
	changed = Output { type: String multivalued: True }
}

paginationLimits = EventService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
	javascript-method: paginationLimits
	itemPerPage = Input { type: Integer multivalued: True }
	timeslotUid = Input { type: String multivalued: True }
	maxItems = Input { type: Integer multivalued: True }
	
	limitDates = Output { type: String multivalued: True }
	maxValue = Output { type: Integer multivalued: False }
}

truncateToInt = StringService {
	javascript-file: "/webportal/pages/bw_ledger_admin/timing/timings.javascript"
	javascript-method: truncateToInt
	inputVar = Input { type: Integer multivalued: True }
	
}