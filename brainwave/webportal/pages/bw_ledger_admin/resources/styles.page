

labelsst = Style {
	background: Color RGB (240,240,240)
	bold: True
}


valuesst = Style {
	background: Color white
}

highlightedValues = Style {
	background: Color HEX ( #FFED92 ) 
}


header = Style {
	foreground: HEX ( #2b2b2b )
	bold: True
	size: 16px
}

headerLight = Style {
	foreground: HEX ( #2b2b2b )
	bold: False
	size: 14px
}

bigLabel = Style {
	foreground: HEX ( #2b2b2b )
	size: 15px
}

normalText = Style {
	foreground: HEX ( #2b2b2b )
	size: 12px
	bold: False 
}

normalBoldText = Style {
	foreground: HEX ( #2b2b2b )
	size: 12px
	bold: True
}

mediumNumber = Style {
	foreground: HEX ( #2b2b2b )
	bold: True
	size: 16px
}

timingMixin = Mixin {

	Header {
		styling: header
		layout: Layout { indent: horizontal 12 vertical 0}
	}
	
	Label {
		layout: Layout { hint: width 120 }
	}
	


}