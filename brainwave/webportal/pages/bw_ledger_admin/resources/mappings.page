}

evolutionNeutroIconsItems = IntImageTemplate {
	when InvalidInteger then ""
	when < 0  then "bw_ledger_admin/arrows/green/arrow_down_green.png"
	when > 0  then "bw_ledger_admin/arrows/green/arrow_up_green.png"
}

evolutionNeutroIcons = IntImageTemplate {
	when < 0  then "bw_ledger_admin/arrows/blue/down_16.png"
	when = 0  then "bw_ledger_admin/arrows/blue/neutro_16.png"
	when > 0  then "bw_ledger_admin/arrows/blue/up_16.png"
}