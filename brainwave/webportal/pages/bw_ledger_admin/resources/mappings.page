timeslotStatus = StringMapping {
	when "C" then $timeslot.timeslotC
	when "A" then $timeslot.timeslotA
	when "D" then $timeslot.timeslotD
	when "I" then $timeslot.timeslotI
	when "S" then $timeslot.timeslotS
	when "W" then $timeslot.timeslotW
}

