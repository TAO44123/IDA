import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_htmlwidgets/tree.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/templates.page"

import "/webportal/pages/bw_fragments/identity/rights.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/repository/details/repositoryDetails.page"
import "/webportal/pages/bw_fragments/businessactivity/details/businessActivityDetails.page" 

bwsod_identitysodproblemrootcauseanalysisNLS = NLS {
	title [ en "SoD problem root cause analysis" fr "Analyse de la cause du problème de SoD" ]
	dyntitle [ en "SoD problem {1} root cause analysis for {0}" fr "Analyse de la cause du problème de SoD {1} pour {0}" ]
	subtitle [en "Double click on a category value to zoom in" fr "Double cliquez sur une valeur de catégorie pour zoomer"]
	dimensions [en "Business activity|transaction / auth obj.|simple role|composite role" fr "Business activity|transaction / obj auth.|simple role|composite role"]
	activitycode [en "Activity code" fr "Code d'activité"]
	activity [en "Activity" fr "Activité"]
	rootcode [en "transaction / auth obj code" fr "transaction / obj auth code"]
	root [en "transaction / auth obj" fr "transaction / obj auth"]
	srole [en "simple role" fr "role simple"]
	crole [en "composite role" fr "role composite"]
	clear [en "clear" fr "effacer"]
	filterflash [en "filter dimension {0} by {1}" fr "filtrage de la dimension {0} par {1}"]
	risklevel [en "Risk level" fr "Niveau de risque"]
	riskinformation [en "Risk information" fr "Description du risque"]
	simulate [en "simulate user roles change" fr "simuler des changements de role pour l'utilisateur"]

	rootcauselist [en "Root Cause List" fr "Root Cause"]
	rightshierarchy [en "Identity Rights Hierarchy" fr "Hiérarchie des droits de l'identité"]
	rootcauseanalysis [en "SAP Root Cause Analysis" fr "Analyse de la Root Cause SAP"]
	
	affectedidentities [en "Affected Identities" fr "Identités affectées"]
	controldetails [en "SoD Control Details" fr "Détails Contrôle SoD"]
}


bwsod_identitysodproblemrootcauseanalysis = Page {
	title: $bwsod_identitysodproblemrootcauseanalysisNLS.title
	dynamic-title: $bwsod_identitysodproblemrootcauseanalysisNLS.dyntitle(identity.fullname, control.controlcode) 
	icon: "16/details/mining_16.png" large-icon: "48/details/mining_48.png"
	
	identityuid = Parameter {
		type:String
		hidden:True
	}
	controlcode = Parameter {
		type:String
		hidden:True
	}

	identity = Record {
		view:br_identityDetail with identityuid to uid
	}
	control = Record {
		view:bwsod_control with controlcode to controlcode
	}
	
	IncludeFragment {
		fragment:bwsod_identitysodsapproblemrootcauseanalysisfragment with value-of identityuid to inidentityuid,  value-of controlcode to incontrolcode
		layout: Layout { grab: horizontal True vertical True }
	}
}

bwsod_identitysodproblemrootcauseanalysisDialog = Dialog {
	title: $bwsod_identitysodproblemrootcauseanalysisNLS.title
	enter-event: StringCase(controltagtype) {
		when "SoD between permissions" then [ Set "bwsod_identitysodproblemrootcauselistPermission" to fragmentIdentifier ]
		when "SoD between activities" then [ Set "bwsod_identitysodproblemrootcauselistActivity" to fragmentIdentifier ]
		otherwise [ Set "bwsod_identitysodproblemrootcauselistActivity" to fragmentIdentifier ]
	}
	buttons:OkButton
	width:1366
	height:768
	
	identityuid = Variable { private:False } // parameter
	controlcode = Variable { private:False } // parameter
	controltagtype = Variable { private:False } // parameter
	
	fragmentIdentifier = Variable { type:String }

	list1uid = Variable { multivalued:True private:True }
	list2uid = Variable { multivalued:True private:True }
	outapplicationsuid = Variable { multivalued:True private:True }
	
	righthierarchytab = Variable { initial:False type:Boolean }
	rootcauseanalysistab = Variable { initial:False type:Boolean }
	
	identity = Record {
		view:br_identityDetail with identityuid to uid
	}
	control = Record {
		view:bwsod_control with controlcode to controlcode
	}

	issapcontrol = Dataset {
		view:bwsod_identityissapsodproblem with identityuid to identityuid, controlcode to controlcode
	}
	
	Header { icon: %concept.identity value:identity.fullname styling:hugeTitleStyle }
	Group {
		title: $bwsod_identitysodproblemrootcauseanalysisNLS.controldetails
		layout: Layout {grab: horizontal True vertical False}
		Grid {
			layout:Layout {grab: horizontal True vertical True}
			columns:GridColumn,GridColumn
			GridRow {
				GridCell {
					Text {
						label:$controlresult.controlcode
						value:control.controlcode
						tooltip:control.controlcode
						compact:True
					}
					Text {
						label:$controlresult.controldisplayname
						value:control.controldisplayname
						tooltip:control.controldisplayname
						compact:True
					}
				}
				GridCell {
					Text {
						label:$bwsod_identitysodproblemrootcauseanalysisNLS.risklevel
						value: Transform control.risklevel using bwf_ControlLevelMapping
						decorator: Decorator {
							width: Fill
							before: Image {
								image: TemplateImageSelection(control.risklevel) using bwf_controllevel
								width: 16
							}
						}
						compact: True 
					}
					Text {
						label:$bwsod_identitysodproblemrootcauseanalysisNLS.riskinformation
						value:control.riskinfo
						compact:True
					}
				}
			}
		}
	}

	TabFolder {
		TabItem {
			text:$bwsod_identitysodproblemrootcauseanalysisNLS.rootcauselist
			IncludeDynamicFragment {
				dynamic-name: fragmentIdentifier  
				base-fragment: bwsod_identitysodproblemrootcauselistPermission with value-of identityuid to inidentityuid,  value-of controlcode to incontrolcode, list1uid binds-to outlist1uid, list2uid binds-to outlist2uid, outapplicationsuid binds-to outapplicationsuid 
				layout: Layout { grab: horizontal True vertical True }
			}
		}
		TabItem {
			text:$bwsod_identitysodproblemrootcauseanalysisNLS.rightshierarchy
			activation-event:Set True to righthierarchytab
		
			IncludeFragment {
				fragment:fragmentIdentityRightsHierarchywSoDColors with value-of identityuid to inuid,  value-of righthierarchytab to inenabled, value-of list1uid to inlist1uid, value-of list2uid to inlist2uid, value-of outapplicationsuid to infilterbyapplications 
				layout: Layout { grab: horizontal True vertical True }
			}
		}
		TabItem {
			text:$bwsod_identitysodproblemrootcauseanalysisNLS.rootcauseanalysis
			activation-event:Set True to rootcauseanalysistab
			hidden:IntPredicate(Count issapcontrol) { when >0 then False otherwise True }
		
			IncludeFragment {
				fragment:bwsod_identitysodsapproblemrootcauseanalysisfragment with value-of identityuid to inidentityuid,  value-of controlcode to incontrolcode, value-of rootcauseanalysistab to inenabled
				layout: Layout { grab: horizontal True vertical True }
			}
		}
	}
}

bwsod_identitysodproblemrootcauselistActivity = PageFragment {
	enter-event:
				TransferData dataTolist1(transactionuid, applicationuid) to (outlist1uid, outapplication1uid),
				TransferData dataTolist2(transactionuid, applicationuid) to (outlist2uid, outapplication2uid),
				MultivaluedAdd outapplication1uid to outapplicationsuid,
				MultivaluedAdd outapplication2uid to outapplicationsuid,
				MultivaluedDistinct outapplicationsuid

	inidentityuid = Variable { private:False } // parameter
	incontrolcode = Variable { private:False } // parameter
	incontroltagtype = Variable { private:False } // parameter

	outlist1uid = Variable { multivalued:True private:False } // return value
	outlist2uid = Variable { multivalued:True private:False } // return value
	outapplication1uid = Variable { multivalued:True private:False } // return value
	outapplication2uid = Variable { multivalued:True private:False } // return value
	outapplicationsuid = Variable { multivalued:True private:False } // return value
	
	selectedapplicationuid = Variable {type: String}
	selectedactivityuid = Variable {type: String}
	selectedpermissionuid = Variable {type: String}

	dataTolist1 = Dataset {
		view: bwsod_identitysodproblemtransactionlistActivity with inidentityuid to identityuid, incontrolcode to controlcode, 1 to listnumber
	}
	dataTolist2 = Dataset {
		view: bwsod_identitysodproblemtransactionlistActivity with inidentityuid to identityuid, incontrolcode to controlcode, 2 to listnumber
	}
	
	showApplicationDetail = NamedAction (
		Dialog bwf_applicationDetailsDialog(selectedapplicationuid to inuid,
												True to inshowperjob,
												True to inshowperorg
		)
	)
	
	showPermissionDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog(
			selectedpermissionuid to inuid,
			True to inshowaccounts,
			True to inshowaccountperimeters,
			True to inshowcontrols,
			True to inshowdecisionhistory,
			True to inshowoverallocated,
			True to inshowperjob,
			True to inshowperorg,
			True to inshowsodmodeldefects,
			True to inshowtheoretical,
			True to inshowusages
		)
	)
	
	showActivityDetail = NamedAction (
		Dialog bwf_businessActivityDetailsDialog(
			selectedactivityuid to inuid,
			True to inshowaccounts,
			True to inshowperjob,
			True to inshowperorg,
			True to inshowsoddefects
		)
	)

	/* Page content */
	Splitter {
		disposition: Horizontal
		size: 50%
		Group {
			Table {
				data:dataTolist1
				label: Label { break: True value: $fragmentIdentityRightsNLS.firstlist }
				show-filter: True
				show-count: True
				configurable:True
				layout: Layout { grab: horizontal True vertical True }
				Column {
					column:activitycode
					header:$bwsod_identitysodproblemrootcauseanalysisNLS.activitycode
					initially-masked:False
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showActivityDetail
				}
				Column {
					column:activitydisplayname
					header:$bwsod_identitysodproblemrootcauseanalysisNLS.activity
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showActivityDetail
				}
				Column {
					column:transactioncode
					header:$ppermission.code
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showPermissionDetails
				}
				Column {
					column:transactiondisplayname
					header:$permission.concept
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showPermissionDetails
				}
				Column {
					column:applicationdisplayname
					header:$application.concept
					sortable:True
					filterable:True
					width:100%
					initially-masked:True
					actions: ExecuteNamedAction showApplicationDetail
				}
				Column {
					column: activityuid
					hidden: True
					selection: selectedactivityuid
				}
				Column {
					column: applicationuid
					hidden: True
					selection: selectedapplicationuid
				}
				Column {
					column: transactionuid
					hidden: True
					selection: selectedpermissionuid
				}
			}
		}
		Group {
			Table {
				data:dataTolist2
				label: Label { break: True value: $fragmentIdentityRightsNLS.secondlist }
				show-filter: True
				show-count: True
				configurable:True
				layout: Layout { grab: horizontal True vertical True }
				Column {
					column:activitycode
					header:$bwsod_identitysodproblemrootcauseanalysisNLS.activitycode
					initially-masked:False
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showActivityDetail
				}
				Column {
					column:activitydisplayname
					header:$bwsod_identitysodproblemrootcauseanalysisNLS.activity
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showActivityDetail
				}
				Column {
					column:transactioncode
					header:$ppermission.code
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showPermissionDetails
				}
				Column {
					column:transactiondisplayname
					header:$permission.concept
					sortable:True
					filterable:True
					width:100%
					actions: ExecuteNamedAction showPermissionDetails
				}
				Column {
					column:applicationdisplayname
					header:$application.concept
					sortable:True
					filterable:True
					width:100%
					initially-masked:True
					actions: ExecuteNamedAction showApplicationDetail
				}
				Column {
					column: activityuid
					hidden: True
					selection: selectedactivityuid
				}
				Column {
					column: applicationuid
					hidden: True
					selection: selectedapplicationuid
				}
				Column {
					column: transactionuid
					hidden: True
					selection: selectedpermissionuid
				}
			}
		}
	}
}

