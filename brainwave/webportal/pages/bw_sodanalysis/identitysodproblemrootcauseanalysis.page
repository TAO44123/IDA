bwsod_identitysodsapproblemrootcauseanalysisfragment = PageFragment {
	
	inidentityuid = Variable { private:False } // parameter
	incontrolcode = Variable { private:False } // parameter
	inenabled = Variable { type:Boolean initial:False }

	activity = Variable
	root = Variable
	srole = Variable
	crole = Variable

	identity = Record {
		view:br_identityDetail with inidentityuid to uid
	}
	control = Record {
		view:bwsod_control with incontrolcode to controlcode
	}

	dataToReport = Dataset {
		view: bwsod_identitysodproblemrootcause with inidentityuid to identityuid, incontrolcode to controlcode,
													activity to activityname unless-empty,
													root to rootcode unless-empty,
													srole to srolecode unless-empty,
													crole to crolecode unless-empty
		disabled:Not BooleanPredicate(inenabled)
	}


	/* Page content */
	Grid {
		layout:Layout {grab: horizontal True vertical False hint: height 138}
		columns:GridColumn,GridColumn,GridColumn,GridColumn
		GridRow {
			GridCell {
				span:4
				Header { value:identity.fullname styling:bigTitleStyle }
			}
		}
		GridRow {
			GridCell {
				span:2
				Text {
					label:$controlresult.controlcode
					value:control.controlcode
					compact:True
				}
				Text {
					label:$controlresult.controldisplayname
					value:control.controldisplayname
					compact:True
				}
			}
			GridCell {
				span:2
				Text {
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.risklevel
					value:control.risklevel
					compact:True
				}
				Text {
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.riskinformation
					value:control.riskinfo
					compact:True
				}
			}
		}
		GridRow {
			GridCell {
				span:4
				Header {value:$bwsod_identitysodproblemrootcauseanalysisNLS.subtitle}
			}
		}
		GridRow {
			GridCell {
				Edit {
					variable:activity
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.activity
					disabled:True
					commands: Command { actions:Set '' to activity icon:'16/famfamfam_silk_icons_v013/cancel.png' tooltip:$bwsod_identitysodproblemrootcauseanalysisNLS.clear }
				}
			}
			GridCell {
				Edit {
					variable:root
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.root
					disabled:True
					commands: Command { actions:Set '' to root icon:'16/famfamfam_silk_icons_v013/cancel.png' tooltip:$bwsod_identitysodproblemrootcauseanalysisNLS.clear }
				}
			}
			GridCell {
				Edit {
					variable:srole
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.srole
					disabled:True
					commands: Command { actions:Set '' to srole icon:'16/famfamfam_silk_icons_v013/cancel.png' tooltip:$bwsod_identitysodproblemrootcauseanalysisNLS.clear }
				}
			}
			GridCell {
				Edit {
					variable:crole
					label:$bwsod_identitysodproblemrootcauseanalysisNLS.crole
					disabled:True
					commands: Command { actions:Set '' to crole icon:'16/famfamfam_silk_icons_v013/cancel.png' tooltip:$bwsod_identitysodproblemrootcauseanalysisNLS.clear }
				}
			}
		}
	}
	IncludeHTMLWidget {
		layout: Layout { grab:horizontal True vertical True }
		template: parallelSet
		datasets: dataToReport (
									activitydisplayname,
									rootcode,
									srolecode,
									crolecode
								  ) 
								  to chartdata ( 
									dim0,
									dim1,
									dim2,
									dim3
								  )
		bindings:
			value-of $bwsod_identitysodproblemrootcauseanalysisNLS.dimensions to dimensions
		widget-events: {
			when oncategorydbleclick then [ 
				Flash $bwsod_identitysodproblemrootcauseanalysisNLS.filterflash(Current dimension,Current category),
				IntCase(Current dimensionindex) {
					when =0 then [ Set Current category to activity ]				
					when =1 then [ Set Current category to root ]				
					when =2 then [ Set Current category to srole ]				
					when =3 then [ Set Current category to crole ]				
				}
			]
		}
	}
	/*
	ButtonGroup {
		Button {
			actions:
			GoTo Page sodwhatif_user_simulation with identityuid to selectedUser
			text:$bwsod_identitysodproblemrootcauseanalysisNLS.simulate
			feature:sodwhatif_usercentric
		}
	}
	*/
}