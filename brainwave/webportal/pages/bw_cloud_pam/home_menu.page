/* Nationalized labels here */
bwcpam_home_menu_NLS = NLS {

	title [en "PAM Booster designed for CyberArk" fr "PAM Booster designed for CyberArk"]

	gotodataupload [en "Data Upload into PAM Booster" fr "Chargement des données"]

	compliance [en "GOVERNANCE AND\nCOMPLIANCE" fr "GOUVERNANCE ET\nCONFORMITÉ"]
	compliance.buttons.policychecks [ en "MEET\nSECURITY POLICIES" fr "CONTROLER LES POLITIQUES\nDE SÉCURITÉ"]
	compliance.buttons.policychecks.description [ en "and reduce risks of conflicts or errors." fr "et réduire les risques de conflits ou d'erreurs."]
	compliance.buttons.license [en "OPTIMIZE CYBERARK\nLICENSE USAGE" fr "OPTIMISER LES\nLICENCES CYBERARK"]
	compliance.buttons.license.description [en "and gain visibility." fr "et gagner en visibilité."]
	compliance.buttons.configuration [ en "CHECK CYBERARK\nCONFIGURATION" fr "VÉRIFIER LA\nCONFIGURATION CYBERARK"]
	compliance.buttons.configuration.description [ en "and empower stakeholders\nthrough dashboards." fr "et informer les parties prenantes\ngrâce aux tableaux de bord."]
	compliance.buttons.safereview [ en "AUTOMATE SAFE\nACCESS REVIEW" fr "AUTOMATISER LA\nREVUE DES SAFES"]
	compliance.buttons.safereview.description [ en "and empower safe owner\nin a few clicks." fr "et solliciter les propriétaires\nde safes en quelques clics."]
		
	operation [en "OPERATIONAL\nEFFICIENCY" fr "EFFICACITÉ\nOPERATIONNELLE"]
	operations.buttons.cpmmonitoring [ en "ANALYZE\nCPM" fr "SUIVRE LE\nCPM"]
	operations.buttons.cpmmonitoring.description [ en "and see where it failed." fr "et investiguer sur les échecs du CPM."]
	operations.buttons.recomendations [ en "ANALYZE WITH\nCLUE FINDER" fr "ANALYSER AVEC\nCLUE FINDER"]
	operations.buttons.recomendations.description [ en "the unusual changes\nwith remediation suggestions." fr "les changements inhabituels\net les remédiations suggérées."]
//	operations.buttons.inventory [ en "CHECK ACCESS\nINVENTORY" fr "CARTOGRAPHIER\nLES ACCÈS"]
//	operations.buttons.inventory.description [ en "and visualize the current\naccesses." fr "et visualiser la situation actuelle\ndes accès."]
	operations.buttons.notification [ en "SUBSCRIBE SAFE\nOWNERS TO REPORTS" fr "ABONNER LES\nPROPRIETAIRES DE SAFES"]
	operations.buttons.notification.description [ en "and give them visibility\nto their safes." fr "aux rapports d'analyses\net leur donner de la visibilité."]
	
	onboarding [en "ONBOARDING\nINTO CYBERARK" fr "EMBARQUEMENT\nDANS CYBERARK"]
	onboarding.buttons.inventory [ en "IDENTIFY\nPRIVILEGED ACCOUNTS" fr "IDENTIFIER LES\nCOMPTES À PRIVILÈGES"]
	onboarding.buttons.inventory.description [ en "and map and document\nhidden accounts." fr "et cartographier, documenter\nles comptes."]
	onboarding.buttons.onboarding [ en "SPEED UP THE\nPAM PROGRAM" fr "ACCÉLÉRER LE\nPROGRAMME PAM"]
	onboarding.buttons.onboarding.description [ en "by defining and planning the accounts\nto be onboarded." fr "et définir, planifier les\ncomptes à embarquer."]
	onboarding.buttons.followonboarding [ en "FOLLOW THE\nPAM PROGRAM" fr "SUIVRE LE\nPROGRAMME PAM"]
	onboarding.buttons.followonboarding.description [ en "and the onboarding velocity." fr "et la vélocité des embarquements."]

	currentnls [ en "en" fr "fr" ]
	
	remediation.config [en "Configure Remediation Strategy" fr "Configurer la stratégie de remédiation"]
	
	warningpendingreview [en "You have {0} entries to review" fr "Vous avez {0} entrées à revoir"]
	
	warningpendingreviewandremediation [en "and {0} remediations to launch" fr "et {0} remédiations en attente de lancement"]
	
	warningpending [en "You have {0} remediations to launch" fr "Vous avez {0} remédiations en attente de lancement"]
	
	warningreviewandremediation [en "and {0} ongoing remediations." fr "et {0} remédiations en cours."]
	
	warningremediation [en "You have {0} ongoing remediations." fr "Vous avez {0} remédiations en cours."]	
}


bwcpam_home_menu = Page {
	homepage-for: pam_pgm_home  priority 3400 
	title: $bwcpam_home_menu_NLS.title
	mixins: dashboardMixin
	icon: %steps_32.home
	large-icon: %steps_48.home
	enter-event: Set gettotaltobereviewedentries.nbtobereviewed to outnbentriestoreview
	feature: All(pam_license, Any(governance_license, compliance_license))
	
	header:PageHeader {
			Button {
				text:$bwcpam_home_menu_NLS.warningpendingreview(outnbentriestoreview)
				hidden: OrPredicate { 
					IntPredicate(outnbentriestoreview) { when >0 then False otherwise True }
				}  
				styling: boldStyle,baseLink
				presentation: Link
				actions: GoTo Page enduser
				feature: pamreview_admin
				align: Right
			}	
			Button {
				text:$bwcpam_home_menu_NLS.warningpendingreviewandremediation(nbpendingremediation)
				hidden: OrPredicate { 
					IntPredicate(outnbentriestoreview) { when >0 then False otherwise True }
					IntPredicate(nbpendingremediation) { when >0 then False otherwise True }
				}  
				styling: boldStyle,baseLink
				presentation: Link
				actions: GoTo Page bwaccess360_remediationmanagement
				feature: pamreview_admin
			}
			Button {
				text: $bwcpam_home_menu_NLS.warningpending(nbpendingremediation)
				hidden: OrPredicate {
					IntPredicate(outnbentriestoreview) { when >0 then True otherwise False }
					IntPredicate(nbpendingremediation) { when >0 then False otherwise True }
				}
				styling: boldStyle,baseLink
				presentation: Link
				actions: GoTo Page bwaccess360_remediationmanagement
				feature: pamremediation_admin
			}
			
			Button {
				text:$bwcpam_home_menu_NLS.warningreviewandremediation(nbongoingremediation)
				hidden: AndPredicate {		
					OrPredicate { 		
						IntPredicate(nbpendingremediation) { when >0 then False otherwise True }
						IntPredicate(nbongoingremediation) { when >0 then False otherwise True }
					}  
					OrPredicate { 		
						IntPredicate(outnbentriestoreview) { when >0 then False otherwise True }
						IntPredicate(nbongoingremediation) { when >0 then False otherwise True }
					} 				
				}
				styling: boldStyle,baseLink
				presentation: Link
				actions: GoTo Page bwaccess360_remediationmanagement
				feature: pamreview_admin
			}
			Button {
				text: $bwcpam_home_menu_NLS.warningremediation(nbongoingremediation)
				hidden: OrPredicate {		
					IntPredicate(outnbentriestoreview) { when >0 then True otherwise False }
					IntPredicate(nbpendingremediation) { when >0 then True otherwise False }
					IntPredicate(nbongoingremediation) { when >0 then False otherwise True }
				}
				styling: boldStyle,baseLink
				presentation: Link
				actions: GoTo Page bwaccess360_remediationmanagement
				feature: pamremediation_admin
			}			
			
			Button {
				text:$bwcpam_home_menu_NLS.remediation.config
				styling: text
				actions: GoTo Page bwiasr_remediationstrategymanagement
				image: %concept_24.techaccount
				feature: pamremediation_admin
			}	
	}

	
	// State manager vars	
	canModifyConfig = Variable { type: Boolean}
	language = Variable { type: String initial: $bwcpam_home_menu_NLS.currentnls }
	state = Variable
	selectedVault = Variable
	
	// Remediation variables
	nbongoingremediation = Variable { type:Integer }
	nbpendingremediation = Variable { type:Integer }
	remediationactionlist = Variable { multivalued:True }
	filterbyclosedstatus = Variable { initial:'active' }

	// Review variables
	nbactivecampaigns = Variable { type: Integer }	
	outnbentriestoreview = Variable { type:Integer } // nb of entries left to review
	inuid = Variable {type: String initial: Principal.uid }
			
	// Home page datasets
	vaults = Dataset {
	  view: vault_list
	}

	// Remediation status datasets
	nbpendingremediation = Dataset {
		view:bwaccess360r_applicationnbremediation with '-1' to filterbyrunstatus
		count-variable:nbpendingremediation
	}	

	nbongoingremediation = Dataset {
		view:bwaccess360r_applicationnbremediation with '0' to filterbyrunstatus
		count-variable:nbongoingremediation
	}	

	gettotaltobereviewedentries = Record {
		view: bwir_identitylistpendingsafecampaigns with inuid to revieweruid
	}

