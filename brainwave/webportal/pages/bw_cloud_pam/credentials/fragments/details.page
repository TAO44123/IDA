fragmentCASecretDetailsNLS = NLS {
	category [en "Category" fr "Catégorie"]
	family [en "Family" fr "Famille"]
	nbsafes [en "# safes" fr "Nb safes"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	nbaccounts [en "Number of active user accounts" fr "Nombre de comptes actifs"]
	nbfolders [en "Number of folders" fr "Nombre de répertoires"]
	expertise [en "Expertise" fr "Responsabilité"]
	managers [en "Managers" fr "Responsables"]
	kpis [en "KPIs" fr "KPIs"]
	secretdetails [en "Credential details" fr "Détails du secret"]
	managetags [en "Manage tags" fr "Gérer les labels"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected CA Vault details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the vault uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentCASecretFullDetails = PageFragment {

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	casecret = Record {
		view:bwpam_casecretDetail with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
	}
	prevcasecret = Record {
		view:bwpam_casecretDetail with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
		timeslot:FromPage(-1)
	}
//	tags = Dataset {
//		view:bwf_applicationtags with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
//	}
//	tagsasString = Record {
//  		 view:bwa_applicationtagsasastring with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
//	}

	// standard
	Grid {
		columns:GridColumn { width: 160 px }, GridColumn { width:grow }
		layout:Layout { grab:horizontal True vertical False hint: height 80 }
		GridRow {
			height:80
			GridCell {
				Header {
					value:''
					styling:bigTitleStyle
					icon:%pam_cyberark_concepts_48.secret
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False}
				}
			}		
			GridCell {
				Header {
					value:casecret.displayname
					styling:bigTitleStyle
					layout:Layout{indent:horizontal 0 vertical 0 hint:height 24}
				}
				Header {
					layout:Layout{indent:horizontal 0 vertical 0 hint:height 20}
					value:casecret.code
					hidden:SameValuePredicate(casecret.code, casecret.displayname)
				}
//				Text {
//					value: @srv_truncatestring (tagsasString.tag to string, 300 to maxlength)
//					tooltip:tagsasString.tag
//					label:Label { break:True }
//					compact: True
//					layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 16}
//					commands:Commands { position: After orientation: Horizontal 
//								Command{	actions:Dialog fragmentApplicationTagsEditor(inuid to uid, incanupdatetags to canupdatetags), 
//													ReloadData (casecret), ReloadData (tags), ReloadData (tagsasString)
//				                        	icon:%collection_16.tag
//				                        	disabled:Not BooleanPredicate(incanupdatetags)
//				                        	tooltip:$fragmentCASecretDetailsNLS.managetags
//				                       }
//				                  }
//				}
			}		
		}
	}
	
	Grid {
		columns:GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 150 }
		GridRow {
			GridCell {
				Group {
					title:$fragmentCASecretDetailsNLS.secretdetails

					IncludeFragment { fragment: fragmentAccountSecretDetails with value-of inuid to inuid }
				}
			}
			GridCell {
				Group {
					title:$fragmentCASecretDetailsNLS.kpis

					Text {
						value: Transform casecret.app_bwa_applicationanalytics_nbaccount using nullToZeroMapping
						label:$search.application.nbaccounts
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casecret.app_bwa_applicationanalytics_nbaccount using mayBeNullMapping, Transform prevcasecret.app_bwa_applicationanalytics_nbaccount using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casecret.app_bwa_applicationanalytics_nbaccount, prevcasecret.app_bwa_applicationanalytics_nbaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value: Transform casecret.app_bwa_applicationanalytics_nbidentity using nullToZeroMapping
						label:$search.application.nbidentities
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casecret.app_bwa_applicationanalytics_nbidentity using mayBeNullMapping, Transform prevcasecret.app_bwa_applicationanalytics_nbidentity using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casecret.app_bwa_applicationanalytics_nbidentity, prevcasecret.app_bwa_applicationanalytics_nbidentity)) using bwf_trend
								width:16
							}
						}
					}
				}
			}
		}
	}
}
