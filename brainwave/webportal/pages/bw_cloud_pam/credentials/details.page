casecretDetailsPage = Page {
	title: $casecretDetailsPageNLS.title
	dynamic-title: $casecretDetailsPageNLS.dynamictitle(secret.secret_label)
	mixins: detailsPage
	enter-event: 	IntCase(secret.safe_bwa_applicationanalytics_nbdirectaccountright) { when >0 then [ Set True to hasrights ] },
					IntCase(secret.safe_bwa_applicationanalytics_nbdirectidentityright) { when >0 then [ Set True to hasidentityrights ] }
	
	// Parameters Here
	paramSecretUid = Parameter {
		type: String
		hidden: True
		mandatory: True
	}
	
	// Variables Here
	selectedSecretUid = Variable {
		type: String
		initial: paramSecretUid
	}

	nbdefects = Variable 
	nboverallocated = Variable
	nbdecision = Variable
	hasrights = Variable { initial:False }
	hasidentityrights = Variable { initial:False }	

	showextended = Variable { initial:False }
	
	// Empty uid when search mode
	nonEmptyUid = Variable { type: String }
	
	active_casecret = Variable { initial:False multivalued:False type:Boolean }
	active_detail = Variable { initial:False multivalued:False type:Boolean }
	active_accounts = Variable { initial:False multivalued:False type:Boolean }
	active_safes = Variable { initial:False multivalued:False type:Boolean }
	active_access = Variable { initial:False multivalued:False type:Boolean }
	active_rights = Variable { initial:False multivalued:False type:Boolean }
	active_perorg = Variable { initial:False multivalued:False type:Boolean }
	active_perjob = Variable { initial:False multivalued:False type:Boolean }
	active_control = Variable { initial:False multivalued:False type:Boolean }
	active_dataviz = Variable { initial:False multivalued:False type:Boolean }
	
	// Record for concept details
	secret = Record {
		view: bwpam_secret_detail with selectedSecretUid to secretUid
	}

	// Start of the Layout based on a 1-column Grid
	Grid {
		columns: GridColumn { width: grow }							
		layout: Layout { grab: horizontal True vertical True }
		// Row for the Navigator

		GridRow {
			height:grow
			GridCell {
				TabFolder {
					border:True
					layout:Layout { indent: horizontal 0 vertical 6 }
					TabItem {
						text:$casecretDetailsPageNLS.details
						activation-event:Set True to active_detail

						TabFolder {
							border:False
							TabItem {
								text:$casecretDetailsPageNLS.casecret
								activation-event:Set True to active_casecret
							
								IncludeFragment {
									fragment:fragmentCASecretFullDetails
									with value-of secret.uid to inuid, value-of True to incanupdatetags, value-of Eval "active_detail.get() && active_casecret.get()" to inenabled
								}
							}
							TabItem {
								text:$casecretDetailsPageNLS.accounts
								activation-event:Set True to active_accounts
							
								IncludeFragment {
									fragment:fragmentCASecretAccounts
									with value-of secret.safe_uid to inuid, value-of True to incanshowdetails, value-of True to incanreconcile, value-of Eval "active_detail.get() && active_accounts.get()" to inenabled
								}
							}
							TabItem {
								text:$casecretDetailsPageNLS.dataviz
								activation-event:Set True to active_dataviz
								hidden: Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))
								IncludeFragment {
									fragment: bwpam_secret_graph
									with value-of secret.safe_uid to inuid, value-of secret.uid to insecretuid, value-of False to insecretsonly, value-of Eval "active_detail.get() && active_dataviz.get()" to inenabled
								}
							}
						}
					}
					TabItem {
						text:$casecretDetailsPageNLS.access
						activation-event:Set True to active_access
						hidden:Not BooleanPredicate(hasrights)
					 
						TabFolder {
							border:False
							TabItem {
								text:$casecretDetailsPageNLS.rights
								hidden:Not BooleanPredicate(hasrights)
								activation-event:Set True to active_rights
							
								IncludeFragment {
									fragment:fragmentSecretRights
									with value-of secret.safe_uid to inuid, value-of True to incanshowdetails, value-of True to incanreconcile,  value-of Eval "active_access.get() && active_rights.get()" to inenabled
								}
							}
							TabItem {
								text:$casecretDetailsPageNLS.oorigin
								hidden:OrPredicate {   
									Not BooleanPredicate(hasidentityrights)
									Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))
									}
								activation-event:Set True to active_perorg
							
								IncludeFragment {
									fragment:fragmentSecretPerOrg
									with value-of secret.safe_uid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_perorg.get()" to inenabled
								}
							}
							TabItem {
								text:$casecretDetailsPageNLS.jorigin
								hidden:OrPredicate {   
									Not BooleanPredicate(hasidentityrights)
									Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))
									}
								activation-event:Set True to active_perjob
							
								IncludeFragment {
									fragment:fragmentSecretPerJob
									with value-of secret.safe_uid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_perjob.get()" to inenabled
								}
							}
						}
					}
					TabItem {
						text:$casecretDetailsPageNLS.controls
						hidden: Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))
						activation-event:Set True to active_control
						badge: Eval "nbdefects.get()>0?nbdefects.get():''"
					
						IncludeFragment {
							fragment:fragmentSecretAllControlDefectsList
							with value-of selectedSecretUid to inuid, value-of True to incanshowdetails, nbdefects binds-to outnbdefects, value-of True to inenabled
						}
					}
				}
			}
		}
	}
}
