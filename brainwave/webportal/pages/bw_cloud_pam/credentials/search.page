casecretSearchPageNLS = NLS {
	title [en "CyberArk Credentials" fr "Secrets CyberArk"]
	safe [en "Safe" fr "Safe"]
	vault [en "Vault" fr "Vault"]
	resource [en "Address" fr "Adresse"]
	resourcetype [en "Platform" fr "Plateforme"]
	login [en "Login" fr "Login"]
	secret [en "Credential" fr "Secret"]
	cpm [en "CPM enabled?" fr "CPM actif ?"]
	nocpmonly [en "Show only credentials without CPM" fr "Ne montrer que les secrets sans CPM"]
	table.columns.vaultname [ en "CyberArk Credential" fr "Secret CyberArk" ]
	table.columns.accountsnb [ en "# users" fr "Nb utilisateurs" ]
}

casecretSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

casecretSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

casecretSearchPage = Page {
	title: $casecretSearchPageNLS.title
	tags: "ca_secret" , "conceptsearch" priority 250
	icon: %pam_cyberark_concepts_32.secret
	large-icon: %pam_cyberark_concepts_48.secret
	description: $casecretSearchPageNLS.title
	
	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	cacredentialSearch = SearchDefinition {
		entity: CACredential
		simple-mode-rule: brpam_casecret_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedSecretUid = Variable {
		type: String
	}
	selectedSafeUid = Variable {
		type: String
	}

	nocpmonly = Variable {
		type: Boolean
		initial: False
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	casecretanalytics = Dataset {
		pages: Pages{tags: "ca_secret" and "searchresults" }
		count-variable:nbanalytics
	}
	
	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}
	
	casecretData = Dataset {
		search: Search {
			definition: cacredentialSearch
			view: brpam_casecret_searchpoint_trend with nocpmonly to nocpmonly, reftimeslot.timeslotuid to reftimeslotuid, False to withtrends //, UserVariable casecretSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	casecretData_count = Dataset {
		search: Search {
			definition: cacredentialSearch
			view: brpam_casecret_searchpoint_trend with nocpmonly to nocpmonly, reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	
	
	goDetails = NamedAction (
		GoTo Activity CACredential( ca_secret ) Detail with selectedSecretUid to paramSecretUid
	)
	
	goSafe = NamedAction (
		GoTo Activity CASafe( ca_safe ) Detail with selectedSafeUid to paramSafeUid
	)
	
	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: cacredentialSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			simple-mode-layout: SimpleModeLayout {
				displayname { label: $casecretSearchPageNLS.secret },
				vault { label: $casecretSearchPageNLS.vault },				
				safe { label: $casecretSearchPageNLS.safe },
				resource { label: $casecretSearchPageNLS.resource },
				login { label: $casecretSearchPageNLS.login }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: casecretData
//					show-count: True
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			show-count-button: True			
			page-size:1000
			
			
			Column {
				column: uid
				hidden: True
				selection: selectedSecretUid
			}
			
			Column {
				column: safe_uid
				hidden: True
				selection: selectedSafeUid
			}
			
			Column {
				column: displayname
				sortable:True
				header: $casecretSearchPageNLS.secret
				width: 100%
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			
			Column {
				column: username
				sortable:True
				header: $casecretSearchPageNLS.login
				width: 100%
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			
			Column {
				column: address
				sortable:True
				header: $casecretSearchPageNLS.resource
				width: 100%
				initially-masked: False
			}
			
			Column {
				column: platformid
				sortable:True
				header: $casecretSearchPageNLS.resourcetype
				width: 100%
				
				initially-masked: False
			}
			
			Column {
				column: automaticmanagement_enabled
				sortable:True
				header: $casecretSearchPageNLS.cpm
				width: 100%
				
				initially-masked: False
			}
			
			Column {
				column: safe_displayname
				sortable:True
				header: $casecretSearchPageNLS.safe
				width: 100%
				
				initially-masked: False
				actions: ExecuteNamedAction goSafe
			}
			
			Column {
				column: vault_displayname
				sortable:True
				header: $casecretSearchPageNLS.vault
				width: 100%
				
				initially-masked: False
			}
			
//			Column {
//				column: isnew				
//				text:Transform Current isnew using booleanDisplayMapping
//				header: $searchlabel.isnew
//				width: 100px
//				styling:BooleanStyling(Current isnew) { when True then casecretSearchPage_highlightnew when False then default }				
//				initially-masked: True
//			}
			Column {
				column:nbaccount
				text:Transform Current nbaccount using bwf_defaultsTo0
				sortable:True
				header:$casecretSearchPageNLS.table.columns.accountsnb
//				image:TemplateImageSelection(Eval "(''+current.prevnbaccount).equals('null')?956487965:current.nbaccount-current.prevnbaccount") using bwf_trend
//				tooltip:$search.application.ratiotooltip(Transform Current nbaccount using mayBeNullMapping, Transform Current prevnbaccount using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbidentity
				text:Transform Current nbidentity using bwf_defaultsTo0
				sortable:True
				header:$search.application.nbidentities
//				image:TemplateImageSelection(Eval "(''+current.prevnbidentity).equals('null')?956487965:current.nbidentity-current.prevnbidentity") using bwf_trend
//				tooltip:$search.application.ratiotooltip(Transform Current nbidentity using mayBeNullMapping, Transform Current prevnbidentity using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
		}
	}

		Grid {
			columns:GridColumn,GridColumn { width: grow }
			layout: Layout { grab:horizontal True vertical False hint: height 75 }
			GridRow {
				GridCell {
					Checkbox {
						variable: nocpmonly
						text: $casecretSearchPageNLS.nocpmonly
					}
//					Checkbox {
//						variable:UserVariable casecretSearchPage_withtrends
//						text:$search.showkpitrends
//					}
				}			
				GridCell {
				ButtonGroup {
					align:Right
					/*
					Button {
						actions: IntCase(Count casecretData_count)	{
										when > NonEmpty(ConfigurationVariable "search_share_analyticserrorthreshold", Constant search_share_analyticserrorthreshold) then [
											Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_share_analyticserrorthreshold", Constant search_share_analyticserrorthreshold))
										]
										when > NonEmpty(ConfigurationVariable "search_share_analyticswarningthreshold", Constant search_share_analyticswarningthreshold) then [
											Confirm $search.analyticswarningthreshold(Count casecretanalytics),
											GoTo Page casecretSearchAnalyticsPage with  SerializeSearch casecretSearch to search
												
										]
										otherwise [
											GoTo Page casecretSearchAnalyticsPage with  SerializeSearch casecretSearch to search
										]
									}
						text:$search.applyanalytics
						tooltip:$search.applyanalyticstooltip
						image:%report_16.analytics
						feature:sharesearch_analytics
						disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
					}
				
					Button {
						actions:	TransferData casecretData(uid) to (uids), 
									Dialog fragmentApplicationBulkAddTag(uids to uids),
									Flash $search.flashaddingatag
						text:$search.addingatag
						image:%collection_16.tag
					}
					Button {
						actions:	TransferData casecretData(uid) to (uids), 
									Dialog fragmentApplicationBulkRemoveTag(uids to uids, SerializeSearch casecretSearch to applicationSearch),
									Flash $search.flashremovingatag
						text:$search.removingatag
						image:%collection_16.tag
					}
					
					Button {
						actions:	TransferData casecretData(uid) to (uids), 
									Dialog fragmentApplicationBulkRemoveAllTags(uids to uids),
									Flash $search.flashremovingalltag
						text:$search.removingalltag
						image:%collection_16.tag
