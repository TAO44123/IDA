/**
 * <span style="white-space: pre-line">
 * Display the selected safe secrets
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the safe uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected secret uid</li>
 * <li><b>outaccountlogin </b>the selected secret login</li>
 * <li><b>outrepositoryuid </b>the selected secret repository uid</li>
 * <li><b>outrepositoryname </b>the selected secret repository name</li>
 * </ul>
 * </span>
 */
fragmentCASafeSecrets = PageFragment {

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	outaccountuid = Variable
	outaccountlogin = Variable
	outaccountusername = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable
	
	selectedSecretUID = Variable

	selectedUids = Variable { type: String multivalued: True}

	secrets = Dataset {
		view:bwf_casafesecrets with inuid to uid
		 trend: Trend {
		 	join-column:secret_uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		 }
		 disabled:Not BooleanPredicate(inenabled)
		 
	}

	Splitter {
		disposition: Horizontal 
		size: 70%
		
		Group {
		
			Table {
				data: secrets
				layout: Layout { grab: horizontal True vertical True}
				//show-filter: True
				show-count: True
				configurable:True
				show-filter:True	
								
				Column { column: secret_uid selection: selectedSecretUID hidden: True }
				Column { 
					sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.safe	column: safe_displayname 
					actions: Dialog bwf_casafeDetailsDialog ( Current safe_code to incode )				
				}
				Column { 
					sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.user		column: secret_custom1
				}	
				Column { 
					sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.address 		column: secret_custom2 
				}
				Column { 
					sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.platform 		column: secret_custom3 
				}
				
				Column {
					column: trends
					header: $bw_fragment.trends
					text:Transform Current trends using bwf_trendStatusColumn 
					styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
					image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
					tooltip:$bwf_trendStatusColumnNLS.tooltip
		
					sortable: True
					filterable: True
					width: 120px
				}
			}
		}
		
		ConditionalGroup {
			BooleanCondition using StringPredicate ( selectedSecretUID ) {
					when IsEmpty then True 
				}
			in {
				when True then [
					Text {
						value: $fragmentCASafeSecretsNLS.details.message.pleaseselect
						compact: True
						hidden: StringPredicate ( selectedSecretUID ) {
							when Not IsEmpty then True 
						}
					}
				]
				when False then [
					IncludeFragment { fragment: fragmentAccountSecretDetails with selectedSecretUID binds-to inuid }
				]
			}
		}
	}
}


