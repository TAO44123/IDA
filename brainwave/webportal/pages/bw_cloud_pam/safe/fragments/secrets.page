	lastmodifiedby [en "Last Modified by" fr "dernière modification par"]
	lastmodificationdate [en "Last Modification Date" fr "date de dernière modification"]
	detailstooltip [ en "Shows selected account details" fr "Affiche les détails du compte sélectionné"]
	
	secrets.safe [
		fr "Safe"
		en "Safe"
	]
	secrets.user [
		fr "Nom d'utilisateur"	
		en "Username"
	]
	secrets.platform [
		fr "Plateforme"
		en "Platform"
	]
	secrets.address [
		fr "Adresse"
		en "Address"
	]
	
	secrets.excpt [
		fr "Exception" 
		en "Exception" 	
	]
	secrets.tab.text [
		fr "Secret"
		en "Credential"
	]
	secrets.secrettype [
		fr "Type de secret"
		en "Credential Type"
