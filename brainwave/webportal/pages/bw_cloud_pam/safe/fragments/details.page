import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/lib/mixins.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/styles.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"
import "/webportal/pages/bw_cloud_pam/resources/icons.page"

fragmentCASafeDetailsNLS = NLS {
	category [en "Category" fr "Catégorie"]
	family [en "Family" fr "Famille"]
	nbsecrets [en "Number of credentials" fr "Nb secrets"]
    nbcpm [en "With CPM active" fr "Avec CPM actif"]
    nbcpmfailed  [en "With CPM in a failed state" fr "Avec CPM en statut échec"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	nbaccounts [en "Number of active users" fr "Nombre d'utilisateurs actifs"]
	nbeffaccounts [en "Number of effective users" fr "Nombre d'utilisateurs effectifs"]
	nbidentities [en "Number of identities" fr "Nombre d'identités"]
	nbfolders [en "Number of folders" fr "Nombre de répertoires"]
	expertise [en "Expertise" fr "Responsabilité"]
	managers [en "Managers" fr "Responsables"]
	nomanagers [en "No manager set" fr "Pas de responsable configuré"]	
	kpis [en "KPIs" fr "KPIs"]
	vault [en "Vault" fr "Vault"]
	vaultname [ en "Vault name" fr "Nom du vault"]
	secrets [en "Credentials" fr "Secrets"]
	updatemetadata [en "Update safe description" fr "Mise à jour de la description de l'application"]	
	managetags [en "Manage tags" fr "Gérer les labels"]
	addowner [en "Add a new safe owner" fr "Ajout d'un nouveau responsable de safe"]
	deleteowner [en "Delete selected safe owner" fr "Suppression du responsable de safe"]
	auditowner [en "Safe owner updates audit trail" fr "Piste d'audit des changements de responsable de safe"]	
	classification [en "Classification" fr "Classification"]	
}

/**
 * <span style="white-space: pre-line">
 * Display the selected CA Safe details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the safe uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentCASafeFullDetails = PageFragment {

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }	
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	casafe = Record {
		view:bwpam_casafeDetail with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
	}
	prevcasafe = Record {
		view:bwpam_casafeDetail with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
		timeslot:FromPage(-1)
	}
	

	managers = Dataset {
		view:bwf_applicationmanagers with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
	}

	
	
	tags = Dataset {
		view:bwf_safetags with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
	}
	tagsasString = Record {
  		 view:bwa_safetagsasastring with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
	}

	// standard
	Grid {
		columns:GridColumn { width: 160 px }, GridColumn { width:grow }
		layout:Layout { grab:horizontal True vertical False hint: height 120 }
		GridRow {
			height:120
			GridCell {
				Header {
					value:''
					styling:bigTitleStyle
					icon:%pam_cyberark_concepts_48.safe
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False}
				}
			}		
			GridCell {
				Header {
					value:casafe.displayname
					styling:bigTitleStyle
					layout:Layout{indent:horizontal 0 vertical 0 hint:height 24}
					commands:Commands { position: After orientation: Horizontal 
									Command{	actions:Dialog bwfApplicationDetailsMetadata_Dialog(inuid to paramApplicationUid, casafe.sensitivitylevel to sensitivitylevel, 
																									casafe.sensitivityreason to sensitivityreason, 
																									casafe.description to description, 
																									casafe.category to category,
																									casafe.applicationtype to applicationtype), 
														ReloadData (casafe)
					                        	icon:%collection_16.pencil
					                        	disabled:Not BooleanPredicate(incanupdatedescription)
					                        	feature:applicationdetails_updatemetadata 
					                        	tooltip:$fragmentCASafeDetailsNLS.updatemetadata
					                       }
					                  }					
				}			
				Header {
					layout:Layout{indent:horizontal 0 vertical 0 hint:height 20}
					value:casafe.code
					hidden:SameValuePredicate(casafe.code, casafe.displayname)
				}
				Text {
					value:casafe.description
					lines:3
					compact:True
					layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 22}
				}									
				Text {
					value: @srv_truncatestring (tagsasString.tag to string, 350 to maxlength)
					tooltip:tagsasString.tag
					label:Label { break:True }
					compact: True
					layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 16}
					commands:Commands { position: After orientation: Horizontal 
								Command{	actions:Dialog fragmentSafeTagsEditor(inuid to uid, incanupdatetags to canupdatetags), 
													ReloadData (casafe), ReloadData (tags), ReloadData (tagsasString)
				                        	icon:%collection_16.tag
				                        	disabled:Not BooleanPredicate(incanupdatetags)
				                        	tooltip:$fragmentCASafeDetailsNLS.managetags
				                       }
				                  }
				}
			}		
		}
	}
	
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 175 }
		GridRow {
			GridCell {
				Group {
					title:$fragmentCASafeDetailsNLS.kpis

					Text {
						value: Transform casafe.effective_users_nb using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbeffaccounts
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.effective_users_nb using mayBeNullMapping, Transform prevcasafe.effective_users_nb using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.effective_users_nb, prevcasafe.effective_users_nb)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value: Transform casafe.bw_pam_safemetrics_nb_users using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbaccounts
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.bw_pam_safemetrics_nb_users using mayBeNullMapping, Transform prevcasafe.bw_pam_safemetrics_nb_users using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.bw_pam_safemetrics_nb_users, prevcasafe.bw_pam_safemetrics_nb_users)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value: Transform casafe.bw_pam_safemetrics_nb_identities using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbidentities
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.bw_pam_safemetrics_nb_identities using mayBeNullMapping, Transform prevcasafe.bw_pam_safemetrics_nb_identities using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.bw_pam_safemetrics_nb_identities, prevcasafe.bw_pam_safemetrics_nb_identities)) using bwf_trend
								width:16
							}
						}
					}
				}
			}

			GridCell {
				Group {
					title:$fragmentCASafeDetailsNLS.secrets

					Text {
						value: Transform casafe.secrets_nb using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbsecrets
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.secrets_nb using mayBeNullMapping, Transform prevcasafe.secrets_nb using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.secrets_nb, prevcasafe.secrets_nb)) using bwf_trend
								width:16
							}
						}
					}
//// CPM KPIs ////
					Text {
						value: Transform casafe.bw_pam_safemetrics_nb_cpm_active using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbcpm
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.bw_pam_safemetrics_nb_cpm_active using mayBeNullMapping, Transform prevcasafe.bw_pam_safemetrics_nb_cpm_active using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.bw_pam_safemetrics_nb_cpm_active, prevcasafe.bw_pam_safemetrics_nb_cpm_active)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value: Transform casafe.bw_pam_safemetrics_nb_cpm_failed using nullToZeroMapping
						label:$fragmentCASafeDetailsNLS.nbcpmfailed
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform casafe.bw_pam_safemetrics_nb_cpm_failed  using mayBeNullMapping, Transform prevcasafe.bw_pam_safemetrics_nb_cpm_failed  using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(casafe.bw_pam_safemetrics_nb_cpm_failed , prevcasafe.bw_pam_safemetrics_nb_cpm_failed )) using bwf_trend
								width:16
							}
						}
					}					
				}							
			}
			
			GridCell {
				Group {
					title:$fragmentCASafeDetailsNLS.classification

					Text {
						value:casafe.vault_displayname
						label:$fragmentCASafeDetailsNLS.vaultname
						compact:True
					}
					Text {
						value:casafe.applicationfamily
						label:$fragmentCASafeDetailsNLS.family
						hidden:StringPredicate(casafe.applicationfamily) { when IsEmpty then True }
						compact:True
					}
					Text {
						value:casafe.category
						label:$fragmentCASafeDetailsNLS.category
						compact:True
					}
					Text {
						value:Transform casafe.sensitivitylevel using bwfApplicationSensitivityLevelMapping
						label:$fragmentCASafeDetailsNLS.sensitivitylevel
						compact:True
					}
					Text {
						value:casafe.sensitivityreason
						label:$fragmentCASafeDetailsNLS.sensitivityreason
						compact:True
					}					
				}
			}	
		}
	}
//// Managers ////	
	Group {
		title:$fragmentCASafeDetailsNLS.managers
		layout:Layout { grab:horizontal True vertical False hint: height 175 }

		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$fragmentCASafeDetailsNLS.nomanagers			
						commands: Commands {
							position: After orientation: Vertical
							Command{	
									actions:Dialog bwfApplicationDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																								selectedExpertiseDomain to paramManagerType, 
																								inuid to paramApplicationUid),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdateowners)
		                        	feature:applicationdetails_updatemanager
		                        	tooltip:$fragmentCASafeDetailsNLS.addowner
		                       }
						}
					}
				]
				otherwise [

					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical False hint:height 150 }
						label:Label { break:True }
						configurable:True
						persist-configuration:True
						commands:Commands { position: After orientation: Vertical
										Command{	
												actions:Dialog bwfApplicationDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerType, 
																											inuid to paramApplicationUid),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:Not BooleanPredicate(incanupdateowners)
					                        	feature:applicationdetails_updatemanager
					                        	tooltip:$fragmentCASafeDetailsNLS.addowner
					                       }
										Command{	
												actions:Dialog bwfApplicationDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerTypeCode,
																											selectedManagerLink to paramManagerLinkRecorduid,
																											inuid to paramApplicationUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdateowners)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:applicationdetails_updatemanager 
					                        	tooltip:$fragmentCASafeDetailsNLS.deleteowner
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Application" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdateowners)
					                        	feature:applicationdetails_updatemanager 
					                        	tooltip:$fragmentCASafeDetailsNLS.auditowner
					                       }
					                  }
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column: ManagerLinkRecorduid
							hidden: True 
							selection: selectedManagerLink
						}
						Column {
							column:expertisedomaincode
							hidden:True
							selection:selectedExpertiseDomain
						}
						Column {
							column:expertisedomaindisplayname
							text: Transform Current expertisedomaincode using bwfManagerTypeMapping
							header:$bwfManagement.type
							sortable:True
							width:140px
						}
						Column {
							column:hrcode
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$identity.hrcode
							initially-masked:True
							sortable:True
						}
						Column {
							column:fullname
							header:$identity.fullname
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							sortable:True
							width:100%
						}
						Column {
							column:internal
							header:$pidentity.internal
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:active
							header:$pidentity.active
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
				
				
						Column {
							column:comment
							header:$bwfManagement.comment
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegation
							header:$bwfManagement.delegated
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegationreason
							header:$bwfManagement.^reason
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:_priority
							header:$bwfManagement.^priority
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:startdate
							header:$bwfManagement.startdate
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:enddate
							header:$bwfManagement.enddate
							//styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
					}
				]
			}
		}
	}	
	
}

/**
 * Edit safe tags
 *
 * @param uid safe uid
 * @param canupdatetags True to enable tags update (false by default)
 */
fragmentSafeTagsEditor = Dialog {
	title:$fragmentApplicationTagsEditorNLS.title
	buttons:[	CancelButton 
				OkButton {
					disabled:Not BooleanPredicate(canupdatetags)
					actions:
							BooleanCase(added) {
								when True then [
								]
								when False then [
									Set currenttags to task.tags,
									Set uid to task.uid,
									TaskComplete task wait-end,
									Flash $fragmentApplicationTagsEditorNLS.flash
								]
							}
				} 
			]
	width:450
	height:200
	enter-event:TransferData tags(tag) to (currenttags), TransferData alltags(tag) to (alltags) 
	
	uid = Variable
	canupdatetags = Variable { type:Boolean initial:False }

	currenttags = Variable { multivalued:True private:True }
	alltags = Variable { multivalued:True private:True }
	newtag = Variable {private:True }
	modified = Variable {private:True }
	added = Variable {private:True }
	
	tags = Dataset {
		view:bwf_safetags with uid to uid
	}
	alltags = Dataset {
		view:bwf_safealltags
	}
	
	atags = Dataset {
		columns:alltags as tag
	}

	task = TaskRecord(create "bwa_updateapplicationtags" in-timeslot PageTimeslot.PrevUID)

	Combo {
		variable:currenttags
		multi-selection:True
		disabled:Not BooleanPredicate(canupdatetags)
		options:Dynamic {
			data:atags
			text:Current tag
			value:Current tag
		}
		commands:Commands {
			position:After
			orientation:Vertical
			Command {
				actions:Set True to added,
						Dialog fragmentSafeNewTag(uid to uid, alltags to alltags, newtag from newtag), 
						CloseDialog Ok
				icon:%status_16.add
				disabled:Not BooleanPredicate(canupdatetags)
				tooltip:$fragmentApplicationTagsEditorNLS.newtag
			}
			Command {
				actions:Message "NOP"
				disabled:True
				icon:''
			}
		}
	}	
}

/*
 * INTERNAL dialog box used by fragmentApplicationTagsEditor
 * 
 * @param 
 */
fragmentSafeNewTag = Dialog {
	title:$fragmentApplicationTagsEditorNLS.addtitle
	width:400
	height:150
	enter-event:Set Join alltags using "|" to alltagsoneline
 	buttons:[CancelButton OkButton {
			disabled:
				OrPredicate {
					Not BooleanPredicate(valid)
					BooleanPredicate(Eval "alltags.indexOf(newtag.get().toUpperCase())!=-1")
				}
			actions:
				TransferData tags(tag) to (tags),
				MultivaluedAdd Eval "newtag.get().toUpperCase()" to tags,
				 Set tags to task.tags,
					Set uid to task.uid,
					TaskComplete task wait-end,
					Flash $fragmentApplicationTagsEditorNLS.flash
			}
		]

	uid = Variable
	alltags = Variable { multivalued:True }
	newtag = Variable

	alltagsoneline = Variable { multivalued:False private:True }
	valid = Variable { private:True }
	tags = Variable { multivalued:True private:True }

	tags = Dataset {
		view:bwf_safetags with uid to uid
	}
	
	task = TaskRecord(create "bwa_updateapplicationtags" in-timeslot PageTimeslot.PrevUID)

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentApplicationTagsEditorNLS.addsyntaxerror
		validity:valid
	}	
}