/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/resources/access360_nls.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

/* Nationalized labels here */
access360r_safe_accessgroupscs360NLS = NLS {
	title [en "Access Group Analysis" fr "Analyse des groupes donnant accès"]
	dyntitle [en "Safe {0} Access Group Analysis" fr "Analyse des groupes donnant accès pour {0}"]
	safe [en "Safe" fr "Safe"]
	rep [en "Repository" fr "Référentiel"]
	job [en "Job" fr "Métier"]
	description [
		en "This report presents the groups giving access to the safe in a pivot table. Only the parent groups are displayed associated with their active accounts from any sub-groups. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right click on the table to do so."
		fr "Ce rapport présente les groupes donnant accès au Safe sous la forme d'un tableau croisé dynamique. Seuls les groupes parents sont considérés associés à leur comptes actifs et ceux de leur sous-groupes. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela."
		]
	}

access360r_safe_accessgroups360cs = Page {
	title: $access360r_safe_accessgroupscs360NLS.title
	dynamic-title: $access360r_safe_accessgroupscs360NLS.dyntitle(safe.displayname)
	description:$access360r_safe_accessgroupscs360NLS.description
	tags: "safe" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwpam_safegroupscs
	mixins: simpleReport	

	/* Parameters here */
    uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	selectedgroupuid = Variable
	selectedaccountuid = Variable
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	safe = Record {
		view:bwpam_casafeDetail with uid to uid
	}

	rights = Dataset {
		view:bwaccess360r_safe_groupscs with uid to uid, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}


	showAccountDetails = NamedAction (
		Dialog bwf_accountDetailsDialog(
			selectedaccountuid to inuid,
			True to inshowowner,
			True to inshowgroups,
			True to incanreconcile
		)
	)

	showGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(
			selectedgroupuid to inuid,
			True to inshowaccounts,
			True to inshowperjob,
			True to inshowperorg
		)
	)
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:rights
					multi-selection:True
					cluster-sortable: True
					cluster-keep-sort-on-change: True
					user-configurable: True
					swappable: True
					layout:Layout {cell-width:64px  grab: horizontal True vertical True}
					columns:Dim {value:repuid label:repdisplayname header:$access360r_safe_accessgroupscs360NLS.rep},Dim {value:grpuid label:grpdisplayname header:$group.concept header-click:selectedgroupuid},Dim {value:permissionuid label:permissiondisplayname header:$permission.concept} 
					rows:Dim {value:orguid label:orgdisplayname header:$organisation.concept},Dim {value:jobtitledisplayname label:jobtitledisplayname header:$access360r_safe_accessgroupscs360NLS.job initially-masked: True},Dim {value:owneruid label:ownerfullname header:$identity.fullname},Dim {value:uid label:login header:$account.login header-click:selectedaccountuid}
					column-header-click:ExecuteNamedAction showGroupDetails
					row-header-click:ExecuteNamedAction showAccountDetails
					cell-content:CellContent {text: Current status cluster-value:'X' styling:StringStyling(Current status) { when 'New' then aartimeline_highlightnew360 when 'Removed' then aartimeline_highlightremoved360 }}
				
				}
			}
		}
	}
}
