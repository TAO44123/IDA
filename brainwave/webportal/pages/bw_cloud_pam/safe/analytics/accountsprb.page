/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
//import "/webportal/pages/bw_cloud_pam/permission/CApermissionDetails.page"
import "/webportal/pages/bw_fragments/control/details/controlDetails.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_cloud_pam/safe/analytics/resources.page"
import "/webportal/pages/bw_cloud_pam/safe/search.page"
import "/webportal/pages/bw_cloud_pam/safe/fragments/safeDetails.page"
import "/webportal/pages/bw_cloud_pam/vault/fragments/vaultDetails.page"
import "/webportal/pages/bw_cloud_pam/resources/pamuserDetails.page"
import "/webportal/pages/bw_cloud_pam/resources/pamidentityDetails.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ""
	otherwise current
}

analytics_safe_usersprbNLS = NLS {
	title [en "Active User List with Control Defects" fr "Liste des utilisateurs actifs ayant des défauts de contrôle"]
	directrightsonly [en "only direct rights" fr "seulement les droits directs"]
	description [
		en "This report lists the safe users with control defects. Only active users are taken into account. It is possible to identify only changes that have occurred since a given date. It is possible to modify the columns or to export the results. You can also filter on user types such as 'Built-in Users', 'AIM Accounts', 'EPV Users' and so on."
		fr "Ce rapport liste les utilisateurs ayant des défauts de contrôle des safes. Seuls les utilisateurs actifs sont pris en compte. Il est possible d'identifier uniquement les changements survenus depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats. Il est également possible de filtrer par type d''utilisateur tel que 'Built-in Users', 'AIM Accounts', 'EPV Users' etc."
	]
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
	empty [ en "You must pick at least one control in the list" fr "Vous devez sélectionner au moins un contrôle dans la liste"]

	risklevel [en "Risk level" fr "Niveau de risque"]
	riskinfo [en "Risk info" fr "Informations sur le risque"]
	suggestedmitigation [en "Suggested mitigation" fr "Remédation suggérée"]

	controlscope [en "Control scope" fr "Portée du controle"]
	minimumrisklevel [en "Minimum risk level" fr "Niveau de risque minimum"]
}

analytics_safe_usersprb= Page {
	title: $analytics_safe_usersprbNLS.title
	description: $analytics_safe_usersprbNLS.description
	feature:bwpam_safeusersprb
	tags: "ca_safe", "searchresults"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	mixins: simpleReport	
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						minimumrisklevel inline,
						controlscope inline,
						controls inline,
						includebuiltin inline
		}

		Spacer {
			height:Fill
		}
		
//		Button {
//			actions:Dialog access360analytics_application_FilterEdition(SerializeSearch search to applicationSearch)
//			text:$access360analytics_resourcesNLS.displayfilterbutton
//			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
//		}
		Button {
			actions:GoTo Activity CASafe Search with SerializeSearch search to casafeSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	controls = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		type:String
		label:$pcontrolresult.controldisplayname
		constraint:Lookup {
			data:controlslist
			text:Current controldisplayname
			value:Current controlcode
		}
	}
	controlscope = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		type:String
		label:$analytics_safe_usersprbNLS.controlscope
		constraint: Choice {
			values:["Account","Identity"]
		}
	}
	minimumrisklevel = Parameter {
		label:$analytics_safe_usersprbNLS.minimumrisklevel
		hidden:False
		mandatory:False
		multivalued:False
		type:Integer
		constraint: Choice {
			values:[
				'':' ',
				4:$bwf_ControlLevel_NLS._4,
				3:$bwf_ControlLevel_NLS._3,
				2:$bwf_ControlLevel_NLS._2,
				1:$bwf_ControlLevel_NLS._1,
				0:$bwf_ControlLevel_NLS._0
			]
		}
	}
	includebuiltin = Parameter {
		type:Boolean
		default:False
		label:$analytics_resourcesNLS.includebuiltin_label
		tooltip:$analytics_resourcesNLS.includebuiltin_tooltip
	}
	search = SearchDefinition {
		entity: CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}
	
		
	/* Variables here */
	inpermissiontypes = Variable { multivalued:True initial:NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") }

	outsafeuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outuseruid = Variable
	outcontrolcode = Variable
	outvaultuid = Variable

//	applications = Variable { multivalued:True }

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	accounts = Dataset {
		search: Search {
			view:bwpam_casafeusersctrl_bv with comparisontimeslot to comparisontimeslot unless-empty, controlscope to controlscope unless-empty, minimumrisklevel to minimumrisklevel unless-empty, controls to controls, exclRemoved to excluderemoved, exclSimilar to excludesimilar, includebuiltin to includebuiltin
			definition:search
		}
/*
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(exclSimilar)
			}
		}
 */
		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	controlslist = Dataset {
		view:access360r_applicationctrllist
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	goSafeDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_casafeDetailsDialog ( outsafeuid to inuid )
			]
			when False then [
			
			]
		}
	)
	
	goVaultDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_cavaultDetailsDialog ( outvaultuid to inuid )
			]
			when False then [
			
			]
		}
	)	
	
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwpam_identityDetailsDialog(outidentityuid to inuid,
												outsafeuid to inapplicationuids,
												True to inshowapplications				
				)
			]
			when False then [
			
			]
		}
	)

	goUserDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwpam_userDetailsDialog(outuseruid to inuid, 
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowowner,
												True to inshowcontrols
				)
			]
			when False then [
			
			]
		}
	)

	goControlDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_controlDetailsDialog(outcontrolcode to incontrolcode, outuseruid to inaccountuid, outidentityuid to inidentityuid)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Header {
					value:$analytics_safe_usersprbNLS.empty				
					hidden:StringPredicate(controls) { when IsEmpty then False otherwise True }
				}
				PaginatedTable {
					data:accounts
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					page-size:1000
					//show-count:True
					show-filter:True
					persist-configuration:True
					show-count-button: True
					
					Column {
						column:identityuid
						hidden:True
						selection:outidentityuid
					}
			
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 when 'Invalid' then tartimeline_highlightremoved360 } text:Transform Current status using tarmapping360 }
			
					Column {
						column:controlentity
						header:$analytics_safe_usersprbNLS.controlscope
						width:120px
						sortable:True
					}

					Column {
						column:identityhrcode
						header:$identity.hrcode
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
						
						actions: ExecuteNamedAction goIdentityDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:identityfullname
						header:$identity.fullname
						sortable:True
						filterable:True
						width:160px
						
						actions: ExecuteNamedAction goIdentityDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:identitymail
						header:$identity.mail
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
					Column {
						column:identityinternal
						header:$identity.internal
						sortable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:identityarrivaldate
						header:$identity.arrivaldate
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:identitydeparturedate
						header:$identity.departuredate
						sortable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:orgshortname
						header:$porganisation.shortname
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:orgdisplayname
						header:$organisation.concept
						sortable:True
						width:160px
						initially-masked:True
					}
			
					Column {
						column:accountuid
						hidden:True
						selection:outuseruid
					}
					Column {
						column:UserType
						header:$analytics_resourcesNLS.type
						sortable:True
						filterable:True
						width:100px
					}						
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						width:128px
						
						actions: ExecuteNamedAction goUserDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:accountusername
						header:$paccount.username
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
						
						actions: ExecuteNamedAction goUserDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:reconnoownercode
						header:$reconciliation.status.noowner
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:reconleavedate
						header:$reconciliation.leavedate
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column: safeuid
						hidden: True
						selection: outsafeuid
					}
					Column {
						column:safecode
						header:$casafeSearchPageNLS.safe.code
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
						
						actions: ExecuteNamedAction goSafeDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
						
					}
					Column {
						column:safedisplayname
						header:$casafeSearchPageNLS.safe
						sortable:True
						filterable:True
						width:160px
						
						actions: ExecuteNamedAction goSafeDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}

					Column {
						column:controlcode
						selection:outcontrolcode
						hidden:True
					}
					Column {
						column:controldisplayname
						header:$pcontrolresult.controldisplayname
						sortable:True
						filterable:True
						width:100%

						actions: ExecuteNamedAction goControlDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:risklevel
						header:$analytics_safe_usersprbNLS.risklevel
						image:TemplateImageSelection(Current risklevel) using bwf_controllevel
						width:120px
						sortable:True
					}
					Column {
						column: vaultuid
						hidden: True
						selection: outvaultuid
					}					
					Column {
						column:vaultdisplayname
						header:$casafeSearchPageNLS.vault
						sortable:True
						filterable:True
						width:160px
						
						actions: ExecuteNamedAction goVaultDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}					
				}
			}
		}	
	}
}
