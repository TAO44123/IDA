safeglossary360 = Page {
	title: $safeglossary360NLS.title
	tags: "ca_safe", "searchresults"
	feature:bwpam_safeglossary		
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	description:$safeglossary360NLS.description

	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	search = SearchDefinition {
		entity: CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}	
	
	/* Variables here */
	selectedsafes = Variable { multivalued:True }
	selectedsafe = Variable
	selectedsafesensitivitylevel = Variable
	selectedsafesensitivityreason = Variable
	selectedsafedescription = Variable
	selectedsafecategory = Variable
	incanshowdetails = Variable { initial:True type:Boolean }	
	
	onlyemptydescription = Variable { initial:False type:Boolean }
	
	/* Datasets and records here */

	managedsafes = Dataset {
		view:enduser360_managedsafe with uid to uid
	}
	safemetadata = Dataset {
		search: Search {
			view:bwpam_safesmetadata with onlyemptydescription to withoutdescriptiononly /* UserVariable session_selectedApplicationsTeam360 to uid */
			definition: search
		}
		excludes:BooleanPredicate(False) /* Contournement de bug produit */

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]		
		
	}
	
	goSafeDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_casafeDetailsDialog ( selectedsafe to inuid )
			]
			when False then [
			
			]
		}
	)
	
	editsafe = NamedAction (
		Dialog bwfSafeDetailsMetadata_Dialog (		selectedsafe to paramSafeUid,
													selectedsafesensitivitylevel to sensitivitylevel,
													selectedsafesensitivityreason to sensitivityreason,
													selectedsafedescription to description,
													selectedsafecategory to category), 
												ReloadData (safemetadata)	
	)
	
	batcheditsafe = NamedAction (
		Dialog bwfSafeDetailsBatchMetadata_Dialog(selectedsafes to safes), 
												ReloadData (safemetadata)	
	)
	
	/* Page content */

	Grid {
		columns:GridColumn { fill:True width: grow }, GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 38 }
		GridRow {
			GridCell {
				ButtonGroup {
					Button {
						actions:ExecuteNamedAction batcheditsafe
						text:$safeglossary360FragmentNLS.bulk
			            image:%collection_16.pencil
			            disabled:StringPredicate(selectedsafes) { when IsEmpty then True otherwise False }
					}
				}
			}
			GridCell {
				Checkbox {
					variable:onlyemptydescription
					text:$safe_accessrights360NLS.onlyempty
				}
			}
		}
	}
	Table {
		data:safemetadata
		layout: Layout { grab: horizontal True vertical True }
		show-count:True
		show-filter:True
		configurable:True
		double-click:ExecuteNamedAction goSafeDetails
		checkboxes:safeuid to selectedsafes

		Column {
			column:safedisplayname
			tooltip:Current safedisplayname
			header:$casafeSearchPageNLS.safe
			width:260px
			filterable:True
			sortable:True
			align:Right
			actions:ExecuteNamedAction editsafe
			
		}
		Column {
			column:safecategory
			header:$analytics_safe_safeglossary360NLS.safecategory
			width:160px
			filterable:True
			sortable:True
			align:Right
			initially-masked:False
			selection:selectedsafecategory	
		}		
		Column {
			column:safesensitivitylevel
			text:Transform Current safesensitivitylevel using bwfApplicationSensitivityLevelMapping
			header:$application.sensitivitylevel
			width:160px
			filterable:True
			sortable:True
			align:Right
			selection:selectedsafesensitivitylevel
		}
		Column {
			column:safesensitivityreason
			tooltip:Current safesensitivityreason
			header:$application.sensitivityreason
			width:200px
			filterable:True
			sortable:True
			align:Right
			selection:selectedsafesensitivityreason
			initially-masked:True
		}
		Column {
			column:safedescription
			tooltip:Current safedescription
			header:$application.description
			width:100%
			filterable:True
			sortable:True
			align:Left
			selection:selectedsafedescription
		}
		Column {
			column:safeuid
			hidden:True
			selection:selectedsafe
		}
		Column {
			column:vaultdisplayname
			tooltip:Current vaultdisplayname
			header:$casafeSearchPageNLS.vault
			width:160px
			filterable:True
			sortable:True
			align:Right
		}		
	}
	Text {
		value:$safeglossary360FragmentNLS.limit
		compact:True
		styling:warningFieldStyle
		hidden:IntPredicate(Count safemetadata) { when =1000 then False otherwise True }
	}
	
	ButtonGroup { align: Right 
		Button {
			disabled: StringPredicate(selectedsafe) { when IsEmpty then True otherwise False }
			actions: ExecuteNamedAction goSafeDetails
			text:$safeglossary360NLS.safedetaildialog
			tooltip:$safeglossary360NLS.safedetaildialog.tooltip
			layout:Layout { grab:horizontal True vertical False }
		}	
		Button {
			actions:GoTo Activity CASafe Search with SerializeSearch search to casafeSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}	
	}
}

