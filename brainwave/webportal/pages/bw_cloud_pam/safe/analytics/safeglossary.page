		Dialog bwfSafeDetailsMetadata_Dialog (	selectedsafe to paramPermissionUid,
												selectedsafesensitivitylevel to sensitivitylevel,
												selectedsafesensitivityreason to sensitivityreason,
												selectedsafedescription to description,
												selectedsafecategory to category), 
											ReloadData (safemetadata)	
	)
	
	batcheditsafe = NamedAction (
		Dialog bwfSafeDetailsBatchMetadata_Dialog(selectedsafes to safes), 
												ReloadData (safemetadata)	
	)
	
	/* Page content */

	Flow {
		disposition:Horizontal
		layout: Layout { grab: horizontal True vertical False hint: height 110 }
		Group {
			Text {
				label:$application.code
				value:application.code
				compact:True
			}
			Text {
				label:$application.displayname
				value:application.displayname
				compact:True
			}
			Text {
				label:$application.applicationfamily
				value:application.applicationfamily
				compact:True
			}
		}
		Group {
			Text {
				label:$fragmentApplicationDetailsNLS.category
				value:application.category
				compact:True
			}
			Text {
				label:$application.sensitivityreason
				value:application.sensitivityreason
				compact:True
			}
			Text {
				label:$application.sensitivitylevel
				value:Transform application.sensitivitylevel using bwfApplicationSensitivityLevelMapping
				compact:True
			}
			Text {
				label:$application.description
				tooltip:application.description
				value:application.description
				compact:True
					commands:Commands { position: After orientation: Horizontal 
									Command{	actions:Dialog bwfApplicationDetailsMetadata_Dialog(applicationuid to paramApplicationUid, application.sensitivitylevel to sensitivitylevel, 
																									application.sensitivityreason to sensitivityreason, 
																									application.description to description, 
																									application.category to category,
																									application.applicationtype to applicationtype), 
														ReloadData (application)
					                        	icon:%collection_16.pencil
					                        	tooltip:$fragmentApplicationDetailsNLS.updatemetadata
					                       }
					                  }
			}
		}
	}
