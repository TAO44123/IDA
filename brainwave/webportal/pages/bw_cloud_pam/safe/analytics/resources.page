/* Import other pages here */
import "/webportal/pages/bw_cloud_pam/safe/search.page"

/* Nationalized labels here */
analytics_resourcesNLS = NLS {
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
	back [en 'Go back to search page' fr 'Retour à la page de recherche']
	back_tooltip [ en 'Clic on this button to go back to the search page\nyou will be able to browse the results\nrefine your search criterias\nor to select another analytics'
				   fr 'Cliquez sur ce bouton pour retourner sur la page de recherche\nvous pourrez alors parcourir les résultats\naffiner les critères de recherche\nou choisir une autre analyse'
	]
	localfiltertitle [en "Comparison and filtering" fr "Comparaison et filtrage" ]
	localfiltertooltip [ en "Use this parameters to refine your results\nand highlight the differences with a comparison timeslot"
						 fr "Utilisez ces paramètres pour affiner les résultats de cette analyse\net mettre en évidence les changements par rapport à une date de référence"
	]
	
	displayfilterbutton [ en "Search filter" fr "Filtre de recherche"]
	displayfiltertooltip [ en "Shows the search filter applied for this analytics" fr "Affiche le filtre de recherche appliqué pour cette analyse"]

	filtereditiontitle [en "Applied filter" fr "Filtre appliqué" ]
	
	includebuiltin_label [en "Include built-in users" fr "Inclure les utilisateurs built-in"]
	includebuiltin_tooltip [en "Include CyberArk built-in users such as breakglass account" fr "Inclure les utilisateurs built-in tels que le compte brise glace"]	
	
	type [en"User Type" fr"Type d''utilisateur"]
}

analytics_safe_FilterEdition = Dialog {
	title:$analytics_resourcesNLS.filtereditiontitle
	width:1024
	height:300
	
	safeSearch = SearchDefinition {
		entity: CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}
	output = Variable
	
	SearchEdition {
		definition: safeSearch
		read-only:True
		layout: Layout { grab: horizontal True vertical False }
		simple-mode-columns: 2
		simple-mode-layout: SimpleModeLayout {
				vault { label: $casafeSearchPageNLS.vault },
				safe { label: $casafeSearchPageNLS.safe }
		}
	}
}
