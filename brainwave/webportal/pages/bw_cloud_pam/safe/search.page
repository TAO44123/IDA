/*
 * Bulk add a new tag for applications
 * 
 * @param uids selected applications
 */
fragmentSafeBulkAddTag = Dialog {
	title:$fragmentApplicationTagsEditorNLS.addtitle
	width:400
	height:200
 	buttons:[CancelButton OkButton {
			disabled:
					OrPredicate {
						AndPredicate {
							Not BooleanPredicate(createtag)
							StringPredicate(existingtag) { when IsEmpty then True }
						}
						AndPredicate {
							BooleanPredicate(createtag)
							Not BooleanPredicate(valid)
						}
					}
			actions:
					Confirm $fragmentApplicationTagsEditorNLS.addconfirmation(SizeOf uids),
					BooleanCase(createtag) {
						when True then [
							Set Eval "newtag.get().toUpperCase()" to task.tag
						]
						when False then [
							Set existingtag to task.tag
						]
					},
					Set uids to task.uids,
					TaskComplete task
			}
		]

	uids = Variable

	newtag = Variable {private:True}
	existingtag = Variable {private:True}
	valid = Variable {private:True}
	createtag = Variable { type:Boolean }
		
	task = TaskRecord(create "bwa_bulkaddapplicationtag" in-timeslot PageTimeslot.PrevUID)
	alltags = Dataset {
		view:bwf_safealltags
	}

	Checkbox {
		variable:createtag
		text:$fragmentApplicationTagsEditorNLS.createnewtag
	}

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentApplicationTagsEditorNLS.addsyntaxerror
		validity:valid
		hidden:Not BooleanPredicate(createtag)
	}
	Combo {
		variable:existingtag
		allow-none:False
		options:Dynamic {
			data:alltags
			text:Current tag
			value:Current tag
		}
		hidden:BooleanPredicate(createtag)
	}
}

/**
 * Remove a tag from selected applications
 * 
 * @param uids application uids
 */
fragmentSafeBulkRemoveTag = Dialog {
	title:$fragmentSafeTagsEditorNLS.removetitle
	width:500
	height:150
 	buttons:[CancelButton OkButton {
			disabled:StringPredicate(tag) { when IsEmpty then True }
			actions:
				Set uids to task.uids,
				Set tag to task.tag,
				TaskComplete task
			}
		]

	applicationSearch = SearchDefinition {
		entity: CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}

	uids = Variable { multivalued:True }
	tag = Variable { multivalued:False }

	task = TaskRecord(create "bwa_bulkremoveallapplicationtag" in-timeslot PageTimeslot.PrevUID)
	taglist = Dataset {
		search: Search {
			definition: applicationSearch
			view: bwa_safetagsfromsearch
		}
	}
	
	Combo {
		variable:tag
		allow-none:True
		label:Label { break:True value:$fragmentApplicationTagsEditorNLS.removepicker }
		options:Dynamic {
			data:taglist
			text:Current tag		
			value:Current tag		
		}
	}
}

/**
 * Remove all tags from selected applications
 * 
 * @param uids application uids
 */
fragmentSafeBulkRemoveAllTags = Dialog {
	title:$fragmentSafeTagsEditorNLS.removealltitle
	width:500
