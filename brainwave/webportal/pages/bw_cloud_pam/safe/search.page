casafeSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

casafeSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

casafeSearchPage = Page {
	title: $casafeSearchPageNLS.title
	tags: "ca_safe" , "conceptsearch" priority 250
	icon: %pam_cyberark_concepts_32.safe
	large-icon: %pam_cyberark_concepts_48.safe
	description: $casafeSearchPageNLS.title
	
	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	casafeSearch = SearchDefinition {
		entity: CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedSafeUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	casafeanalytics = Dataset {
		pages: Pages{tags: "ca_safe" and "searchresults" }
		count-variable:nbanalytics
	}
	
	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}
	
	casafeData = Dataset {
		search: Search {
			definition: casafeSearch
			view: brpam_casafe_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, UserVariable casafeSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	casafeData_count = Dataset {
		search: Search {
			definition: casafeSearch
			view: brpam_casafe_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	
	
	goDetails = NamedAction (
		GoTo Activity CASafe ( ca_safe ) Detail with selectedSafeUid to paramSafeUid
	)
	
	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: casafeSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			simple-mode-layout: SimpleModeLayout {
				vault { label: $casafeSearchPageNLS.vault },
				safe { label: $casafeSearchPageNLS.safe }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: casafeData
//					show-count: True
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size:1000
			show-count-button: True				
			
			Column {
				column: uid
				hidden: True
				selection: selectedSafeUid
			}
			
			Column {
				column: vault_displayname
				sortable:True
				header: $casafeSearchPageNLS.table.columns.vaultname
				width: 50%
				
				initially-masked: False
				//actions: ExecuteNamedAction goDetails
			}
			
			
			Column {
				column: displayname
				sortable:True
				header: $casafeSearchPageNLS.table.columns.safename
				width: 100%
				
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}

			Column {
				column: description
				sortable:True
				header: $casafeSearchPageNLS.table.columns.safedescription
				width: 100%	
				initially-masked: True
			}
			
			Column {
				column: isnew
				text:Transform Current isnew using booleanDisplayMapping		
				header: $searchlabel.isnew
				width: 100px
				styling:BooleanStyling(Current isnew) { when True then casafeSearchPage_highlightnew when False then default }				
				initially-masked: True
			}
			Column {
				column:bw_pam_safemetrics_nb_secrets
				text:Transform Current bw_pam_safemetrics_nb_secrets using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$casafeSearchPageNLS.metrics_nb_secrets
				image:TemplateImageSelection(Eval "(''+current.prev_bw_pam_safemetrics_nb_secrets).equals('null')?956487965:current.bw_pam_safemetrics_nb_secrets-current.prev_bw_pam_safemetrics_nb_secrets") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current bw_pam_safemetrics_nb_secrets using mayBeNullMapping, Transform Current prev_bw_pam_safemetrics_nb_secrets using mayBeNullMapping)
				align:Left
