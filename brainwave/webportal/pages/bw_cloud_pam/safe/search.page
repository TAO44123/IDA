		Grid {
			columns:GridColumn,GridColumn { width: grow }
			layout: Layout { grab:horizontal True vertical False hint: height 38 }
			GridRow {
				GridCell {
					Checkbox {
						variable:UserVariable casafeSearchPage_withtrends
						text:$search.showkpitrends
					}
				}			
				GridCell {
				ButtonGroup {
					align:Right
					Button {
						actions: IntCase(Count casafeData_count)	{
										when > NonEmpty(ConfigurationVariable "search_share_analyticserrorthreshold", Constant search_share_analyticserrorthreshold) then [
											Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_share_analyticserrorthreshold", Constant search_share_analyticserrorthreshold))
										]
										when > NonEmpty(ConfigurationVariable "search_share_analyticswarningthreshold", Constant search_share_analyticswarningthreshold) then [
											Confirm $search.analyticswarningthreshold(Count casafeanalytics),
											GoTo Page casafeSearchAnalyticsPage with  SerializeSearch casafeSearch to search
												
										]
										otherwise [
											GoTo Page casafeSearchAnalyticsPage with  SerializeSearch casafeSearch to search
										]
									}
						text:$search.applyanalytics
						tooltip:$search.applyanalyticstooltip
						image:%report_16.analytics
						feature:safesearch_analytics
						disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
					}
			
					Button {
						actions:	TransferData casafeData(uid) to (uids), 
									Dialog fragmentSafeBulkAddTag(uids to uids),
									Flash $search.flashaddingatag
						text:$fragmentSafeTagsEditorNLS.addingatag
						image:%collection_16.tag
					}
					Button {
						actions:	TransferData casafeData(uid) to (uids), 
									Dialog fragmentSafeBulkRemoveTag(uids to uids, SerializeSearch casafeSearch to applicationSearch),
									Flash $search.flashremovingatag
						text:$fragmentSafeTagsEditorNLS.removingatag
						image:%collection_16.tag
					}
					
					Button {
						actions:	TransferData casafeData(uid) to (uids), 
									Dialog fragmentSafeBulkRemoveAllTags(uids to uids),
									Flash $search.flashremovingalltag
						text:$fragmentSafeTagsEditorNLS.removingalltag
						image:%collection_16.tag
					}

				}
			}
		}
	}
}


casafeSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity:CASafe
		simple-mode-rule: brpam_casafe_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "ca_safe" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
