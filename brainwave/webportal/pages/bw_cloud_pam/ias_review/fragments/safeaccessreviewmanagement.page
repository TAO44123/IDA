bwir_safeaccountreviewmanagementPerimeterTable = PageFragment {
	campaignid = Variable
	campaignname = Variable { type: String }	
	filterbyreviewstatus = Variable { multivalued:True }
	filterbyrepositories = Variable { multivalued:True }
	revieweruid = Variable
	reviewername = Variable
	accountableuid = Variable
	accountablename = Variable
	
	incanshowdetails = Variable { initial:True type:Boolean }	
	incanfilterbystatus = Variable { initial:False type:Boolean}	
	incanfilterbyrepository = Variable { initial:True type:Boolean}	
	incanfilterbyaccount = Variable { initial:True type:Boolean}	
	inenabled = Variable { initial:False type:Boolean }	
	intimestamp = Variable

	outidentityuid = Variable
	outaccountuid = Variable

	selectedentries = Variable { multivalued:True }
	delegatedentries = Variable { multivalued:True }

	updatestatus = Variable { type:Boolean }
	statustowrite = Variable
	updatecomment = Variable { type:Boolean }
	commenttowrite = Variable
	changeaccountable = Variable

	newrevieweruid = Variable
	newreviewername = Variable

	selectedrevieweruid = Variable { type: String }
	
	reviewcount = Variable

	reportname = Variable { type: String }
	
	editablereview = Dataset {
		view: bwir_safeusersforcampaign with
			campaignid to campaignid unless-empty,
			filterbyreviewstatus to filterbyreviewstatus unless-empty,
			revieweruid to revieweruid unless-empty,
			accountableuid to accountableuid unless-empty,
			filterbyrepositories to filterbyrepositories unless-empty,
			$bwaccess360_accessreviewmanagementNLS.onbehalfof to delegationtext,
			$bwaccess360_review.reviewerAbsent to reviewergonetext,
			False to compliancereportmode,
			[1,2] to excludeexplicitstatus,
			intimestamp to dummy
		limit: 2000
		disabled:
			Not BooleanPredicate(inenabled)
	}
	countreview = Dataset {
		view:bwir_safeaccessrightsforcampaign with 	campaignid to campaignid unless-empty,
			[1,2] to excludeexplicitstatus,
			intimestamp to dummy
		disabled:Not BooleanPredicate(inenabled)
		count-variable:reviewcount
	}

	finalizedreview = Record {
		view:bwaccess360_accessreviewcampaignsfinalized with campaignid to campaignid
		disabled:Not BooleanPredicate(inenabled)
	}

	reviewers = Dataset {
		view:bwaccess360r_applicationreviewers with	campaignid to campaignid
		disabled:Not BooleanPredicate(inenabled)
	}
	accountables = Dataset {
		view:bwaccess360r_applicationaccountables with	campaignid to campaignid
		disabled:Not BooleanPredicate(inenabled)
	}
	repositories = Dataset {
		view:bwaccess360r_repositorylist with	campaignid to campaignid
		disabled:Not BooleanPredicate(inenabled)
	}

	delegatedEntries = Dataset {
		view:bwaccess360_delegatedentries with selectedentries to recorduid
		disabled:Not BooleanPredicate(inenabled)
	}

	task = TaskRecord( create "bwaccess360_writeAccessRightsReviewTickets")
	reassigntask = TaskRecord( create "bwaccess360_reassignAccessRightsReviewTickets")
	escalatetask = TaskRecord ( create "bwaccess360_escalateAccessRightsReviewTickets" )
	resetdelegation = TaskRecord( create "bwaccess360_resetDelegationAccessRightReviewTickets")
	markEntryExplicitelyReviewed = TaskRecord( create "bwaccess360_markEntryExplicitelyReviewed")

	goReviewerDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				StringCase ( selectedrevieweruid ) {
					when IsEmpty then []
					otherwise [
						Dialog bwf_identityDetailsDialog(selectedrevieweruid to inuid)
					]
				}
			]
			when False then [
			
			]
		}
	)

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowowner,
												True to inshowdecisionhistory,
												True to inshowcontrols
				)
			]
			when False then [
			
			]
		}
	)

	writeBulkStatus = NamedAction (
		Set selectedentries to task.ticketreviewrecorduid,
		Set [statustowrite repeat SizeOf selectedentries] to task.status,
		Set [commenttowrite repeat SizeOf selectedentries] to task.comment,
		Set [Date.valueLDAP repeat SizeOf selectedentries] to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 300,
		Flash Concat(SizeOf selectedentries, $bwaccess360_accessreviewmanagementPerimeterTable.writeBulkStatus.flash),
		ReloadData (editablereview),
		ReloadData (reviewers)
	)
	
	resetDelegation = NamedAction (
		TransferData delegatedEntries(recorduid) to (delegatedentries),
		IntCase(SizeOf delegatedentries) {
			when >0 then [
				Set delegatedentries to resetdelegation.ticketrecorduid,
				TaskComplete resetdelegation wait-end timeout-seconds 240,  
				ReloadData (reviewers)
			]
		}
	)

	Header {
		value:$bwaccess360_accessreviewmanagementPerimeterTable.thresholdwarning(2000)
		styling:warningFieldStyle
		hidden:
			IntPredicate(reviewcount) { when >2000 then False otherwise True }
	}
	ButtonGroup {
		layout:Layout { align:horizontal Beginning vertical Center }
		nb-inline:2
		hidden:
				StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }

			// reassign button
			Button {
				actions:	Dialog identityPicker(newrevieweruid from outUid, newreviewername from outDisplayname, True to inExcludenomail),
							Dialog bwaccess360_accessmanagementreassignconfirm(SizeOf selectedentries to innbentries,newreviewername to innewreviewername, changeaccountable from outwithaccountable),
							Set "to be reviewed" to statustowrite,
							Set "" to commenttowrite,
							Set True to updatestatus,
							Set True to updatecomment,
							ExecuteNamedAction writeBulkStatus, 
							Set newrevieweruid to reassigntask.reviewer,
							Set selectedentries to reassigntask.ticketreviewrecorduids,
							Set changeaccountable to reassigntask.updateAccountable,
							TaskComplete reassigntask wait-end timeout-seconds 120,
							Flash Concat(SizeOf selectedentries, $bwaccess360_accessreviewmanagementPerimeterTable.bulkreassign.flash, newreviewername),
							Unset selectedentries,
							ReloadData (editablereview),
							ReloadData (reviewers)
				image:"16/audit/identity_16.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreassign.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreassign.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// escalate button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.confirm(SizeOf selectedentries),
							Set selectedentries to escalatetask.ticketreviewrecorduids,
							TaskComplete escalatetask wait-end timeout-seconds 120,
							Flash Concat(SizeOf selectedentries, $bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.flash),
							Unset selectedentries,
							ReloadData (editablereview),
							ReloadData (reviewers)
				image:"16/audit/manager_16.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True when >999 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk approve button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkapproval.confirm,
							Set "ok" to statustowrite,
							Dialog bwaccess360_accessreviewmanagementComment(commenttowrite from comment),
							// reassign entries to the campaign manager
							Set Principal.uid to reassigntask.reviewer,
							Set selectedentries to reassigntask.ticketreviewrecorduids,
							TaskComplete reassigntask wait-end timeout-seconds 120,
							// force status
							Set True to updatestatus,
							Set True to updatecomment,
							ExecuteNamedAction writeBulkStatus, 
							Unset selectedentries
				image:"16/famfamfam_silk_icons_v013/accept.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkapproval.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkapproval.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk revoke button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkremove.confirm,
							Set "revoke" to statustowrite,
							Dialog bwaccess360_accessreviewmanagementComment(commenttowrite from comment),
							// reassign entries to the campaign manager
							Set Principal.uid to reassigntask.reviewer,
							Set selectedentries to reassigntask.ticketreviewrecorduids,
							TaskComplete reassigntask wait-end timeout-seconds 120,
							// force status
							Set True to updatestatus,
							Set True to updatecomment,
							ExecuteNamedAction writeBulkStatus, 
							Unset selectedentries
				image:"16/famfamfam_silk_icons_v013/delete.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkremove.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkremove.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk update button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkupdate.confirm,
							Set "update" to statustowrite,
							Dialog bwaccess360_accessreviewmanagementComment(commenttowrite from comment),
							// reassign entries to the campaign manager
							Set Principal.uid to reassigntask.reviewer,
							Set selectedentries to reassigntask.ticketreviewrecorduids,
							TaskComplete reassigntask wait-end timeout-seconds 120,
							// force status
							Set True to updatestatus,
							Set True to updatecomment,
							ExecuteNamedAction writeBulkStatus, 
							Unset selectedentries
				image:"16/famfamfam_silk_icons_v013/pencil.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkupdate.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkupdate.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk reset button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.confirm,
							// reset delegation
							ExecuteNamedAction resetDelegation,
							// reset status
							Set "to be reviewed" to statustowrite,
							Set "" to commenttowrite,
							Set True to updatestatus,
							Set True to updatecomment,
							ExecuteNamedAction writeBulkStatus, 
							Unset selectedentries
				image:"16/famfamfam_silk_icons_v013/resultset_previous.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						IntPredicate(SizeOf selectedentries) { when >999 then True } // SQL limitation
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk sign off button
			Button {
				actions:	Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulksignof.confim,
							Set True to markEntryExplicitelyReviewed.forcemarkentry,
							Set campaignid to markEntryExplicitelyReviewed.campaignid,
							Set selectedentries to markEntryExplicitelyReviewed.reviewtickets,
							Set Principal.uid to markEntryExplicitelyReviewed.currentreviewer,
							TaskComplete markEntryExplicitelyReviewed wait-end timeout-seconds 300,
							Unset selectedentries, 
							ReloadData (editablereview)
							
				image:"16/famfamfam_silk_icons_v013/resultset_next.png"
				text:$bwaccess360_accessreviewmanagementPerimeterTable.bulksignof.text
				tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulksignof.tooltip
				disabled:
					OrPredicate {
						StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						IntPredicate(SizeOf selectedentries) { when =0 then True }
						Not FeaturePredicate iasr_canmanagecampaignentries
					}
			}
			// bulk comment button
			Button {
