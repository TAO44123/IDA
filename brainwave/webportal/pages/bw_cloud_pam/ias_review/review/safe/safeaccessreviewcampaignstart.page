		GridRow {
			GridCell {
				Text {
					value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1.warning(gettotalnbrights.totalnbrights)
					styling:warningFieldStyle
					layout: Layout { grab: horizontal True vertical True align:vertical Center horizontal Beginning hint:width 400 }
					hidden:
						OrPredicate {
							BooleanPredicate(advancedmode) // hidden if advanced mode is selected as we consider that it is filtered...
							IntPredicate(gettotalnbrights.totalnbrights) { when <Constant access360analytics_safeaccessrightsmaxentries then True when InvalidInteger then True otherwise False }
						}
				}			
			}		
			GridCell {
				ButtonGroup {
					align:Right 
					Button {
						actions:GoTo //BackInHistory 
						Page replace-history bwir_cloud_pam_accessrightsreviewcampaignconfiguration with
									selectedsafes to param_safelist,
									includeuseraccounts to param_includeuseraccounts,
									includeorphanaccounts to param_includeorphanaccounts,
									includetechaccounts to param_includetechaccounts,
									includeleaveraccounts to param_includeleaveraccounts,
									includebookingusers to param_includebookingusers,
									includebuiltinusers to param_includebuiltinusers,
									filterbyaccounttag to param_filterbyaccounttag,
//									filterbypermissiontag to param_filterbypermissiontag,
									includelatestreviewstatus to param_includelatestreviewstatus,
									filterifalreadyreviewed to param_filterifalreadyreviewed,
									nbdays to param_nbdays,
									forcehimselfasreviewer to param_forcehimselfasreviewer,
									forcesafeownerasreviewer to param_forcesafeownerasreviewer,
									defaultrevieweruid to param_defaultrevieweruid, 
									reviewerstrategy to param_reviewerstrategy,
									advancedmode to param_advancedmode,
									dynamicmode to param_dynamicmode,
									staticmode to param_staticmode,
									taglist to param_taglist
								
						text:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab2.back
						image:%browsing_16.rewind
					}					
					Button {
						actions:Confirm $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1.previewbutton.tooltip,
								StringCase(reviewerstrategy) {
									// User accounts by the line manager, other accounts by the application owner
									// "All accounts by the application owner"
									when "b" then [
										Set "1" to forcesafeownerasreviewer,
										Set "0" to forcesafeownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer
									]
									when "a" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcesafeownerasreviewer,
										Set "0" to forcesafeownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer
									]
									// User accounts by the line manager, all other accounts by the application owner
									when "d" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcesafeownerasreviewer,
										Set "1" to forcesafeownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer
									]
									// User accounts by themself, all other accounts by the repository owner
									when "e" then [
										Set "1" to forcehimselfasreviewer,
										Set "0" to forcesafeownerasreviewer,
										Set "1" to forcesafeownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer
									]
									// "All accounts by the default reviewer"
									when "c" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcesafeownerasreviewer,
										Set "0" to forcesafeownerforallotheraccounts,
										Set "1" to forcedefaultreviewerasreviewer
									]
								},
								GoTo Page bwir_cloud_pam_accessrightsreviewcampaignpreview with
											safelist to safelist,
											includelatestreviewstatus to includelatestreviewstatus,
											includeleaveraccounts to includeleaveraccounts,
											includebookingusers to includebookingusers,
											includeorphanaccounts to includeorphanaccounts,
											includeuseraccounts to includeuseraccounts,
											includetechaccounts to includetechaccounts,
											includebuiltinusers to includebuiltinusers,
											defaultrevieweruid to defaultrevieweruid,
											param_filterbyaccounttag to filterbyaccounttag,
											filterifalreadyreviewed to filterifalreadyreviewed,
											forcehimselfasreviewer to forcehimselfasreviewer,
											forcesafeownerasreviewer to forcesafeownerasreviewer,
											forcesafeownerforallotheraccounts to forcesafeownerforallotheraccounts,
											forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
											reviewerstrategy to reviewerstrategy,
											param_advancedmode to advancedmode,
											nbdays to nbdays,
											dynamicmode to dynamicmode,
											staticmode to staticmode,
											taglist to taglist
											save-state
											
											
						disabled:
//							StringPredicate(defaultrevieweruid) { when IsEmpty then True otherwise False } // le choix d'un reviewer par défaut doit être fait
							OrPredicate {
									IntPredicate(safelist) { when <1 then True when >999 then True otherwise False }							
									IntPredicate(gettotalnbrights.totalnbrights) { when =0 then True when InvalidInteger then True otherwise False }
									AndPredicate {
										Not BooleanPredicate(advancedmode) // si advanced mode, on verifiera apres le calcul de preview...
										IntPredicate(gettotalnbrights.totalnbrights) { when >Constant access360analytics_safeaccessrightsmaxentries then True when =0 then True when InvalidInteger then True otherwise False } // limite arbitraire pour l'instant pour eviter de planter la plate forme
									}
//									AndPredicate {
//										StringPredicate(reviewerstrategy) { when 'z' then True }
//										StringPredicate(reviewerstrategyscript) { when IsEmpty then True }
//									}
								}
						text:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1.previewbutton
						image:%collection_16.gear		
					}
				}
			}		
		}
	}
}

bwir_cloud_pam_accessrightsreviewcampaignpreview = Page {
	title: $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.title
	description: $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.description
	icon: "16/details/review_16.png" large-icon: "48/details/review_48.png"
	feature:iasreview_license
	enter-event:	
					Set @access360analytics_reviewcampaignDate(nbdays to nbdays) to filterminimumreviewdate,
					TransferData accessrights	(revieweruid, reviewermail, reviewerorigin, accountuid, permissionuid, reviewstatus, reviewcomment, identitypositionkey, rightlabel) to 
												(allreviewers, allreviewersmail, allreviewerorigin, allaccounts, allpermissions, allstatus, allcomment, allidentitypositionkeys, allrightlabels), 
					Set allreviewers to reviewerlist, 
					MultivaluedDistinct reviewerlist,
					Set SizeOf filterbyaccounttag to nbaccountfiltertags, // to avoid a bug as Eval "filterbyaccounttag.length" does not work if filterbyaccounttag is empty
					BooleanCase(Eval "includeuseraccounts.get().equals('1') && includeorphanaccounts.get().equals('1') &&  includetechaccounts.get().equals('1') && includeleaveraccounts.get().equals('1') && nbaccountfiltertags.get()==0 ") { when True then [  Set True to isafullreview ] when False then [ Set False to isafullreview ] }
					
	mixins: simpleReport	

	/* Parameters here */
	dynamicmode = Parameter { type:Boolean mandatory:False hidden:True label:"Tags selection mode" }
	staticmode = Parameter { type:Boolean mandatory:False hidden:True label:"Static selection mode" }
	taglist = Parameter { type:String multivalued:True mandatory:False hidden:True label:"List of tags" }
		
	safelist = Parameter { type:String mandatory:True hidden:True multivalued:True label:"Safes to review" }
	includeuseraccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include User Accounts" }
	includeorphanaccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Orphaned User Accounts" }
	includetechaccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Technical User Accounts" }
	includeleaveraccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Leaver User Accounts" }
	includebookingusers = Parameter { type:String mandatory:True hidden:True default:True label:"Include Booking User Accounts" }
	includebuiltinusers = Parameter { type:String mandatory:True hidden:True default:False label:"Include Built-In Accounts" }
	filterbyaccounttag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Users with Tag" }
//	filterbypermissiontag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Permissions with Tag" }
	includelatestreviewstatus = Parameter { type:String mandatory:False hidden:True label:"Include Last Reviewed Status" }
	filterifalreadyreviewed = Parameter { type:String mandatory:True hidden:True label:"Filter Entries Already Reviewed" }
	nbdays = Parameter { type:Integer mandatory:False hidden:True label:"Consider Only Entries Reviewed in the Last N Days" }
	forcehimselfasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force user himself as the Reviewer" }
	forcesafeownerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force Safe Owner as the Reviewer" }
	forcesafeownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True label:"Force Safe Owner as the Reviewer for all other accounts" }
	forcedefaultreviewerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force Default Reviewer as the Reviewer" }
	defaultrevieweruid = Parameter { type:String mandatory:False hidden:True label:"Default reviewer" }
	reviewerstrategy = Parameter { type:String mandatory:False hidden:True label:"Reviewer Strategy" }
	advancedmode = Parameter { type:String mandatory:False hidden:True default:False label:"Advanced Mode"}
			
	/* Variables here */

	outsafeuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable

	isafullreview = Variable { type:Boolean }
	nbaccountfiltertags = Variable { type:Integer }
	
	reviewerlist = Variable { multivalued:True }
	filterminimumreviewdate = Variable
	selectedreviewer = Variable
	allaccounts = Variable { multivalued:True } 
	allpermissions = Variable { multivalued:True } 
	allidentitypositionkeys = Variable { multivalued:True } 
	allrightlabels = Variable { multivalued:True } 
	allreviewers = Variable { multivalued:True } 
	allreviewersmail = Variable { multivalued:True } 
	allreviewerorigin = Variable { multivalued:True }
	allstatus = Variable { multivalued:True } 
	allcomment = Variable { multivalued:True } 

	incanshowdetails = Variable { initial:True type:String }	
	
	nbemptyreviewers = Variable { type:Integer }	

	reviewname = Variable { type:String }
	reviewdescription = Variable { type:String }
	reviewpriority = Variable { type:Integer initial:3 }
	reviewdeadline = Variable { type:Date initial:Date.offset( 30 days).value }
	boolofflinemode = Variable { type:Boolean initial:False }
	offlinemode = Variable
	boolselfdelegation = Variable { type:Boolean initial:False }
	selfdelegation = Variable
	
	wizardstep = Variable { initial:0 type:Integer }
	
	/* Datasets and records here */
	containsemptyreviewers = Dataset {
		columns:allreviewersmail
		includes: StringPredicate(Current allreviewersmail) { when IsEmpty then True otherwise False}
		count-variable:nbemptyreviewers
	}

	accessrights = Dataset {
		view:bwir_safeaccessrightsreviewbv with
															safelist to safelist,
															includeuseraccounts to includeuseraccounts,
															includeorphanaccounts to includeorphanaccounts,
															includetechaccounts to includetechaccounts,
															includeleaveraccounts to includeleaveraccounts,
															includebookingusers to includebookingusers,
															includebuiltinusers to includebuiltinusers,
															filterbyaccounttag to filterbyaccounttag,
												//			filterbypermissiontag to filterbypermissiontag,
															includelatestreviewstatus to includelatestreviewstatus,
															filterifalreadyreviewed to filterifalreadyreviewed,
															filterminimumreviewdate to filterminimumreviewdate,
															forcehimselfasreviewer to forcehimselfasreviewer,
															forcesafeownerasreviewer to forcesafeownerasreviewer,
															forcesafeownerforallotheraccounts to forcesafeownerforallotheraccounts,
															forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
															defaultrevieweruid to defaultrevieweruid,
															selectedreviewer to filterbyreviewer unless-empty // used to filter per reviewer in the GUI
	}
	
	reviewers = Dataset {
		view:access360r_identity with reviewerlist to uids
	}

	task = TaskRecord (create "bwaccess360_assignAccessRightsReviewTickets")
	
	goSafeDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_casafeDetailsDialog(outsafeuid to inuid)
			]
			when False then [
			
			]
		}
	)
	
	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_CApermissionDetailsDialog(
					outpermissionuid to inuid,
					outaccountuid to inaccountuids,
					True to inshowaccountrights,
					True to inshowaccounts,
					True to inshowperjob,
					True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowgroups,
												True to inshowsafes,
												True to inshowshares,
												True to inshowowner,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}
	)


