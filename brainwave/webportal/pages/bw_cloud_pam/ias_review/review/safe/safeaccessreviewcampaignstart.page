/* Nationalized labels here */
bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS = NLS {
	title [	en "Safe Permissions Review" 
			fr "Revue des droits d'accès aux safes"
			]
	description [	en "This analytics configures and launch a CyberArk safe permissions review." 
					fr "Cette analyse configure et lance une revue des droits d'accès aux safes CyberArk."
				]

	lmhrcode [en "Reviewer \nEmployee Number" fr "Matricule de \nl'acteur"]
	lmfullname [en "Reviewer \nName" fr "Nom de \nl'acteur"]
	lmmail [en "Reviewer \nMail" fr "Mail de \nl'acteur"]
	lmorigin [en "Reviewer \nOrigin" fr "Origine de \nl'acteur"]

	lrstatus [en "Last Review \nStatus" fr "Statut de \nla dernière revue"]
	lrby [en "Last Review \nby" fr "Dernière revue \npar"]
	lrdate [en "Last Review \nDate" fr "Date \nla dernière revue"]
	lrcomment [en "Last Review \nComment" fr "Commentaire de \nla dernière revue"]

	info [
		en "This analytics will help you to launch an access rights review for the selected CyberArk safes.\nThe first step helps you to refine your review perimeter,\nthe second step proposes review strategies you can choose from,\nthe third step shows the data which will be reviewed,\nthe final step concerns review campaign information and launching the review.\nALL selected data MUST be reviewed, the reviewer is automatically identified based by default on the characteristic of the current line:\nEPV user accounts and AIM accounts are reviewed by Safe Owners.\nYou can choose another review strategy."
		fr "Cette analyse vous aidera à lancer une revue des droits d'accès pour les safes CyberArk sélectionnés.\nLa première étape vous aide à affiner votre périmètre de revue.\nLa deuxième étape propose des stratégies de revue que vous pouvez choisir.\nLa troisième étape présente les données qui seront révisées.\nLa dernière étape concerne les informations de la campagne et le lancement de celle-ci.\nIl faut revoir l'ensemble des droits d'accès.\n Les réviseurs des droits d'accès sont par défaut calculés de la manière suivante :\nLes comptes utilisateurs EPV et comptes AIM sont examinés par le propriétaire de safe.\nVous pouvez sélectionner une autre stratégie de revue."	]

	tab1 [en "1. Refine Perimeter" fr "1. Affiner le périmetre"]
	tab1bis [en "2. Define Review Strategy" fr "2. Définir la stratégie"]	
	tab2 [en "3. Preview Data" fr "3. Prévisualiser les données"]
	tab3 [en "4. Launch Review" fr "4. Lancer la revue"]
	
	tab1.safesubtitle [en "Safes to Review" fr "Safes à revoir"]
	tab1.accountsubtitle [en "User Accounts Review Perimeter" fr "Périmètre des comptes utilisateurs revus"]
	tab1.useraccounts [en "Include EPV Users" fr "Inclure les utilisateurs EPV"]
	tab1.techaccounts [en "Include AIM Accounts" fr "Inclure comptes AIM"]
	tab1.staticselection [en "Static Selection" fr "Sélection statique"]
	tab1.tagselection [en "Selection by Tags" fr "Sélection par tag"]	
	tab1.warningscope [
		fr "L'ensemble des safes listés ci-dessous seront pris en compte dans la revue indépendamment de la ligne sélectionnée. Pour affiner la sélection, veuillez passer en mode recherche libre."
		en "All the safes listed below will be included in the review, regardless of the line selected. To refine your selection, please switch to free search mode."
	]

	tab1.orphanaccounts [en "Include Orphaned Users" fr "Inclure les utilisateurs orphelins"]
	tab1.orphanaccounts.tooltip [	en "Orphaned users are users that have not been matched\nwith an identity from the HR datasources and that have not\nbeen identified as a technical or service account."
									fr "Les utilisateurs orphelins sont les utilisateurs n'ayant pas été rapprochés\nd'une identité au sein des sources de données RH et\nqui n'ont pas été identifiés comme compte technique ou de service."]
	
	tab1.leaveraccounts [en "Include Leaver Users" fr "Inclure les utilisateurs résiduels"]
	tab1.leaveraccounts.tooltip [	en "Leaver users are active user accounts which used to be matched\nwith an identity but this identity is no longer part of the identity ledger\nmost probably because the entry has been removed from\nthe HR datasources in the latest timeslots." 
									fr "Les comptes utilisateurs résiduels sont des comptes qui étaient réconciliés avec une identité\ncependant cette identité n'est plus présente dans le grand livre\ntrès certainement car cette identité a été supprimée des données sources RH\ndans les derniers chargements."]

	tab1.bookingusers [en "Include Booking Users" fr "Inclure les utilisateurs Booking"]	
	tab1.bookingusers.tooltip [		en "Booking users are LDAP users who have never logged in\nto CyberArk but have the right to do so via a group.\nThese users do not hold any CyberArk license."
									fr "Les utilisateurs 'Booking' sont les utilisateurs LDAP\nqui ne se sont jamais connectés à CyberArk mais\nqui ont un droit pour le faire via un groupe. Ces utilisateurs n'occupent pas de licence CyberArk."]

	tab1.builtinaccounts [en "Include Built-In Users" fr "Inclure les comptes built-in"]
	tab1.builtinaccounts.tooltip [		en "Built-in users are users who are predefined by default\nby CyberArk in the Vault. The break glass user account could be one of them."
								fr "Les utilisateurs 'Built-In' sont les utilisateurs prédéfinis\n par défaut par CyberArk dans le Vault.Le compte brise-glace peut être l'un d'eux."]
	
	
	tab1.accountag [en "Consider only user accounts who have one \nof the following Tag" fr "Prendre les comptes utilisateurs \navec l'un des labels"]
	tab1.accountag.tooltip [	en "By default all selected active user accounts are included in the review.\nYou can further refine this list by tagging the user accounts." 
								fr "Par défaut tous les comptes utilisateurs actifs sélectionnés sont intégrés dans la revue.\nVous pouvez affiner cette liste en taguant des comptes utilisateurs."]

//	tab1.permissionsubtitle [en "Permission Review Perimeter" fr "Périmètre des autorisations revues"]
//	tab1.permissiontag [en "Consider only permissions who have one \nof the following Tags" fr "Prendre les autorisations \navec l'un des labels"]
//	tab1.permissiontag.tooltip [	en "By default all CyberArk permissions type permissions directly associated with active user accounts are included in the review.\nYou can refine this list by tagging the permissions." 
//									fr "Par défaut toutes les autorisations CyberArk directement associées aux comptes utilisateurs actifs sont inclues dans la revue.\nVous pouvez affiner cette liste en taguant des autorisations."]

	tab1.incsubtitle [en "Incremental Review Strategy" fr "Stratégie de revue incrémentale"]
	tab1.incprefill [en "Prefill the review table with the latest review status" fr "Préremplir la table avec les derniers résultats de revue"]
	tab1.incprefill.tooltip [	en "Latest review status and comment is taken\nif the entry has been reviewed in the configured timeframe\n and if the user account owner characteristics haven't changed since then (organization, jobtitle, internal status)."
								fr "Le dernier statut de revue ainsi que le commentaire sont repris si\nl'entrée a été revue dans la fenêtre de temps précisée et que\nles caractéristiques de l'utilisateur n'ont pas changé depuis (organisation, métier, interne)."
	]

	tab1.incremove [en "Remove from the list the entries who have already been reviewed" fr "Supprimer de la liste les entrées qui ont déjé été revues"]
	tab1.incvalid [en "A valid entry is an entry who has been reviewed in the last X days." fr "Une entrée valide est une entrée qui a été revue dans les X derniers jours."]

	reviewersubtitle [en "Reviewer Strategy" fr "Acteurs de revue"]
	tab1.forceappowner [en "Force the safe owner as the reviewer for user accounts" fr "Forcer le responsable de safe à revoir les comptes utilisateur"]
	tab1.forceappowner.tooltip [en "By default, line managers will have to review user accounts access rights.\nThis can be disabled, in such case the safe owner will also have to review the user accounts."
								fr "Par défaut, les responsables opérationnels auront à revoir les droits d'accès des comptes utilisateur.\nVous pouvez désactiver cette fonctionnalité de manière à ce que le responsable de safe ait aussi à revoir les comptes utilisateur."
								]
	tab1.defaultreviewer [ en "Default Reviewer" fr "Acteur par défaut"]
	tab1.defaultreviewer.tooltip [ 	en "This reviewer is used if no reviewers are found for the entry\nor if the reviewer does not have an email address."
									fr "Cet acteur est utilisé si aucun acteur n'est trouvé pour l'entrée\nou si l'acteur ne dispose pas d'un email valide."
									]
	tab1.defaultreviewer.error [ en "Error: Default reviewer email cannot be empty."
								 fr "Erreur: Le mail de l'acteur par défaut ne peut pas être vide."
								]

	tab1.reviewerstrategy.tooltip [	en "The reviewer strategy defines who will review each access right."
									fr "La stratégie de revue permet de définir qui va revoir chaque droit d'accès."
									]


	tab1.reviewerstrategy.a [	en "EPV users by the line manager, AIM accounts by the safe owner" 
								fr "Utilisateurs EPV par le manager, comptes AIM par le responsable de safe"	
							]
	tab1.reviewerstrategy.d [	en "EPV users by the line manager, all other users by the safe owner" 
								fr "Utilisateurs EPV par le manager, tous les autres utilisateurs par le responsable de safe"	
							]
	tab1.reviewerstrategy.e [	en "EPV users by themself, all other users by the safe owner" 
								fr "Utilisateurs EPV par eux-mêmes, tous les autres utilisateurs par le responsable de safe"	
							]
	tab1.reviewerstrategy.b [	en "All users by the safe owner" 
								fr "Tous les utilisateurs par le responsable de safe"	
							]
	tab1.reviewerstrategy.c [	en "All users by the default reviewer" 
								fr "Tous les utilisateurs par l'acteur par défaut"	
							]
	
	tab1.warning [
		en "Overall, your safes are totalizing more than 1000000 access permissions,\nyou should consider refining your review perimeter in this page."
		fr "Au total, les safes contiennent plus de 1000000 de droits d''accès,\nvous devriez affiner le périmètre de revue dans cette page."
	]
	tab1.noquery [
		en "No safe have been listed in the table. Please use the filter or the free search, then click on the magnifier to list the safes to review."
		fr "Aucun safe n'a été répertorié dans le tableau. Veuillez utiliser le filtre ou la recherche libre, puis cliquez sur la loupe pour lister les safes devant être revus."	
	]
	tab1.strategybutton [en 'Define the Review Strategy' fr 'Définir la stratégie de revue']
	tab1.previewbutton [en 'Preview Review Data' fr 'Prévisualiser les données à revoir']
	tab1.previewbutton.tooltip [
			en "This will prepare the review campaign\nand identify a reviewer for each entry to review,\nthis operation can take several minutes."
			fr "Ceci va lancer le calcul de la préparation de la campagne\net identifier le responsable pour chaque entrée à revoir,\ncette opération peut prendre plusieurs minutes."
	]
	tab1.advancedmode [en "Advanced Mode" fr "Mode avancé"]

	tab2.filter [en "Filter Table for" fr "Filtrer la table pour"]
	tab2.error [en "{0} entries found without a valid reviewer, please refine your configuration." fr "{0} entrées trouvées sans acteur de revue valide, veuillez affiner votre configuration."]
	tab2.error.tooltip[en "Some entries do not have a reviewer or the reviewer do not have an email." fr "Des entrées n'ont pas d'acteur de revue  valide, ou l'acteur n'a pas d'email valide."]

	tab2.back [en "Refine Perimeter" fr "Affiner le périmetre"]
	tab2.configure [en "Configure the Review" fr "Configurer la revue"]
	tab2.configure.tooltip [en "Next step will be to configure you review information and to launch the review task.\nTip: You can also bookmark this page in your favorites if you want to run a review with this configuration\n on a regular basis, the review content will be refreshed accordingly." 
							fr "La prochaine étape consistera à configurer les informations relatives à la revue et à lancer la revue.\nAstuce : vous pouvez également ajouter cette page à vos favoris si vous souhaitez effectuer régulièrement une revue avec cette configuration.\nle contenu à revoir sera mis à jour automatiquement à chaque accès à la page."]

	tab3.backhistory [en "Refine Strategy" fr "Modifier la stratégie"]
	tab3.back [en "Preview Data" fr "Prévisualiser les données"]
	tab3.arinfo [en "Access Review Information" fr "Informations sur la campagne de revue"]
	tab3.reviewid [en "Review Unique Identifier" fr "Identifiant unique de revue"]
	tab3.reviewname [en "Review Name" fr "Nom de la revue"]
	tab3.reviewdescr [en "Review Description" fr "Description de la revue"]
	tab3.reviewpriority[en "Review Priority"fr "Priorité de la revue"]
	tab3.reviewdeadline [en "Expected Deadline"fr "Date d'échéance de la revue"]

	tab3.selfdelegation [en "Enable Self Delegation" fr "Activer la délégation en self-service"]
	tab3.selfdelegation.tooltip [
				en "When self delegation is enabled, the reviewer can reassign its entries to team members\n(subordinates if reviewing as a line manager, other safe owners if reviewing as a safe owner).\nRACI principles are enforced: the initial reviewer will remain marked as accountable for the results."
				fr "Quand la délégation en self service est activée, l'acteur peut réassigner ses entrées à ses collègues\n(équipe si revue en tant que manager, autres responsables de safe si revue en tant que responsable de safe).\nLes principes RACI s'appliquent: l'acteur initial restera indiqué comme Accountable du résultat."
	]

	tab3.offlinemode [en "Enable Offline Mode" fr "Activer le mode hors-ligne"]
	tab3.offlinemode.tooltip [
				en "When offline mode is enabled you can send notification and gentle reminder emails\nwith the entries to review as an attachement (excel format),\nthe reviewer just has to fulfill the excel document and send it back to the campaign manager.\nOnce checked, the campaign manager can import those results in the review through the UI."
				fr "Lorsque les fonctionnalités de revue en mode hors-ligne sont activées il est possible d'envoyer\ndes emails de notification et de relance qui contiennent en piece jointe\nles entrées à revoir sous la forme d'un fichier excel.\nL'acteur de revue peut alors remplir le fichier et le renvoyer par mail au responsable de la campagne\nqui après vérification peut directement importer les résultats de revue via le gestionnaire de campagne."
	]

	tab3.appstoreview [en "Safes to Review" fr "Safes à revoir"]
	tab3.entriestoreview [en "Entries to Review" fr "Entrées à revoir"]
	tab3.reviewers [en "Reviewers" fr "Acteurs"]
	tab3.confim [en "Are you sure?\nThis will launch the review" fr "êtes-vous sûr de vouloir lancer la revue ?"]
	tab3.launch [en "Launch the Review" fr "Lancer la revue"]
	tab3.launch.tooltip [en "The entries will be marked as to be reviewed\nand the review will be launched" fr "Les entrées vont être marquées comme étant à revoir\net la revue va être lancée"]
}


