bwir_cloud_pam_accessrightsreviewcampaignconfigurationNLS = NLS {
	nbaccount [en "Nb Users" fr "Nb Utilisateurs"]
	nbidentity [en "Nb Identities" fr "Nb Identités"]
	nbprofile [en "Nb Profiles" fr "Nb Profils"]
	nbdirectaccountright [en "Nb Direct \nUser Permissions" de "Nb d''autorisations directs \nsur des comptes utilisateurs"]
	usertype [en "User Type" fr "Type"]
}

// Max number of entries to be able to review per campaign...
access360analytics_safeaccessrightsmaxentries = Constant { value:100000 type:Integer }

bw_cloud_pam_cyberark_safeaccessreviewcampaignconfigurationFirst = UserVariable { type:Boolean initial:True }
bwir_cloud_pam_accessrightsreviewcampaignconfiguration = Page {
	title: $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.title
	description: $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.description
	icon: "32/details/review_32.png" large-icon: "48/details/review_48.png"
	tags: "safes", "iasreview25"
	feature: All(iasreview_license, pam_license, Any(governance_license, compliance_license))
	enter-event:
		Set param_dynamicmode to dynamicmode,
		Set param_staticmode to staticmode,
		Set param_taglist to taglist,
		Set param_safelist to selectedsafes, 
		Set param_includeuseraccounts to includeuseraccounts, 
		Set param_includeorphanaccounts to includeorphanaccounts, 
		Set param_includetechaccounts to includetechaccounts,
		Set param_includeleaveraccounts to includeleaveraccounts,
		Set param_includebookingusers to includebookingusers,	
		Set param_includebuiltinusers to includebuiltinusers,	
		Set param_filterbyaccounttag to filterbyaccounttag, 
//		Set param_filterbypermissiontag to filterbypermissiontag,
		Set param_advancedmode to advancedmode,
		StringCase ( defaultrevieweruid ) {
			when Not IsEmpty then [
				Set defaultreviewerinfos.fullname to defaultreviewer
			]
		},
		StringCase ( staticmode ) {
			when IsEmpty then [
				Set True to staticmode
			]
		}		
	post-render-event: BooleanCase(UserVariable bw_cloud_pam_cyberark_safeaccessreviewcampaignconfigurationFirst) 
		{ 
			when True then [ 
				Set False to UserVariable bw_cloud_pam_cyberark_safeaccessreviewcampaignconfigurationFirst,
				Message $bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.info 
				]
				when False then [
				]
		}

	mixins: simpleReport	

	param_dynamicmode = Parameter { type:Boolean mandatory:False hidden:True label:"Tags selection mode" }
	param_staticmode = Parameter { type:Boolean mandatory:False hidden:True label:"Static selection mode" }
	param_taglist = Parameter { type:String multivalued:True mandatory:False hidden:True label:"List of tags" }

	param_safelist = Parameter { type:String mandatory:False hidden:True multivalued:True label:"Safes to review" }
	paramInitialIndex = Parameter { type: Integer hidden: True }
	param_includeuseraccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include User Accounts" }
	param_includeorphanaccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Orphaned User Accounts" }
	param_includetechaccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Technical User Accounts" }
	param_includeleaveraccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Leaver User Accounts" }
	param_includebookingusers = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Booking User Accounts" }
	param_includebuiltinusers = Parameter { type:String mandatory:False hidden:True default:'0' label:"Include Built-In User Accounts" }
	param_filterbyaccounttag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter User Accounts with Tag" }
//	param_filterbypermissiontag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Permissions with Tag" }
	param_advancedmode = Parameter { type:String mandatory:False hidden:True default:False label:"Advanced Mode"}

	param_includelatestreviewstatus = Parameter { type:String mandatory:False hidden:True default:'0' label:"Include Last Reviewed Status" }
	param_filterifalreadyreviewed = Parameter { type:String mandatory:False hidden:True default:'0' label:"Filter Entries Already Reviewed" }
	param_nbdays = Parameter { type:Integer mandatory:False hidden:True default:90 label:"Consider Only Entries Reviewed in the Last N Days" }
	param_reviewerstrategy = Parameter { type:String mandatory:False hidden:True default:"b" label:"Reviewer Strategy"}
	param_forcehimselfasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force user himself as the Reviewer" }
	param_forcesafeownerasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force Safe Owner as the Reviewer" }
	param_defaultrevieweruid = Parameter { type:String mandatory:False hidden:True label:"Default Reviewer if no Reviewer Found"}

	includeuseraccounts = Variable { type:String}
	includeorphanaccounts = Variable { type:String}
	includetechaccounts = Variable { type:String}
	includeleaveraccounts = Variable { type:String}
	includebuiltinusers = Variable { type:String}
	includebookingusers = Variable { type:String}
	filterbyaccounttag = Variable { type:String multivalued:True}

	defaultrevieweruid = Variable { type:String}
	defaultreviewer = Variable { type:String }
	defaultreviewermail = Variable { type:String }

	selectedsafes = Variable { multivalued:True }
	selectessafe = Variable 
	initialIndex = Variable { type: Integer	}
	totalnbrightsselected = Variable { type: Integer }

	dynamicmode = Variable { type: Boolean }
	staticmode = Variable { type: Boolean }
	taglist =  Variable { multivalued:True }
	
	advancedmode = Variable { initial:False type:Boolean }

	accounttags = Dataset {
		view:bwaccess360r_applicationaccountags // with selectedapplications to applications
	}
	
	defaultreviewerinfos = Record {
		view:bwf_identityDetail with defaultrevieweruid to uid
	}
	
	gettotalnbrights = Record {
		view:bwir_safebyuidaccessrightsnbrights with selectedsafes to uid
	}
	
	safelist = Dataset {
			view:bwir_safelist 
	}

	safetaglist = Dataset {
			view: bwir_safetaglist  with taglist to tags
		}	

	safetags = Dataset {
			view: bwd_safes_tags with "ca_safe" to applicationfamily 
		}

	Grid {
		columns:GridColumn { group:a },GridColumn { group:a },GridColumn { group:a },GridColumn { group:a }
		layout:Layout { hint:height 32 grab:horizontal True vertical False }
		GridRow {
			GridCell {
				background:Color HEX (#2969B0) // dark blue
				
				Header {
					value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1
					icon:%browsing_16.play
					styling:wizardheaderstyle
					layout:Layout { grab:horizontal True vertical True align:horizontal Beginning vertical Center }
				}
			}
			GridCell {
				background:Color HEX (#A5D0FF) // blue
				
				Header {
					value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1bis
					styling:wizardheaderstyle
					layout:Layout { grab:horizontal True vertical True align:horizontal Beginning vertical Center }
				}
			}			
			GridCell {
				background:Color HEX (#A5D0FF) // blue
				
				Header {
					value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab2
					styling:wizardheaderstyle
					layout:Layout { grab:horizontal True vertical True align:horizontal Beginning vertical Center }
				}
			}
			GridCell {
				background:Color HEX (#A5D0FF) // blue
				
				Header {
					value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab3
					styling:wizardheaderstyle
					layout:Layout { grab:horizontal True vertical True align:horizontal Beginning vertical Center }
				}
			}
		}
	}
	Header {
		value:$bw_cloud_pam_cyberark_safeaccessreviewcampaignNLS.tab1.safesubtitle
		styling:bigTitleStyle
	}					
	Separator {
		width:1
		color:blue
	}

	// Search section
	Grid {
		columns:GridColumn {}, GridColumn { width: 100 }, GridColumn { width: grow }
		layout:Layout { grab:horizontal False vertical False } 
		GridRow {
			GridCell {		
				Checkbox { 
