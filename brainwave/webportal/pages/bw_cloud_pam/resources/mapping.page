scope_status = StringMapping {   
   when IsNull then $scope_statusNLS.created
   when Constant SCOPE_STATE_INIT1 then $scope_statusNLS.unplanned
   when Constant SCOPE_STATE_PLAN2 then $scope_statusNLS.planned
   when Constant SCOPE_STATE_ONBOARD3 then $scope_statusNLS.progress
   when Constant SCOPE_STATE_DONE4 then $scope_statusNLS.done
   otherwise $scope_statusNLS.other
}

scope_status_image_mapping = StringImageTemplate {
   when Constant SCOPE_STATE_PLAN2 then %pam_scope_status_20.planned2
   when Constant SCOPE_STATE_ONBOARD3 then %pam_scope_status_20.onboarding3
   when Constant SCOPE_STATE_DONE4 then %pam_scope_status_20.onboarded4
   when Constant SCOPE_STATE_INIT1 then %pam_scope_status_20.unplanned1
}

