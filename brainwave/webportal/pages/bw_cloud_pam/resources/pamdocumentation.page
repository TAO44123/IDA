/* Import other pages here */
import "/webportal/pages/bw_portaluar_base/admin/documentation.page"

/* Nationalized labels here */

bwcpam_documentation_ciso_guideNLS = NLS {
	title [
		en "PAM Booster: CISO User Guide"
		fr "PAM Booster : Guide utilisateur pour le RSSI"
	]
	url [ 
		fr "static/static/bw_cloud_pam/generated_doc/ciso_enduser_guide_en.html" 
		en "static/static/bw_cloud_pam/generated_doc/ciso_enduser_guide_en.html"
	]
}
bwcpam_documentation_ciso_guide = Page {
	title: $bwcpam_documentation_ciso_guideNLS.title
	
	IncludeHTMLWidget {
		template: BrainwaveDocDisplayWidget
		layout: Layout { grab: horizontal True vertical True }
		bindings:
			value-of $bwcpam_documentation_ciso_guideNLS.title to title,
			value-of $bwcpam_documentation_ciso_guideNLS.url to url
	}
}

