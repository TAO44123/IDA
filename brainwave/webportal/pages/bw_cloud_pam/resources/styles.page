import "/webportal/pages/bw_fragments/lib/colors.page"

/* base  */

base_font = Style {
    font: "Segoe UI, Roboto"
}

boldStyle = Style {
  bold: True
}

linkColor = Color #0088F3

baseLink = Style (base_font) {
  foreground: linkColor
  image-color: linkColor
}


/* page with 16px font size */

pageMixin = Mixin {
	Text {
	  compact: True
	  styling: stdText
	}
	 Header {
	  styling: mediumText 
	}
	Table {
	  styling: stdText
	}
	Tree {
	  styling: stdText
	}
	Label {
	  styling: stdText
	}
	Combo {
	  styling: stdText
	}
	Button {
	  styling: stdText
	}
}

stdText = Style(base_font) {
	size: 16px
	image-width: 16px
}

stdTextGreen = Style(base_font) {
	size: 16px
	image-width: 16px
	foreground: HEX ( #4db6ac )
}

mediumText = Style(base_font) {
	size: 20px
	image-width: 20px
}

bigText = Style(base_font){
  size: 24px
  image-width: 24px
}

biggerText = Style(base_font){
  size: 28px
  image-width: 28px
}


stdLink =  Style(baseLink) {
	size: 16px
	bold: False
}


wizardTitleStyle =  Style(base_font) {
	bold: True
	size: 16px
}

wizardSubTitleStyle =  Style(base_font) {
	bold: True
}

wizardButtonStyle =  Style(base_font) {
	size: 16px
}

mainButtonStyle = Style(wizardButtonStyle){
  background: Color Theme.background2
  foreground: Theme.foreground2
}

/* red button for dangerous operations */
stdButtonMixin = Mixin {
  Button {
    styling: stdText
  }
}

dangerButtonStyle = Style(wizardButtonStyle){
  background: Color #F94F79
  foreground: white 
}

mainButtonMixin = Mixin {
  Button {
    styling: mainButtonStyle, boldStyle
  } 
}

secondaryButtonMixin = Mixin {
  Button {
    align: Center
    presentation: Link
    layout: Layout { hint: height 30}
    styling: stdLink
  }
}

linkButtonMixin = Mixin {
	 Button {
	    align: Center
	    presentation: Link
	    layout: Layout { hint: height 30}
	    styling: stdLink
	  }
}

mainBigButtonMixin = Mixin {
  Button {
    styling: mainButtonStyle, bigText
  } 
}

/* DASHBOARD styles ( rounded panels, indicators , gray background )  */

dashboardMixin = Mixin {
  	Text {
	  compact: True
	  styling: stdText
	}
	Header {
	  styling: mediumText 
	}
	Table {
	  styling: stdText
	}
	Tree {
	  styling: stdText
	}
	Label {
	  styling: stdText
	}
	Combo {
	  styling: stdText
	}
}

linksPanelMixin = Mixin {
  This Group {
     styling: cssRound
	  layout: Layout { indent: horizontal 0 vertical 5 minimal: height 80}	  
  }
  Header {
    styling: cssGroupTitle
  }
  Button {
		presentation: Link
		styling: stdLink
		align: Left
		layout: Layout { grab: horizontal False vertical False hint: height 28 }
  }
}

wizardButtonBarMixin = Mixin {
  ButtonGroup {
    align: Right
    layout: Layout { grab: horizontal True vertical False }
    margins: Top 10 Right 50 Bottom 20
	 spacing: 20 
  }
  Button {
    styling: wizardButtonStyle   
  }
}

dashboardSubTitleStyle =  Style(stdText) {
	bold: True
}


indCountStyle = Style {
  size: 64px
  foreground: #444
}

indCountMixin = Mixin {
  Text {
    align: Right
    styling: indCountStyle
  }
}

indLabelStyle = Style(base_font) {
  size: 16px
  foreground: #666 
  image-color: #666
  image-width: 32px
}

indLabelMixin = Mixin {
  Text {
    align: Left
    styling: indLabelStyle
  }
}

indMediumMixin = Mixin {
 
  Label {
    styling: mediumText
    layout: Layout {  indent: horizontal 0  vertical 5 }
  }
  // number text 
  Text {
    align: Right
    styling: bigText
    layout: Layout { hint: height 28 }
    compact: True
    
  }
  // eval icon
  Button {
    styling: mediumText
    layout: Layout { indent: vertical 2 horizontal 9}
    presentation: Link
    hide-text: True
  }
  Image {
    styling: mediumText
    layout: Layout { indent: vertical 0 horizontal 0}
  }

}

indTextStyle = Style(base_font) {
	size: 16px	
}

dashStatus = Mixin {
      Group {
          layout: Layout { grab: horizontal True vertical False hint: height 65 }                  
      }
}

titleStyle = Style(stdText) {
  foreground: #666
}

helpDashboardMixin = Mixin {
	This Group {
	    layout: Layout { indent: horizontal 0 vertical 0 
	      grab: horizontal True vertical True}   
	    styling: cssRoundHelp               
	}
	Header {
	  styling: titleStyle
	  layout: Layout {indent: horizontal 0 vertical 0 }
	}
	Text {
	  styling: titleStyle
	  layout: Layout {indent: horizontal 0 vertical 5 }
	}
}

helpPageMixin = Mixin {
	This Group {
	    layout: Layout { indent: horizontal 15 vertical 15 
	      grab: horizontal True vertical True}   
	    styling: cssRoundHelp               
	}
	Header {
	  styling: titleStyle
	  layout: Layout {indent: horizontal 0 vertical 0 }
	}
	Text {
	  styling: titleStyle
	  layout: Layout {indent: horizontal 0 vertical 5 }
	}
}

statusStyle = Style(base_font) {
  size: 16px
  image-width: 24px	
}

infoStyle = Style {
  foreground: blackNG
}

okStyle = Style {
  foreground: greenNG
}

errorStyle = Style {
  foreground: redNG
}

indStdMixin = Mixin {
  Label {
     styling: indTextStyle
  }
  Image {
    styling: stdText
  }
  Text {
    styling: stdText
    compact: True
    align: Left
  }
}

indErrorMixin = Mixin {
  Label {
     styling: indTextStyle, errorStyle
  }
  Image {
    styling: errorStyle, stdText
  }
}

indOkMixin = Mixin {
  Label {
     styling: indTextStyle, okStyle
  }
  Image {
    styling: okStyle, stdText
  }
}

mediumTextMixin = Mixin{
  Text {
    compact: False
    styling:mediumText,boldStyle
  }
}

grayStyle = Style {
  foreground: grayNG
  image-color: grayNG
}

kpiVPanelMixin = Mixin {
  This Group {
    styling: cssRound  // ca marche pas, il faut remettre le style    
    //margins: Left 15 Top 15
    layout: Layout { indent: horizontal 15 vertical 15  
    //grab: horizontal False vertical False  
    } 
    compact: True
  }
  Header {
    align: Left
    styling: bigText,grayStyle
  }   
}

homePanelMixin = Mixin {
  This Group {
    styling: cssRound  
    layout: Layout { indent: horizontal 10 vertical 10
    } 
    compact: True
  }
  Header {
    align: Left
    styling: mediumText,grayStyle
  }   
}

homeLinksPanelMixin = Mixin {
  This Group {
    styling: cssRound  
    layout: Layout { indent: horizontal 10 vertical 10
    } 
    compact: True
  }
  Header {
    align: Left
    styling: mediumText,grayStyle
  }
  Button {
	    align: Center
	    presentation: Link
	    layout: Layout { hint: height 28 indent: horizontal 0 vertical 5 }
	    styling: stdLink
	  }
}

/* CSS Theme styles for dashboards  */
cssPageDashboard = Style { theme-class: "page-dashboard"}
cssPageHeader = Style { theme-class: "page-header"}
cssButtonSquare = Style {   theme-class: "button-square"}
cssRound = Style { theme-class: "round"}
cssRoundHelp = Style { theme-class: "round-help"}
cssRoundNoPadding = Style { theme-class: "round-nopadding"}
cssVRoundFirst = Style { theme-class: "vround-first"}
cssVRoundMiddle = Style { theme-class: "vround-middle"}
cssVRoundLast = Style { theme-class: "vround-last"}
cssHRoundFirst = Style { theme-class: "hround-first"}
cssHRoundMiddle = Style { theme-class: "hround-middle"}
cssHRoundLast = Style { theme-class: "hround-last"}
cssGroupTitle = Style(stdText) { theme-class: "group_title"}

