/* Nationalized labels here */

bwcpam_createprogramwizard_NLS = NLS {

	title [ 
		en "Welcome Wizard"
		fr "Assistant de bienvenue"
	]
	button.back [
		en "Previous"
		fr "Précédent"
	]
	button.forward [
		en "Next"
		fr "Suivant"
	]
	button.finish [
		en "Finish"
		fr "Terminer"
	]
	
	welcome.title [
		en "Welcome to the PAM/CyberArk Service"
		fr "Bienvenue dans le service PAM/CyberArk"
	]
	welcome.p1 [
		en "PAM/CyberArk Service"
		fr "Service PAM/CyberArk"
	]
	welcome.p2 [
		fr "Ce service est unique en son genre car il vous offre un accompagnement issu de l'expérience de Brainwave en matière d'analyse de données. Le service a été conçu de manière à ce que vous puissiez vous concentrer sur l'aspect métier. Les techniques d'Intelligence Artificielle et d'analyse vous apportent une aide dans la compréhension de vos données."
		en "This exceptional service offers support based on Brainwave's experience in data analysis. It has been designed to allow users to focus on the business aspects of their project by allowing Artificial Intelligence and analysis techniques to help them better understand their data."
	]
	welcome.p3 [
		fr "Comment démarrer"
		en "How to start"
	]
	welcome.p4 [
		fr "Dans l'esprit d'un service Cloud, l'approche est guidée, expliquée et décomposée en étapes."
		en "As with most cloud services, the approach is guided, explained and broken down into steps."
	]
	
	content.title [
		en "PAM Program Settings - General Information"
		fr "Configuration du programme - Info générales"
	]
	content.p1 [
		en "To start, define the program characteristics: name and description"
		fr "Pour commencer, définissez les caractéristiques du programme : nom et description."
	]
	content.label.name [
		en "Name"
		fr "Nom"
	]
	content.label.description [
		en "Description"
		fr "Description"
	]
	content.program.name.defaultvalue [
		en "Privileged account on-boarding program"
		fr "Programme d'embarquement des comptes à privilèges"
	]
	
	review.title [
		en "PAM Program Settings - Summary"
		fr "Configuration du programme - Résumé"
	]
	review.p1 [
		en "Congratulations, the PAM programs has been created. Click \"Finish\" to begin working."
		fr "Félicitations, vous avez créé votre programme. Cliquez sur Terminer pour commencer à travailler."
	]
	review.message.emptydescription [
		en "Not provided"
		fr "Non renseignée"
	]
	flash [
		fr "Désactivé"
		en "Disabled"
	]
	defaultRuleLabel [
		fr "Comptes dont le niveau de sensibilité est élevé"
		en "Accounts having a high sensitivity level"
	]
	
}

