scope_prio_NLS = NLS {
  dialog.title [ fr "Prioriser les périmètres" en "Prioritize scopes"]
  label.msg [ fr "Faites glisser les périmètres pour les ordonner du plus au moins prioritaire, en fonction des critères affichés :
 - Comptes : nombre de comptes inclus dans le périmètre
 - Ecarts : nombre d'écarts de contrôles sur les comptes inclus dans le périmètre
 - Ressources : nombre de ressources ( applications, annuaires, composants d'infrastructures) sélectionnées par l'utilisateur dans l'interface de configuration
 - Prestataires : pourcentage de prestataires associés aux comptes inclus dans le périmètre.\n\n " 
 
 en "Drag scopes to prioritize them according to the displayed criteria:
 - Accounts: number of accounts included in each scope
 - Discrepencies: number of control discrepencies on the accounts included in each scope
 - Resources: number of resources ( applications, directories and infrastructure components) selected in the configuration user interface 
 - Contractors: percentage of contractors associated to the accounts included in each scope.\n\n "
 ]
 
  header.scope [ fr "Périmètre" en "Scope"] 
  header.importance [ fr "Importance" en "Importance"] 
  header.onboarding [ fr "Embarquement" en "On-boarding"] 
  header.accounts [ fr "Comptes" en "Accounts"] 
  header.discrepencies [ fr "Ecarts" en "Discrepencies"] 
  header.contractors [ fr "Prestataires" en "Contractors"] 
  header.resources [ fr "Ressources" en "Resources"]
}












	