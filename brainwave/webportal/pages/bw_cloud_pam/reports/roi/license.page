bwpam_user_list = Dialog {
	title: $bwpam_licenseNLS.userlist
	height: 600
	width: 1150

	title = Variable
	type = Variable
	vault_code = Variable
	
	outaccountuid = Variable
	
	user_list = Dataset {
		view: bwpam_full_user_list with $bwpam_licenseNLS.other_type to other_type, vault_code to vault_code
		includes: OrPredicate {
			SameValuePredicate (type, Current user_type)
			StringPredicate (type) { when 'All' then True otherwise False }
		}
	}

	goDetails = NamedAction (
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowcontrols
												)
	)

	Group {
		layout: Layout { grab: horizontal True vertical False }
		Header {
			value: title
			layout: Layout { align: horizontal Center vertical Beginning grab: horizontal True vertical False }
			align: Center
			styling: titleStyle
		}
	}
	Group {
		layout: Layout { hint: width 975 grab: horizontal True vertical False }
		Text {
