bwpam_licenseNLS = NLS {
	title [en "CyberArk License Usage" fr "Utilisation de la licence CyberArk"]
	description [
		en "This report presents the analysis of CyberArk license usage. The analysis is focused on the number of current users, the distribution by type and the projection in the coming months and years by keeping the same pace of adding or removing users."
		fr "Ce rapport présente l'analyse de l'utilisation de la licence CyberArk. L'analyse est centrée sur le nombre d'utilisateurs actuels, la répartition par type et la projection dans les mois et années à venir en restant sur le même rythme d'ajout ou de retrait des utilisateurs."
	]
	vault [en 'Vault' fr 'Vault' ]
	vaultcaidentity [en 'Vault and CA Identity Users' fr 'Utilisateurs Vault et CA Identity' ]
	
	synthesis [en "Current Situation" fr "Situation actuelle"]
	
	totalnbaccount [en 'Total Number of Users' fr "Nombre total d'utilisateurs"]
	totalnbaccount.subtitle [en 'Users using one license' fr "Utilisateurs prenant une licence"]
	totalnbaccountsafesecrets [en "{0} SAFES AND {1} CREDENTIALS" fr "{0} SAFES ET {1} SECRETS"]
	userdistribution [en 'Distribution by User Types' fr "Répartition par type d'utilisateurs"]
