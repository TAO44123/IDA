	]
	identitiesjob [en 'Users with Job Title {0}' fr "Utilisateurs ayant le métier {0}"]
	identitiesorg [en 'Users in Organization {0}' fr "Utilisateurs dans l''organisation {0}"]
	detailsnotavailable [en 'Details for category "Others" not available' fr "Détail pour la catégorie 'Others' non disponible"]

	projection [en 'Projection' fr "Projection"]

	totalnbprojection [en 'Users (Estimate)' fr "Utilisateurs (estimation)"]
	estimatenbsafesecrets [en "{0} SAFES AND {1} CREDENTIALS (ESTIMATE)" fr "{0} SAFES ET {1} SECRETS (ESTIMATION)"]
	futuredays [en 'Projection of users accessing CyberArk in approximately' fr "Projection des utilisateurs de CyberArk dans environ"]
	futuredaystooltip [en 'Choose a date for which you want to get an estimate of the number of users.' fr "Choisissez une date pour laquelle vous souhaitez avoir une estimation du nombre d'utilisateurs"]
	projectiondate [en 'Date:' fr "Date :"]
	in1month [en '1 month' fr '1 mois']
	in3months [en '3 months' fr '3 mois']
	in6months [en '6 months' fr '6 mois']
	in9months [en '9 months' fr '9 mois']
	in1year [en '1 year' fr '1 an']
	in1yearandahalf [en '1 year and a half' fr '1 an et demi']
	in2years [en '2 years' fr '2 ans']
	in3years [en '3 years' fr '3 ans']
	totalprojectionaccount [en 'Estimate of the Total Number of Users' fr "Estimation du nombre total d'utilisateurs"]
	notenoughtimeslot [en 'Not enough data to display a projection' fr "Données insuffisantes pour afficher une projection"]
	
	booking [en 'Booking' fr "Réservation"]

	totalnbadaccount [en "Additional LDAP Users" fr "Utilisateurs LDAP supplémentaires"]
	totalnbbooking [en "Users on {0}" fr "Utilisateurs le {0}"]
	inactiveadaccount [en 'Inactive LDAP Users having CyberArk Rights' fr "Utilisateurs LDAP inactifs ayant des droits CyberArk"]
	jobdistribution [en 'Distribution by Job Titles (Top 8)' fr "Répartition par métier (Top 8)"]
	orgdistribution [en 'Distribution by Organizations (Top 8)' fr "Répartition par organisation (Top 8)"]
	fullinactiveadlist [en 'All LDAP users not using their CyberArk rights' fr "Tous les comptes LDAP n'utilisant pas leurs droits dans CyberArk"]
	warningadrecords [
		en 'There may be some duplicate LDAP account if the owner has several job titles or organizations.'
		fr "Certains comptes LDAP peuvent apparaître en double si le propriétaire a plusieurs métiers ou organisations."
	]
	inactiveadjob [en 'LDAP User Accounts with Owner Having Job Title {0}' fr "Compte LDAP dont le propriétaire a le métier {0}"]
	inactiveadorg [en 'LDAP User Accounts with Owner Working in Organization {0}' fr "Compte LDAP dont le propriétaire est dans l''organisation {0}"]
	booking.explananation [en "Number of LDAP users who have never logged in but have the right to do so via a group." fr "Nombre d'utilisateurs LDAP qui ne se sont jamais connectés mais qui ont un droit pour le faire via un groupe"]

	dormantroi [en 'Dormant Users' fr "Utilisateurs dormants"]

	lastconnection [en 'Dormant users for the last' fr 'Utilisateurs dormants depuis au moins']
	logindate [en 'Last Login Date Before' fr "Date de dernière connexion avant le"]
	nbdormanttitle [en 'Number of Dormant Users for a Certain Period of Time' fr "Nombre d'utilisateurs dormants depuis une certaine période"]
	nbdormant [en "Dormant Users" fr "Utilisateurs dormants"]
	potentialnbaccount [en '{0} REMAINING USER SLOTS' fr '{0} ENTREES UTILISATEURS RESTANTES']
	lastloginday [en 'Last Login Age' fr "Age du dernier login"]
	morethan1month [en 'More than 1 Month ({0} days)' fr "Plus d''un mois ({0} jours)"]
	morethan3months [en 'More than 3 Months ({0} days)' fr "Plus de 3 mois ({0} jours)"]
	morethan6months [en 'More than 6 Months ({0} days)' fr "Plus de 6 mois ({0} jours)"]
	morethan9months [en 'More than 9 Months ({0} days)' fr "Plus de 9 mois ({0} jours)"]
	morethan1year [en 'More than 1 Year ({0} days)' fr "Plus d''un an ({0} jours)"]
	morethan1yearandahalf [en 'More than 1 Year and a Half ({0} days)' fr "Plus d''un an et demi ({0} jours)"]
	morethan2years [en 'More than 2 Years ({0} days)' fr "Plus de 2 ans ({0} jours)"]
	morethan3years [en 'More than 3 Years ({0} days)' fr "Plus de 3 ans ({0} jours)"]
	morethan3years_unknown [en 'More than 3 Years' fr "Plus de 3 ans"]

	noright [en "Users with No Rights" fr "Utilisateurs sans droits"]
	totalnbnoright [en 'Total Number of Users with No Rights' fr "Nombre total d'utilisateurs sans droit dans CyberArk"]
	totalnbnoright.subtitle [en "Users with no rights using one license" fr "Utilisateurs sans droit prenant une licence"]

	details [en "Details" fr "Détails"]

	usertype [en 'User type' fr "Type d'utilisateur"]
	repository [en "Repository" fr "Référentiel"]

	guide [en 'Guide' fr 'Guide']
}

bwpam_license_script = StringService {
	javascript-file:"/webportal/pages/bw_cloud_pam/reports/roi/roi.javascript"
	javascript-method:getDate

    currentdate = Input {
        type: String
        mandatory: True
    }	

    nbdays = Input {
        type: Integer
        mandatory: True
    }	
}

bwpam_login_age = IntMapping {
	when > 1095 then $bwpam_licenseNLS.morethan3years(current)
	when > 730 then $bwpam_licenseNLS.morethan2years(current)
	when > 547 then $bwpam_licenseNLS.morethan1yearandahalf(current)
	when > 365 then $bwpam_licenseNLS.morethan1year(current)
	when > 273 then $bwpam_licenseNLS.morethan9months(current)
	when > 182 then $bwpam_licenseNLS.morethan6months(current)
	when > 91 then $bwpam_licenseNLS.morethan3months(current)
	when > 30 then $bwpam_licenseNLS.morethan1month(current)
}

style3years = Style { background: Color RGB(255,140,140) }
style2years = Style { background: Color RGB(255,155,155) }
style1yearandahalf = Style { background: Color RGB(255,170,170) }
style1year = Style { background: Color RGB(255,185,185) }
style9months = Style { background: Color RGB(255,200,200) }
style6months = Style { background: Color RGB(255,215,215) }
style3months = Style { background: Color RGB(255,230,230) }
style1month = Style { background: Color RGB(255,245,245) }

bwpam_age_styling = IntStylingTemplate {
	when > 1095 then style3years
	when > 730 then style2years
	when > 547 then style1yearandahalf
	when > 365 then style1year
	when > 273 then style9months
	when > 182 then style6months
	when > 91 then style3months
	when > 30 then style1month
}

bwpam_user_title = StringMapping {
	when 'Other' then $bwpam_licenseNLS.otheruserlist
	when 'Autre' then $bwpam_licenseNLS.otheruserlist
	when 'EPV' then $bwpam_licenseNLS.epvuserlist
	when 'Application' then $bwpam_licenseNLS.appuserlist
	when 'Built-in' then $bwpam_licenseNLS.builtinuserlist
	when 'CA Id Service' then $bwpam_licenseNLS.caidservice
}

tab_synthesis = Constant { type:Integer value:0 }
tab_distribution = Constant { type:Integer value:1 }
tab_projection = Constant { type:Integer value:2 }
tab_booking = Constant { type:Integer value:3 }
tab_dormantroi = Constant { type:Integer value:4 }
tab_noright = Constant { type:Integer value:5 }
tab_details = Constant { type:Integer value:6 }

bwpam_license = Page {
	title: $bwpam_licenseNLS.title
	description: $bwpam_licenseNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: dashboardMixin
//	homepage-for: All


	/* Parameters here */
	
	/* Variables here */
	selectedVault = Variable { type: String }
	selectedAccount = Variable 
	selectedDays = Variable { type: Integer }
	ad_inactive_users_count = Variable { type: Integer }
	nbdays = Variable { initial:365 multivalued:False type:Integer }

	active_tab = Variable { type: Integer initial:0 }

	/* Datasets and records here */
//	vaults = Dataset {
//	  view: vault_list
//	  disabled: False
//	}

	vaultsandcaid = Dataset {
	  view: vault_caid_list
	  disabled: False
	}

	caidentity = Record {
		view: bwpam_vault_CDS		
		disabled: False
	}

	absolute_total_users = Record {
		view: bwpam_total_users with selectedVault to vault_code
		disabled: False
	}

	total_users = Record {
		view: bwpam_total_users with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}
	
	total_users_previous = Record {
		view: bwpam_total_users with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}

	nb_safes = Record {
		view: bwpam_nb_safes with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}
	
	nb_secrets = Record {
		view: bwpam_nb_secrets with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}

	users_distribution = Dataset {
		view: bwpam_users_distribution with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}
	
	users_history = Dataset {
		view: bwpam_users_distribution_history with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_synthesis then False otherwise True }
	}
	
	inactive_ad_users = Dataset {
		view: bwpam_ad_inactive_users with selectedVault to vault_code
		count-variable: ad_inactive_users_count
		disabled: IntPredicate(active_tab) { when = Constant tab_booking then False otherwise True }
	}
	
	inactive_ad_job_distribution = Dataset {
		view: bwpam_ad_inactive_users_job with selectedVault to vault_code
		limit:8
		disabled: IntPredicate(active_tab) { when = Constant tab_booking then False otherwise True }
	}
	
	inactive_ad_org_distribution = Dataset {
		view: bwpam_ad_inactive_users_org with selectedVault to vault_code
		limit:8
		disabled: IntPredicate(active_tab) { when = Constant tab_booking then False otherwise True }
	}
	
	nb_timetlots = Record {
		view: bwpam_nb_timeslots
		disabled: False
	}

	users_projection = Record {
		view: bwpam_users_projection with selectedDays to ^days, 'Aggregate' to mode, $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_projection then False otherwise True }
	}
	
	users_projection_distribution = Dataset {
		view: bwpam_users_projection with selectedDays to ^days, 'Full' to mode, $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_projection then False otherwise True }
	}
	
	users_projection_history = Dataset {
		view: bwpam_users_projection with 'Full' to mode, $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_projection then False otherwise True }
	}
	
	safes_projection = Record {
		view: bwpam_safe_projection with selectedDays to ^days, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_projection then False otherwise True }
	}
	
	secrets_projection = Record {
		view: bwpam_secret_projection with selectedDays to ^days, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_projection then False otherwise True }
	}
	
	absolute_nb_identities = Record {
		view: bwpam_nb_identities with selectedVault to vault_code
		disabled: False
	}
	
	nb_identities = Record {
		view: bwpam_nb_identities with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_distribution then False otherwise True }
	}
	
	identities_job_distribution = Dataset {
		view: bwpam_identities_job with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_distribution then False otherwise True }
	}
	
	identities_org_distribution = Dataset {
		view: bwpam_identities_org with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_distribution then False otherwise True }
	}

	dormant_users_distribution = Dataset {
		view: bwpam_users_distribution with nbdays to nbdays unless-empty, $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_dormantroi then False otherwise True }
	}

	dormant_identities_job_distribution  = Dataset {
		view: bwpam_identities_job with nbdays to nbdays unless-empty, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_dormantroi then False otherwise True }
	}
	
	dormant_identities_org_distribution = Dataset {
		view: bwpam_identities_org with nbdays to nbdays unless-empty, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_dormantroi then False otherwise True }
	}
	
	absolute_roi = Record {
		view:bwpam_unusedaccountroi with nbdays to nbdays, selectedVault to vault_code
		disabled: False
	}

	roi = Record {
		view:bwpam_unusedaccountroi with nbdays to nbdays, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_dormantroi then False otherwise True }
	}

	// record used only in badge but badge is disable because it slows the first fisplay of the page (even without activating this tab)
	// absolute_noright_users = Record {
	// 	view: bwpam_all_users_count with $bwpam_licenseNLS.other_type to other_type
	// }

	noright_users = Record {
		view: bwpam_all_users_count with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_noright then False otherwise True }
	}

	noright_users_previous = Record {
		view: bwpam_all_users_count with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: IntPredicate(active_tab) { when = Constant tab_noright then False otherwise True }
	}

	user_list = Dataset {
		view: bwpam_full_user_list with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_details then False when = Constant tab_synthesis then False otherwise True }
	}
	
	noright_distribution = Dataset {
		view: all_users_no_right_distribution with $bwpam_licenseNLS.other_type to other_type, selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_noright then False otherwise True }
	}
	
	noright_identities_job_distribution = Dataset {
		view: bwpam_all_identities_no_right_job with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_noright then False otherwise True }
	}
	
	noright_identities_org_distribution = Dataset {
		view: bwpam_all_identities_no_right_org with selectedVault to vault_code
		disabled: IntPredicate(active_tab) { when = Constant tab_noright then False otherwise True }
	}
	
	/* Page content */
	showDetails = NamedAction (
		Dialog bwf_accountDetailsDialog (
					selectedAccount to inuid,
					True to inshowowner,
					True to inshowgroups,
					True to inshowapplications,
					True to inshowshares,
					True to inshowcontrols
		)
	
	)

	ConditionalGroup {
		layout: Layout { grab: horizontal True vertical False }
		compact: True
		StringCondition ( caidentity.repositorytype )
		{
			when "CDS" then [
				Group {
					layout: Layout { grab: horizontal True vertical False }
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaultsandcaid text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_licenseNLS.vaultcaidentity
						allow-none: True
		                         
					}
				}
			]
			otherwise [ 
				Group {
					layout: Layout { grab: horizontal True vertical False }
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaultsandcaid text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_licenseNLS.vault
						allow-none: True
		                         
					}
				}
			]
		}													
	}

	TabFolder {
		selected-index: active_tab
		layout:Layout { indent: horizontal 0 vertical 6 }

		TabItem {
			text:$bwpam_licenseNLS.synthesis
			badge: Eval "absolute_total_users.nb_users>0?absolute_total_users.nb_users:''"
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_licenseNLS.totalnbaccount
					IncludeHTMLWidget {
						layout: Layout { hint: height 150 width 400 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_licenseNLS.totalnbaccount.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(total_users.nb_users, 0) to count,
							value-of Difference(NonEmpty(total_users.nb_users, 0), NonEmpty(total_users_previous.nb_users, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_user_list ( $bwpam_licenseNLS.fulluserlist to title, 'All' to type, selectedVault to vault_code )
							]
						}
					}
					Header {
						hidden: StringPredicate ( selectedVault ) { when "CAIDENTITY" then True otherwise False }
						value: $bwpam_licenseNLS.totalnbaccountsafesecrets(NonEmpty(nb_safes.nb_safes, 0), NonEmpty(nb_secrets.nb_secrets, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}
				Group {
					border:True
					title:$bwpam_licenseNLS.userdistribution
					IncludeHTMLWidget {
						layout: Layout { hint: height 150 width 300 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: users_distribution ( user_type, user_type, nb_users ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_user_list ( Transform Current code using bwpam_user_title to title, Current code to type, selectedVault to vault_code )
							]
						}
					}
				}
			}
		
			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_licenseNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 300 width 600 align: horizontal Center vertical Center }
						template: multibarChart
						datasets: users_history ( timeslotuid, timeslot_date, user_type, user_type, nb_users ) to chartdata ( code, label, categorycode , category, count )
						bindings: 
							value-of 'right' to legendPosition,
							value-of True to isStacked,
							value-of True to showLegend,
							value-of Constant contrastedPalette to customColors
					}
				}

//				Group {
//					border:True
//					title:$bwpam_licenseNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
			}		
		}

		TabItem {
			text:$bwpam_licenseNLS.distribution
			badge: Eval "absolute_nb_identities.nb_identities>0?absolute_nb_identities.nb_identities:''"

			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_licenseNLS.reconciledusers
					IncludeHTMLWidget {
						layout: Layout { hint: height 130 width 150 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_licenseNLS.identities to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_identities.nb_identities, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
