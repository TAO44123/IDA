	fulluserlist [en 'All Users' fr "Tous les utilisateurs"]
	otheruserlist [en 'Non EPV and non Application Users' fr "Utilisateurs non EPV et non application"]
	appuserlist [en 'Users of Type Application' fr "Utilisateurs de type application"]
	epvuserlist [en 'Users of Type EPV' fr "Utilisateurs de type EPV"]
	builtinuserlist [en 'Default Built-in CyberArk Users' fr "Utilisateurs CyberArk présents par défaut"]
	caidservice [en 'Users of Type CyberArk Identity Service' fr "Utilisateurs de type CyberArk Identity Service"]
	warningnbrecords [
		en 'There may be some duplicate users if they have several job titles or organizations.'
		fr "Certains utilisateurs peuvent apparaître en double s'ils ont plusieurs métiers ou plusieurs organisations."
	]
	ldapidentifier [en 'LDAP Identifier' fr "Identifiant LDAP"]
	other_type [en 'Other' fr 'Autre']

	distribution [en 'HR Context' fr "Contexte RH"]

	reconciledusers [en 'Number of Users Matching an Identity' fr "Nombre d'utilisateurs rapprochés d'une identité"]
	identities [en 'identities' fr "identités"]
	identitiesjobdistribution [en 'Distribution by Job Titles (Top 8)' fr "Répartition par métier (Top 8)"]
	identititesorgdistribution [en 'Distribution by Organizations (Top 8)' fr "Répartition par organisation (Top 8)"]
	fullidentitylist [en 'All Identities' fr "Toutes les identités"]
	warningnbidentities [
		en 'There may be some duplicate identities if they have several user accounts, job titles or organizations.'
