				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_resourceNLS.nbresourcesforcontractors
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_resourceNLS.nbresourcesforcontractors.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_contractors_resources.nb_resources, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_contractor_resource_list ( $bwpam_resourceNLS.contractorsresourceslist to title, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_resourceNLS.nbcontractors(NonEmpty(nb_contractors.nb_contractors, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_resourceNLS.ratioresourcescontractors
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 160 grab:horizontal True vertical False align: horizontal Center vertical Center }
						template: mashupGaugeIndicator //liquidGaugeIndicator
						bindings:
							value-of NonEmpty(Ratio(Product(nb_contractors_resources.nb_resources, 100), nb_resources.nb_resources, "{0,number,integer}"), 0) to count,
							value-of 100 to maxValue,
							value-of $bwpam_resourceNLS.percent to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of False to hasThresholds,							
							value-of "#3F1F72" to gaugeColor,
							value-of False to animation	
					}
				}
			}

			Flow {
				disposition:Horizontal

				Group {
					border:True
					title:$bwpam_resourceNLS.ratioresourcescontractorshistory
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }
						template: lineChart
						datasets: ratio_contractors_resources ( timeslotuid, timeslot_date, resources_percent ) to chartdata ( code, label, count )
					}
				}

//				Group {
//					border:True
//					title:$bwpam_resourceNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 400 align: horizontal Center vertical Center }
//					}
//				}
			}
		}

		TabItem {
			text:$bwpam_resourceNLS.projection
			activation-event: Set True to active_projection
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
	
					Combo { 
						layout: Layout { hint: width 300 grab: horizontal False vertical False }
						options: Dynamic { data: vaults text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_resourceNLS.vault
						allow-none: True                          
					}
				}
				Group {
					layout: Layout { grab: horizontal False vertical False }

					Combo {
						variable: selectedDays
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						label: $bwpam_resourceNLS.futuredays
						tooltip: $bwpam_resourceNLS.futuredaystooltip
						allow-none: False
						options: Static {
							Option {
								text: $bwpam_resourceNLS.in1month
								value: 30
							}
							Option {
								text: $bwpam_resourceNLS.in3months
								value: 91
							}
							Option {
								text: $bwpam_resourceNLS.in6months
								value: 182
							}
							Option {
								text: $bwpam_resourceNLS.in1year
								value: 365
							}
							Option {
								text: $bwpam_resourceNLS.in1yearandahalf
								value: 547
							}
							Option {
								text: $bwpam_resourceNLS.in2years
								value: 730
							}
						}
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }

					Text {
						value: SubString(10) DateLDAP(@bwpam_resource_script(Date(PageTimeslot.CommitDate).valueLDAP to currentdate, Eval "0-selectedDays.get()" to nbdays)).value
						label: $bwpam_resourceNLS.projectiondate
						layout: Layout { grab: horizontal True vertical False }
						align: Left
						compact: True
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal
				hidden: OrPredicate {
							IntPredicate(nb_timetlots.nb) { when <2 then True otherwise False }
							IntPredicate(resource_projection.nb_resources) { when =0 then True when InvalidInteger then True otherwise False }
						}

				Group {
					border:True
					title:$bwpam_resourceNLS.totalprojectionresources
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_resourceNLS.totalnbprojectionresources to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(resource_projection.nb_resources, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
				}

				Group {
					border:True
					title:$bwpam_resourceNLS.totalprojectionplatforms
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_resourceNLS.totalnbprojectionplatforms to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(platform_projection.nb_platforms, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
				}
			}

//			Flow {
//				disposition:Horizontal
//				hidden: OrPredicate {
//							IntPredicate(nb_timetlots.nb) { when <2 then True otherwise False }
//							IntPredicate(resource_projection.nb_resources) { when =0 then True when InvalidInteger then True otherwise False }
//						}
//
//				Group {
//					border:True
//					title:$bwpam_resourceNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 400 align: horizontal Center vertical Center }
//					}
//				}
//			}

			Header {
				value: $bwpam_resourceNLS.notenoughtimeslot
				layout: Layout { grab: horizontal True vertical True align: horizontal Center vertical Beginning }
				align: Center
				styling: biggerText
				hidden: Not OrPredicate {
							IntPredicate(nb_timetlots.nb) { when <2 then True otherwise False }
							IntPredicate(resource_projection.nb_resources) { when =0 then True when InvalidInteger then True otherwise False }
						}
			}
		}
	}
}

