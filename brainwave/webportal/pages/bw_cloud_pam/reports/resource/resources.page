bwpam_all_platform_list = Dialog {
	title: $bwpam_resourceNLS.platformlist
	height: 600
	width: 1000

	title = Variable
	vault_code = Variable
	safe_uid = Variable

	platform_list = Dataset {
		view: bwpam_platforms with vault_code to vault_code
	}

	Group {
		layout: Layout { grab: horizontal True vertical False }
		Header {
			value: title
			layout: Layout { align: horizontal Center vertical Beginning grab: horizontal True vertical False }
			align: Center
			styling: titleStyle
		}
	}
	Group {
		Table {
			data:platform_list
			layout:Layout { grab: horizontal True vertical True }
			show-count:True
			show-filter:True
			configurable:True

			Column {
				column:platform
				header:$bwpam_resourceNLS.platforms
				sortable:True
				filterable:True
				width:250px
			}
		}
	}
}

bwpam_platform_list = Dialog {
	title: $bwpam_resourceNLS.platformlist
	height: 600
	width: 1000

	title = Variable
	safe_uid = Variable

	platform_list = Dataset {
		view: bwpam_platforms_per_safe with safe_uid to safe_uid
	}

	safe_vault = Record {
		view: bwpam_safe_vault with safe_uid to safe_uid
	}

	Group {
		layout: Layout { grab: horizontal True vertical False }
		Header {
			value: Concat(title, ' ', $bwpam_resourceNLS.vault_name(safe_vault.vault_displayname))
			layout: Layout { align: horizontal Center vertical Beginning grab: horizontal True vertical False }
			align: Center
			styling: titleStyle
		}
	}
	Group {
		Table {
			data:platform_list
			layout:Layout { grab: horizontal True vertical True }
			show-count:True
			show-filter:True
			configurable:True

			Column {
				column:platform
				header:$bwpam_resourceNLS.platforms
				sortable:True
				filterable:True
				width:250px
			}
		}
	}
}

