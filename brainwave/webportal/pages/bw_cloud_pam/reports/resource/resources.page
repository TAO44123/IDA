bwpam_resource_script = StringService {
	javascript-file:"/webportal/pages/bw_cloud_pam/reports/roi/roi.javascript"
	javascript-method:getDate

    currentdate = Input {
        type: String
        mandatory: True
    }	

    nbdays = Input {
        type: Integer
        mandatory: True
    }	
}

bwpam_resource = Page {
	title: $bwpam_resourceNLS.title
	description: $bwpam_resourceNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: dashboardMixin
//	homepage-for: All
	
	/* Parameters here */
	
	/* Variables here */
	selectedVault = Variable
	selectedSafe = Variable 
	selectedDays = Variable { type: Integer }
	nb_shared_resources = Variable { type: Integer }

	/* Variable to activate dataset only when tab is active */
	active_resources = Variable { initial:False multivalued:False type:Boolean }
	active_platforms = Variable { initial:False multivalued:False type:Boolean }
	active_distribution = Variable { initial:False multivalued:False type:Boolean }
	active_contractors = Variable { initial:False multivalued:False type:Boolean }
	active_projection = Variable { initial:False multivalued:False type:Boolean }
	
	/* Datasets and records here */
	vaults = Dataset {
	  view: vault_list
	}

	nb_resources = Record {
		view: bwpam_nb_resources with selectedVault to vault_code
		disabled: False
	}

	nb_resources_per_safe = Dataset {
		view: bwpam_nb_resources_per_safe with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_resources)
	}

	nb_resources_history = Dataset {
		view: bwpam_nb_resources_history with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_resources)
	}

	nb_resources_multiple_safes = Dataset {
		view: bwpam_nb_resources_multiple_safes with selectedVault to vault_code
		count-variable: nb_shared_resources
		disabled: False
	}

	nb_platforms = Record {
		view: bwpam_nb_platforms with selectedVault to vault_code
		disabled: False
	}

	nb_platforms_per_safe = Dataset {
		view: bwpam_nb_platforms_per_safe with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_platforms)
	}

	nb_safes_per_platform = Dataset {
		view: bwpam_nb_safes_per_platform with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_platforms)
	}

	nb_secrets_per_platform = Dataset {
		view: bwpam_nb_secrets_per_platforms with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_distribution)
	}

	nb_resources_per_platform = Dataset {
		view: bwpam_nb_resources_per_platforms with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_distribution)
	}

	nb_contractors_resources = Record {
		view: bwpam_nb_contractors_resources with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}

	nb_contractors = Record {
		view: bwpam_nb_contractors with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}

	ratio_contractors_resources = Dataset {
		view: bwpam_ratio_contractors_resources with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}

	resource_projection = Record {
		view: bwpam_resource_projection with selectedVault to vault_code, selectedDays to ^days
		disabled: Not BooleanPredicate (active_projection)
	}

	platform_projection = Record {
		view: bwpam_platform_projection with selectedVault to vault_code, selectedDays to ^days
		disabled: Not BooleanPredicate (active_projection)
	}

	nb_timetlots = Record {
		view: bwpam_nb_timeslots
		disabled: Not BooleanPredicate (active_projection)
	}

	TabFolder {
		layout:Layout { indent: horizontal 0 vertical 6 }
		TabItem {
			text:$bwpam_resourceNLS.resources
			badge: Eval "nb_resources.nb_resources>0?nb_resources.nb_resources:''"
			activation-event: Set True to active_resources
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
	
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaults text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_resourceNLS.vault
						allow-none: True                          
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_resourceNLS.nbresources
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_resourceNLS.nbresources.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_resources.nb_resources, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_resource_list ( $bwpam_resourceNLS.allresourcelist to title, 'All' to type, selectedVault to vault_code )
							]
						}
					}
				}

				Group {
					border:True
					title:$bwpam_resourceNLS.resourcespersafe
					IncludeHTMLWidget {
						layout: Layout { hint: height 200 width 400 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: nb_resources_per_safe ( displayname, uid, nb_resources ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of False to showOther,
							value-of 8 to nbMaxElements,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_safe_resource_list ( $bwpam_resourceNLS.saferesourcelist(Current label) to title, Current code to safe_uid )
							]
						}
					}
				}
			}

			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_resourceNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }
						template: lineChart
						datasets: nb_resources_history ( timeslotuid, timeslot_date, nb_resources ) to chartdata ( code, label, count )
					}
				}

//				Group {
//					border:True
//					title:$bwpam_resourceNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
			}		
		}

		TabItem {
			text:$bwpam_resourceNLS.shared
