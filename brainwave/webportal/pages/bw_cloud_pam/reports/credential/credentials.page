bwpam_secret = Page {
	title: $bwpam_secretNLS.title
	description: $bwpam_secretNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: dashboardMixin
//	homepage-for: All
	
	/* Parameters here */
	
	/* Variables here */
	selectedVault = Variable
	selectedSafe = Variable 
	selectedDays = Variable { type: Integer }
	nbDuplicateSecrets = Variable { type: Integer }
	nbDuplicateSecretsPrevious = Variable { type: Integer }
	
	/* Variable to activate dataset only when tab is active */
	active_synthesis = Variable { initial:False multivalued:False type:Boolean }
	active_duplicates = Variable { initial:False multivalued:False type:Boolean }
	active_contractors = Variable { initial:False multivalued:False type:Boolean }
	active_failedcpm = Variable { initial:False multivalued:False type:Boolean }
	active_disabledbycpm = Variable { initial:False multivalued:False type:Boolean }
	active_users = Variable { initial:False multivalued:False type:Boolean }
	
	/* Datasets and records here */
	vaults = Dataset {
	  view: vault_list
	}

	nb_secrets = Record {
		view: bwpam_nb_secrets with selectedVault to vault_code
		disabled: False
	}

	nb_secrets_previous = Record {
		view: bwpam_nb_secrets with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_synthesis)
	}

	nb_secrets_disabled_by_cpm = Record {
		view: bwpam_nb_secrets_disabled_by_cpm with selectedVault to vault_code
		disabled: False
	}

	nb_resources_disabled_by_cpm = Record {
		view: bwpam_nb_resources_disabled_by_cpm with selectedVault to vault_code
	}

	nb_resources_failed_cpm = Record {
		view: bwpam_nb_resources_failed_cpm with selectedVault to vault_code
	}

	nb_secrets_disabled_by_cpm_history = Dataset {
		view: bwpam_nb_secrets_disabled_by_cpm_history with selectedVault to vault_code
	}

	nb_secrets_failed_cpm_history = Dataset {
		view: bwpam_nb_secrets_failed_cpm_history with selectedVault to vault_code
	}
	
	nb_secrets_failed_cpm = Record {
		view: bwpam_nb_secrets_failed_cpm with selectedVault to vault_code
		disabled: False
	}	

	nb_secrets_per_platform = Dataset {
		view: bwpam_nb_secrets_per_platform with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_synthesis)
	}

	nb_secrets_history = Dataset {
		view: bwpam_nb_secrets_history_all with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_synthesis)
	}

	nb_duplicate_secrets = Dataset {
		view: bwpam_nb_duplicate_secrets with selectedVault to vault_code
		count-variable: nbDuplicateSecrets
		disabled: False
	}

	nb_duplicate_secrets_previous = Dataset {
		view: bwpam_nb_duplicate_secrets with selectedVault to vault_code
		count-variable: nbDuplicateSecretsPrevious
		disabled: Not BooleanPredicate (active_duplicates)
	}

	nb_duplicate_secrets_all = Dataset {
		view: bwpam_nb_duplicate_secrets with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_duplicates)
	}

	nb_users_no_cpm = Record {
		view: bwpam_nb_users_no_cpm with selectedVault to vault_code
		disabled: False
	}

	nb_users_no_cpm_previous = Record {
		view: bwpam_nb_users_no_cpm with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_users)
	}

	nb_identities_no_cpm = Record {
		view: bwpam_nb_identities_no_cpm with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	nb_secrets_no_cpm_org = Dataset {
		view: bwpam_nb_secrets_no_cpm_org with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_users)
	}

	nb_secrets_no_cpm = Record {
		view: bwpam_nb_secrets_no_cpm with selectedVault to vault_code
		disabled: False
	}

	nb_users_no_cpm_history = Dataset {
		view: bwpam_nb_users_no_cpm_history with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	nb_contractors_no_cpm = Record {
		view: bwpam_nb_contractors_no_cpm with selectedVault to vault_code
		disabled: False
	}

	nb_contractors_no_cpm_previous = Record {
		view: bwpam_nb_contractors_no_cpm with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_contractors)
	}

	nb_contractors_no_cpm_org = Dataset {
		view: bwpam_nb_contractors_no_cpm_org with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_contractors)
	}

	nb_contractors_no_cpm_history = Dataset {
		view: bwpam_nb_contractors_no_cpm_history with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}
	
	Group {
		layout: Layout { grab: horizontal True vertical False }
		compact: True
		Combo { 
			layout: Layout { hint: width 250 grab: horizontal False vertical False }
			options: Dynamic { data: vaults text: Current displayname value: Current code }
			variable: selectedVault
			label: $bwpam_secretNLS.vault
			allow-none: True                          
		}
	}
	
	TabFolder {
		layout:Layout { indent: horizontal 0 vertical 6 }
		TabItem {
			text:$bwpam_secretNLS.synthesis
			badge: Eval "nb_secrets.nb_secrets>0?nb_secrets.nb_secrets:''"
			activation-event: Set True to active_synthesis
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }

				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_secretNLS.nbsecrets
					IncludeHTMLWidget {
						layout: Layout { hint: height 150 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_secretNLS.nbsecrets.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_secrets.nb_secrets, 0) to count,
							value-of Difference(NonEmpty(nb_secrets.nb_secrets, 0), NonEmpty(nb_secrets_previous.nb_secrets, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_secrets_list ( $bwpam_secretNLS.nbsecrets.subtitle to title, selectedVault to vault_code )
							]
						}
					}
				}

				Group {
					border:True
					title:$bwpam_secretNLS.nbsecretsbyplatforms
					IncludeHTMLWidget {
						layout: Layout { hint: height 200 width 400 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: nb_secrets_per_platform ( platform, platform, nb_secrets ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of False to showOther,
							value-of 8 to nbMaxElements,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_secrets_list ( $bwpam_secretNLS.nbsecrets.subtitle to title, selectedVault to vault_code, Current code to platform )
							]
						}
					}
				}
			}
		
			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_secretNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }
						template: lineChart
						datasets: nb_secrets_history ( timeslotuid, timeslot_date, nb_secrets ) to chartdata ( code, label, count )
					}
				}

//				Group {
//					border:True
//					title:$bwpam_secretNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
			}		
		}

// Duplicated credentials
		TabItem {
			text:$bwpam_secretNLS.duplicates
			badge: Eval "nbDuplicateSecrets>0?nbDuplicateSecrets:''"
			activation-event: Set True to active_duplicates
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_secretNLS.nbduplicatesecrets
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_secretNLS.nbduplicatesecrets.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nbDuplicateSecrets, 0) to count,
							value-of Difference(NonEmpty(nbDuplicateSecrets, 0), NonEmpty(nbDuplicateSecretsPrevious, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_duplicate_secrets_list ( $bwpam_secretNLS.nbduplicatesecrets.subtitle to title, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_secretNLS.duplicateexplanation
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_secretNLS.duplicatesecrets
					IncludeHTMLWidget {
						layout: Layout { hint: height 200 width 400 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: nb_duplicate_secrets_all ( secret, secret, nb_duplicates ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of False to showOther,
							value-of 8 to nbMaxElements,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_safes_list ( $bwpam_secretNLS.safesforsecrets(Current label) to title, selectedVault to vault_code, Current code to destination )
							]
						}
					}
				}
			}
		
//			Flow {
//				disposition:Horizontal

//				Group {
//					border:True
//					title:$bwpam_secretNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
//			}
		}

// Users with access to credentials without CPM

		TabItem {
			text:$bwpam_secretNLS.users
			badge: Eval "nb_users_no_cpm.nb_users>0?nb_users_no_cpm.nb_users:''"
			activation-event: Set True to active_users
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }

				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_secretNLS.nbusersnocpm
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 350 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_secretNLS.nbusersnocpm.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_users_no_cpm.nb_users, 0) to count,
							value-of Difference(NonEmpty(nb_users_no_cpm.nb_users, 0), NonEmpty(nb_users_no_cpm_previous.nb_users, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_users_no_cpm_list ( $bwpam_secretNLS.nbusersnocpm.subtitle to title, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_secretNLS.nbidentitiesnocpm(NonEmpty(nb_identities_no_cpm.nb_identities, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_secretNLS.usersnocpmorg
					IncludeHTMLWidget {
						layout: Layout { hint: height 200 width 400 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: nb_secrets_no_cpm_org ( organizationdisplayname, organizationuid, nb_credentials ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of False to showOther,
							value-of 8 to nbMaxElements,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_organization_no_cpm_list ( $bwpam_secretNLS.usersnocpmorg.subtitle (Current label) to title, Current code to org_uid, selectedVault to vault_code )
							]
						}
					}
				}
			}

			Flow {
				disposition:Horizontal

				Group {
					border:True
					title:$bwpam_secretNLS.usersnocpmhistory
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }
						template: lineChart
						datasets: nb_users_no_cpm_history ( timeslotuid, timeslot_date, nb_users ) to chartdata ( code, label, count )
						bindings: 
						   value-of False to animation					}
				}

//				Group {
//					border:True
//					title:$bwpam_cpmNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 400 align: horizontal Center vertical Center }
//					}
//				}
			}
		}

// Contractors with access to credentials without CPM

		TabItem {
			text:$bwpam_secretNLS.contractors
			badge: Eval "nb_contractors_no_cpm.nb_contractors>0?nb_contractors_no_cpm.nb_contractors:''"
