						template: lineChart
						datasets: nb_contractors_no_cpm_history ( timeslotuid, timeslot_date, nb_contractors ) to chartdata ( code, label, count )
						bindings: 
						   value-of False to animation					}
				}
			}
		}

// Credentials with CPM status in Failed
		TabItem {
			text:$bwpam_secretNLS.failedcpm
			badge: Eval "nb_secrets_failed_cpm.nb_secrets>0?nb_secrets_failed_cpm.nb_secrets:''"
			activation-event: Set True to active_failedcpm
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }

				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_secretNLS.nbfailedcpm
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 350 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_secretNLS.nbfailedcpm.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_secrets_failed_cpm.nb_secrets, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_secrets_failed_cpm_list ( $bwpam_secretNLS.nbfailedcpm.subtitle to title, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_secretNLS.nbfailedresources(NonEmpty(nb_resources_failed_cpm.nb_resources, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_secretNLS.ratiosecretsfailedcpm
					IncludeHTMLWidget {
						layout: Layout { hint: height 160 width 160 grab:horizontal True vertical False align: horizontal Center vertical Center }
						template: mashupGaugeIndicator //liquidGaugeIndicator
						bindings:
							value-of NonEmpty(Ratio(Product(nb_secrets_failed_cpm.nb_secrets, 100), nb_secrets.nb_secrets, "{0,number,integer}"), 0) to count,
							value-of 100 to maxValue,
							value-of $bwpam_secretNLS.percent to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of False to hasThresholds,							
							value-of "#3F1F72" to gaugeColor	,
							value-of False to animation	
