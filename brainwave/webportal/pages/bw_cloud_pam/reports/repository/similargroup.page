/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/resources/access360_nls.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"
import "/webportal/pages/bw_comparison/group_comparison.page"

/* Nationalized labels here */
bwcdpamr_repository_similargroupNLS = NLS {
	title [en "CyberArk - Analysis of Similar Groups" fr "CyberArk - Analyse des groupes similaires"]
	dyntitle [en "CyberArk - {0} Analysis of Similar Groups" fr "CyberArk - Analyse des groupes similaires pour {0}"]
	limited [
		en "More than {0} groups found. Please refine your analysis criteria."
		fr  "Plus de {0} groupes trouvés. Veuillez affiner vos critères d'analyse"
	]
	groupfilter [en "Filter" fr "Filtre"]
	groupfilter_tooltip [en "Filter by group code or name" fr "Filtrer par code groupe ou nom de groupe"]
	
	Similarity_threshold [en "Similarity threshold" fr "Seuil de similarité"]
	Similarity_threshold_tooltip [en "Filter the results based on the given similarity threshold\nall the results under the threshold will be filtered" fr "Filtrer les résultats sur la base du seuil de similarité configuré\ntous les résultats sous le seuil seront filtrés"]
	nbmemberthreshold [en "Minimum number of users" fr "Nombre de comptes minimum"]
	nbmemberthreshold_tooltip [	en "minimum number of users to consider\nall results with a number of joint users under the threshold\nwill be excluded from he results" 
								fr "nombre de comptes minimum à considérer\ntous les résultats avec un nombre de comptes commun inférieur au seuil\nseront exclus des résultats"]
	apply [en 'Apply filter' fr 'Appliquer le filtre']
	analysis [en 'Analysis' fr 'Analyse']
	refgroup [en 'Reference group' fr 'Groupe de référence']
	group [en 'Group' fr 'Groupe']
	details [en 'Details' fr 'Détails']
	empty [en "This repository does not contain groups" fr "Ce référentiel ne contient pas de groupes"]
	noresults [en "No results found. Try to refine the filter settings." fr "Pas de résultats, essayez d'affiner les paramètres de filtrage"]
	comparegroups [en 'Click to compare the group content' fr 'Cliquer pour comparer le contenu des groupes']
	refgroupcodeheader [en "reference group code" fr "code groupe de référence"]
	refgroupheader [en "Reference Group" fr "Groupe de référence"]
	groupdetailtooltip [en "Click to display group details." fr "Cliquer pour afficher les détails du groupe."]
	compgroupcodeheader [en "Comparison Group Code" fr "Code groupe de comparaison"]
	compgroupheader [en "Comparison Group" fr "Groupe de comparaison"]
	nbaccountscommonheader [en "number of users\nin common" fr "nb de comptes\nen commun"] 
	similarityheader [en "similarity\n(percent)" fr "similarité\n(pourcentage)"]
	similaritytooltip [	en "100% means the reference group user accounts and the comparison group user accounts are the same.\nThe higher the percentage, the greater the opportunity to merge those groups."
						fr "100% signifie que les comptes du groupe de référence et les comptes du groupe de comparaison sont les mêmes\nplus le pourcentage est élevé, plus vous avez de chances de pouvoir fusionner ces groupes" ]
	pt_tooltip [en "{0}% similarity\nwith {1} user accounts in common" fr "{0}% de similarité\navec {1} comptes en commun"]

	included [en "Included in\ncomparison group" fr "Inclus dans\nle groupe de comparaison"]
	includedtooltip [	en "Yes means the reference group user accounts are all\nincluded in the comparison group.\nTherefore, the reference group can be considered as a sub-group\nof the comparison group."
						fr "Oui signifie que tous les comptes du groupe de référence\nsont inclus dans le groupe de comparaison\nle groupe de référence peut donc être considéré comme étant un sous groupe\ndu groupe de comparaison" ]
	includedpercent [en "inclusion factor\n(percent)" fr "facteur d'inclusion\n(pourcentage)"]
	includedpercenttooltip [	en "100% means the reference group user accounts are all\nincluded in the comparison group.\nTherefore, the reference group can be considered as a sub-roup\nof the comparison group."
								fr "Oui signifie que tous les comptes du groupe de référence\nsont inclus dans le groupe de comparaison\nle groupe de référence peut donc être considéré comme étant un sous groupe\ndu groupe de comparaison" ]
	description [
		fr "Ce rapport permet d'analyser les similitudes entre les groupes. Un calcul est effectué afin d'identifier le nombre de comptes actifs en commun entre les groupes. Les résultats sont présentés sous la forme d'un tableau croisé dynamique. Seuls les groupes directs sont pris en compte. Il est aussi possible de présenter les résultats sous forme de liste afin de faciliter l'export des résultats. Quelque soit le mode d'affichage retenu, il est possible d'obtenir des détails sur les 'profils applicatifs' ainsi que d'identifier les comptes en commun et les comptes spécifiques de chaque profil."
		en "This report allows the analysis of the similarities between groups. A calculation is performed to identify the number of active user accounts in common between the groups. The results are presented in the form of a pivot table. Only direct group assignments are taken into consideration. It is also possible to present the results in a list format in order to facilitate the their export. Regardless of the display mode selected, it is possible to obtain details on the \"application profiles\" as well as to identify the common and specific user accounts of each profile."
	]
	
	accesstypefilter [
		fr "Type d'accès"
		en "Access Type"
	]
	
	accesstypefilter.safetype [
		fr "Groupes donnant accès aux safes"
		en "Groups Giving Access to Safes"
	]
	
	accesstypefilter.vaulttype [
		fr "Groupes donnant accès aux vaults"
		en "Groups Giving Access to Vaults"
	]
	
	vaultsfilter [
		fr "Filtrer par vault"
		en "Filter by Vault"
	]
	
	domain [
		en "Domain"
		fr "Domaine"
	]
}

green1style = Style {
	background:Color RGB(0, 203, 178)
}
green2style = Style {
	background:Color RGB(0, 178, 140)
}
green3style = Style {
	background:Color RGB(0, 153, 102)
	foreground:white
}
green4style = Style {
	background:Color RGB(0, 128, 64)
	foreground:white
}

similarStyle = IntStylingTemplate {
	when >80 then green4style
	when >60 then green3style
	when >40 then green2style
	when >20 then green1style
}

clusterBuckets = IntMapping {
	when = 100 then 'A'
	when >= 90 then 'B'
	when >= 90 then 'C'
	when >= 90 then 'D'
	when >= 90 then 'E'
	when >= 90 then 'F'
	otherwise 'G'
}

inclusionMapping = IntMapping {
	when = 100 then $yesnoNLS.yes
	otherwise $yesnoNLS.no
}

bwcdpamr_repository_similargroup_threshold = Constant {
	value:200
	type:Integer
}

bwcdpamr_repository_similargroup = Page {
	title: $bwcdpamr_repository_similargroupNLS.title
	description: $bwcdpamr_repository_similargroupNLS.description
	dynamic-title: $bwcdpamr_repository_similargroupNLS.dyntitle(repository.displayname)
	//tags: "server", "repositoryext" priority 200, "AD","byuid" , "analytics", "cyberark"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	enter-event:Set 80 to similarityThreshold, Set 80 to currentsimilarityThreshold  
	
	/* Parameters here */
    uid = Parameter { type: String 
    	constraint: Lookup {
    		data: alldomains
    		text: Current code
    		value: Current uid
    	}
    	mandatory: True
    	label: $bwcdpamr_repository_similargroupNLS.domain
    }
    
	similarityThreshold = Variable { type:Integer }
	nbmembersThreshold = Variable { initial:3 type:Integer }
	codefilter = Variable { type:String }

	currentsimilarityThreshold = Variable { type:Integer }
	currentnbmembersThreshold = Variable { initial:3 type:Integer }
	currentcodefilter = Variable { type:String }
	
	/* Variables here */
	grp1 = Variable
	grp2 = Variable

	ptgrp1 = Variable
	ptgrp2 = Variable
	
	selectedTab = Variable
	
	grpCount = Variable 
	
	accesstype = Variable
	currentaccesstype = Variable
	selectedVault = Variable
	currentselectedVault = Variable
	
	/* Datasets and records here */
	repository = Record {
		view:bwf_repositoryDetail with uid to uid
	}

	vaultList = Dataset {
		view: bwcdpam_vaultlist
	}
	
	alldomains = Dataset {
		view: bwpam_analyticsdomain
	}
	
	grpCount = Dataset {
		view:bwcdpamr_repository_similargroupnb with uid to uid, currentnbmembersThreshold to nbmembersThreshold, currentcodefilter to codefilter
		disabled:IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True } 
		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:500
			}
		]
	}


	groupmining = Dataset {
		view:bwcdpamr_repository_similargroupmembersbv with uid to uid, currentsimilarityThreshold to threshold, currentnbmembersThreshold to nbmembersThreshold, currentcodefilter to codefilter, currentaccesstype to accesstype, currentselectedVault to vault
		disabled:
			OrPredicate {
				// disable mining if more than bwcdpamr_repository_similargroup_threshold groups are spotted
				IntPredicate(Count grpCount) { when >Constant bwcdpamr_repository_similargroup_threshold then True otherwise False }	
				IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True } 
			}
		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:500
			}
		]
	}

	groupminingdetails = Dataset {
		view:bwcdpamr_repository_similargroupmembersbv with uid to uid, currentsimilarityThreshold to threshold, currentnbmembersThreshold to nbmembersThreshold, True to dedup, currentcodefilter to codefilter, currentaccesstype to accesstype, currentselectedVault to vault
		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:500
			}
		]
		disabled:
		OrPredicate {
			IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True } 
			StringPredicate(selectedTab) { when "DETAILS" then False otherwise True }
		}
	}

	grp1detail = NamedAction (
		Dialog bwf_groupDetailsDialog(
								grp1 to inuid,
								True to inshowaccounts,
								True to inshowapplications,
								True to inshowshares,
								True to inshowperorg,
								True to inshowperjob)
	)

	grp2detail = NamedAction (
		Dialog bwf_groupDetailsDialog(
								grp2 to inuid,
								True to inshowaccounts,
								True to inshowapplications,
								True to inshowshares,
								True to inshowperorg,
								True to inshowperjob)
	)

	grpcomparison = NamedAction (
		Dialog bwc_group_comparison_dialog(grp1 to inuid, grp2 to inotheruid)
	)
	
	/* Page content */
	ConditionalGroup {
		IntCondition(repository.bwa_repositoryanalytics_nbgroup) {
			when >0 then [
				Grid {
					columns:GridColumn,GridColumn,GridColumn,GridColumn,GridColumn {width:grow},GridColumn
					layout:Layout {grab:horizontal True vertical False hint:height 40}
					GridRow {
						GridCell {
							Combo {
								variable:similarityThreshold
								label:$bwcdpamr_repository_similargroupNLS.Similarity_threshold
								tooltip:$bwcdpamr_repository_similargroupNLS.Similarity_threshold_tooltip
								allow-none:False
								options:Static {
									Option { value:100 text:"100%" }
									Option { value:90 text:"90%" }
									Option { value:80 text:"80%" }
									Option { value:70 text:"70%" }
									Option { value:60 text:"60%" }
									Option { value:50 text:"50%" }
									Option { value:40 text:"40%" }
									Option { value:30 text:"30%" }
									Option { value:20 text:"20%" }
									Option { value:10 text:"10%" }
								}
							}
						}
						GridCell {
							Spinner {
								variable:nbmembersThreshold
								minimum:1
								maximum:99999
								label:$bwcdpamr_repository_similargroupNLS.nbmemberthreshold
								tooltip:$bwcdpamr_repository_similargroupNLS.nbmemberthreshold_tooltip
							}
						}
						GridCell {
							Combo {
								variable: accesstype
								label: $bwcdpamr_repository_similargroupNLS.accesstypefilter
								allow-none: True
								options: Static {
									Option { value: "ca_safe" text: $bwcdpamr_repository_similargroupNLS.accesstypefilter.safetype }
									Option { value: "ca_vault" text: $bwcdpamr_repository_similargroupNLS.accesstypefilter.vaulttype }
								}
							}
						}
						GridCell {
							Combo {
								variable: selectedVault
								label: $bwcdpamr_repository_similargroupNLS.vaultsfilter
								allow-none: True
								modify-event: StringCase ( accesstype ) {
									when IsEmpty then [ Set "ca_vault" to accesstype ]
								}
								options: Dynamic {
									data: vaultList
									text: Current displayname
									value: Current uid
								}
							}
						}
						GridCell {}
						GridCell {
							Button {
								actions:Set nbmembersThreshold to currentnbmembersThreshold, Set similarityThreshold to currentsimilarityThreshold, Set codefilter to currentcodefilter, Set accesstype to currentaccesstype, Set selectedVault to currentselectedVault
								text:$bwcdpamr_repository_similargroupNLS.apply
							}
						}
					}
				}
					Header {
						value:$bwcdpamr_repository_similargroupNLS.limited(Constant bwcdpamr_repository_similargroup_threshold)
						hidden: IntPredicate(Count grpCount) { when >=Constant bwcdpamr_repository_similargroup_threshold then False otherwise True }	
						styling:errorStyle
					}
				TabFolder {
					hidden: IntPredicate(Count grpCount) { when <Constant bwcdpamr_repository_similargroup_threshold then False otherwise True }	
					TabItem {
						text:$bwcdpamr_repository_similargroupNLS.analysis		
						activation-event:Set "ANALYSIS" to selectedTab
					
						ConditionalGroup {
							IntCondition(Count groupmining) {
								when =0 then [
									Header {
										value:$bwcdpamr_repository_similargroupNLS.noresults					
									}					
								]
								otherwise [
									CrossTable {
										data:groupmining		
										multi-selection:False
										cluster-sortable:True
										layout:Layout {cell-width:32px  grab: horizontal True vertical True}
										rows:Dim { value:grp1uid label:grp1displayname header:$bwcdpamr_repository_similargroupNLS.refgroup selection:ptgrp1 header-click:grp1 }
										columns:Dim { value:grp2uid label:grp2displayname header:$bwcdpamr_repository_similargroupNLS.group selection:ptgrp2 header-click:grp2 }
										cell-content:CellContent { text:Current similarity cluster-value:Transform Current similarity using clusterBuckets styling:StylingTemplateSelection (Current similarity) using similarStyle align:Right tooltip:$bwcdpamr_repository_similargroupNLS.pt_tooltip(Current similarity, Current nbaccount) } 
										row-header-click:ExecuteNamedAction grp1detail
										column-header-click:ExecuteNamedAction grp2detail
									}
									ButtonGroup {
										Button {
											actions:Set ptgrp1 to grp1, Set ptgrp2 to grp2, ExecuteNamedAction grpcomparison
											text:$bwcdpamr_repository_similargroupNLS.comparegroups					
											disabled:
												OrPredicate {
													StringPredicate(ptgrp1) { when IsEmpty then True otherwise False }
													StringPredicate(ptgrp2) { when IsEmpty then True otherwise False }
												}		
										}
									}
								]				
							}
						}
					}
					TabItem {
						text:$bwcdpamr_repository_similargroupNLS.details		
						activation-event:Set "DETAILS" to selectedTab
					
						Table {
							data:groupminingdetails			
							layout:Layout {grab: horizontal True vertical True}
							configurable:True
							persist-configuration:True
							persist-configuration-key:uid
							show-count:True
							show-filter:True
						
							Column {
								column:grp1uid
								selection:grp1
								hidden:True
							}
							Column {
								column:grp1code
								actions:ExecuteNamedAction grp1detail
								header:$bwcdpamr_repository_similargroupNLS.refgroupcodeheader
								width:300px
								initially-masked:True
								sortable:True
								filterable:True
								tooltip:$bwcdpamr_repository_similargroupNLS.groupdetailtooltip
							}
							Column {
								column:grp1displayname
								actions:ExecuteNamedAction grp1detail
								header:$bwcdpamr_repository_similargroupNLS.refgroupheader
								width:300px
								sortable:True
								filterable:True
								tooltip:$bwcdpamr_repository_similargroupNLS.groupdetailtooltip
							}
							Column {
								column:grp2uid
								selection:grp2
								hidden:True
							}
							Column {
								column:grp2code
								actions:ExecuteNamedAction grp2detail
								header:$bwcdpamr_repository_similargroupNLS.compgroupcodeheader
								width:300px
								initially-masked:True
								sortable:True
								filterable:True
								tooltip:$bwcdpamr_repository_similargroupNLS.groupdetailtooltip
							}
							Column {
								column:grp2displayname
								actions:ExecuteNamedAction grp2detail
								header:$bwcdpamr_repository_similargroupNLS.compgroupheader
								width:300px
								sortable:True
								filterable:True
								tooltip:$bwcdpamr_repository_similargroupNLS.groupdetailtooltip
							}
							Column {
								column:nbaccount
								header:$bwcdpamr_repository_similargroupNLS.nbaccountscommonheader
								actions:ExecuteNamedAction grpcomparison
								tooltip:$bwcdpamr_repository_similargroupNLS.comparegroups
								width:100px
								align:Right 
								sortable:True
							}
							Column {
								column:similarity
								width:100px
								header:$bwcdpamr_repository_similargroupNLS.similarityheader
								styling:StylingTemplateSelection (Current similarity) using similarStyle 
								sortable:True
								align:Right 
								tooltip:$bwcdpamr_repository_similargroupNLS.similaritytooltip
								
							}
							Column {
								column:included
								text:Transform Current included using inclusionMapping
								width:160px
								header:$bwcdpamr_repository_similargroupNLS.included
								sortable:True
								align:Right 
								tooltip:$bwcdpamr_repository_similargroupNLS.includedtooltip
							}
							Column {
								column:included
								width:160px
								header:$bwcdpamr_repository_similargroupNLS.includedpercent
								sortable:True
								align:Right 
								tooltip:$bwcdpamr_repository_similargroupNLS.includedpercenttooltip
								initially-masked:True
							}
						}		
						ButtonGroup {
							Button {
								actions:ExecuteNamedAction grpcomparison
								text:$bwcdpamr_repository_similargroupNLS.comparegroups					
								disabled:
									OrPredicate {
										StringPredicate(grp1) { when IsEmpty then True otherwise False }
										StringPredicate(grp2) { when IsEmpty then True otherwise False }
									}		
							}
						}
					}
				}
			]		
			otherwise [
				Header {
					value:$bwcdpamr_repository_similargroupNLS.empty
				}			
			]
		} 
	}
}
