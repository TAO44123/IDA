	uid = Variable // either jobtitleuid or organizationuid depending on type

	outaccountuid = Variable
	outidentityuid = Variable

	user_list = Dataset {
		view: bwpam_groups_identities_list
		includes: OrPredicate {
			StringPredicate (type) { when 'All' then True otherwise False }
			AndPredicate {
				StringPredicate (type) { when 'Job' then True otherwise False }
				StringPredicate (uid) { when IsEmpty then False otherwise True }
				SameValuePredicate (uid, Current jobtitleuid)
			}
			AndPredicate {
				StringPredicate (type) { when 'Job' then True otherwise False }
				StringPredicate (uid) { when 'others' then True otherwise False }
