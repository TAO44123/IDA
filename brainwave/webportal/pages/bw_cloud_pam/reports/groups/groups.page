bwpam_groups = Page {
	title: $bwpam_groupsNLS.title
	description: $bwpam_groupsNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: dashboardMixin
//	homepage-for: All
	
	/* Parameters here */
	
	/* Variables here */
	selectedparentgroupuid = Variable
	selectedVault = Variable
	selectedSafeChart = Variable		
	selectedGroup = Variable 
	selectedNestedGroupChart = Variable
	selectedUserChart = Variable
	selectedDays = Variable { type: Integer }
	ad_inactive_groups_count = Variable { type: Integer }
	
	/* Variable to activate dataset only when tab is active */
	active_synthesis = Variable { initial:False multivalued:False type:Boolean }
	active_users = Variable { initial:False multivalued:False type:Boolean }
	active_identities = Variable { initial:False multivalued:False type:Boolean }
	active_nested = Variable { initial:False multivalued:False type:Boolean }
	active_safeaccess = Variable { initial:False multivalued:False type:Boolean }
	active_details = Variable { initial:False multivalued:False type:Boolean }
	
	/* Datasets and records here */

	vaults = Dataset {
	  view: vault_list
	}

	total_groups = Record {
		view: bwpam_groups_total_safevault 
		disabled: False
	}
	
	total_groups_previous = Record {
		view: bwpam_groups_total_safevault 
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_synthesis)
	}

	total_groups_safes = Record {
		view: bwpam_total_groups_safes
		disabled: Not BooleanPredicate (active_synthesis)
	}

	total_groups_vault = Record {
		view: bwpam_total_groups_vault
		disabled: Not BooleanPredicate (active_synthesis)
	}

	groups_top8 = Dataset {
		view: bwpam_groups_total_top8
		limit: 8		
		disabled: Not BooleanPredicate (active_synthesis)
	}
	
	users_top8 = Dataset {
		view: bwpam_users_nb_groups
		limit: 8		
		disabled: Not BooleanPredicate (active_users)
	}

	users_top8_rec = Record {
		view: bwpam_users_nb_groups	with selectedUserChart to useruid
		disabled: Not BooleanPredicate (active_users)
	}
		
	groups_history = Dataset {
		view: bwpam_groups_distribution_history
		disabled: Not BooleanPredicate (active_synthesis)
	}
	
	nb_nested = Record {
		view: bwpam_indirect_ldap_groups 
		disabled: False
	}
	
	groups_nested_nb_subgroups = Dataset {
		view: bwpam_indirect_nbsubgroups
		disabled: Not BooleanPredicate (active_nested)
	}
	
	groups_nested_nb_subgroups_rec = Record {
		view: bwpam_indirect_nbsubgroups with selectedNestedGroupChart to groupuid
		disabled: Not BooleanPredicate (active_nested)
	}

// disabled because too slow
//	groups_nested_distribution_history = Dataset {
//		view: bwpam_groups_distribution_indirect_history with $bwpam_groupsNLS.chartcategory.direct to direct_nls , $bwpam_groupsNLS.chartcategory.indirect to indirect_nls
//		disabled: Not BooleanPredicate (active_nested)
//	}

	nb_users = Record {
		view: bwpam_groups_nb_users //with selectedVault to vault_code
		disabled: False
	}
	
	nb_identities = Record {
		view: bwpam_groups_nb_identities //with selectedVault to vault_code
		disabled: False
	}

	nb_identities_internal = Record {
		view: bwpam_groups_nb_identities_internal //with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_identities)
	}

	nb_identities_external = Record {
		view: bwpam_groups_nb_identities_external //with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_identities)
	}

	group_list = Dataset {
		view: bwpam_groups_total_list with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_details)
	}

	identities_org_distribution = Dataset {	
		view: bwpam_groups_identities_org 
		disabled: Not BooleanPredicate (active_identities)
	}
	
	groups_identity_history = Dataset {	
		view: bwpam_groups_nb_id_inex_history
		disabled: Not BooleanPredicate (active_identities)
	}
	
	indirect_nb_safe = Record {
		view: bwpam_safe_indirect_group_nb
		disabled: False
	}
	
	safe_group_nb_top8 = Dataset { 
		view: bwpam_safe_group_nb_top8
		limit: 8		
		disabled: Not BooleanPredicate (active_safeaccess)
	}
	
	safe_group_nb_top8_rec = Record { 
		view: bwpam_safe_group_nb_top8 with selectedSafeChart to safeuid
		disabled: Not BooleanPredicate (active_safeaccess)
	}
	
	safe_indirect_group_nb_history = Dataset {	
		view: bwpam_safe_indirect_group_nb_history
		disabled: Not BooleanPredicate (active_safeaccess)
	}
	
	/* Page content */
	showDetails = NamedAction (
		Dialog bwf_groupDetailsDialog (
					selectedGroup to inuid,
					True to inshowaccounts,
					True to inshowvaults,
					True to inshowsafes,
					True to inshowperorg,
					True to inshowperjob,					
					True to inshowapplications,
					True to inshowshares,
					True to inshowcontrols
		)
	
	)

	TabFolder {
		layout:Layout { indent: horizontal 0 vertical 6 }
		
//TAB1 SYNTHESIS
		TabItem {
			text:$bwpam_groupsNLS.synthesis
			badge: Eval "total_groups.nb_group>0?total_groups.nb_group:''"
			activation-event: Set True to active_synthesis
			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_groupsNLS.totalnbgroup
					IncludeHTMLWidget {
						layout: Layout { hint: height 150 width 400 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_groupsNLS.totalnbgroup.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(total_groups.nb_group, 0) to count,
							value-of Difference(NonEmpty(total_groups.nb_group, 0), NonEmpty(total_groups_previous.nb_group, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_group_list ( $bwpam_groupsNLS.fullgrouplist to title, 'All' to type )
							]
						}
					}
					Header {
						value: $bwpam_groupsNLS.totalnbgroupsafesvaults(NonEmpty(total_groups_safes.nb_group, 0), NonEmpty(total_groups_vault.nb_group, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}
				Group {
					border:True
					title:$bwpam_groupsNLS.grouptop8
					IncludeHTMLWidget {
						layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: groups_top8 ( displayname, uid, bw_pam_groupmetrics_nb_safes) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors,
							value-of False to showOther,
							value-of 8 to nbMaxElements 
						widget-events: {
							when onclick then [
								Dialog bwpam_safe_group_list ( $bwpam_groupsNLS.safelistgroup(NonEmpty(Current label, 0)) to title, Current code to group )
							]
						}
					}
				}
			}
		
			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_groupsNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }					
						template: multibarChart
						datasets: groups_history ( timeslotuid, timeslot_date, group_type, group_type, nb_groups ) to chartdata ( code, label, categorycode , category, count )
						bindings: 
							value-of 'right' to legendPosition,
							value-of True to isStacked,
							value-of True to showLegend,
							value-of Constant contrastedPalette to customColors
					}					
				}
			}		
		}

//TAB2 USERS IN GROUPS
		TabItem {
			text:$bwpam_groupsNLS.users
			badge: Eval "nb_users.nb_users>0?nb_users.nb_users:''"
			activation-event: Set True to active_users
			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_groupsNLS.nbusers
					IncludeHTMLWidget {
						layout: Layout { hint: height 130 width 400 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_groupsNLS.userscyberark to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_users.nb_users, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_group_alluser_list ( $bwpam_groupsNLS.groupuserlist to title )
							]
						}
					}			
				}
				
				Group {
					border:True
					title:$bwpam_groupsNLS.usertop8
					IncludeHTMLWidget {
						layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: users_top8 ( login, uid, nb_groups) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors,
							value-of False to showOther,
							value-of 8 to nbMaxElements
						widget-events: {
							when onclick then [
								Set Current code to selectedUserChart,							
								Dialog bwpam_group_user_list ( $bwpam_groupsNLS.grouplistuser(NonEmpty(Current label, 0), users_top8_rec.repo_displayname) to title, Current code to user_uid)
							]
						}
					}
				}				
			}
		}

//TAB3 IDENTITIES IN GROUPS
		TabItem {
			text:$bwpam_groupsNLS.identities
			badge: Eval "nb_identities.nb_identities>0?nb_identities.nb_identities:''"
			activation-event: Set True to active_identities
			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_groupsNLS.totalnbidentities
					IncludeHTMLWidget {
						layout: Layout { hint: height 130 width 400 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_groupsNLS.identities to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_identities.nb_identities, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_group_allidentity_list ( $bwpam_groupsNLS.groupidentitylist to title, 'All' to type  )
							]
						}
					}
					Header {
						value: $bwpam_groupsNLS.identitiesinout(NonEmpty(nb_identities_internal.nb_identities, 0), NonEmpty(nb_identities_external.nb_identities, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}
				Group {
					border:True
					title:$bwpam_groupsNLS.identititesorgdistribution
					IncludeHTMLWidget {
						layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: identities_org_distribution ( displayname, uid, nb_identities ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of False to showOther,
							value-of 8 to nbMaxElements,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								StringCase (Current code) {
									when 'others' then [ Flash $bwpam_groupsNLS.detailsnotavailable ]
									otherwise [
										Dialog bwpam_group_allidentity_list ( $bwpam_groupsNLS.identitiesorg(NonEmpty(Current label, 0)) to title, 'Org' to type, Current code to uid )
									]
								}
							]
						}
					}
				}
			}
		
			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_groupsNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }					
						template: multibarChart
						datasets: groups_identity_history ( timeslotuid, timeslot_date, internal, internal_label, nb_identities ) to chartdata ( code, label, categorycode , category, count )
						bindings: 
							value-of 'right' to legendPosition,
							value-of True to isStacked,
							value-of True to showLegend,
							value-of Constant contrastedPalette to customColors
					}					
				}
			}		
		}

//TAB4 NESTED GROUPS
		TabItem {
			text:$bwpam_groupsNLS.nested
			badge: Eval "nb_nested.nb_groups>0?nb_nested.nb_groups:''"
			activation-event: Set True to active_nested
			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_groupsNLS.nestedfull
					IncludeHTMLWidget {
