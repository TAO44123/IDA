							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_nested.nb_groups, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_group_nested_list_perparent ( $bwpam_groupsNLS.nested to title, 'All' to type )
							]
						}
					}
				}
				Group {
					border:True
					title:$bwpam_groupsNLS.nestedtop8
					IncludeHTMLWidget {
						layout: Layout { hint: height 250 width 500 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: groups_nested_nb_subgroups ( displayname, uid, nb_groups ) to chartdata ( label, code , count )
