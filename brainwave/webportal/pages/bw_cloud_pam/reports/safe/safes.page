bwpam_safe_list = Dialog {
	title: $bwpam_safesNLS.safelist
	height: 600
	width: 1200

	title = Variable
	type = Variable
	vault_code = Variable

	outsafecode = Variable

	safe_list = Dataset {
		view: bwpam_all_safes with vault_code to vault_code
		includes: OrPredicate {
			StringPredicate (type) { when 'All' then True otherwise False }
			AndPredicate {
				StringPredicate (type) { when 'CyberArkUsers' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_epv_users) { when >0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'LDAPUsers' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_other_users) { when >0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'AppUsers' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_app_users) { when >0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'Identities' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_identities) { when >0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'Contractors' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_contractors) { when >0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'NoUsers' then True otherwise False }
				IntPredicate (Current bw_pam_safemetrics_nb_users) { when =0 then True otherwise False }
			}
			AndPredicate {
				StringPredicate (type) { when 'NoSecrets' then True otherwise False }
