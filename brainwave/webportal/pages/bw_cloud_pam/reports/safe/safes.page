bwpam_license_script = StringService {
	javascript-file:"/webportal/pages/bw_cloud_pam/reports/roi/roi.javascript"
	javascript-method:getDate

    currentdate = Input {
        type: String
        mandatory: True
    }	

    nbdays = Input {
        type: Integer
        mandatory: True
    }	
}

bwpam_safes = Page {
	title: $bwpam_safesNLS.title
	description: $bwpam_safesNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: dashboardMixin
//	homepage-for: All
	
	/* Parameters here */
	
	/* Variables here */
	selectedVault = Variable
	selectedSafe = Variable 
	selectedDays = Variable { type: Integer }
	ad_inactive_users_count = Variable { type: Integer }
	
	/* Variable to activate dataset only when tab is active */
	active_synthesis = Variable { initial:False multivalued:False type:Boolean }
	active_statistics = Variable { initial:False multivalued:False type:Boolean }
	active_users = Variable { initial:False multivalued:False type:Boolean }
	active_contractors = Variable { initial:False multivalued:False type:Boolean }
	active_emptysafes = Variable { initial:False multivalued:False type:Boolean }
	active_projection = Variable { initial:False multivalued:False type:Boolean }
	active_details = Variable { initial:False multivalued:False type:Boolean }
	
	/* Datasets and records here */
	vaults = Dataset {
	  view: vault_list
	}

	nb_safes = Record {
		view: bwpam_nb_safes with selectedVault to vault_code
		disabled: False
	}

	nb_safes_previous = Record {
		view: bwpam_nb_safes with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_synthesis)
	}

	nb_resources = Record {
		view: bwpam_nb_resources with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_synthesis)
	}

	nb_secrets = Record {
		view: bwpam_nb_secrets with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_synthesis)
	}

	secrets_per_safe = Dataset {
		view: bwpam_secrets_per_safe with selectedVault to vault_code
		limit: 8
		disabled: Not BooleanPredicate (active_synthesis)
	}

	safes_history = Dataset {
		view: bwpam_safe_history with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_synthesis)
	}

	users_count = Record {
		view: bwpam_users_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_statistics)
	}

	secrets_count = Record {
		view: bwpam_secrets_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_statistics)
	}

	resources_count = Record {
		view: bwpam_resources_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_statistics)
	}

	platforms_count = Record {
		view: bwpam_platforms_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_statistics)
	}

	epv_count = Record {
		view: bwpam_epv_users_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	epv_count_previous = Record {
		view: bwpam_epv_users_count with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_users)
	}

	other_count = Record {
		view: bwpam_other_users_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	other_count_previous = Record {
		view: bwpam_other_users_count with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_users)
	}

	app_count = Record {
		view: bwpam_app_users_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	app_count_previous = Record {
		view: bwpam_app_users_count with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_users)
	}

	identities_count = Record {
		view: bwpam_identities_count with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_users)
	}

	contractors_count = Record {
		view: bwpam_contractors_count with selectedVault to vault_code
		disabled: False
	}

	safes_contractors = Dataset {
		view: bwpam_safes_contractors with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}

	contractors_history = Dataset {
		view: bwpam_contractors_count_history with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_contractors)
	}

	no_secret_count = Record {
		view: bwpam_no_secret_count with selectedVault to vault_code
		disabled: False
	}

	no_secret_count_previous = Record {
		view: bwpam_no_secret_count with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_emptysafes)
	}

	no_user_count = Record {
		view: bwpam_no_user_count with selectedVault to vault_code
		disabled: False
	}

	no_user_count_previous = Record {
		view: bwpam_no_user_count with selectedVault to vault_code
		timeslot: FromPage(-1)
		disabled: Not BooleanPredicate (active_emptysafes)
	}

	nb_timetlots = Record {
		view: bwpam_nb_timeslots
	}

	safes_projection = Record {
		view: bwpam_safe_projection with selectedVault to vault_code, selectedDays to ^days
		disabled: Not BooleanPredicate (active_projection)
	}
	
	secrets_projection = Record {
		view: bwpam_secret_projection with selectedVault to vault_code, selectedDays to ^days
		disabled: Not BooleanPredicate (active_projection)
	}

	safe_projection_history = Dataset {
		view: bwpam_safe_projection_full with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_projection)
	}

	total_safes = Dataset {
		view: bwpam_all_safes with selectedVault to vault_code
		disabled: Not BooleanPredicate (active_details)
	}
	
	/* Page content */
	showDetails = NamedAction (
		Dialog bwf_casafeDetailsDialog (
					selectedSafe to incode
		)
	
	)

	TabFolder {
		layout:Layout { indent: horizontal 0 vertical 6 }
		TabItem {
			text:$bwpam_safesNLS.synthesis
			badge: Eval "nb_safes.nb_safes>0?nb_safes.nb_safes:''"
			activation-event: Set True to active_synthesis
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
	
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaults text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_safesNLS.vault
						allow-none: True                          
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_safesNLS.totalnbsafe
					IncludeHTMLWidget {
						layout: Layout { hint: height 170 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_safesNLS.totalnbsafe.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(nb_safes.nb_safes, 0) to count,
							value-of Difference(NonEmpty(nb_safes.nb_safes, 0), NonEmpty(nb_safes_previous.nb_safes, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_safe_list ( $bwpam_safesNLS.allsafelist to title, 'All' to type, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_safesNLS.totalnbsaferesourcesecrets(NonEmpty(nb_resources.nb_resources, 0), NonEmpty(nb_secrets.nb_secrets, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_safesNLS.secretspersafe
					IncludeHTMLWidget {
						layout: Layout { hint: height 200 width 400 align: horizontal Center vertical Center }
						template: doughnutChart
						datasets: secrets_per_safe ( displayname, uid, nb_secrets ) to chartdata ( label, code , count )
						bindings: 
							value-of True to showLegend,
							value-of True to tooltipShowPercent,
							value-of "right" to legendPosition,
							value-of Constant contrastedPalette to customColors
						widget-events: {
							when onclick then [
								Dialog bwpam_secrets_list ( $bwpam_safesNLS.secretsforsafe(Current label) to title, Current code to safe, selectedVault to vault_code )
							]
						}
					}
				}
			}
		
			Flow {
				disposition:Horizontal
			
				Group {
					border:True
					title:$bwpam_safesNLS.history
					IncludeHTMLWidget {
						layout: Layout { hint: height 220 width 450 align: horizontal Center vertical Center }
						template: lineChart
						datasets: safes_history ( timeslotuid, timeslot_date, nb_safes ) to chartdata ( code, label, count )
					}
				}

//				Group {
//					border:True
//					title:$bwpam_safesNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
			}		
		}

		TabItem {
			text:$bwpam_safesNLS.statistics
			activation-event: Set True to active_statistics
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
	
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaults text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_safesNLS.vault
						allow-none: True                          
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_safesNLS.nbavgsecrets
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_safesNLS.nbavgsecrets.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(secrets_count.nb_avg_int_secrets, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
					Header {
						value: $bwpam_safesNLS.nbminmax(NonEmpty(secrets_count.nb_min_secrets, 0), NonEmpty(secrets_count.nb_max_secrets, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_safesNLS.nbavgusers
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_safesNLS.nbavgusers.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(users_count.nb_avg_int_users, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
					Header {
						value: $bwpam_safesNLS.nbminmax(NonEmpty(users_count.nb_min_users, 0), NonEmpty(users_count.nb_max_users, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}
			}
		
			Flow {
				disposition:Horizontal

				Group {
					border:True
					title:$bwpam_safesNLS.nbavgresources
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_safesNLS.nbavgresources.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(resources_count.nb_avg_int_resources, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
					Header {
						value: $bwpam_safesNLS.nbminmax(NonEmpty(resources_count.nb_min_resources, 0), NonEmpty(resources_count.nb_max_resources, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

				Group {
					border:True
					title:$bwpam_safesNLS.nbavgplatforms
					IncludeHTMLWidget {
						layout: Layout { hint: height 110 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							value-of $bwpam_safesNLS.nbavgplatforms.subtitle to title, 
							value-of "numeric" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(platforms_count.nb_avg_int_platforms, 0) to count,
							value-of "#9400D3" to gaugeColor,
							value-of False to animation
					}
					Header {
						value: $bwpam_safesNLS.nbminmax(NonEmpty(platforms_count.nb_min_platforms, 0), NonEmpty(platforms_count.nb_max_platforms, 0))
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
				}

//				Group {
//					border:True
//					title:$bwpam_safesNLS.guide
//					Group {
//						layout: Layout { hint: height 150 width 150 align: horizontal Center vertical Center }
//					}
//				}
			}		
		}

		TabItem {
			text:$bwpam_safesNLS.users
			activation-event: Set True to active_users
			Flow {
				disposition: Horizontal
				layout: Layout { grab: horizontal True vertical False }
	
				Group {
					layout: Layout { grab: horizontal True vertical False }
	
					Combo { 
						layout: Layout { hint: width 250 grab: horizontal False vertical False }
						options: Dynamic { data: vaults text: Current displayname value: Current code }
						variable: selectedVault
						label: $bwpam_safesNLS.vault
						allow-none: True                          
					}
				}
				Group {
					layout: Layout { grab: horizontal True vertical False }
				}
			}

			Flow {
				disposition: Horizontal

				Group {
					border:True
					title:$bwpam_safesNLS.nbsafesepv
					IncludeHTMLWidget {
						layout: Layout { hint: height 150 width 300 align: horizontal Center vertical Center }
						template: mashupGaugeIndicator
						bindings:
							// value-of $bwpam_safesNLS.nbsafescyberark.subtitle to title, 
							value-of "radial" to mode, // radial, numeric, row
							value-of True to hasLink,
							value-of False to hasThresholds,
							value-of NonEmpty(epv_count.nb_safes, 0) to count,
							value-of Difference(NonEmpty(epv_count.nb_safes, 0), NonEmpty(epv_count_previous.nb_safes, 0)) to trendValue,
							value-of "#1774FF" to gaugeColor,
							value-of False to animation
						widget-events: {
							when onclick then [
								Dialog bwpam_safe_list ( $bwpam_safesNLS.nbsafesepv.subtitle to title, 'CyberArkUsers' to type, selectedVault to vault_code )
							]
						}
					}
					Header {
						value: $bwpam_safesNLS.nbsafesepv.subtitle
						layout: Layout { align: horizontal Center vertical Beginning }
						align: Center
						styling: titleStyle
					}
