bwpam_secrets_list = Dialog {
	title: $bwpam_safesNLS.secretlist
	height: 600
	width: 1200

	title = Variable
	vault_code = Variable
	safe = Variable
	outsecretuid = Variable
	outsafecode = Variable
	
	resource_list = Dataset {
		view: bwpam_secrets_list with vault_code to vault_code, safe to safe unless-empty
	}

	goSafeDetails = NamedAction (
				Dialog bwf_casafeDetailsDialog(outsafecode to incode)
	)

	goSecretDetails = NamedAction (
				Dialog bwf_casecretDetailsDialog(outsecretuid to selectedSecretUid)
	)

	Group {
		layout: Layout { grab: horizontal True vertical False }
		Header {
			value: title
			layout: Layout { align: horizontal Center vertical Beginning grab: horizontal True vertical False }
			align: Center
			styling: titleStyle
		}
	}
	Group {
		Table {
			data:resource_list
			layout:Layout { grab: horizontal True vertical True }
			show-count:True
			show-filter:True
			configurable:True

			Column {
				column:secretuid
				header:$bwpam_safesNLS.secret
				hidden: True
				selection: outsecretuid
			}
			Column {
				column:code
				header:$bwpam_safesNLS.safe
				hidden: True
				selection: outsafecode
			}
			Column {
				column:displayname
				header:$bwpam_safesNLS.secret
				sortable:True
				filterable:True
				width:250px
				actions: ExecuteNamedAction goSecretDetails				
			}
			Column {
				column:login
				header:$bwpam_safesNLS.secretlogin
				sortable:True
				filterable:True
				width:250px
				actions: ExecuteNamedAction goSecretDetails				
			}			
			Column {
				column:resource
				header:$bwpam_safesNLS.resource
				sortable:True
				filterable:True
				width:250px
			}
			Column {
				column:safe
				header:$bwpam_safesNLS.safe
				sortable:True
				filterable:True
				width:200px
				actions: ExecuteNamedAction goSafeDetails					
			}
			Column {
				column:vault
				header:$bwpam_safesNLS.vault
				sortable:True
				filterable:True
				width:130px
			}
		}
	}
}

