/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/resources/access360_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

/* Nationalized labels here */
pamanalytics_identity_groupsNLS = NLS {
	title [en "List of Groups Accessing CyberArk" fr "Liste des groupes accédant à CyberArk"]
	dyntitle [en "{0} Groups" fr "Groupes de {0}"]
	directgrouponly [en "only direct groups" fr "seulement les groupes directs"]
	description [
		en "This report lists the user groups providing access to CyberArk. It is possible to filter the results in order to retrieve only the groups directly associated with the user or all the groups; it is also possible to filter the groups by repository; it is finally possible to identify only the changes made since a given date. The columns displayed are configurable and the data can be exported. To do so, right click on the report."
		fr "Ce rapport liste les groupes de l'utilisateur donnant accès à CyberArk.\nIl est possible de filtrer les résultats de manière à ne récupérer que les groupes directements associés à l'utilisateur\nou l'ensemble des groupes\nil est aussi possible de filtrer les groupes par référentiel\nil est enfin possible d'identifier uniquement les changements réalisés depuis une date donnée\nles colonnes affichées sont configurables, il est enfin possible d'exporter le résultat en faisant clic droit sur le rapport"
	]
}

tgtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tgtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tgtmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

pamanalytics_identity_groups = Page {
	title: $pamanalytics_identity_groupsNLS.title
	description: $pamanalytics_identity_groupsNLS.description
	dynamic-title: $pamanalytics_identity_groupsNLS.dyntitle(identity.fullname)
	tags: "identity" priority 500, "byuid" , "browsing"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	repositoryfilter = Variable
	onlydirectgroup = Variable { initial:True type:Boolean }
	selectedgroup = Variable
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid 
	}
	repocyberarklist = Dataset {
		view:pam_identitycyberarkrepositorypicker with uid to uid
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	identitycyberarkgroups = Dataset {
		view:pamidanalytics_groups with uid to uid, UserVariable session_comparisonTimeslotTeam360 to dummy, repositoryfilter to repository unless-empty, onlydirectgroup to directgrouponly
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	goDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedgroup to inuid, 
										True to inshowapplications,
										True to inshowshares,
										True to inshowperjob,
										True to inshowperorg,
										False to inshowaccounts,
										False to inshowcontrols,
										False to inshowdecisionhistory
										)
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
				Combo {
					variable:repositoryfilter
					allow-none:True
					layout:Layout { hint: width 200 }
					label:$repository.concept
					options:Dynamic {
						data:repocyberarklist
						text:Current repositorydisplayname
						value:Current repositoryuid
					}
				}				
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Checkbox {
					variable:onlydirectgroup
					label:$pamanalytics_identity_groupsNLS.directgrouponly
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:identitycyberarkgroups
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tgtimeline_highlightnew360 when 'Removed' then tgtimeline_highlightremoved360 when 'Invalid' then tgtimeline_highlightremoved360 } text:Transform Current status using tgtmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
					}
					Column {
						column:groupuid
						selection:selectedgroup
						hidden:True
					}
					Column {
						sortable:True
						filterable:True
						column:groupcode
						header:$pgroup.code
						width:300px
						initially-masked:True
						actions:ExecuteNamedAction goDetails
					}
					Column {
						sortable:True
						filterable:True
						column:groupdisplayname
						header:$pgroup.displayname
						width:260px
						actions:ExecuteNamedAction goDetails
					}
					Column {
						sortable:True
						filterable:True
						column:groupcomment
						header:$pgroup.comment
						width:200px
						actions:ExecuteNamedAction goDetails
					}
				}
			}
		}
	}
}
