/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/resources/access360_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

/* Nationalized labels here */
pam_identity_accessrightsNLS = NLS {
	title [en "CyberArk Access Rights List" fr "Liste des droits d'accès à CyberArk"]
	dyntitle [en "{0} CyberArk access rights list" fr "Liste des droits d''accès CyberArk pour {0}"]
	description [
		en "This report lists the user's CyberArk access rights. Only the CyberArk Vaults and Safes type rights directly associated with the user are taken into account. Only the user's active accounts are taken into account. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported; right-click on the table to do so."
		fr "Ce rapport liste les droits d'accès à CyberArk de l'utilisateur. Seuls les droits de type 'CyberArk Safe' et 'CyberArk Vault' directement associés à l'utilisateur sont pris en compte. Seuls les comptes actifs de l'utilsateur sont pris en compte. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
	]
	safevault [en "Safe or Vault" fr "Safe ou Vault"]
	permissiontype [en "Type" fr "Type"]
	repository [en "User Repository" fr "Référentiel de l'utilisateur" ]
}

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

pam_identity_accessrights = Page {
	title: $pam_identity_accessrightsNLS.title
	dynamic-title: $pam_identity_accessrightsNLS.dyntitle(identity.fullname)
	description:$pam_identity_accessrightsNLS.description
	tags: "identity" priority 600, "byuid" , "browsing"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	
	mixins: simpleReport

	/* Parameters here */
	uid = Parameter {
		label:"Concept Uid"
		type:String
	}
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid 
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	teamrights = Dataset {
		view:pam_accessrights with uid to uid, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:teamrights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 when 'Invalid' then tartimeline_highlightremoved360 } text:Transform Current status using tarmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$pam_identity_accessrightsNLS.repository
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:cyberarktype
						header:$pam_identity_accessrightsNLS.permissiontype
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$ppermission.displayname
						width:250px
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$pam_identity_accessrightsNLS.safevault
						width:250px
					}
				}
			}
		}	
	}
}
