/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/resources/access360_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

/* Nationalized labels here */
pam_identity_credentialsNLS = NLS {
	title [en "CyberArk Credentials Access List" fr "Liste des accès aux secrets CyberArk"]
	dyntitle [en "{0} CyberArk Credentials Access List" fr "Liste des accès aux secrets CyberArk pour {0}"]
	description [
		en "This report lists the user's CyberArk credentials access. Only the user's active accounts are taken into account. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported; right-click on the table to do so."
		fr "Ce rapport liste les accès aux secrets CyberArk de l'utilisateur. Seuls les comptes actifs de l'utilsateur sont pris en compte. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
	]
	label [en "CyberArk Vault" fr "Vault CyberArk"]
	tooltip [en "Filter per Vault" fr "Filtrer par vault" ]
	repository [en "User Repository" fr "Référentiel de l'utilisateur" ]
	user [en "User" fr "Utilisateur"]	
	safe [en "CyberArk Safe" fr "Safe CyberArk"]
	vault [en "CyberArk Vault" fr "Vault CyberArk"]
	safenumber [en "Safe Number" fr "Numéro de Safe"]
	managingcpm [en "Active CPM" fr "CPM actif"]
	credentials [en "Credential" fr "Secrets"]
	authorization [en "Authorization" fr "Autorisation"]
	type [en "Type" fr "Type"]
	username [en "Login" fr "Login"]
	resource [en "Resource" fr "Ressource"]
	platformid [en "Platform" fr "Plateforme"]
	secrettype [en "Credential Type" fr "Type de secret"]
	autocpm [en "CPM" fr "CPM"]
	managementstatus [en "CPM Status" fr "Statut CPM"]
	manualmanagement_reason [en "Reason" fr "Raison"]
	lastreconciledtime [en "Last Reconciled" fr "Dernière réconciliation"]	
	lastverifiedtime [en "Last Verified" fr "Dernière vérifictaion"]		
	
}

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

pam_identity_credentials = Page {
	title: $pam_identity_credentialsNLS.title
	dynamic-title: $pam_identity_credentialsNLS.dyntitle(identity.fullname)
	description:$pam_identity_credentialsNLS.description
	tags: "identity" priority 550, "byuid" , "browsing"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	
	mixins: simpleReport

	/* Parameters here */
	uid = Parameter {
		label:"Concept Uid"
		type:String
	}
	
	/* Variables here */
	selectedvault = Variable
	selectedcred = Variable
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid 
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	selection_vault = Dataset {
		view: pam_vaultpicker with uid to uid
	}
	
	teamcreds = Dataset {
		view:pam_credentials with uid to uid, UserVariable session_comparisonTimeslotTeam360 to dummy, selectedvault to vault
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	goDetails = NamedAction ( GoTo Activity CACredential Detail with selectedcred to paramSecretUid)
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
				Combo {
					variable: selectedvault
					allow-none:True
					layout:Layout { hint: width 200 }
					label:$pam_identity_credentialsNLS.label
					tooltip:$pam_identity_credentialsNLS.tooltip
					options:Dynamic {
						data:selection_vault
						text:Current vaultdisplayname
						value:Current vaultuid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:teamcreds
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 when 'Invalid' then tartimeline_highlightremoved360 } text:Transform Current status using tarmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$pam_identity_credentialsNLS.user
					}					
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						hidden:True 
						column:credentialuid
						selection: selectedcred
					}						
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:140px 
						header:$pam_identity_credentialsNLS.credentials 
						column:credentialdisplayname
						actions:ExecuteNamedAction goDetails						
					}					
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:140px 
						header:$pam_identity_credentialsNLS.username 
						column:credentialusername
						actions:ExecuteNamedAction goDetails						
					}
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:250px 
						header:$pam_identity_credentialsNLS.resource 
						column:credentialaddress
					}
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:250px 
						header:$pam_identity_credentialsNLS.platformid 
						column:credentialplatformid
					}
					Column {
						sortable:True 
						initially-masked:True 
						filterable:True 
						width:60px 
						header:$pam_identity_credentialsNLS.secrettype 
						column:credentialsecrettype
					}
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:60px 
						header:$pam_identity_credentialsNLS.autocpm 
						column:credentialautomaticmanagement_enabled
					}
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:200px 
						header:$pam_identity_credentialsNLS.managementstatus 
						column:credentialmanagementstatus
					}
					Column {
						sortable:True 
						initially-masked:True 
						filterable:True 
						width:100px 
						header:$pam_identity_credentialsNLS.manualmanagement_reason 
						column:credentialmanualmanagement_reason
					}
					Column {
						sortable:True 
						initially-masked:True 
						filterable:True 
						width:100px 
						header:$pam_identity_credentialsNLS.lastreconciledtime 
						column:credentiallastreconciledtime
					}	
					Column {
						sortable:True 
						initially-masked:True 
						filterable:True 
						width:100px 
						header:$pam_identity_credentialsNLS.lastverifiedtime 
						column:credentiallastverifiedtime
					}
					Column {
						sortable:True 
						initially-masked:False 
						filterable:True 
						width:100px 
						header:$pam_identity_credentialsNLS.safe 
						column:safedisplayname
					}
					Column {
						sortable:True 
						initially-masked:True 
						filterable:True 
						width:100px 
						header:$pam_identity_credentialsNLS.vault 
						column:vaultdisplayname
					}											
				}
			}
		}	
	}
}
