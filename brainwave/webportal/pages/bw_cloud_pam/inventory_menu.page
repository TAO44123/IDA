import "/webportal/pages/bw_fragments/lib/colors.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_cloud_base/resources/icons.page"
import "/webportal/pages/bw_cloud_pam/resources/icons.page"
import "/webportal/pages/bw_cloud_base/resources/styles.page"

bwcpam_inventory_menu_NLS = NLS {
	title [ en "Access Inventory" fr "Cartographie des accès"]
	
	cyberark.title [ en "CyberArk Resources" fr "Ressources CyberArk"]
	cyberark.buttons.safes [ en "Safes" fr "Safes"]
	cyberark.buttons.vaults [ en "Vaults" fr "Vaults"]
	cyberark.buttons.credentials [ en "Credentials\n(Accounts)" fr "Secrets\n(Comptes)"]
	
	business.title [ en "Business" fr "Métier"]
	business.buttons.organizations [ en "Organizations" fr "Organisations"]
	business.buttons.identities [en "Identities" fr "Identités"]
	business.buttons.applications [ en "Business\nApplications" fr "Applications\nmétier"]
	
	infrastructure.title [ en "Repositories" fr "Référentiels"]
	infrastructure.buttons.servers [ en "Servers" fr "Serveurs"]
	infrastructure.buttons.accounts [ en "Cyberark\nUser Accounts" fr "Comptes\nutilisateurs CyberArk"]
	infrastructure.buttons.groups [ en "Groups" fr "Groupes"]
}

pam_cyberark_concepts_48 = ImageMap {
	vault ["bw_cloud_pam/SVG/vault.svg" width: 48px color: darkgrayNG ]
	safe ["bw_cloud_pam/SVG/safe.svg" width: 48px color: darkgrayNG ]
	secret ["bw_cloud_pam/SVG/compte_ref_dans_cyberark.svg" width: 48px color: darkgrayNG ]
}

lightGrayNG = Color RGB(240, 240, 240)
veryDarkgrayNG = Color RGB(48, 48, 48)
mediumGrayNG = Color RGB(100, 100, 100)

cssButtonHomeMenu2 = Style (base_font) {
	theme-class: "button-square"
	foreground: veryDarkgrayNG
	background: Color lightGrayNG
	image-color: veryDarkgrayNG
	size: 16px
	image-width: 48px
}

cssButtonHomeMenu3 = Style (base_font) {
	theme-class: "button-square"
	foreground: veryDarkgrayNG
	background: Color lightGrayNG
	image-color: grayNG
	size: 16px
	image-width: 48px
}

cssButtonHomeMenu4 = Style (base_font) {
	theme-class: "button-square"
	foreground: veryDarkgrayNG
	background: Color lightGrayNG
	image-color: mediumGrayNG
	size: 16px
	image-width: 48px
}

homeMenuPanelMixin2 = Mixin {
  This Group {
    styling: cssRound  
    layout: Layout { indent: horizontal 10 vertical 10
    } 
    compact: True
  }
  Header {
    align: Left
    styling: mediumText,grayStyle
  }
  Button {
    align: Left
    presentation: Link
    layout: Layout { hint: height 100 indent: horizontal 20 vertical 0 minimal: width 240 }
    styling: cssButtonHomeMenu2
  }
}

bwcpam_inventory_menu = Page {
	title: $bwcpam_inventory_menu_NLS.title
	mixins: dashboardMixin
	icon: %steps_32.home
	large-icon: %steps_48.home

	Group {
		layout: Layout { grab: horizontal True vertical True }
		styling: cssPageDashboard
		compact: True

	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		Group {
			layout: Layout { grab: horizontal True vertical True }
			styling: cssPageDashboard
		}
		Group {
			layout: Layout { grab: horizontal True vertical True }
			styling: cssPageDashboard
			Grid {
				columns:  GridColumn { width: none fill:False }, GridColumn { width: 6px fill:False}
				gap: 5
				insets: 0
				
				GridRow {
					height: none //grow
					group: r
					GridCell {
						Group {
							mixins: homeMenuPanelMixin2
							Header { value:  $bwcpam_inventory_menu_NLS.cyberark.title }
							ButtonGroup {
								layout: Layout { grab: horizontal False vertical True align: vertical Center horizontal Beginning }
								uniform: True
								Button {
									text: $bwcpam_inventory_menu_NLS.cyberark.buttons.safes
									actions: GoTo Activity CASafe Search
									image: %pam_cyberark_concepts_48.safe
									styling: cssButtonHomeMenu3
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.cyberark.buttons.vaults
									actions: GoTo Activity CAVault Search
									image: %pam_cyberark_concepts_48.vault
									styling: cssButtonHomeMenu3
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.cyberark.buttons.credentials
									actions: GoTo Activity CACredential Search
									image: %pam_cyberark_concepts_48.secret
									styling: cssButtonHomeMenu3
								}
							}
						}
					}
				}
				GridRow {
					height: none //grow
					group: r
					GridCell {
						Group {
							mixins: homeMenuPanelMixin2
							Header { value: $bwcpam_inventory_menu_NLS.business.title  }
							ButtonGroup {
								layout: Layout { grab: horizontal False vertical True align: vertical Center horizontal Beginning }
								uniform: True
								Button {
									text: $bwcpam_inventory_menu_NLS.business.buttons.organizations
									actions: GoTo Activity Organisation Search
									image: %concept_48.organisation
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.business.buttons.identities
									actions: GoTo Activity Identity Search
									image: %concept_48.identity
									styling: cssButtonHomeMenu4
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.business.buttons.applications
									actions: GoTo Activity Application Search
									image: %concept_48.application
								}
							}
						}
					}
				}
				GridRow {
					height: none //grow
					group: r
					GridCell {
						Group {
							mixins: homeMenuPanelMixin2
							Header { value:  $bwcpam_inventory_menu_NLS.infrastructure.title }
							ButtonGroup {
								layout: Layout { grab: horizontal False vertical True align: vertical Center horizontal Beginning }
								uniform: True
								Button {
									text: $bwcpam_inventory_menu_NLS.infrastructure.buttons.accounts
									actions: GoTo Activity Account (CAusers) Search
									image: %concept_48.account
									styling: cssButtonHomeMenu4
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.infrastructure.buttons.groups
									actions: GoTo Activity Group Search
									image: %concept_48.group
								}
								Button {
									text: $bwcpam_inventory_menu_NLS.infrastructure.buttons.servers
									actions: GoTo Activity Repository ( Server ) Search
									image: %concept_48.server
									hidden: StringPredicate(ConfigurationVariable "SHOW_ALL_ONBOARDING") { when 'true' then False otherwise True }
								}
							}
						}
					}
				}
				GridRow {
					height: 6px
				}
			}
		}
		Group {
			layout: Layout { grab: horizontal True vertical True }
			styling: cssPageDashboard
		}
	}
	}
}
