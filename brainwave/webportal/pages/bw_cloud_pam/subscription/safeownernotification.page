bwpam_safeownernotification = Page {
	title: $bwpam_safeownernotificationNLS.title
	icon: "16/details/printable_16.png" large-icon: "48/details/printable_48.png"
	description:$bwpam_safeownernotificationNLS.description
	feature:All(pam_license, Any(governance_license, compliance_license),Any(pamnotification_canselfdownload, pamnotification_canselfsubscribe))
	
	/* Parameters here */
//    org = Parameter { type: String hidden: True }
//    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	selectedsafes = Variable { multivalued: True }
	selectedsafesubscriptionuid = Variable
	updatedsafes = Variable { multivalued: True }
	currentIdentity = Variable { initial:Principal.uid }
	newsafes = Variable { multivalued: True }
	
	// ///////////////////////////////	
	reportsubscriptioncheck = Record {
		view:bwpam_safeownersubscriptionsall with currentIdentity to subscriber
	}

	safesubscriptions = Dataset {
		view:bwpam_safeownersubscriptionsall with currentIdentity to subscriber
	}
	
	// ///////////////////////////////	
	
	addsafesubscription = TaskRecord(create "bwpam_notification_addsafesubscriber" in-timeslot PageTimeslot.PrevUID)
	removesubscription = TaskRecord(create "bw_subscription_removesubscription" in-timeslot PageTimeslot.PrevUID)

	safeListDetails = NamedAction (
		Dialog SafeListDialog(
						currentIdentity  to inIdUid, 
						selectedsafesubscriptionuid to inNotifUid
		)
	)
	
	doSubscribeSafe = NamedAction (
		Dialog ownedsafeMultiPicker(newsafes from outUid, currentIdentity to inIncludedOwnerUid unless-empty),
		Set Principal.uid to addsafesubscription.subscriber,
		Set newsafes to addsafesubscription.insafes,
		TaskComplete addsafesubscription wait-end timeout-seconds 30,
		ReloadData(safesubscriptions),
		ReloadData(reportsubscriptioncheck)
	)

	EditSubscribeSafe = NamedAction (
		Dialog ownedsafeMultiPicker(selectedsafes to outUid, currentIdentity to inIncludedOwnerUid unless-empty, updatedsafes from outUid),	
		Set Principal.uid to addsafesubscription.subscriber,
		Set updatedsafes to addsafesubscription.insafes,
		TaskComplete addsafesubscription wait-end timeout-seconds 30,
		ReloadData(safesubscriptions),
		ReloadData(reportsubscriptioncheck)
	)

	doUnsubscribeSafe = NamedAction (
		Set selectedsafesubscriptionuid to removesubscription.metadatauid,
		TaskComplete removesubscription wait-end timeout-seconds 30,
		ReloadData(safesubscriptions),
		ReloadData(reportsubscriptioncheck)
	)
	
	Group {
		ButtonGroup {
			Button {
				actions:ExecuteNamedAction doSubscribeSafe
				text:$bwpam_safeownernotificationNLS.subscribe
				tooltip:$bwpam_safeownernotificationNLS.subscribe_tooltip
				image:%collection_16.mail
				disabled:
				OrPredicate {				
				Not FeaturePredicate pamnotification_canselfsubscribe		
				StringPredicate(reportsubscriptioncheck.bwpam_notification_safes_subscribed) { when True then True otherwise False}				
				}
			}
			Button {
				actions:ExecuteNamedAction EditSubscribeSafe				
				text:$bwpam_safeownernotificationNLS.editsubscription
				tooltip:$bwpam_safeownernotificationNLS.editsubscription_tooltip
				image:%collection_16.pencil
				disabled:
				OrPredicate {
					Not FeaturePredicate pamnotification_canselfsubscribe				
					StringPredicate(selectedsafesubscriptionuid) { when IsEmpty then True otherwise False }
				} 
			}				
			Button {
				actions:ExecuteNamedAction doUnsubscribeSafe				
				text:$bwpam_safeownernotificationNLS.unsubscribe
				tooltip:$bwpam_safeownernotificationNLS.unsubscribe_tooltip
				image:%collection_16.delete
				disabled:
				OrPredicate {
					Not FeaturePredicate pamnotification_canselfsubscribe				
					StringPredicate(selectedsafesubscriptionuid) { when IsEmpty then True otherwise False }
				} 
			}
			Button {
				actions:Message "todo" // never displayed button, for layouting purposes
				disabled:True
				presentation:Link
				text:''
			}
			Button {
				actions:
					Confirm $bwpam_safeownernotificationadminNLS.send_confirm, 
					ExecuteNotifyRule bwpam_safeowner with selectedsafesubscriptionuid to subscriptionuid,
					Flash $bwpam_safeownernotificationadminNLS.send_flash
				disabled:StringPredicate(selectedsafesubscriptionuid) { when IsEmpty then True otherwise False }
				text:$bwpam_safeownernotificationadminNLS.send
				tooltip:$bwpam_safeownernotificationadminNLS.send_tooltip
				image:%collection_16.mail
			}			
		}

		Table {
			data:safesubscriptions
			layout: Layout { grab: horizontal True vertical True }
			show-filter:True
			configurable:True
			
				Column {
					header:$bwpam_safeownernotificationNLS.col_report
					column:bwpam_notification_safes_subkey
					width:160px					
					filterable:True
					sortable:True
				}
				Column {
					column:mail
					header:$identity.mail
					width:300px
					filterable:True
					sortable:True
				}
				Column {
					header:$bwpam_safeownernotificationNLS.col_subscribed
					column:bwpam_notification_safes_subscribed
					sortable:True
				}
				Column {
					column:bwpam_notification_safes_uid
					selection:selectedsafesubscriptionuid
					hidden:True
				}
				Column {
					column:safes
					header:$bwpam_safeownernotificationNLS.col_safe
					actions:ExecuteNamedAction safeListDetails 
					width:160px
					filterable:True
					sortable:True
				}					
		}
	}	
}
