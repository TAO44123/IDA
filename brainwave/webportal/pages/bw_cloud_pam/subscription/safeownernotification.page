/* Nationalized labels here */
bwpam_safeownernotificationNLS = NLS {
	title [en "My Reports Notification About My Safes" fr "Souscription aux rapports sur mes safes"]
	description [
		en "This page is used to subscribe to managed safes reports and analytics notification per email. You can both download those reports and subscribe to those reports. When a subscription is made, the report will be sent by email on a regular basis."
		fr "Cette page est utilisée pour souscrire aux rapports concernant les safes gérés. Vous pouvez à la fois télécharger ces rapports et vous abonner à ces derniers. Une fois abonné, vous recevrez ces rapports régulièrement par email."
	]
	
	subscribed [en "subscribed"fr "abonné"] 
	subscribe [en "Subscribe" fr "Abonnement"]
	subscribe_tooltip[en "Subscribe to this report.\nOnce subscribed, you will automatically receive this report by email on a regular basis." fr "Souscrire à ce rapport.\nUne fois souscrit vous recevrez automatiquement ce rapport régulièrement par email"]
	unsubscribe [en "Unsubscribe" fr "Désabonnement"]
	unsubscribe_tooltip[en "Unsubscribe from this report.\nYou will no longer receive this report by email." fr "Se désabonner de ce rapport.\nUne fois désabonné, vous ne recevrez plus ce rapport régulièrement par email"]
	editsubscription [en "Modify" fr "Modifier"]
	editsubscription_tooltip  [en "Edit subscription to modify the safes perimeter." fr "Editer la souscription pour modifier le périmètre de safes."]
	getreport [en "Build Report" fr "Générer le rapport"]
	getreport_tooltip[en "Build and get this report" fr "Générer et récupérer ce rapport"]
	generating_flash [en "Report is being generated, you will receive it by email" fr "Le rapport est en cours de génération, vous allez le recevoir par mail"]

	subscriptionstatus [en "Subscription\nstatus" fr "Statut\nd'abonnement"]
	
	lang [en "en" fr "fr"]
	
	col_report [en "Report" fr "Rapport"]
	col_subscribed [en "Subscribed" fr "Abonné"]
	col_safe [en "Safes" fr "Safes"]	
}


subscribedMapping = StringMapping {
	when IsEmpty then ""
	otherwise $bwpam_safeownernotificationNLS.subscribed
}

subscribedImage = StringImageTemplate {
	when IsEmpty then ""
	otherwise %report_16.xls
}



bwpam_safeownernotificationdetail = Page {
	title: $bwpam_safeownernotificationNLS.title
	description:$bwpam_safeownernotificationNLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "applicationmanager"
	feature: All(pam_license, Any(governance_license, compliance_license),Any(pamnotification_canselfdownload, pamnotification_canselfsubscribe))
	icon: "16/details/printable_16.png" large-icon: "48/details/printable_48.png"
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page bwpam_safeownernotification with-current-parameters
	}

//    org = Parameter { type: String hidden: True }
//    uid = Parameter { type: String hidden: True }
}

bwpam_safeownernotificationdetailhp = Page {
	title: $bwpam_safeownernotificationNLS.title
	description:$bwpam_safeownernotificationNLS.description
	tags: "my_access360" priority 10
	feature:All(pam_license, Any(governance_license, compliance_license),Any(pamnotification_canselfdownload, pamnotification_canselfsubscribe))
