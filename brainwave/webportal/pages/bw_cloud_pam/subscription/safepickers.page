	safe.title [en "Safe Selection" fr "Sélection d'un safe"]
	safe.dislayname [en "Safe" fr "Safe"]
	safe.code [en "Safe Code" fr "Code du safe"]
	safe.result [en "List of Safes Found" fr "Liste des safes trouvés"]
	vault.title [en "Vault Selection" fr "Sélection d'un vault"]
	vault.dislayname [en "Vault" fr "Vault"]
	searchaction [en "Apply" fr "Appliquer"]
	emptyaction [en "Reset" fr "Vider"]
	cred [en "Credential" fr "Secret"]
