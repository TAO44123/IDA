       layout: Layout { grab:horizontal True vertical True  }
       border: False
       TabItem {
         text: $ciso_qualityNLS.table.label.safe
        IncludeFragment {
          fragment: bwcpam_quality_safe
          inline: True
        }         
     }
     TabItem {
       text: $ciso_qualityNLS.table.label.vault
       IncludeFragment {
          fragment: bwcpam_quality_vault
          inline: True
       } 
     }
