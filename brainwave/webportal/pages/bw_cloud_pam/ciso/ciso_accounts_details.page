bwcpam_accounts_discrepancies_details_hiderecon = StringMapping {
	when "CA_SAFE_ACCOUNT04" then True
	when "CA_VAULT_ACCOUNT04" then True
	when "PAM_ACCOUNT01" then True
	when "PAM_ACCOUNT03" then True
	
	otherwise False
}
bwcpam_accounts_discrepancies_details_highlight_style = Style {
	background: Color HEX (#ffe0b2) 
}

bwcpam_accounts_discrepancies_details = Page {
	title: ""
	dynamic-title: Transform controlid using controls_displayname_mapping
	enter-event:
		TransferData safesInVault ( safe_code , vault_code, vault_displayname ) to ( safes_code, vaults_code, vaults_displayname ), 
		MultivaluedDistinct vaults_code and ( vaults_displayname )
	
	controlid = Parameter { hidden: True }
	
	paramVaultFilter = Parameter { multivalued: True }
	
	selectedAccountUID = Variable
	selectedVault = Variable { initial: paramVaultFilter }
	selectedType = Variable
	
	selectedTarget = Variable
	selectedTargetDisplayname = Variable
	
	// Datasets for the filters
	safes_code = Variable { multivalued: True } 
	vaults_code = Variable { multivalued: True }
	vaults_displayname = Variable { multivalued: True }

	vaults = Dataset {
		columns: vaults_code as code, vaults_displayname as displayname
	}
	safesInVault = Dataset {
		view: safes_in_vault_bycontrol with /*selectedVault to vault_code,*/ controlid to controlid
	}
	
	accountsindiscrepancy = Dataset {
		view: accountsindiscrepancy_bycontrol with controlid to controlid, selectedVault to vaults unless-empty
		trend: Trend { 
			join-column: account_uid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		disabled: AndPredicate {
			Not SameValuePredicate ( control.controltagscope, "safe" )
			Not SameValuePredicate ( control.controltagscope, "vault" )
		}
	}
	
	cyberarkpermissions = Dataset {
		view: pamciso_getaccountpermissions with selectedType to scope, selectedAccountUID to account, controlid to controlid
		disabled: StringPredicate ( selectedAccountUID ) { when IsEmpty then True }
	} 
	
	control = Record {
		view: ciso_controldetails with controlid to controlid
	}

