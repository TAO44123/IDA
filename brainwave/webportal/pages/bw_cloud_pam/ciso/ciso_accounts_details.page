//						GridCell {
//							Combo {
//								options: Dynamic {
//									data: safesInVault
//									text: $bwcpam_accounts_discrepancies_details_NLS.labels.filters.safe.pattern ( Current safe_displayname, Current vault_displayname )
//									value: Current safe_code
//								}
//								label: $bwcpam_accounts_discrepancies_details_NLS.labels.filters.safe
//								variable: selectedSafe
//								allow-none: True
//								hidden: StringPredicate ( control.controltagscope )  { when "vault" then True }
//							}
