			Table {
				data: accountsindiscrepancy
				layout: Layout { grab: horizontal True vertical True}
				show-filter: True
				show-count: True
				
				Column { column: account_uid selection: selectedAccountUID hidden: True }
				Column { 
					sortable: True filterable: True width: 50% header: $repository.concept	column: repo_code 
					actions: Dialog bwf_repositoryDetailsDialog ( Current repo_uid to inuid  ), ReloadData ( cyberarkpermissions )
					
				}
				Column { 
					sortable: True filterable: True width: 100% header: $account.login 		column: account_login 
					actions: Dialog bwpam_userDetailsDialog ( Current account_uid to inuid , True to inshowapplications, True to incanreconcile ), ReloadData ( cyberarkpermissions )
				}
				Column { 
					sortable: True filterable: True width: 100% header: $pidentity.fullname	column: identity_fullname 
					hidden: BooleanPredicate( Transform controlid using bwcpam_accounts_discrepancies_details_hiderecon )
