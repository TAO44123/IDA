import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_cloud_pam/ciso/cpm_exception_dialogs.page"
import "/webportal/pages/bw_cloud_pam/resources/nls/ciso_secret_details_nls.page"
import "/webportal/pages/bw_cloud_pam/safe/fragments/safeDetails.page"
import "/webportal/pages/bw_cloud_pam/safe/fragments/secrets.page"

cpm_mode_mapping = StringMapping {
  when "true" then $account_secret_detailsNLS.mode.mapping.true
  when "false" then $account_secret_detailsNLS.mode.mapping.false
}

fragmentAddressCredentailsDialog = Dialog {
	title: $account_secret_detailsNLS.address.title
	mixins: detailPageMixin
	width: 650
	height: 500

	inaddress = Variable

	secrets = Dataset {
		view: bwpam_secrets_at_address with inaddress to address
	}

	Group {
	
		Table {
			data: secrets
			layout: Layout { grab: horizontal True vertical True}
			//show-filter: True
			show-count: True
			configurable:True
			show-filter:True	
							
			Column { column: uid hidden: True }
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.safe	column: safe_displayname 
				actions: Dialog bwf_casafeDetailsDialog ( Current safe_code to incode )				
			}
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.user		column: userName
			}	
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.platform 		column: platformId
			}
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.secrettype 		column: secretType
			}
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCASafeSecretsNLS.secrets.cpm.enabled 		column: cpm_enabled
			}
		}
	}
}

fragmentAccountSecretDetails = PageFragment {
	/* Parameters here */
	mixins: detailPageMixin
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incansetexception = Variable { multivalued:False type: Boolean initial: False }
	
	result = Variable { private: True}
	
	/* Datasets and records here */
	detail = Record {
		view: bwpam_ca_account_secret with
			inuid to uid unless-empty
		disabled:
		 	Not BooleanPredicate ( inenabled )
	}
	
	doCreateException = NamedAction(
		Dialog bwpam_createCPMExceptionDialog (inuid to accountUids, result from resultaction )
		, Flash $ciso_secrets_detailsNLS.exception_set1.msg(1)
		, FireFragmentEvent "changed"
	)
	
	doEditException = NamedAction(
			Dialog bwpam_modifyCPMExceptionDialog (inuid to accountUid, detail.ex_uid to exceptionuid , result from resultaction ) 
			, Flash $ciso_secrets_detailsNLS.exception_edit.msg
			, FireFragmentEvent "changed"
	)
	
	doDeleteException = NamedAction(
		Dialog bwpam_deleteCPMExceptionDialog (inuid to accountUids,  result from resultaction ) 
		, Flash $ciso_secrets_detailsNLS.exception_delete1.msg(1) 
		, FireFragmentEvent "changed"
	)
	
	
	Text { value: detail.login label: $account_secret_detailsNLS.fragment.label.log}	
	Text {
		label: $account_secret_detailsNLS.fragment.label.safe
		value: detail.safe_displayname
		commands: Commands {
			position: After
			presentation: Icon
			Command {
				icon: %browsing_16.information
				actions: Dialog bwf_casafeDetailsDialog (detail.safe_code to incode)
			}
		}
	}	
	Text { value: detail.platformId label: $account_secret_detailsNLS.fragment.label.platform}
	Text { value: detail.secretType label: $account_secret_detailsNLS.fragment.label.secret}
	Text {
		label: $account_secret_detailsNLS.fragment.label.address
		value: detail.address
		commands: Commands {
			position: After
			presentation: Icon
			Command {
				icon: %browsing_16.information
				actions: Dialog fragmentAddressCredentailsDialog (detail.address to inaddress)
			}
		}
	}
	Group {
	  title: $account_secret_detailsNLS.fragment.title.pswd
	  layout: Layout { grab: horizontal True vertical False }
	  Text {label: $account_secret_detailsNLS.fragment.label.mode  value: Transform detail.cpm_enabled using cpm_mode_mapping}
	  Text {label: $account_secret_detailsNLS.fragment.label.manual value: detail.cpm_manual_reason }
	  Text {label: $account_secret_detailsNLS.fragment.label.state value: detail.cpm_status }
	  Text {label: $account_secret_detailsNLS.fragment.label.update value: Date(detail.cpm_lastmodified).value }
	  Text {label: $account_secret_detailsNLS.fragment.label.reconciled value: DateLDAP(detail.cpm_last_reconciled).value}
	  Text {label: $account_secret_detailsNLS.fragment.label.verif value: DateLDAP(detail.cpm_last_verified).value }
	  
	  Button {
	    text: $account_secret_detailsNLS.fragment.button.expt
	    actions: ExecuteNamedAction doCreateException
	    hidden: OrPredicate {
	    	BooleanPredicate ( detail.isexception)
	    	Not BooleanPredicate ( incansetexception )
	    }
	    layout: Layout { hint: width 200 indent: horizontal 0 vertical 10 }
	  }  	  
	}
	
	Group {
	  title: $account_secret_detailsNLS.fragment.title.excpt
	  hidden: Not BooleanPredicate ( detail.isexception)
	  layout: Layout { grab: horizontal True vertical False }
	  Text { value: detail.ex_issuername label: $account_secret_detailsNLS.fragment.label.author}
	  Text { value: detail.ex_reason label: $account_secret_detailsNLS.fragment.label.reasons}

	  Button {
	    text: $account_secret_detailsNLS.fragment.button.modif
	    actions:ExecuteNamedAction doEditException
	    layout: Layout { hint: width 220 indent: horizontal 0 vertical 10 }
	  }	  
	  Button {
	    text: $account_secret_detailsNLS.fragment.button.delete
	    actions: ExecuteNamedAction doDeleteException
	    layout: Layout { hint: width 220 indent: horizontal 0 vertical 10 }
	  }
	}
		
		

}