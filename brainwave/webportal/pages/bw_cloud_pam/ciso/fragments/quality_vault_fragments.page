/* Import other pages here */

import "/webportal/pages/bw_cloud_base/resources/styles.page"
import "/webportal/pages/bw_cloud_base/resources/icons.page"
import "/webportal/pages/bw_cloud_base/resources/mappings.page"
import "/webportal/pages/bw_cloud_pam/ciso/fragments/quality_safe_fragments.page"
import "/webportal/pages/bw_cloud_pam/resources/nls/ciso_fragments_quality.page"

/* VAULT  */

CTRL_VAULT_GROUP_EMPTY = Constant {value: "CA_VAULT_GROUP01" }
CTRL_VAULT_GROUP_DISABLED_ACCOUNTS = Constant {value: "CA_VAULT_GROUP02"}
CTRL_VAULT_GROUP_ONEGROUP = Constant {value: "CA_VAULT_GROUP03"}
CTRL_VAULT_GROUP_ONEACCOUNT = Constant {value: "CA_VAULT_GROUP04"}
GROUP_ALL = Constant {value: "GROUP_ALL"}


CTRL_VAULT_ACCOUNT_DORMANT = Constant {value: "CA_VAULT_ACCOUNT11"}
CTRL_VAULT_ACCOUNT_DISABLED = Constant {value: "CA_VAULT_ACCOUNT12"}
CTRL_VAULT_ACCOUNT_SERVICE = Constant {value: "CA_VAULT_ACCOUNT13"}
CTRL_VAULT_ACCOUNT_ANY = Constant {value: "CA_VAULT_ACCOUNT"}
ACCOUNT_ALL = Constant { value: "ACCOUNTS_ALL" }

CTRL_VAULT_SAFE_EMPTY = Constant {value: "CA_SAFE01"}
CTRL_VAULT_SAFE_NOACCESS = Constant {value: "CA_SAFE02"}
CTRL_VAULT_SAFE_ANY = Constant {value: "CA_SAFE"}
//SAFE_ALL = Constant {value: "SAFE_ALL"}

bwcpam_quality_vault = PageFragment {
	mixins: dashboardMixin
	
	selectedVault = Variable
	controlName = Variable
	detailType = Variable 
	detailTitle = Variable 
	accountRead = Variable { type: Boolean initial: False }
	
//	safes_nb = Variable  { type: Integer}
//	all_safes_nb = Variable  { type: Integer}
	
	// datasets
	vaults = Dataset {
	  view: vault_list
	}

	nb_accounts = Record {
		view: ciso_risk_count_discrepancies with selectedVault to vault_code, 'NB_ACCOUNTS_ACCESSING_VAULT' to control_code, 1 to isquality
	}

	groups_access = Dataset {
     view: vault_groups_access with selectedVault to vault	
	}
	
	_account_controls_nb = Dataset {
		view: ciso_risk_count_discrepancies with selectedVault to vault_code, 'true' to isvault, 1 to isquality
		trend: Trend {
			value-column: nbdiscrepancies
			join-column: controlidentifier
			difference-column-name: diff
			timeslot: FromPage(-1)
			exclude-new: False
			exclude-same: False
			include-removed: True
		}
	}
	
	_account_controls_titles = Dataset {
	   values: [  
	    ( id -> Constant CTRL_VAULT_ACCOUNT_DORMANT , title -> $fragments_commonNLS.title.ctrl.dormant),
			( id -> Constant CTRL_VAULT_ACCOUNT_DISABLED , title -> $fragments_commonNLS.title.ctrl.disabled),
			( id -> Constant CTRL_VAULT_ACCOUNT_SERVICE , title -> $fragments_commonNLS.title.ctrl.service)  
	   ]
	}
	
	account_controls_nb_titles = Dataset {
	  join: Join { 
	    primary-dataset: _account_controls_titles 
	    primary-column: id 
	    primary-optional: False
	    primary-prefix: ctrl_
	    secondary-dataset: _account_controls_nb 
	    secondary-column: controlidentifier
	    secondary-cardinality: optional      
	  }	  
	}
	
	 accounts_access = Dataset {
     view: vault_accounts_access with selectedVault to vault	
     disabled: AndPredicate {
     	Not BooleanPredicate(accountRead)
		StringPredicate(detailType) { when Constant ACCOUNT_ALL then False otherwise True }
	 }
	}
	
	/* safe controls */
	
	_safes_controls_nb = Dataset {
	  view: vault_safes_controls_nb with selectedVault to vault
	  trend: Trend { value-column: nb_safes  join-column: controlid difference-column-name: diff timeslot: FromPage(-1) exclude-new: False exclude-same: False include-removed: True }
	}
	
	_safes_controls_titles = Dataset {
	   values: [  
	    ( id -> Constant CTRL_VAULT_SAFE_EMPTY , title -> $fragments_vaultNLS.ctrl.empty),
			( id -> Constant CTRL_VAULT_SAFE_NOACCESS , title -> $fragments_vaultNLS.ctrl.noaccess)
	   ]
	}
	
	safes_controls_nb_titles = Dataset {
	  join: Join { 
	    primary-dataset: _safes_controls_titles 
	    primary-column: id 
	    primary-optional: False
	    primary-prefix: ctrl_
	    secondary-dataset: _safes_controls_nb 
	    secondary-column: controlid 
	    secondary-cardinality: optional      
	  }	  
	}
	
//	safes = Dataset {
//     view: vault_safes with selectedVault to vault	
//     count-variable: safes_nb  
//	}
	
	allsafes = Record {
     view: vault_safes
	}
         
  Grid {
   layout: Layout { grab:horizontal True vertical True  } 
   columns: GridColumn { width: grow 45 gap:20 }, GridColumn { width: grow 55 }
     GridRow{
       GridCell {
         span: 2
         height: 50 width: 600
        Combo { 
	         options: Dynamic { data: vaults text: Current displayname value: Current code }
	         variable: selectedVault
	         label: $fragments_commonNLS.label.vault
	         allow-none: True                          
	       }        
       }
     }
	   GridRow {  
	   
	      gap: 10 // after
	      height: 300

	      // account kpis 
	  		GridCell {
	 	  		 Group {
	  		    styling: cssRound		  		    
	  		    Header { value: $fragments_commonNLS.ca.vault}

						Grid {
						  columns: GridColumn{ width: grow}, GridColumn{ width:100 },GridColumn{ width: 50}
						  GridRowGroup {
						    iterate-on: account_controls_nb_titles
						    GridRow{
						      GridCell {
						        Text { value: Current ctrl_title styling: indLabelStyle lines: 2}
						      }
						      GridCell {
						        Text { value: Eval "current.nbdiscrepancies ? current.nbdiscrepancies : 0 " styling: indCountSmallStyle align: Right}
						      }	
							    GridCell {
						        Image { image: TemplateImageSelection( Current diff) using bwcdrm_trend_16 
						        }
						      }
						      GridCell {
						        Button {
						          image: %cmd_24.next
						          mixins: linkButtonMixin
						          actions: Set Current ctrl_id to controlName, Set Constant CTRL_VAULT_ACCOUNT_ANY to detailType, Set Current ctrl_title to detailTitle
						          disabled: Eval "current.nbdiscrepancies == 0 "
						        }
						      }	
						      							      							      
						    }
						  }
						  
						  GridRow {
						     
						     GridCell {
						        Text { value: $fragments_commonNLS.text.vaultaccount styling: indLabelStyle lines: 2}
						     }
						     GridCell {
						        Text { value: NonEmpty(nb_accounts.nbdiscrepancies, 0) styling: indCountSmallStyle align: Right}
						     }
						     GridCell { }
						     GridCell {
						        Button {
						          image: %cmd_24.next
						          mixins: linkButtonMixin
						          actions: Set True to accountRead, Set Constant ACCOUNT_ALL to detailType, Set $fragments_commonNLS.button.vaultaccount to detailTitle
						          disabled: Eval "nb_accounts.controlidentifier == null || nb_accounts.nbdiscrepancies == 0 "
						        }
						     }						     
						  }
						}		  		    
	  		  } 		  
	  		} 
	  		
	  		// safes controls
	  		GridCell {
	  		
	  		  Group {
	  		    styling: cssRound
	  		    Header { value: $fragments_commonNLS.header.safe}

						Grid {
						  columns: GridColumn{ width: grow}, GridColumn{ width:100 },GridColumn{ width: 50}
						  GridRowGroup {
						    iterate-on: safes_controls_nb_titles
						    GridRow{
						      height: 40
						      GridCell {
						        Text { value: Current ctrl_title styling: indLabelStyle lines: 2}
						      }
						      GridCell {
						        Text { value: Eval "current.nb_safes ? current.nb_safes: 0 " styling: indCountSmallStyle align: Right}
						      }	
							    GridCell {
						        Image { image: TemplateImageSelection( Current diff) using bwcdrm_trend_16 
						        }
						      }
						      GridCell {
						        Button {
						          image: %cmd_24.next
						          mixins: linkButtonMixin
						          actions: Set Current ctrl_id to controlName, Set Constant CTRL_VAULT_SAFE_ANY to detailType, Set Current ctrl_title to detailTitle
						          disabled: Eval "current.nb_safes == 0 "
						        }
						      }						      							      							      
						    }
						  }

//						  GridRow {
//						     
//						     GridCell {
//						        Text { value: $fragments_vaultNLS.nb.safe styling: indLabelStyle lines: 2}
//						     }
//						     GridCell {
//						        Text { value: allsafes.nb_safes styling: indCountSmallStyle align: Right}
//						     }
//						     GridCell {
//						     }
//						      GridCell {
//						        Button {
//						          image: %cmd_24.next
//						          mixins: linkButtonMixin					      
//						          actions: Set Constant SAFE_ALL to detailType, Set $fragments_vaultNLS.button.safe to detailTitle
//                      disabled: Eval "allsafes.nb_safes == 0 "
//						        }
//						      }							     
//						  }
						}
														
	  		  }	  			    		
	  		}	  		     		
		 }
	
		 GridRow {
		   height: grow
	   
		   GridCell {
		     span: 2
		     height: grow
		     width: grow
	     
				 // Detail panel 
			  Group {
			     layout: Layout { grab: horizontal True vertical True }
			     styling: cssRound	
			     Header {
			       value: detailTitle
			     }
			     ConditionalGroup { StringCondition( detailType )	{
			       when Constant CTRL_VAULT_GROUP_EMPTY then [
			         IncludeFragment ( bwcpam_quality_groups_empty_detail with detailType binds-to controlname, selectedVault binds-to vault, value-of True to hideNbAcounts, value-of "ca_vault" to type)
			       ]
			       when Constant CTRL_VAULT_GROUP_DISABLED_ACCOUNTS then [
			         IncludeFragment ( bwcpam_quality_groups_disabled_accounts_detail with detailType binds-to controlname, selectedVault binds-to vault, value-of "ca_vault" to type)
			       ]      
			       when Constant CTRL_VAULT_GROUP_ONEGROUP then [
			         IncludeFragment ( bwcpam_quality_groups_onegroup_detail with detailType binds-to controlname, selectedVault binds-to vault, value-of "ca_vault" to type)
			       ]      
			       when Constant CTRL_VAULT_GROUP_ONEACCOUNT then [
			         IncludeFragment ( bwcpam_quality_groups_oneaccount_detail with detailType binds-to controlname, selectedVault binds-to vault, value-of "ca_vault" to type )
			       ]
			       when Constant CTRL_VAULT_ACCOUNT_ANY then [
			        IncludeFragment ( bwcpam_quality_account_detail with value-of controlName to controlname, selectedVault binds-to vault, value-of True to accountAnyRead , value-of "ca_vault" to type )
			       ]
			       when Constant CTRL_VAULT_SAFE_ANY then [
			        IncludeFragment ( bwcpam_quality_safe_detail with value-of controlName to controlname, selectedVault binds-to vault )
			       ]
			       when Constant ACCOUNT_ALL then [
			         Table {
							  data: accounts_access
							  show-filter: True	  show-count: True
							  layout: Layout { grab: horizontal True vertical True }
							  Column { column: acc_uid  hidden: True }
							  Column { column: acc_login header: $fragments_commonNLS.header.login width: 250px sortable: True filterable: True
							  	actions: CloseDialog Cancel, GoTo Activity Account (CAusers) Detail with Current acc_uid to paramAccountUid save-state}
							  Column { column: repo_code header: $fragments_commonNLS.header.ref width: 180px sortable: True filterable: True} 
							  Column { column: ca_acc_lastlogindate header: $fragments_commonNLS.header.ca.connexion width: 200px sortable: True}
							  Column { column: acc_lastlogindate header: $fragments_commonNLS.header.connexion width: 180px sortable: True}
							}
			       ]
			       when Constant GROUP_ALL then [
			         	Table {
								  data: groups_access
								  	  show-filter: True	  show-count: True
								  layout: Layout { grab: horizontal True vertical True }
								  Column { column: grp_uid  hidden: True }
								  Column { column: grp_displayname header: $fragments_commonNLS.header.gp width: 250px sortable: True filterable: True
								  	actions: CloseDialog Cancel, GoTo Activity Group Detail with Current grp_uid to paramGroupUid save-state}
								  Column { column: repo_code header: $fragments_commonNLS.header.ref width: 180px sortable: True filterable: True}
								}
			       ]
//			       when Constant SAFE_ALL then [
//			         	Table {
//								  data: safes
//								  	  show-filter: True	  show-count: True
//								  layout: Layout { grab: horizontal True vertical True }
//								  Column { column: safe_uid  hidden: True }
//								  Column { column: safe_displayname header: $fragments_commonNLS.label.safe width: 200px sortable: True filterable: True}
//								  Column { column: vault_displayname header: $fragments_commonNLS.label.vault width: 200px sortable: True filterable: True}
//								  Column { column: nb_secrets header: $fragments_vaultNLS.nb.secrets align: Right width: 120px sortable: True}
//								}
//			       ]
			     }
			  }   
			     
				}		     
		     
		   }
		 }
	} 
			

             			
}


bwcpam_quality_safe_detail = PageFragment {
   mixins: dashboardMixin 
  controlname = Variable 
  vault = Variable
   
  safes = Dataset {
    view: vault_safes_controls_detail with controlname to control_name, vault to vault
  }
  
	Table {
	  data: safes
	  show-filter: True	  show-count: True
	  layout: Layout { grab: horizontal True vertical True }
					  Column { column: safe_uid  hidden: True }
					  Column { column: safe_displayname header: $fragments_commonNLS.label.safe width: 200px sortable: True filterable: True }
					  Column { column: vault_displayname header: $fragments_commonNLS.label.vault width: 200px sortable: True filterable: True}
					  Column { column: nb_secrets header: $fragments_vaultNLS.nb.secrets align: Right width: 120px sortable: True}
	}
}	 


