/* Import other pages here */
import "/webportal/pages/bw_cloud_pam/resources/nls/ciso_quality_nls.page"
import "/webportal/pages/bw_fragments/lib/styles.page"

bwcpam_quality_analytics = PageFragment {
	
	analyticsReports = Dataset {
		pages: Pages{tags: "analytics" and "cyberark" }
	}
	
	TemplateTable {
		data:analyticsReports
		layout:Layout { grab:horizontal True vertical True }
		show-filter:True
		pagination:10
		row-height:100
		double-click:GoTo Dynamic (Current type, Current name)  save-state
							
		ImageCell {
			image:Current largeIcon
			left:20
			top:30
			width:48
			height:48
			on-click:GoTo Dynamic (Current type, Current name) save-state
		}
		TextCell {
			column:title							
			left:10
			top:10
			width:970
			height:20
			filterable:True
			styling:bwf_boldNG
			on-click:GoTo Dynamic (Current type, Current name) save-state
		}
		TextCell {
			column:description
			vertical-align:Top
			horizontal-align:Left
			styling:bwf_notboldNG
			filterable:True
			wrap:True
			left:80
			top:30
			width:900
			height:60
		}
	}
}