bwcpam_home_ciso = Page {
	homepage-for: pam_ciso_home priority 7000
	title: $ciso_homepageNLS.title
	mixins: dashboardMixin
	icon: %steps_32.home
	large-icon: %steps_48.home
	feature: All(pam_license, Any(governance_license, compliance_license))
//	enter-event: ExecuteNamedAction doInit
	//header: PageHeader {
	//	IncludeFragment ( notificationsFragment )
	//}	
	header: PageHeader {
     IncludeFragment { fragment: bw_help_frag with  
        value-of "static/bw_cloud_pam/guides/guide_home_ciso.html" to url , 
        value-of "en,fr" to locales,
        value-of "30%" to ^width 
        inline: True }
   }

	language = Variable { type: String initial: $bwcdrm_mylang.currentnls  }
		
	// kpis
	nb_nonboarded = Variable { type: Integer initial: 0}
	nb_nonboarded_prev = Variable { type: Integer initial: 0}
		
	nb_privileged = Variable { type: Integer initial: 0}
	nb_privileged_prev = Variable { type: Integer initial: 0}
	
/* datasets */
	
	nb_notonboarded_discrepencies = Record {
	  view: pam_notonboarded_nbdiscrepancies
	}
	nb_notonboarded_discrepencies_prev = Record {
	  view: pam_notonboarded_nbdiscrepancies
	  timeslot: FromPage(-1) 
	}
		
	nb_quality_discrepencies = Record {
	  view: ca_quality_nbdiscrepancies
	}
	nb_quality_discrepencies_prev = Record {
	  view: ca_quality_nbdiscrepancies
	  timeslot: FromPage(-1)
	}
		
	nb_risk_discrepencies_nocpm = Record {
	  view: ca_risk_asset_nbdiscrepancies with Constant CTRL_CA_SAFE_ASSET01_nocpm to controlname 
	}	
	nb_risk_discrepencies_nocpm_prev = Record {
	  view: ca_risk_asset_nbdiscrepancies with Constant CTRL_CA_SAFE_ASSET01_nocpm to controlname
	  timeslot: FromPage(-1) 
	}	
			
	nb_risk_discrepencies = Record {
	  view: ca_risk_nbdiscrepancies
	}	
	nb_risk_discrepencies_prev = Record {
	  view: ca_risk_nbdiscrepancies
	  timeslot: FromPage(-1)
	}	
	
	nb_risk_discrepencies_leavers_safeaccess = Record {
	  view: ca_risk_nbdiscrepancies_leavers_safeaccess
	}		
	nb_risk_discrepencies_leavers_safeaccess_prev = Record {
	  view: ca_risk_nbdiscrepancies_leavers_safeaccess
	  timeslot: FromPage(-1)
	}
	
	nb_pam_privileged_nbdiscrepancies_leavers = Record {
	  view: pam_privileged_nbdiscrepancies_leavers
	}		
	nb_pam_privileged_nbdiscrepancies_leavers_prev = Record {
	  view: pam_privileged_nbdiscrepancies_leavers
	  timeslot: FromPage(-1)
	}
	
	nb_pam_privileged_nbdiscrepancies_orphan = Record {
	  view: pam_privileged_nbdiscrepancies_orphan
	}		
	nb_pam_privileged_nbdiscrepancies_orphan_prev = Record {
	  view: pam_privileged_nbdiscrepancies_orphan
	  timeslot: FromPage(-1)
	}
	
	/* cpm */
	nb_secrets = Record {
	  view: bwpam_cpm_accounts_nb
	}	
	nb_secrets_prev = Record {
	  view: bwpam_cpm_accounts_nb
	  timeslot: FromPage(-1)
	}
		
	referenceCube = Record { view: bwpam_referencecube }	
		
