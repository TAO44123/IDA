    Group {  
       layout: Layout { grab:horizontal True vertical True  }
       styling: cssPageDashboard
       
       Grid {
       	columns: GridColumn{ width: grow },GridColumn{ width: grow },GridColumn { width: 350 }, GridColumn { width: grow }
       	mixins: gridPageLayout
       	layout: Layout { grab:horizontal True vertical False  }
       	GridRow {
       		GridCell {
        		Group {
			        styling: cssRound
			        Header { value: $ciso_homepageNLS.header.ca.risk}
			        			        Grid {
			        	columns: GridColumn{},GridColumn{}
			        	gap: 6
			        	GridRow {
			        		GridCell {
			        		  //5  comptes sans CPM 
			        			IncludeFragment { inline: True fragment: pam_indicator_tile with 
			        			  value-of Constant CISO_IND5 to type,
			        			  value-of "diff" to evalMode,
			        			  value-of Transform Constant CISO_IND5 using ciso_home_icons to icon, 			        			   
			        			  value-of $ciso_homepageNLS.cpm to title,
			        			  value-of nb_risk_discrepencies_nocpm.nb_discrepencies to val, 
			        			  value-of nb_secrets.nb to total ,
			        			  value-of nb_risk_discrepencies_nocpm_prev.nb_discrepencies to val_prev, 
			        			  value-of nb_secrets_prev.nb to total_prev ,	
			        			  value-of True to hasLink	        			  
			        			  fragment-events: {
			        			    when "click" then [
			        			      GoTo Page bwcpam_secrets_discrepancies_details with Constant CTRL_CA_SAFE_ASSET01_nocpm to controlid
			        			    ]
			        			  }			        			  		        			  
			        			}
			        			 //7 quality Cyberark nb
			        			IncludeFragment { inline: True fragment: pam_indicator_tile with 
			        			  value-of Constant CISO_IND7 to type, 
			        			  value-of "diff" to evalMode,
			        			  value-of Transform Constant CISO_IND7 using ciso_home_icons to icon, 
			        			  value-of $ciso_homepageNLS.quality to title ,
			        			  value-of nb_quality_discrepencies.nb_discrepencies to val,
			        			  value-of nb_quality_discrepencies_prev.nb_discrepencies to val_prev, 
			        			  value-of True to hasLink
			        			  fragment-events: {
			        			    when "click" then [
			        			      GoTo Page bwcpam_quality
			        			    ]
			        			  }			        			  
			        			}
			        		}
			        		GridCell {
			        			//6 Risques CA  
			        			IncludeFragment { inline: True fragment: pam_indicator_tile with 
			        			  value-of Constant CISO_IND6 to type, 
			        			  value-of "diff" to evalMode,
			        			  value-of Transform Constant CISO_IND6 using ciso_home_icons to icon, 
			        			  value-of $ciso_homepageNLS.ca.access to title,
			        			  value-of nb_risk_discrepencies.nb_discrepencies to val ,
			        			  value-of nb_risk_discrepencies_prev.nb_discrepencies to val_prev,			        			  
			        			  value-of True to hasLink	        			  
			        			  fragment-events: {
			        			    when "click" then [
			        			      GoTo Page bwcpam_risk
			        			    ]
			        			  }
			        			  
			        			}
			        			 //Leavers with access to a CA safe
			        			
			        			IncludeFragment { inline: True fragment: pam_indicator_tile with 
			        			  value-of Constant CISO_IND9 to type, 
			        			  value-of "diff" to evalMode,
			        			  value-of Transform Constant CISO_IND9 using ciso_home_icons to icon, 
			        			  value-of $ciso_homepageNLS.ca.acess.leavers to title ,
			        			  value-of nb_risk_discrepencies_leavers_safeaccess.nb_discrepencies to val,
			        			  value-of nb_risk_discrepencies_leavers_safeaccess_prev.nb_discrepencies to val_prev,
			        			  value-of True to hasLink	        			  
			        			  fragment-events: {
			        			    when "click" then [
			        			      GoTo Page bwcpam_accounts_leavers_details with "CA_SAFE_ACCOUNT03" to controlid
			        			    ]
			        			  }
			        			}
			        		}       		
			        	}	
			        }
			      }      			
       		} 
       		GridCell {
       			Group {
			        styling: cssRound
			         layout: Layout { hint:  height 200}
			         Header { value:   $bwcd_mias_home_NLS.group.datacube.title align: Center}
							 Text {
										value: PortalTimeslot.CommitDate
										 align: Center
										styling: stdText
							 }
							 Header { value:   $bwcd_mias_home_NLS.group.referencedatacube.title  align: Center}								
							 Text {
									value: Transform referenceCube.commitdate using referenceCube_Mapping
									 align: Center
									styling: stdText
							 }
			      }
			      Group {
			        styling: cssRound
					mixins: linksPanelMixin
			        layout: Layout { hint:  height 200}
			        Header { value:  $ciso_homepageNLS.links}

					Button {
						actions: GoTo Page bwcpam_documentation_ciso_guide
						text: $home_pageNLS.button.cisodocumentation
						image: %dashboardicons_24.help
						align: Left
					}
//					Button {
//						actions: GoTo Activity Organisation Search
//						text: $home_pageNLS.button.search.orgs
//						image: %concept_24.organisation
//						align: Left
//					}
//					Button {
//						actions: GoTo Activity Identity Search
//						text: $home_pageNLS.button.search.identitites
//						image: %concept_24.identity
//						align: Left
//					}
			      }
       		}      		
       	}	
       }
       
    }
}

bwpam_sensitive_assets_tile = PageFragment {

   nb_sensitive_assets = Variable { type: Integer }
   nb_sensitive_assets_prev = Variable { type: Integer }
  
    sensitive_assets = Dataset {
      view: bwpam_sensitive_assets
      count-variable: nb_sensitive_assets      
    }
    
    sensitive_assets_prev = Dataset {
      view: bwpam_sensitive_assets
      timeslot: FromPage(-1)
      count-variable: nb_sensitive_assets_prev      
    }
    
    
    nb_assets = Record {
      view: bwpam_nb_assets
    }
    
    nb_assets_prev = Record {
      view: bwpam_nb_assets
      timeslot: FromPage(-1)
    }
    
		IncludeFragment {
		  inline: True 
		  fragment: pam_indicator_tile with 
		  value-of Constant CISO_IND3 to type, 
		  value-of Transform Constant CISO_IND3 using ciso_home_icons to icon, 
		  value-of $ciso_homepageNLS.active to title, 
		  nb_sensitive_assets binds-to val, 
		  value-of nb_assets.nb_assets to total,
		  nb_sensitive_assets_prev binds-to val_prev, 
		  value-of nb_assets_prev.nb_assets to total_prev
		}           
    
    
}


	
			   


