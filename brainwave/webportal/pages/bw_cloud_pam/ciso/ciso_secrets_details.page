exception_label_mapping = BooleanMapping {
  when True then $ciso_secrets_detailsNLS.excpt.title.true
  when False then $ciso_secrets_detailsNLS.excpt.title.false 
}


bwcpam_secrets_discrepancies_details = Page {
	title: ""
	dynamic-title: Transform controlid using controls_displayname_mapping
	enter-event:
		TransferData vaults_rootcause ( code, displayname ) to ( vaults_root_code ,vaults_root_displayname),
		TransferData safesInVault ( safe_code , vault_code, vault_displayname ) to ( safes_code, vaults_code, vaults_displayname ), 
		MultivaluedAdd vaults_root_code to vaults_code  , MultivaluedAdd vaults_root_displayname to vaults_displayname,
		MultivaluedDistinct vaults_code and ( vaults_displayname )
	
	controlid = Parameter { hidden: True }	
	paramVaultFilter = Parameter { multivalued: True }
	
	selectedSecretUID = Variable
	checkedSecretUIDs = Variable { multivalued: True }
	nbCheckedNoException = Variable { type: Integer }
	selectedVault = Variable { initial: paramVaultFilter }
	selectedType = Variable
	showExceptions = Variable { type: Boolean}
	
	
	selectedTarget = Variable
	selectedTargetDisplayname = Variable
	
	// Datasets for the filters
	safes_code = Variable { multivalued: True } 
	vaults_code = Variable { multivalued: True }
	vaults_displayname = Variable { multivalued: True }
	vaults_root_displayname = Variable { multivalued: True }
	vaults_root_code = Variable { multivalued: True }
	ex_result = Variable { }
	
	vaults = Dataset {
		columns: vaults_code as code, vaults_displayname as displayname
	}
	vaults_rootcause = Dataset {
		view: vault_list_bycontrol with controlid to controlid  
	}
	safesInVault = Dataset {
		view: safes_in_vault_bycontrol with selectedVault to vault_code, controlid to controlid
	}
	
	assetsindiscrepancy = Dataset {
		view: assetsindiscrepancy_bycontrol with controlid to controlid, control.controltagscope to scope, selectedVault to vaults unless-empty,
		    showExceptions to showExceptions  
		trend: Trend { 
			join-column: secret_uid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		
	}
	
	_checkedSecretsNotInException = Dataset {
	  view: secretsnoexceptionsinlist with checkedSecretUIDs to uids
	  count-variable: nbCheckedNoException
	}
	
	
	control = Record {
		view: ciso_controldetails with controlid to controlid
	}
	
	doCreateExceptions = NamedAction(
		Dialog bwpam_createCPMExceptionDialog (checkedSecretUIDs to accountUids, ex_result from resultaction )
		, Flash $ciso_secrets_detailsNLS.exception_set1.msg(SizeOf checkedSecretUIDs)
		, ReloadData( assetsindiscrepancy)
		, Unset checkedSecretUIDs
	)
	
	doDeleteExceptions = NamedAction(
		Dialog bwpam_deleteCPMExceptionDialog (checkedSecretUIDs to accountUids, ex_result from resultaction )
		, Flash $ciso_secrets_detailsNLS.exception_delete1.msg(SizeOf checkedSecretUIDs)
		, ReloadData( assetsindiscrepancy)
		, Unset checkedSecretUIDs
	)	
	
	
	Splitter {
		disposition: Horizontal 
		size: 70%
		Group {		
			Group {
				title: $bwcpam_accounts_discrepancies_details_NLS.labels.filters.tile
				layout: Layout { grab: horizontal True vertical False indent: horizontal 8 vertical 0 }
				margins: All 0
				Grid {
					columns:  GridColumn {}, GridColumn { width: 100 }, GridColumn { width: grow }
					layout: Layout { grab: horizontal True vertical False }
					gap: 20
					GridRow {
						GridCell {
							Combo {
								options: Dynamic {
									data: vaults
									text: Current displayname
									value: Current code
								}
								label: $bwcpam_accounts_discrepancies_details_NLS.labels.filters.vault
								variable: selectedVault
								allow-none: True
							}
						}
						GridCell {
							Button {
								image: %collection_16.delete
								actions: Unset selectedVault
								presentation: Link
								align: Left
								tooltip: $bwcpam_accounts_discrepancies_details_NLS.labels.filters.clear
								layout: Layout { hint: width 20 indent: horizontal 0 vertical 4 }
								disabled: StringPredicate ( selectedVault ) { when IsEmpty then True }
							}
						}						
						GridCell {
						  Checkbox {  text: $ciso_secrets_detailsNLS.secrets.checkbox variable: showExceptions }
						}
					}
					
				}
			}
		 	ButtonGroup {
		 	  align:  Right 	  
		     Button {
		       text: $ciso_secrets_detailsNLS.add_bulk_exceptions1.button( SizeOf checkedSecretUIDs)
		       actions: ExecuteNamedAction doCreateExceptions
		       disabled: Eval "checkedSecretUIDs.length == 0"
		     }
		     Button {
		       text: $ciso_secrets_detailsNLS.delete_bulk_exceptions1.button( SizeOf checkedSecretUIDs)
		       actions: ExecuteNamedAction doDeleteExceptions
		       disabled: Eval "checkedSecretUIDs.length == 0 || nbCheckedNoException.get() != 0"
		     }
			}
		
			Table {
				data: assetsindiscrepancy
				layout: Layout { grab: horizontal True vertical True}
				//show-filter: True
				show-count: True
				checkboxes: secret_uid to checkedSecretUIDs   				
				Column { column: secret_uid selection: selectedSecretUID hidden: True }
				Column { 
					sortable: True filterable: True width: 50% header: $ciso_secrets_detailsNLS.secrets.safe	column: safe_displayname 
					actions: Dialog bwf_casafeDetailsDialog ( Current safe_code to incode )				
				}
				Column { 
					sortable: True filterable: True width: 100% header: $ciso_secrets_detailsNLS.secrets.tab.text 		column: secret_displayname
				}
				Column { 
					sortable: True filterable: True width: 100% header: $ciso_secrets_detailsNLS.secrets.user		column: secret_custom1
				}	
				Column { 
					sortable: True filterable: True width: 100% header: $ciso_secrets_detailsNLS.secrets.platform 		column: secret_custom3 
				}			
				Column {
				  column: exception header: $ciso_secrets_detailsNLS.secrets.excpt 
				  text: Transform Current exception using exception_label_mapping
				  sortable: True
				}
				
				Column {
					column: trends
					header: $bw_fragment.trends
					text:Transform Current trends using bwf_trendStatusColumn 
					styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
					image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
					tooltip:$bwf_trendStatusColumnNLS.tooltip
		
					sortable: True
					filterable: True
					width: 120px
				}
			}
		}
		Group {
			Text {
				value: $bwcpam_accounts_discrepancies_details_NLS.details.message.pleaseselect
				compact: True
				hidden: StringPredicate ( selectedSecretUID ) {
					when Not IsEmpty then True 
				}
			}
			TabFolder {
				hidden: StringPredicate ( selectedSecretUID ) {
					when IsEmpty then True 
				}
				TabItem {
				 text: $ciso_secrets_detailsNLS.secrets.tab.text
				 IncludeFragment { fragment: fragmentAccountSecretDetails with selectedSecretUID binds-to inuid
				                  , value-of True to incansetexception
				   fragment-events: {
				     when "changed" then [
				       ReloadData( assetsindiscrepancy )
				     ]
				   }
				 }
				}
				/*TabItem {
				 text: "Compte cible"
				 Header { value: "TODO"}
				}*/
				 
			}
		}
	}
}
