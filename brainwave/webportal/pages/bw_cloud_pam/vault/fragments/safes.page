fragmentCAVaultSafesNLS = NLS {
	safe [
		en "Safe"
		fr "Safe"
	]
	secrets [
		en "# credentials"
		fr "Nb secrets"
	]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected safe secrets
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the safe uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected secret uid</li>
 * <li><b>outaccountlogin </b>the selected secret login</li>
 * <li><b>outrepositoryuid </b>the selected secret repository uid</li>
 * <li><b>outrepositoryname </b>the selected secret repository name</li>
 * </ul>
 * </span>
 */
fragmentCAVaultSafes = PageFragment {

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	outaccountuid = Variable
	outaccountlogin = Variable
	outaccountusername = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable
	
	selectedSafeUID = Variable

	selectedUids = Variable { type: String multivalued: True}

	safes = Dataset {
		view:bwpam_cavaultsafes with inuid to uid
		 trend: Trend {
		 	join-column:safe_uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		 }
		 disabled:Not BooleanPredicate(inenabled)
		 
	}
		
	Group {
	
		Table {
			data: safes
			layout: Layout { grab: horizontal True vertical True}
			//show-filter: True
			show-count: True
			
			Column { column: safe_uid selection: selectedSafeUID hidden: True }
			Column { 
				sortable: True filterable: True width: 100% header: $fragmentCAVaultSafesNLS.safe	column: safe_displayname 
				actions: Dialog bwf_casafeDetailsDialog ( Current safe_code to incode  )					
			}
			Column { 
				sortable: True filterable: True width: 200px header: $fragmentCAVaultSafesNLS.secrets	column: nb_secrets  text: Transform Current nb_secrets using nullToZeroMapping
				//actions: Dialog bwf_accountDetailsDialog ( Current account_uid to inuid , True to inshowapplications, True to incanreconcile )
			}
			
			Column {
				column: trends
				header: $bw_fragment.trends
				text:Transform Current trends using bwf_trendStatusColumn 
				styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
				image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
				tooltip:$bwf_trendStatusColumnNLS.tooltip
	
				sortable: True
				filterable: True
				width: 120px
			}
		}
	}
}


casafeDetailsPageNLS = NLS {

	casafe [en "Safe" fr "Safe"]
	accounts [en "Accounts" fr "Comptes"]
	secrets [en "Secrets" fr "Secrets"]

}
