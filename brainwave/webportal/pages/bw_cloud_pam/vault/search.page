cavaultSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity: CAVault
		simple-mode-rule: brpam_cavault_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "ca_vault" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
	ButtonGroup {
		align:Right
		Button {
			actions:GoTo BackInHistoryTruncate
			text:$search.back
			image:%browsing_16.back
		}
	}
}