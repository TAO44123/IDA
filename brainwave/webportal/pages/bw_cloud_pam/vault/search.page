cavaultSearchPageNLS = NLS {
	title [en "CyberArk Vaults" fr "Vaults CyberArk"]
	vault [en "Vault" fr "Vault"]
	safe [en "Safe" fr "Safe"]
	table.columns.vaultname [ en "CyberArk Vault" fr "Vault CyberArk" ]
	metrics_nb_secrets [en '# Credentials' fr "Secrets"]
	metrics_nb_resources [en '# Resources\n(Address)' fr "Ressources\n(Adresses)"]
	metrics_nb_platforms [en '# Platforms' fr "Plateformes"]
	metrics_nb_other_users [en '# non EPV and non AIM Users' fr "Utilisateurs non APV et non AIM"]
	metrics_nb_epv_users [en '# EPV Users' fr "Utilisateurs de type EPV"]
	metrics_nb_app_users [en '# Application Users (AIM)' fr "Utilisateurs de type application (AIM)"]
	metrics_nb_cyberark_users [en '# Internal CyberArk Users' fr "Utilisateurs internes CyberArk"]
	metrics_nb_builtin_users [en '# Default Built-in CyberArk Users' fr "Utilisateurs CyberArk présents par défaut"]
	metrics_nb_users [en '# Users' fr "Utilisateurs"]
	metrics_nb_cpm_failed [en '# Credentials with Failed CPM' fr "Secrets avec CPM en échec"]
	metrics_nb_cpm_active [en '# Credentials with Active CPM' fr "Secrets avec CPM actif"]
	metrics_nb_cpm_inactive [en '# Credentials without Active CPM' fr "Secrets sans CPM actif"]
	metrics_nb_identities [en '# Identities' fr "Identités"]
	metrics_nb_contractors [en '# Contractors' fr "Prestataires"]
	metrics_nb_admin_auditor [en '# Admin/Audit Users' fr "Administrateurs/auditeurs"]
	metrics_nb_users_get_credentials [en '# Users with credential access' fr "Utilisateurs avec accès aux secrets"]
	metrics_nb_safe_cpm_inactive [en '# Safe with credentials without CPM' fr "Safes avec secrets sans CPM"]
	metrics_nb_resources_cpm_inactive [en '# Resources without CPM' fr "Ressources sans CPM"]
	metrics_nb_safes [en '# Safes' fr "Safes"]
}

cavaultSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

cavaultSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

cavaultSearchPage = Page {
	title: $cavaultSearchPageNLS.title
	tags: "ca_vault" , "conceptsearch" priority 250
	icon: %pam_cyberark_concepts_32.vault
	large-icon: %pam_cyberark_concepts_48.vault
	description: $cavaultSearchPageNLS.title
		
	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	cavaultSearch = SearchDefinition {
		entity: CAVault
		simple-mode-rule: brpam_cavault_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedVaultUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	cavaultanalytics = Dataset {
		pages: Pages{tags: "ca_vault" and "searchresults" }
		count-variable:nbanalytics
	}
	
	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}
	
	cavaultData = Dataset {
		search: Search {
			definition: cavaultSearch
			view: brpam_cavault_searchpoint_trend with ["ca_vault"] to applicationtype, reftimeslot.timeslotuid to reftimeslotuid, UserVariable cavaultSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	cavaultData_count = Dataset {
		search: Search {
			definition: cavaultSearch
			view: brpam_cavault_searchpoint_trend with ["ca_vault"] to applicationtype, reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	
	
	goDetails = NamedAction (
		GoTo Activity CAVault Detail with selectedVaultUid to paramVaultUid
	)
	
	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: cavaultSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			simple-mode-layout: SimpleModeLayout {
				vault { label: $cavaultSearchPageNLS.vault }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: cavaultData
//					show-count: True
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size:1000
			show-count-button: True				
			
			Column {
				column: uid
				hidden: True
				selection: selectedVaultUid
			}
			
			Column {
				column: displayname
				sortable:True
				header: $cavaultSearchPageNLS.table.columns.vaultname
				width: 100%
				
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			
			Column {
				column: isnew
				text:Transform Current isnew using booleanDisplayMapping
				header: $searchlabel.isnew
				width: 100px
				styling:BooleanStyling(Current isnew) { when True then cavaultSearchPage_highlightnew when False then default }				
				initially-masked: True
			}

			Column {
				column:bw_pam_vaultmetrics_nb_safes
				text:Transform Current bw_pam_vaultmetrics_nb_safes using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$cavaultSearchPageNLS.metrics_nb_safes
				image:TemplateImageSelection(Eval "(''+current.prev_bw_pam_vaultmetrics_nb_safes).equals('null')?956487965:current.bw_pam_vaultmetrics_nb_safes-current.prev_bw_pam_vaultmetrics_nb_safes") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current bw_pam_vaultmetrics_nb_safes using mayBeNullMapping, Transform Current prev_bw_pam_vaultmetrics_nb_safes using mayBeNullMapping)
				align:Left
				width:110px
			}
			Column {
