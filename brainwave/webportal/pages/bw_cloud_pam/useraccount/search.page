CAuserlicense = UserVariable {
		initial:True
		type:Boolean
		persistent:True
}

CAuseraccountSearchPage_withtrends = UserVariable {
		initial:True
		type:Boolean
		persistent:True
}

CAuseraccountSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

CAuseraccountSearchPageNLS = NLS {
	usertype [en "User Type" fr "Type d''utilisateur"]
	nbsecretcpminactive [en "Credentials Inactive CPM " fr "Secrets CPM inactif"]
	nbsecrets [en "# Credentials" fr "Nb secrets"]
	nbsafecpminactive [en "Safes Inactive CPM" fr "Safes CPM inactif"]
	nbsafemanage [en "Safes Managed" fr "Safes gérés"]
	nbsafeuse [en "Safes with\nUse Credentials" fr "Safes avec\nutilisation des secrets"]
	nbsafe [en "# Safes" fr "Nb safes"]
}

CAuseraccountSearchPage = Page {
	title: $search.causer.title
	tags: "causeraccount", "conceptsearch" priority 200
	icon: %concept_32.account
	large-icon: %concept_48.account
	description: $searchlabel.useraccount

	initialUid = Parameter {
		type: String
		hidden: True 
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	causerSearch = SearchDefinition {
		entity: Account
		simple-mode-rule: br_causer_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedAccountUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	accountanalytics = Dataset {
		pages: Pages{tags: "causeraccount" and "searchresults" }
		count-variable:nbanalytics
	}

	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	causerData = Dataset {
		search: Search {
			definition: causerSearch
			view: br_causer_effective_searchpoint_trend_only with reftimeslot.timeslotuid to reftimeslotuid, UserVariable CAuseraccountSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	causerData_count = Dataset {
		search: Search {
			definition: causerSearch
			view: br_causer_effective_searchpoint_trend_only with reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}


	goDetails = NamedAction (
		GoTo Activity Account (CAusers) Detail with selectedAccountUid to paramAccountUid
	)

	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: causerSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			simple-mode-layout: SimpleModeLayout {
				repository { label: $repocyberark.concept break: True },
				login { label: $account.login },
				username { label: $account.username }
			}
		}
	}

