import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/details_nls.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/styles/workflow_mixins.page"

import "/webportal/pages/resources/services.page"
import "/webportal/pages/resources/reconciliation_dialogs.page"

import "/webportal/pages/bw_fragments/account/details.page"
import "/webportal/pages/bw_fragments/account/groups.page"
import "/webportal/pages/bw_fragments/account/serverrights.page"
import "/webportal/pages/bw_fragments/account/rights.page"
import "/webportal/pages/bw_fragments/account/cyberarkrights.page"
import "/webportal/pages/bw_fragments/account/fsrights.page"
import "/webportal/pages/bw_fragments/account/controls.page"
import "/webportal/pages/bw_fragments/account/owner.page"
import "/webportal/pages/bw_fragments/account/usages.page"
import "/webportal/pages/bw_cloud_pam/useraccount/fragments/analytics.page"
import "/webportal/pages/bw_fragments/account/decisionhistory.page"
import "/webportal/pages/bw_fragments/account/businessactivities.page"
import "/webportal/pages/bw_fragments/account/theoreticalrights/theoreticalrights.page"
import "/webportal/pages/bw_fragments/account/theoreticalrights/overallocations.page"
import "/webportal/pages/bw_fragments/custom/accountExtendedDetails.page"


CAuseraccountDetailsPageNLS = NLS {
	dynamictitle [en "User Details {0}" fr "Détails de l''utilisateur {0}" ]
	details [en "Details" fr "Détails"]
	extended [en "Additional information" fr "Informations complémentaires"]
	owner [en "Owner" fr "Propriétaire"]
	account [en "User" fr "Utilisateur"]
	groups [en "Groups" fr "Groupes"]
	access [en "Access" fr "Accès"]
	infrastructure [en "Servers" fr "Serveurs"]
	applications [en "Applications" fr "Applications"]
	shares [en "Shares" fr "Partages"]
	usages [en "Usages" fr "Usages"]
	controls [en "Controls" fr "Contrôles"]
	analytics [en "Analytics" fr "Analyses"]
	decisionhistory [en "Decision history" fr "Historique des décisions"]
	model [en "Security Model" fr "Modèle de sécurité"]
	theoretical [en "Granted rights" fr "Droits assignés"]
	businessactivities [en "Business Activities" fr "Activités Métier"]
	overallocated [en "Overallocated rights" fr "Droits suralloués"]
	cyberark.vault [en "CyberArk Vaults" fr "Vaults CyberArk"]
	cyberark.safe [en "CyberArk Safes" fr "Safes CyberArk"]
	cyberark.graph [en "CyberArk Graph" fr "Graphe CyberArk"]
}

CAuseraccountDetailsPageRecorduid = Page {
	title: "Recorduid redirection (account)"
	conditional-redirect: ConditionalRedirect { condition: True target: Activity Account (CAusers) Detail with accountUid.uid to paramAccountUid }
	feature: accountdetails_access
	
	recorduid = Parameter {
		type: Integer
		hidden: True
		recorduid-of: Account
		mandatory: True
	}
	
	accountUid = Record {
		view: br_accountDetail_uid with recorduid to recorduid
	}
}

CAuseraccountDetailsPage = Page {
	title: $accountDetails.title
	dynamic-title: $CAuseraccountDetailsPageNLS.dynamictitle (account.login)
	enter-event: 	Set account.bwa_accountanalytics_nbdirectgroup to nbgroups,
					IntCase(account.bwa_accountanalytics_nbdirectinfrastructureright) { when >0 then [ Set True to hasinfrastructurerights ] },
					IntCase(userapp.nbapp) { when >0 then [ Set True to hasrights ] },
					IntCase(account.bwa_accountanalytics_nbdirectfsright) { when >0 then [ Set True to hasfsrights ] },
					IntCase(account.bwa_accountanalytics_nbbusinessactivity) { when >0 then [ Set True to hasbusinessactivities ] },
					IntCase(account.bwa_accountanalytics_nbtheoretical) { when >0 then [ Set True to hastheoreticalrights ] },
					IntCase(account.bwa_accountanalytics_nbusage) { when >0 then [ Set True to hasusages ] }
					
								
	// Parameters Here
	paramAccountUid = Parameter {
		type: String
		hidden: True
		mandatory: True
	}
	
	// Variables Here
	selectedAccountUid = Variable {
		type: String
		initial: paramAccountUid
	}
	
	reconciliationResult = Variable {
		type: String
	}

	active_detail = Variable { initial:False type:Boolean multivalued:False }
	active_model = Variable { initial:False type:Boolean multivalued:False }
	active_access = Variable { initial:False type:Boolean multivalued:False }
	
	active_account = Variable { initial:False type:Boolean multivalued:False }
	active_extended = Variable { initial:False multivalued:False type:Boolean }
	active_owner = Variable { initial:False type:Boolean multivalued:False }
	active_groups = Variable { initial:False type:Boolean multivalued:False }
	active_businessactivities = Variable { initial:False type:Boolean multivalued:False }
	active_theoreticalrights = Variable { initial:False type:Boolean multivalued:False }
	active_overallocatedrights = Variable { initial:False type:Boolean multivalued:False }
	active_servers = Variable { initial:False type:Boolean multivalued:False }
	active_applications = Variable { initial:False type:Boolean multivalued:False }
	active_cavaults = Variable { initial:False multivalued:False type:Boolean }
	active_casafes = Variable { initial:False multivalued:False type:Boolean }
	active_cagraph = Variable { initial:False multivalued:False type:Boolean }
	active_shares = Variable { initial:False type:Boolean multivalued:False }
	active_usages = Variable { initial:False type:Boolean multivalued:False }
	active_control = Variable { initial:False type:Boolean multivalued:False }
	active_anaytics = Variable { initial:False type:Boolean multivalued:False }
	active_decisionhistory = Variable { initial:False type:Boolean multivalued:False }

	nbgroups = Variable { initial:0 }
	hastheoreticalrights = Variable { type:Boolean initial:False } 
	hasbusinessactivities = Variable { type:Boolean initial:False } 
	hasinfrastructurerights = Variable { type:Boolean initial:False } 
	hasrights = Variable { type:Boolean initial:False } 
	hasfsrights = Variable { type:Boolean initial:False } 
	hasusages = Variable { type:Boolean initial:False } 
	hascarights = Variable { type:Boolean initial:True } 

	showextended = Variable { initial:False }

	nbdefects = Variable 
	nboverallocated = Variable 
	nbdecision = Variable 
	nbcavaults = Variable
	nbcasafes = Variable

	// Empty uid when search mode
	nonEmptyUid = Variable { type: String }
	
	// Records for concept details
	account = Record {
		view: bwf_accountDetail with selectedAccountUid to uid
	}

	userapp = Record {
		view: bwf_userAppDetail with selectedAccountUid to uid
	}
		
	// Start of the Layout based on a 1-column Grid
	Grid {
		columns: GridColumn { width: grow }							
		layout: Layout { grab: horizontal True vertical True }

		GridRow {
			height:grow
			GridCell {
				TabFolder {
					border:True
					layout:Layout { indent: horizontal 0 vertical 6 }

					TabItem {
						text:$CAuseraccountDetailsPageNLS.details
						activation-event:Set True to active_detail
						
						TabFolder {
							border:False
							TabItem {
								text:$CAuseraccountDetailsPageNLS.account
								activation-event:Set True to active_account

								IncludeFragment {
									fragment:fragmentAccountFullDetails
									with value-of selectedAccountUid to inuid, value-of True to inshowrisks, value-of True to incanupdatedescription, value-of True to incanupdatetags, value-of Eval "active_detail.get() && active_account.get()" to inenabled
								}
							}
							TabItem {
								text:$CAuseraccountDetailsPageNLS.owner
								activation-event:Set True to active_owner

								IncludeFragment {
									fragment:fragmentAccountOwnerFull
									with value-of selectedAccountUid to inuid, value-of True to inenablemanualreconciliation, value-of True to incanupdateowners, value-of Eval "active_detail.get() && active_owner.get()" to inenabled
								}
							}
							TabItem {
								text:$CAuseraccountDetailsPageNLS.groups
								hidden: OrPredicate{
									StringPredicate(nbgroups) { when IsEmpty then True otherwise False }
									IntPredicate(nbgroups) { when >0 then False otherwise True }	
								}
								activation-event:Set True to active_groups

								IncludeFragment {
									fragment:fragmentAccountGroupsSelection
									with value-of selectedAccountUid to inuid, value-of True to incanshowdetails, value-of Eval "active_detail.get() && active_groups.get()" to inenabled
								}
							}
						}
					}
					TabItem {
						text:$CAuseraccountDetailsPageNLS.access
						activation-event:Set True to active_access
						hidden: 
							AndPredicate {
								Not BooleanPredicate(hasinfrastructurerights)
								Not BooleanPredicate(hasrights)
								Not BooleanPredicate(hasfsrights)
								Not BooleanPredicate(hasusages)
								Not BooleanPredicate(hascarights)
							}

						TabFolder {
							border:False
							TabItem {
								text:$CAuseraccountDetailsPageNLS.infrastructure
								hidden:Not BooleanPredicate(hasinfrastructurerights)
								activation-event:Set True to active_servers
								feature: All(pam_license, Any(governance_license, compliance_license))

								IncludeFragment {
									fragment:fragmentAccountServerRightsList
									with value-of selectedAccountUid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_servers.get()" to inenabled
								}
							}
							TabItem {
								text:$CAuseraccountDetailsPageNLS.applications
								hidden:Not BooleanPredicate(hasrights)
								activation-event:Set True to active_applications
								feature: All(pam_license, Any(governance_license, compliance_license))
								IncludeFragment {
									fragment:fragmentAccountRightsSelection
									with value-of selectedAccountUid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_applications.get()" to inenabled
								}
							}
							TabItem {
								text: $CAuseraccountDetailsPageNLS.cyberark.vault
								activation-event:Set True to active_cavaults
								hidden:
									OrPredicate {
										IntPredicate(nbcavaults) { when >0 then False otherwise True }
										StringPredicate (nbcavaults) { when IsEmpty then True }
									}
								IncludeFragment {
									fragment:fragmentAccountCAVaultsRights
									with value-of selectedAccountUid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_cavaults.get()" to inenabled,
									nbcavaults binds-to nbvaults
								}
							}
							TabItem {
								text: $CAuseraccountDetailsPageNLS.cyberark.safe
								activation-event:Set True to active_casafes
								hidden:
									OrPredicate {
										IntPredicate(nbcasafes) { when >0 then False otherwise True }
										StringPredicate (nbcasafes) { when IsEmpty then True }
									}
								IncludeFragment {
									fragment:fragmentAccountCASafesRights
									with value-of selectedAccountUid to inuid, value-of True to incanshowdetails, value-of Eval "active_access.get() && active_casafes.get()" to inenabled,
									nbcasafes binds-to nbsafes
								}
							}
							TabItem {
								text: $CAuseraccountDetailsPageNLS.cyberark.graph
								activation-event:Set True to active_cagraph
								feature: All(pam_license, Any(governance_license, compliance_license))
								hidden:
									AndPredicate {
										OrPredicate {
											IntPredicate(nbcavaults) { when >0 then False otherwise True }
											StringPredicate (nbcavaults) { when IsEmpty then True }
										}
										OrPredicate {
											IntPredicate(nbcasafes) { when >0 then False otherwise True }
											StringPredicate (nbcasafes) { when IsEmpty then True }
										}
									}
								IncludeFragment {
									fragment:fragmentAccountCAGraphRights360
									with value-of selectedAccountUid to inuid, value-of nbcasafes to innbsafes, value-of Eval "active_access.get() && active_cagraph.get()" to inenabled
								}
							}
							TabItem {
								text:$CAuseraccountDetailsPageNLS.shares
								feature: All(pam_license, unstructureddata_license, Any(governance_license, compliance_license))
								hidden:Not BooleanPredicate(hasfsrights)
								activation-event:Set True to active_shares

								IncludeFragment {
									fragment:fragmentAccountAllFSRightsList
									with 	value-of selectedAccountUid to inuid, 
											value-of True to incanshowdetails,
											value-of Eval "active_access.get() && active_shares.get()" to inenabled
								}
							}
							TabItem {
								text:$CAuseraccountDetailsPageNLS.usages
								hidden:Not BooleanPredicate(hasusages)
								activation-event:Set True to active_usages
								feature: All(pam_license, Any(governance_license, compliance_license))
								IncludeFragment {
									fragment:fragmentAccountUsages
									with 	value-of selectedAccountUid to inuid, 
											value-of True to incanshowdetails,
											value-of Eval "active_access.get() && active_usages.get()" to inenabled
								}
							}
						}
					}
					TabItem {
						text:$CAuseraccountDetailsPageNLS.controls
						activation-event:Set True to active_control
						badge: Eval "nbdefects.get()>0?nbdefects.get():''"
						feature: All(pam_license, Any(governance_license, compliance_license))
						IncludeFragment {
							fragment:fragmentAccountControlDefectsList
							with value-of selectedAccountUid to inuid, value-of True to inenabled,nbdefects binds-to outnbdefects, value-of True to incanshowdetails
						}
					}
					TabItem {
						text:$CAuseraccountDetailsPageNLS.analytics
						activation-event:Set True to active_anaytics
						feature: All(pam_license, Any(governance_license, compliance_license))
						IncludeFragment {
							fragment:fragmentCAuserAnalytics
							with value-of selectedAccountUid to inuid, value-of active_anaytics to inenabled
						}
					}
					TabItem {
						text:$CAuseraccountDetailsPageNLS.decisionhistory
						hidden:IntPredicate(nbdecision) { when >0 then False otherwise True }
						activation-event:Set True to active_decisionhistory
						feature: All(pam_license, Any(governance_license, compliance_license))
						IncludeFragment {
							fragment:fragmentAccountDecisionHistory
							with value-of selectedAccountUid to inuid, nbdecision binds-to outnbdecision, value-of active_decisionhistory to inenabled
						}
					}
				}
			}
		}
	}
}