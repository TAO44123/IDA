ds_pambooster_bridge_NLS = NLS {
  title [ en "PAM Booster - file" fr "PAM Booster - fichier" ]
  description [ 
    en "Collects CyberArk PAM or Privilege Cloud data"
    fr "Collecte des données CyberArk PAM ou Privilege Cloud"]
}


ds_pambooster_bridge_file = Page {
	title: $ds_pambooster_bridge_NLS.title
	tags: "bwds_connector" , "file" , "custom"
	description: $ds_pambooster_bridge_NLS.description
	icon: "bw_dsm/L/bw_genericapp.png"
	large-icon: "bw_dsm/XL/bw_genericapp.png"	
	metadata: (  
	 category -> "application", 
	 collector -> "bw_ias_cyberark",
	 destPathVar -> "bw_cyberark_model_sourceFolder",
	 filePattern -> "*.csv",
	 multiFile -> True,
	 hasMapping -> False
   )
}
