/* Import other pages here */
import "/webportal/pages/bw_portaluar_base/admin/documentation.page"

/* Nationalized labels here */

admin_documentation_enduser_guideNLS = NLS {
	title [en "PAM Booster Administration Guide" fr "Guide d'administration du service PAM Booster" ]
	url [ 
		fr "static/static/bw_cloud_pam/generated_doc/adm_enduser_guide_en.html" 
		en "static/static/bw_cloud_pam/generated_doc/adm_enduser_guide_en.html"
	]
}
admin_documentation_enduser_guide = Page {
	title: $admin_documentation_enduser_guideNLS.title
	
	IncludeHTMLWidget {
		template: BrainwaveDocDisplayWidget
		layout: Layout { grab: horizontal True vertical True }
		bindings:
			value-of $admin_documentation_enduser_guideNLS.title to title,
			value-of $admin_documentation_enduser_guideNLS.url to url
	}
}
