/* Import other pages here */
import "/webportal/pages/bw_fragments/lib/icons.page"

/* Nationalized labels here */
BrainwaveDocsNLS = NLS {
	title [en "Documentations" fr "Documentations"]
}

BrainwaveDocDisplayWidget = HTMLWidgetTemplate {
	source-file: "static/bw_portaluar_base/doclibrary.html"
	bindings:
			title as in String ,
			url as in String
}
BrainwaveDocsStyle = Style {
	size:24px
}

/**
 * Displays the available documentations
 * in order to do so the Dataset dynamically crawls the /static subdirectory for documentations
 * 
 */
pgs_documentationPage = Page {
	title:$BrainwaveDocsNLS.title

	docs = Dataset {
		view:bw_getGeneratedDocs
		includes: StringPredicate ( Current url ) {
			when "static/static/bw_cloud_pam/generated_doc/ciso_enduser_guide_en.html" then True
			when "static/static/bw_cloud_pam/generated_doc/adm_enduser_guide_en.html" then True
			when "static/static/bw_cloud_pam/generated_doc/pgm_enduser_guide_en.html" then True
			when "static/static/bw_cloud_pam/generated_doc/uar_pambooster_myfirstreview_en.html" then True			
			otherwise False
		}
	}
	
	TemplateTable {
		data:docs
		pagination:8
		show-filter:True
		layout: Layout { grab:horizontal True vertical True }

		ImageCell {
			image:%report_48.word
			left:0
			top:0
			width:48
			height:48
		}
		
		TextCell {
			left:50
			top:20
			width:1000
			height:48
			column:title
			styling:BrainwaveDocsStyle
			on-click:GoTo Page pgs_BrainwaveDoc with Current title to title, Current url to url
			filterable:True 
		}
	}
}

pgs_BrainwaveDoc = Page {
	title:'Documentation'
	dynamic-title:title
	
	title = Parameter
	url = Parameter

	IncludeHTMLWidget {
		template: BrainwaveDocDisplayWidget
		layout: Layout { grab: horizontal True vertical True }
		bindings:
			value-of title to title,
			value-of url to url
	}
}