	}
	savenote = TaskRecord(create "bw_saveNote")

	save = NamedAction (
		Set val to savenote.note,
		Set Principal.uid to savenote.identity,
		TaskComplete savenote
	)

	Group {
        styling: cssRound
        
		Header {
			value:$bw_admin_home_notesblockNLS.header
			icon:%collection_16.pencil
			styling:bigTitleStyle
		}
		Separator {
			color:blue
			width:1
		}
		Spacer {
			height:16
		}
		IncludeHTMLWidget {
			template:textEditorArea
			layout:Layout {grab:horizontal True vertical True hint: height 600}
			bindings:
			val binds-to content,
			value-of False to readonly
		}
		ButtonGroup {
			Button {
				actions:ExecuteNamedAction save, Flash $bw_admin_home_notesblockNLS.save.flash
				text:$bw_admin_home_notesblockNLS.save
			}
		}
		Spacer {
			height:Fill
		}
	}
}

bw_admin_home_top10riskblock = PageFragment {
	Group {
		styling:cssRound
		layout:Layout { grab: horizontal True vertical False hint:height 400 }
	
		Grid {
			columns:GridColumn{width:grow group:a},GridColumn{width:grow group:a},GridColumn{width:grow group:a}

			GridRow {
				height:32
				GridCell {
					span:3
					Header {
						value:$bw_admin_home_top10riskblockNLS.header
						icon:%status_16.warning
						styling:bigTitleStyle
					}
					Separator {
						color:blue
						width:1
					}
				}
			}
			GridRow {
				height:grow
				GridCell {
					IncludeFragment (bw_admin_home_top10riskaccount)
				}
				GridCell {
					IncludeFragment (bw_admin_home_top10riskidentity)
				}
				GridCell {
					IncludeFragment (bw_admin_home_top10riskorganisation)
				}
			}
		}	
	}
}

bw_admin_home_top10riskorganisation = PageFragment {
	organisations = Dataset {
		view:bwd_topxriskorganisations
		limit:10
	}

	Header { 
		value:$bw_admin_home_top10riskNLS.top10organisation
		styling:bigTitleStyle
	}
	
	Link {
		iterate-on:organisations
		value:Current displayname
		tooltip:Current organisationtypedisplayname
		target:Activity Organisation Detail with Current uid to paramOrganisationUid
	}
}

bw_admin_home_top10riskidentity = PageFragment {
	identities = Dataset {
		view:bwd_topxriskidentities
		limit:10
	}

