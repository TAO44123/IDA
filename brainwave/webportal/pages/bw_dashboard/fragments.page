bw_admin_home_nbidentitiesperrisklevel = PageFragment {
	chart = Dataset {
		view:bwd_nbidentitypermaxrisklevel
	}

	Group {
        styling: cssRound
        
		Header {
			value:$bw_admin_home_nbidentitiesperrisklevelNLS.header
			icon:%concept_16.identity
			styling:bigTitleStyle
		}
		Separator {
			color:blue
			width:1
		}
		Spacer {
			height:32
		}
		IncludeHTMLWidget {
		layout: Layout { grab: horizontal False vertical False hint:width 280 height 165 align: horizontal Center vertical Center }
			template: doughnutChart
			datasets: chart ( bwa_identityanalytics_aggmaxrisklevel, bwa_identityanalytics_aggmaxrisklevel, nb ) to chartdata ( label, code , count )
			bindings: 
				value-of True to tooltipShowPercent,
				value-of False to showLegend,
				value-of True to showHalfOnly,
				value-of Constant higherTheWorstPalette to customColors
			widget-events: {
				when onclick then [
					GoTo Activity Identity Search with Concat('midentity(*eqActive,eqbwa_identityanalytics_aggmaxrisklevel[valueIntegerParam=^"',Current code,'"])') to identitySearch
				]
			}
		}
	}
}

