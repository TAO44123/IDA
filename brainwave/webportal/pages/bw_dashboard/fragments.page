bw_admin_home_ledgerinfosblock = PageFragment {
	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	identities_stat = Dataset {
		service: srv_identities_statistics with PortalTimeslot.UID to timeslotUid
		}
	data_stat = Dataset {
		service: srv_data_statistics with PortalTimeslot.UID to timeslotUid
		}

	org_stat = Dataset {
		service: srv_org_statistics with PortalTimeslot.UID to timeslotUid
		}

	asset_stat = Dataset {
		service: srv_asset_statistics with PortalTimeslot.UID to timeslotUid
		}
	
	repositories = Dataset {
		view:bwd_allrepositoriescount
	}
	servers = Dataset {
		view:bwd_allrepositoriescount with True to server
	}
	
	stats = Dataset {
		union:Union {
			datasets:identities_stat projects (identities_ to label, current_ to val), 
						org_stat projects(organization_ to label, current_ to val), 
						asset_stat projects (assets_ to label, current_ to val),
						repositories projects(repositorylabel to label, nb to val),
						repositories projects(repositoryaccountlabel to label, bwa_repositoryanalytics_nbaccount to val),
						repositories projects(grouplabel to label, bwa_repositoryanalytics_nbgroup to val),
						servers projects(serverlabel to label, nb to val),
						servers projects(repositorylocalaccountlabel to label, bwa_repositoryanalytics_nbaccount to val),
						servers projects(localgrouplabel to label, bwa_repositoryanalytics_nbgroup to val),
						data_stat projects (data_ to label, current_ to val)
			discriminator-column:discr
		}
		excludes: StringPredicate(Current label) { 
			when "unknown_relation_ship_count" then True 
			when "asset_count" then True 
			when "derogation_count" then True 
			when "support_count" then True 
			otherwise False }
	}
	

	prev_identities_stat = Dataset {
		service: srv_identities_statistics with reftimeslot.timeslotuid to timeslotUid
	}
	prev_data_stat = Dataset {
		service: srv_data_statistics with reftimeslot.timeslotuid to timeslotUid
	}

	prev_org_stat = Dataset {
		service: srv_org_statistics with reftimeslot.timeslotuid to timeslotUid
	}

	prev_asset_stat = Dataset {
		service: srv_asset_statistics with reftimeslot.timeslotuid to timeslotUid
	}
	prev_repositories = Dataset {
		view:bwd_allrepositoriescount
		timeslot:reftimeslot.timeslotuid
	}
	prev_servers = Dataset {
		view:bwd_allrepositoriescount with True to server
		timeslot:reftimeslot.timeslotuid
	}
	
	prev_stats = Dataset {
		union:Union {
			datasets:prev_identities_stat projects (identities_ to label, current_ to val), 
						prev_data_stat projects (data_ to label, current_ to val), 
						prev_org_stat projects(organization_ to label, current_ to val), 
						prev_asset_stat projects (assets_ to label, current_ to val),
						prev_repositories projects(repositorylabel to label, nb to val),
						prev_repositories projects(repositoryaccountlabel to label, bwa_repositoryanalytics_nbaccount to val),
						prev_repositories projects(grouplabel to label, bwa_repositoryanalytics_nbgroup to val),
						prev_servers projects(serverlabel to label, nb to val),
						prev_servers projects(repositorylocalaccountlabel to label, bwa_repositoryanalytics_nbaccount to val),
						prev_servers projects(localgrouplabel to label, bwa_repositoryanalytics_nbgroup to val)
			discriminator-column:discr
		}
	}

	all_stats = Dataset {
		join:Join {
			primary-dataset:stats
			secondary-dataset:prev_stats
			primary-column:label // false positive... igrcAnalytics Pages editor BUG
			secondary-column:label // false positive... igrcAnalytics Pages editor BUG
			primary-optional:False
			secondary-cardinality:optional
			secondary-prefix:prev_
		
		}
	
	}

	Group {
        styling: cssRound
        
		Grid {
			layout:Layout { grab: horizontal True vertical False hint:height 32 }
			columns:GridColumn { width:grow }, GridColumn {width:48px }
			GridRow {
				GridCell {
					Header {
						value:$bw_admin_home_ledgerinfosblockNLS.header
						icon:%logos_16.brainwavegrc_cube
						styling:bigTitleStyle
					}
				}
				GridCell {
					ButtonGroup {
						nb-inline:1
						Button {
							actions:Message "nop"
							text:""
							presentation:Link
							disabled:True
						}
						Button {
							actions:GoTo Page timeslot_statistics
							text:$bw_admin_home_ledgerinfosblockNLS.explorestatistics
							presentation:Link
							disabled:Not FeaturePredicate adminmenu
						}
						Button {
							actions:GoTo Page timeslot_changes
							text:$bw_admin_home_ledgerinfosblockNLS.explorechanges
							presentation:Link
							disabled:Not FeaturePredicate adminmenu
						}
						Button {
							actions:GoTo Page manage_timeslot
							text:$bw_admin_home_ledgerinfosblockNLS.managetimeslot
							presentation:Link
							disabled:Not FeaturePredicate adminmenu
						}
					}
				}
			}
		}
		Separator {
			width:1
			color:blueNG
		}
		Header {
			value:$bw_adminHomeNLS.commitdate(PageTimeslot.CommitDate)
		}
		Table {	   
			layout:Layout{grab: horizontal True vertical False hint:height 670}
			data:all_stats								
			Column {
				header: $bw_adminHomeNLS.entity
				column:label
				tooltip:Transform Current label using statistics												
				image: Transform Current label using statisticsIcons
				text: Transform Current label using statistics												
				width: 100%				
			}
			Column {
				header:$bw_adminHomeNLS.cur
				column:val
				text:Transform Current val using bw_adminHomeNumber	
				align:Right
				width: 80px																		
			}
			Column {
				column:label
				header:""
				text:''
				tooltip:Difference(Current val, Current prev_val)
				align:Right
				width:32px																		
				fixed-width:True
				image:TemplateImageSelection(Difference(Current val, Current prev_val)) using bwf_trend
			}
			Column {
				header:$bw_adminHomeNLS.prev
				column:prev_val
				text:Transform Current prev_val using bw_adminHomeNumber	
				align:Right
				width: 80px																		
			}
		}
	}
}

bw_admin_home_controlblock = PageFragment {

	count_identitieswsodprb = Variable

	totalactiveaccounts = Record {
		view:bwd_totalactiveaccounts
	}
	totalactiveidentities = Record {
		view:bwd_totalactiveidentities
	}
	unusedaccounts= Record {
		view:bwd_accountnbcontroldefects with "ACC01" to controlname
	}
	orphanaccounts= Record {
		view:bwd_accountnbcontroldefects with "ACC02" to controlname
	}
	leaveraccounts= Record {
		view:bwd_accountnbcontroldefects with "ACC03" to controlname
	}
	newaccount = Record {
		view:bwd_accountnbnewactiveaccounts
	}
	
	identityoverallocatedrights = Record {
		view:bwd_identitynbcontroldefects with "ACC17" to controlname
	}
	
	identities = Dataset {
		view:bwsodd_identities
		count-variable:count_identitieswsodprb
	}
	

	Group {
		styling:cssRound
		layout:Layout { grab: horizontal True vertical False hint:height 420 }
		
		Grid {
			columns:GridColumn{width:grow group:a},GridColumn{width:grow group:a},GridColumn{width:grow group:a},GridColumn{width:grow group:a}
	
			GridRow {
				height:32
				GridCell {
					span:4
					Header {
						value:$bw_admin_home_controlblockNLS.header
						icon:%concept_16.control
						styling:bigTitleStyle
					}
					Separator {
						color:blue
						width:1
					}
				}
			}
			GridRow {
				GridCell {
					// Leaver accounts
					IncludeHTMLWidget {
						layout: Layout { hint: height 140 width 120 align: horizontal Center vertical Center }
						template: liquidGaugeIndicator
						bindings:
							value-of False to displayPercent,
							value-of leaveraccounts.nb to count,
							value-of totalactiveaccounts.nb to maxValue,
							value-of '#E96959' to waveTextColor,
							value-of '#E96959' to textColor,
							value-of '#CF4544' to circleColor,
							value-of '#CF4544' to waveColor
						widget-events: {
							when onclick then [
								GoTo Activity Account Search with 'maccount(*|controldiscrepancy(*|controllog(*eqControlName[controlNameParam=^"ACC03"])))' to accountSearch 
							]
						}
					}
					Header {
						value:$bw_admin_home_controlblockNLS.leaver
						layout: Layout { grab:horizontal True vertical False align:horizontal Center vertical Center }
					}
				}
				GridCell {
