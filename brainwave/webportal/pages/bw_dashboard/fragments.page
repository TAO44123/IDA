		count-variable:count_repositoriesReviewedNotReviewed
	}
	accountremediationinprogress = Record {
		view:bwd_nbopenremediations with "account" to reviewtype, inrepositorySelectedTag to accountTagfilter
	}


	safesReviewedAll = Dataset {
		view:bwiasr_safeRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, insafeSelectedTag to tagfilter
		count-variable:count_safesReviewedAll
		disabled: Not FeaturePredicate  All(pam_license, Any(governance_license, compliance_license))
	}
	safesReviewedCompliant = Dataset {
		view:bwiasr_safeRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, insafeSelectedTag to tagfilter
