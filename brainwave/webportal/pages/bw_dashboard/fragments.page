bw_admin_home_reviewblock = PageFragment {
	/* Variables here */
	inerrorThreshold = Variable { initial:365 }
	inwarningThreshold = Variable { initial:45 }
	inapplicationSelectedTag = Variable {  }
	inrepositorySelectedTag = Variable {  }
	insafeSelectedTag = Variable {  }

	count_applicationsReviewedAll = Variable
	count_applicationsReviewedCompliant = Variable
	count_applicationsReviewedWarning = Variable
	count_applicationsReviewedNotReviewed = Variable

	count_repositoriesReviewedAll = Variable
	count_repositoriesReviewedCompliant = Variable
	count_repositoriesReviewedWarning = Variable
	count_repositoriesReviewedNotReviewed = Variable

	count_safesReviewedAll = Variable
	count_safesReviewedCompliant = Variable
	count_safesReviewedWarning = Variable
	count_safesReviewedNotReviewed = Variable

	count_activereviews = Variable
	
	/* Datasets and records here */
	
	campaigns = Dataset { // all campaigns
		view:bwaccess360_accessreviewcampaignsbv with ["ok","update","revoke"] to filterbystatus
		includes:StringPredicate(Current currentcampaignstatus) {
			when "init" then True
			when "active" then True
			when "pause" then True
			when "finalizing" then True
			otherwise False
		}
		count-variable:count_activereviews
	}
		
	// review stats
	applicationsReviewedAll = Dataset {
		view:bwiasr_applicationRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inapplicationSelectedTag to tagfilter
		count-variable:count_applicationsReviewedAll
	}
	applicationsReviewedCompliant = Dataset {
		view:bwiasr_applicationRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inapplicationSelectedTag to tagfilter
		includes:StringPredicate(Current compliancestatus) { when "ok" then True otherwise False }
		count-variable:count_applicationsReviewedCompliant
	}
	applicationsReviewedWarning = Dataset {
		view:bwiasr_applicationRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inapplicationSelectedTag to tagfilter
		includes:StringPredicate(Current compliancestatus) { when "warning" then True otherwise False }
		count-variable:count_applicationsReviewedWarning
	}
	applicationsReviewedNotReviewed = Dataset {
		view:bwiasr_applicationRightReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inapplicationSelectedTag to tagfilter
		includes:StringPredicate(Current compliancestatus) { when "ko" then True otherwise False }
		count-variable:count_applicationsReviewedNotReviewed
	}
	rightremediationinprogress = Record {
		view:bwd_nbopenremediations with "right" to reviewtype, inapplicationSelectedTag to applicationrightTagfilter
	}



	repositoriesReviewedAll = Dataset {
		view:bwiasr_repositoryAccountReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inrepositorySelectedTag to tagfilter
		count-variable:count_repositoriesReviewedAll
	}
	repositoriesReviewedCompliant = Dataset {
		view:bwiasr_repositoryAccountReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inrepositorySelectedTag to tagfilter
		includes:StringPredicate(Current compliancestatus) { when "ok" then True otherwise False }
		count-variable:count_repositoriesReviewedCompliant
	}
	repositoriesReviewedWarning = Dataset {
		view:bwiasr_repositoryAccountReviewStatusBV with inwarningThreshold to warningThreshold, inerrorThreshold to errorThreshold, inrepositorySelectedTag to tagfilter
