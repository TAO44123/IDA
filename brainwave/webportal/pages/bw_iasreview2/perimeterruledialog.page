/* Import other pages here */

/* Nationalized labels here */
perimeterruledialogNLS = NLS {
	title [en "Custom perimeter rule" fr "Règle de périmètre personnalisé"]
	label [en "Select Custom Perimeter Rule" fr "Sélectionner une règle de périmètre personnalisée"]
}

perimeterruledialog = Dialog {
	title: $perimeterruledialogNLS.title
	width: 600
	height: 150
	
	buttons: [
	OkButton {
		actions: Set namerecord.ruledisplayname to name
	}
	CancelButton
	]
	
	/* variables here */
	
	uid = Variable
	name = Variable
	
	/* Datasets and records here */
	namerecord = Record {
		view: getruledisplayname with uid to rulename
	}
	
	/* dialog page content */
	RuleSelector {
		entity: Account
		selection: uid
		editable: True		
		tag-family: "Perimeter"
		label: $perimeterruledialogNLS.label
		layout: Layout { hint: width 350  }
	}
}

