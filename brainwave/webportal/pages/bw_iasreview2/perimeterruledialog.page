perimeterruledialog_test = Page {
	title: "Test Perimeter Rule Dialog"
	// homepage-for: All

	selectedRuleUid = Variable
	selectedRuleName = Variable
	
	Button {
		text: "Open Perimeter Rule Dialog"
		actions:
			Dialog perimeterruledialog(selectedRuleUid to uid, selectedRuleName to name, selectedRuleUid from uid, selectedRuleName from name)
		}

	Text {
		value: selectedRuleName
		label: "Selected Rule Name"
	}

	Text {
		value: selectedRuleUid
		label: "Selected Rule UID"
	}
}