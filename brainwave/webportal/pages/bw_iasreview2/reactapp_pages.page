bwaccess360_accessrightsreviewpage = Page {
	title: "Rights Review" 
	jsapp-id: "review_rights"
	feature: iasreview_license	
	sticky-timeslot: stickyTimeslot timeslot-label stickyTimeslotLabel
	uid = Parameter { mandatory:True } // reviewer uid
	campaignrecorduid = Parameter 
	stickyTimeslot = Parameter { hidden: True }	
	stickyTimeslotLabel = Parameter { hidden: True }		
	aida_enabled = Parameter { default: ConfigurationVariable "aida_enabled" hidden: True }
	aida_service_url = Parameter { default: ConfigurationVariable "aida_service_url" hidden: True }
	aida_demo_mode = Parameter { default: ConfigurationVariable "aida_demo_mode" hidden: True }
}

