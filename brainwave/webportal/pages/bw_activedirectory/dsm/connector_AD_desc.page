
ds_activedirectory_file_NLS = NLS {
  title [ en "Microsoft Active Directory - file" fr "Microsoft Active Directory - fichier"]
  description [ 
    en "Collects all provided LDIF files, one file per AD domain. The AD domain name will be the file name."
    fr "Collecte tous les fichiers LDIF fournis, un fichier par domaine AD. Le nom du domaine AD est celui du fichier."]
}


ds_activedirectory_file = Page {
	title: $ds_activedirectory_file_NLS.title
	tags: "bwds_connector" , "file" , "csv", "microsoft"
	description: $ds_activedirectory_file_NLS.description
	icon: "bw_dsm/L/bw_activedirectory.png"
	large-icon: "bw_dsm/XL/bw_activedirectory.png"	
	 metadata: ( 	 
	    fixedName -> "ad"  ,  
	    category -> "infrastructure", 
	    family -> "LDAP",
	    collector -> "bw_activedirectory",
	    destPathVar -> "ad_sourceFolder",
	    filePattern -> "*.ldif",
	    hasMapping -> False,
	    multiFile -> True
	 )
}


