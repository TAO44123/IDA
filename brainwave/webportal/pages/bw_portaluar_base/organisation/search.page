
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_fragments/organisation/resources.page"

import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/styles.page"

import "/webportal/pages/resources/constants.page"

organisationSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

organisationSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

organisationSearchPage = Page {
	title: $search.organisation.title
	tags: "organisation" , "conceptsearch" priority 50
	icon: %concept_32.organisation
	large-icon: %concept_48.organisation
	description: $searchlabel.organisation

	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	organisationSearch = SearchDefinition {
		entity: Organisation
		simple-mode-rule: br_organisation_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedOrganisationUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	organisationanalytics = Dataset {
		pages: Pages{tags: "organisation" and "searchresults" }
		count-variable:nbanalytics
	}

	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	organisationData = Dataset {
		search: Search {
			definition: organisationSearch
			view: br_organisation_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, UserVariable organisationSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	organisationData_count = Dataset {
		search: Search {
			definition: organisationSearch
			view: br_organisation_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}


	goDetails = NamedAction (
		GoTo Activity Organisation Detail with selectedOrganisationUid to paramOrganisationUid
	)

	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: organisationSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			rule-mode-enabled:FeaturePredicate organisationsearch_rulemode
			simple-mode-layout: SimpleModeLayout {
				shortname { label: $organisation.shortname },
				name { label: $organisation.displayname }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: organisationData
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size:1000			
			show-count-button: True		
			Column {
				column: uid
				hidden: True
				selection: selectedOrganisationUid
			}
			Column {
				column: shortname
				header: $organisation.shortname
				width: 100%
				sortable:True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: displayname
				header: $organisation.displayname
				width: 100%
				sortable:True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: code
				header: $organisation.code
				width: 100%
				sortable:True
				initially-masked: True
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: organisationtypedisplayname
				header: $organisation.organisationtypedisplayname
				width: 100%
				sortable:True
				initially-masked: True
			}
			Column {
				column: isnew
				text:Transform Current isnew using booleanDisplayMapping
				header: $searchlabel.isnew
				width: 100px
				styling:BooleanStyling(Current isnew) { when True then organisationSearchPage_highlightnew when False then default }				
				initially-masked: True
			}
			Column {
				column:bwa_organisationanalytics_nbdirectmembers
				text:Transform Current bwa_organisationanalytics_nbdirectmembers using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbdirectmembers.header
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbdirectmembers).equals('null')?956487965:current.bwa_organisationanalytics_nbdirectmembers-current.prevbwa_organisationanalytics_nbdirectmembers") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbdirectmembers using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbdirectmembers using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_nbtotalmembers
				text:Transform Current bwa_organisationanalytics_nbtotalmembers using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbmembers.header
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbtotalmembers).equals('null')?956487965:current.bwa_organisationanalytics_nbtotalmembers-current.prevbwa_organisationanalytics_nbtotalmembers") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbtotalmembers using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbtotalmembers using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_nbdirectsuborg
				text:Transform Current bwa_organisationanalytics_nbdirectsuborg using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbdirectsuborg.header
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbdirectsuborg).equals('null')?956487965:current.bwa_organisationanalytics_nbdirectsuborg-current.prevbwa_organisationanalytics_nbdirectsuborg") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbdirectsuborg using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbdirectsuborg using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:bwa_organisationanalytics_nbsuborg
				text:Transform Current bwa_organisationanalytics_nbsuborg using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbsuborg.header
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbsuborg).equals('null')?956487965:current.bwa_organisationanalytics_nbsuborg-current.prevbwa_organisationanalytics_nbsuborg") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbsuborg using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbsuborg using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:bwa_organisationanalytics_nbapplication
				text:Transform Current bwa_organisationanalytics_nbapplication using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbapplications.header
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbapplication).equals('null')?956487965:current.bwa_organisationanalytics_nbapplication-current.prevbwa_organisationanalytics_nbapplication") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbapplication using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbapplication using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_nbshare
				feature:unstructureddata_license
				text:Transform Current bwa_organisationanalytics_nbshare using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbshares.header
				initially-masked:True
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbshare).equals('null')?956487965:current.bwa_organisationanalytics_nbshare-current.prevbwa_organisationanalytics_nbshare") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbshare using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbshare using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_nbbusinessactivity
				feature:sod_license
				text:Transform Current bwa_organisationanalytics_nbbusinessactivity using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbbusinessactivity.header
				initially-masked:True
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbbusinessactivity).equals('null')?956487965:current.bwa_organisationanalytics_nbbusinessactivity-current.prevbwa_organisationanalytics_nbbusinessactivity") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbbusinessactivity using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbbusinessactivity using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_nbtheoretical
				feature:iam_license
				text:Transform Current bwa_organisationanalytics_nbtheoretical using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbtheoretical.header
				initially-masked:True
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbtheoretical).equals('null')?956487965:current.bwa_organisationanalytics_nbtheoretical-current.prevbwa_organisationanalytics_nbtheoretical") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbtheoretical using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbtheoretical using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:bwa_organisationanalytics_nbusage
				text:Transform Current bwa_organisationanalytics_nbusage using bwf_defaultsTo0
				sortable:True
				header:$search.organisation.nbusage.header
				initially-masked:True
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbusage).equals('null')?956487965:current.bwa_organisationanalytics_nbusage-current.prevbwa_organisationanalytics_nbusage") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbusage using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbusage using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:bwa_organisationanalytics_riskrank
				sortable:True
				header:$bwfOrganisationNLS.riskrank
				initially-masked:False
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_riskrank).equals('null')?956487965:current.bwa_organisationanalytics_riskrank-current.prevbwa_organisationanalytics_riskrank") using bwf_trend_higherbest
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_riskrank using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_riskrank using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:bwa_organisationanalytics_aggmaxrisklevel
				sortable:True
				header:$bwfOrganisationNLS.maxrisk
				image:TemplateImageSelection(Current bwa_organisationanalytics_aggmaxrisklevel) using bwf_controllevel
				width:120px
				initially-masked:False
			}
			Column {
				column:bwa_organisationanalytics_nbidentityrisks
				sortable:True
				header:$bwfOrganisationNLS.nbrisk.header
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbidentityrisks).equals('null')?956487965:current.bwa_organisationanalytics_nbidentityrisks-current.prevbwa_organisationanalytics_nbidentityrisks") using bwf_trend_lowerbest
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbidentityrisks using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbidentityrisks using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:bwa_organisationanalytics_nbidentityrisksratio
				sortable:True
				header:$bwfOrganisationNLS.nbriskratio
				initially-masked:True
				image:TemplateImageSelection(Eval "(''+current.prevbwa_organisationanalytics_nbidentityrisksratio).equals('null')?956487965:current.bwa_organisationanalytics_nbidentityrisksratio-current.prevbwa_organisationanalytics_nbidentityrisksratio") using bwf_trend_lowerbest
				tooltip:$search.repository.ratiotooltip(Transform Current bwa_organisationanalytics_nbidentityrisksratio using mayBeNullMapping, Transform Current prevbwa_organisationanalytics_nbidentityrisksratio using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
		}
	}
	Grid {
		columns:GridColumn,GridColumn { width: grow }
		layout: Layout { grab:horizontal True vertical False hint: height 38 }
		GridRow {
			GridCell {
				Checkbox {
					variable:UserVariable organisationSearchPage_withtrends
					text:$search.showkpitrends
					tooltip:$search.showkpitrends.tooltip
				}
			}			
			GridCell {
				ButtonGroup {
					nb-inline:2
					align:Right
					Button {
						actions:ExecuteNamedAction goDetails
						text:$search.showdetails
						tooltip:$search.showdetailstooltip
						disabled:StringPredicate(selectedOrganisationUid) { when IsEmpty then True }	
						image:%browsing_16.link
					}
					Button {
						actions: IntCase(Count organisationData_count)	{
										when > NonEmpty(ConfigurationVariable "search_organisation_analyticserrorthreshold", Constant search_organisation_analyticserrorthreshold) then [
											Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_organisation_analyticserrorthreshold", Constant search_organisation_analyticserrorthreshold))
										]
										when > NonEmpty(ConfigurationVariable "search_organisation_analyticswarningthreshold", Constant search_organisation_analyticswarningthreshold) then [
											Confirm $search.analyticswarningthreshold(Count organisationData_count),
											GoTo Page organisationSearchAnalyticsPage with  SerializeSearch organisationSearch to search
												
										]
										otherwise [
											GoTo Page organisationSearchAnalyticsPage with  SerializeSearch organisationSearch to search
										]
									}
						text:$search.applyanalytics
						tooltip:$search.applyanalyticstooltip
						image:%report_16.analytics
						feature:organisationsearch_analytics
						disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
					}
					Button {
						actions:	TransferData organisationData(uid) to (uids), 
									Dialog fragmentOrganisationBulkAddTag(uids to uids),
									Flash $search.flashaddingatag
						text:$search.addingatag
						image:%collection_16.tag
						feature:organisationsearch_updatetags
					}
					Button {
						actions:	TransferData organisationData(uid) to (uids), 
									Dialog fragmentOrganisationBulkRemoveTag(uids to uids, SerializeSearch organisationSearch to organisationSearch),
									Flash $search.flashremovingatag
						text:$search.removingatag
						image:%collection_16.tag
						feature:organisationsearch_updatetags
					}
					Button {
						actions:	TransferData organisationData(uid) to (uids), 
									Dialog fragmentOrganisationBulkRemoveAllTags(uids to uids),
									Flash $search.flashremovingalltag
						text:$search.removingalltag
						image:%collection_16.tag
						feature:organisationsearch_updatetags
					}
				}
			}
		}
	}
}


organisationSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity:Organisation
		simple-mode-rule: br_organisation_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "organisation" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
	ButtonGroup {
		align:Right
		Button {
			actions:GoTo BackInHistoryTruncate
			text:$search.back
			image:%browsing_16.back
		}
	}
}