				sortable:True
				header:$search.account.nbdirectfsright.header
				image:TemplateImageSelection(Eval "(''+current.prevbwa_accountanalytics_nbdirectfsright).equals('null')?956487965:(current.bwa_accountanalytics_nbdirectfsright-current.prevbwa_accountanalytics_nbdirectfsright)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current bwa_accountanalytics_nbdirectfsright using mayBeNullMapping,Transform Current prevbwa_accountanalytics_nbdirectfsright using mayBeNullMapping)
