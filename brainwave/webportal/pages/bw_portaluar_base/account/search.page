		Grid {
			columns:GridColumn,GridColumn { width: grow }
			layout: Layout { grab:horizontal True vertical False hint: height 38 }
			GridRow {
				GridCell {
					Checkbox {
						variable:UserVariable accountSearchPage_withtrends
						text:$search.showkpitrends
						tooltip:$search.showkpitrends.tooltip
					}
				}			
				GridCell {
					ButtonGroup {
						nb-inline:2
						align:Right
						Button {
							actions:ExecuteNamedAction goDetails
							text:$search.showdetails
							tooltip:$search.showdetailstooltip
							disabled:StringPredicate(selectedAccountUid) { when IsEmpty then True }	
							image:%browsing_16.link
						}
						Button {
							actions: IntCase(Count accountData_count)	{
											when > NonEmpty(ConfigurationVariable "search_account_analyticserrorthreshold", Constant search_account_analyticserrorthreshold) then [
												Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_account_analyticserrorthreshold", Constant search_account_analyticserrorthreshold))
											]
											when > NonEmpty(ConfigurationVariable "search_account_analyticswarningthreshold", Constant search_account_analyticswarningthreshold) then [
												Confirm $search.analyticswarningthreshold(Count accountData_count),
												GoTo Page accountSearchAnalyticsPage with  SerializeSearch accountSearch to search
													
											]
											otherwise [
												GoTo Page accountSearchAnalyticsPage with  SerializeSearch accountSearch to search
											]
										}
							text:$search.applyanalytics
							tooltip:$search.applyanalyticstooltip
							image:%report_16.analytics
							feature:accountsearch_analytics
							disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
						}
						Button {
							actions:	TransferData accountData(uid) to (uids), 
										Dialog fragmentAccountBulkAddTag(uids to uids),
										Flash $search.flashaddingatag
							text:$search.addingatag
							image:%collection_16.tag
							feature:accountsearch_updatetags
						}
						Button {
							actions:	TransferData accountData(uid) to (uids), 
										Dialog fragmentAccountBulkRemoveTag(uids to uids, SerializeSearch accountSearch to accountSearch),
										Flash $search.flashremovingatag
							text:$search.removingatag
							image:%collection_16.tag
							feature:accountsearch_updatetags
						}
						Button {
							actions:	TransferData accountData(uid) to (uids), 
										Dialog fragmentAccountBulkRemoveAllTags(uids to uids),
										Flash $search.flashremovingalltag
							text:$search.removingalltag
							image:%collection_16.tag
							feature:accountsearch_updatetags
						}
					}
				}
			}
		}
	}
}

accountSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity:Account
		simple-mode-rule: br_account_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "account" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
	ButtonGroup {
		align:Right
		Button {
			actions:GoTo BackInHistoryTruncate
			text:$search.back
			image:%browsing_16.back
		}
	}
}