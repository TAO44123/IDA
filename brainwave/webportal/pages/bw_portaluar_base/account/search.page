accountSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

accountSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

accountSearchPage = Page {
	title: $search.account.title
	tags: "account", "conceptsearch" priority 200
	icon: %concept_32.account
	large-icon: %concept_48.account
	description: $searchlabel.account

	initialUid = Parameter {
		type: String
		hidden: True 
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	accountSearch = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedAccountUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	accountanalytics = Dataset {
		pages: Pages{tags: "account" and "searchresults" }
		count-variable:nbanalytics
	}

	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	accountData = Dataset {
		search: Search {
			definition: accountSearch
			view: br_account_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, UserVariable accountSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	accountData_count = Dataset {
		search: Search {
			definition: accountSearch
			view: br_account_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}


	goDetails = NamedAction (
		GoTo Activity Account Detail with selectedAccountUid to paramAccountUid
	)

	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: accountSearch
			layout: Layout { grab: horizontal True vertical False }
			simple-mode-columns: 2
			completion-view:[
				Repository as br_repository_searchpoint
			]
			rule-mode-enabled:FeaturePredicate accountsearch_rulemode
			simple-mode-layout: SimpleModeLayout {
				repository { label: $repository.concept break: True },
				login { label: $account.login },
				username { label: $account.username }
			}
		}
	}

	Group{
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: accountData
			//show-count: True
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size: 1000
			show-count-button: True
			Column {
				column: uid
				hidden: True
				selection: selectedAccountUid
			}
			Column {
				column: login
				header: $account.login
				width: 100%
				sortable: True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: username
				header: $account.username
				width: 100%
				sortable: True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: lastlogindate
				header: $account.lastlogindate
				width: 100%
				sortable: True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: repository_displayname
				header: $prepository.displayname
				width: 100%
				sortable: True
				initially-masked: False
			}
			Column {
				column: identity_hrcode
				header: $pidentity.hrcode
				width: 100%
				sortable: True
				initially-masked: False
			}
			Column {
				column: identity_fullname
				header: $pidentity.fullname
				width: 100%
				sortable: True
				initially-masked: False
			}
			Column {
				column: identifier
				header: $account.identifier
				width: 100%
				sortable: True
				initially-masked: True
			}
			Column {
				column: profile
				header: $account.profile
				width: 100%
				sortable: True
				initially-masked: True
			}
			Column {
