
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/resources/mappings.page"


import "/webportal/pages/bw_fragments/share/resources.page"

import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/bw_fragments/permission/resources.page"

import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/styles.page"

import "/webportal/pages/resources/constants.page"
import "/webportal/pages/bw_portaluar_base/parking.page"

applicationextNLS = NLS {
	sensitivityreason [en "Sensitivity \nReason" fr "Raison \nde sensibilité"]
	sensitivitylevel [en "Sensitivity \nLevel" fr "Niveau \nde sensibilité"]
	description [en "Description" fr "Description"]
	category [en "Category" fr "Catégorie"]
}

papplicationextNLS = NLS {
	sensitivityreason [en "Share \nSensitivity \nReason" fr "Raison \nde Sensibilité \ndu Partage"]
	sensitivitylevel [en "Share \nSensitivity \nLevel" fr "Niveau \nde Sensibilité \ndu Partage"]
	description [en "Share \nDescription" fr "Description \nPartage"]
	category [en "Share \nCategory" fr "Catégorie \nPartage"]
	applicationtype [en "Share \nType" fr "Type \nde Partage"]
	code [en "Share code" fr "Code partage"]
	displayname [en "Share name" fr "Nom partage"]
	concept [en "Share" fr "Partage"]
}

permissionextNLS = NLS {
	sensitivityreason [en "Sensitivity \nReason" fr "Raison \nde sensibilité"]
	sensitivitylevel [en "Sensitivity \nLevel" fr "Niveau \nde sensibilité"]
	description [en "Description" fr "Description"]
}

ppermissionextNLS = NLS {
	sensitivityreason [en "Folder \nSensitivity \nReason" fr "Raison \nde Sensibilité \nDonnées"]
	sensitivitylevel [en "Folder \nSensitivity \nLevel" fr "Niveau \nde Sensibilité \nDonnées"]
	description [en "Folder \nDescription" fr "Description \nDonnées"]
}

sharedfolderSearchPageNLS = NLS {
	title [en "Shared folder" fr "Répertoire partagé"]
	path [en "Path" fr "Chemin"]
}

sharedfolderSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

sharedfolderSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

sharedfolderSearchPage = Page {
	title: $sharedfolderSearchPageNLS.title
	tags: "sharedfolder", "conceptsearch" priority 300
	icon: %concept_32.folder
	large-icon: %concept_48.folder
	description: $searchlabel.permission
	conditional-redirect:ConditionalRedirect { condition:Not FeaturePredicate unstructureddata_license target:Page bwias_parking with-current-parameters }  

	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	permissionSearch = SearchDefinition {
		entity: Permission		
		simple-mode-rule: br_sharedfolder_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}
	
	nbanalytics = Variable {
		type:Integer
	}

	selectedPermissionUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	permissionanalytics = Dataset {
		pages: Pages{tags: "sharedfolder" and "searchresults" }
		count-variable:nbanalytics
	}

	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	permissionData = Dataset {
		search: Search {
			definition: permissionSearch
			view: br_folder_searchpoint_trend with ["Filesystem", "Sharepoint"] to applicationtype, reftimeslot.timeslotuid to reftimeslotuid, UserVariable sharedfolderSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	permissionData_count = Dataset {
		search: Search {
			definition: permissionSearch
			view: br_folder_searchpoint_trend with ["Filesystem", "Sharepoint"] to applicationtype, reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}


	goDetails = NamedAction (
		GoTo Activity Permission Detail with selectedPermissionUid to paramPermissionUid
	)


	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: permissionSearch
			layout: Layout { grab: horizontal True vertical False }
			rule-mode-enabled:FeaturePredicate sharedfoldersearch_rulemode
			simple-mode-columns: 2
			completion-view:[
				Application as br_share_applicationcompletion
				Permission as br_share_applicationpermissioncompletion
			]
			simple-mode-layout: SimpleModeLayout {
				code { label: $fragmentFolderNLS.code },
				name { label: $fragmentFolderNLS.displayname },
				type { label: $fragmentFolderNLS.type },
				application { label: $fragmentShareNLS.concept },
				family { label: $fragmentShareNLS.pfamily }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: permissionData
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size:1000
			show-count-button: True
			Column {
				column: uid
				hidden: True
				selection: selectedPermissionUid
			}
			Column {
				column: code
				header: $sharedfolderSearchPageNLS.path
				sortable:True
				width: 100%
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: displayname
				header: $permission.displayname
				sortable:True
				width: 50%
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: permissiontype
				text:Transform Current permissiontype using fragmentFolderTypeMapping
				header: $permission.permissiontype
				sortable:True
				width: 50%
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: sensitivitylevel
				text:Transform Current sensitivitylevel using bwfPermissionSensitivityLevelMapping
				header: $permissionextNLS.sensitivitylevel
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: sensitivityreason
				header: $permissionextNLS.sensitivityreason
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: managed
				text:Transform Current managed using booleanDisplayMapping
				header: $search.folder.managed
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: inherited
				text:Transform Current inherited using booleanDisplayMapping
				header: $search.folder.inherited
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: description
				header: $permissionextNLS.description
				width: 50%
				initially-masked: True
			}
			Column {
				column: application_code
				header: $papplicationextNLS.code
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: application_displayname
				header: $papplicationextNLS.concept
				sortable:True
				width: 50%
				initially-masked: False
			}
			Column {
				column: application_applicationtype
				text:Current family
				header: $fragmentShareNLS.pfamily
				sortable:True
				width: 20%
				initially-masked: False
			}
			Column {
				column: application_category
				header: $papplicationextNLS.category
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: application_sensitivitylevel
				text:Transform Current application_sensitivitylevel using bwfApplicationSensitivityLevelMapping
				header: $papplicationextNLS.sensitivitylevel
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: application_sensitivityreason
				header: $papplicationextNLS.sensitivityreason
				sortable:True
				width: 50%
				initially-masked: True
			}
			Column {
				column: application_description
				header: $papplicationextNLS.description
				width: 50%
				initially-masked: True
			}
			Column {
				column: isnew
				text:Transform Current isnew using booleanDisplayMapping
				header: $searchlabel.isnew
				width: 100px
				styling:BooleanStyling(Current isnew) { when True then sharedfolderSearchPage_highlightnew when False then default }				
				initially-masked: True
			}
			Column {
				column:nbaccount
				text:Transform Current nbaccount using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.permission.nbaccount.header
				image:TemplateImageSelection(Eval "(''+current.prevnbaccount).equals('null')?956487965:current.nbaccount-current.prevnbaccount") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbaccount using mayBeNullMapping, Transform Current prevnbaccount using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbidentity
				text:Transform Current nbidentity using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.permission.nbidentity.header
				image:TemplateImageSelection(Eval "(''+current.prevnbidentity).equals('null')?956487965:current.nbidentity-current.prevnbidentity") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbidentity using mayBeNullMapping, Transform Current prevnbidentity using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbreadaccess
				text:Transform Current nbreadaccess using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.folder.nbreadaccess.header
				image:TemplateImageSelection(Eval "(''+current.prevnbreadaccess).equals('null')?956487965:current.nbreadaccess-current.prevnbreadaccess") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbreadaccess using mayBeNullMapping, Transform Current prevnbreadaccess using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbwriteaccess
				text:Transform Current nbwriteaccess using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.folder.nbwriteaccess.header
				image:TemplateImageSelection(Eval "(''+current.prevnbwriteaccess).equals('null')?956487965:current.nbwriteaccess-current.prevnbwriteaccess") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbwriteaccess using mayBeNullMapping, Transform Current prevnbwriteaccess using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbfullcontrolaccess
				text:Transform Current nbfullcontrolaccess using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.folder.nbfullcontrolaccess.header
				image:TemplateImageSelection(Eval "(''+current.prevnbfullcontrolaccess).equals('null')?956487965:current.nbfullcontrolaccess-current.prevnbfullcontrolaccess") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbfullcontrolaccess using mayBeNullMapping, Transform Current prevnbfullcontrolaccess using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:120px
			}
			Column {
				column:nbusage
				text:Transform Current nbusage using bwf_defaultsTo0
				initially-masked: True
				sortable:True
				header:$search.folder.nbusage.header
				image:TemplateImageSelection(Eval "(''+current.prevnbusage).equals('null')?956487965:current.nbusage-current.prevnbusage") using bwf_trend
				tooltip:$search.repository.ratiotooltip(Transform Current nbusage using mayBeNullMapping, Transform Current prevnbusage using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
		}
	}
	Grid {
		columns:GridColumn,GridColumn { width: grow }
		layout: Layout { grab:horizontal True vertical False hint: height 38 }
		GridRow {
			GridCell {
				Checkbox {
					variable:UserVariable sharedfolderSearchPage_withtrends
					text:$search.showkpitrends
					tooltip:$search.showkpitrends.tooltip
				}
			}			
			GridCell {
				ButtonGroup {
					nb-inline:2
					align:Right
					Button {
						actions:ExecuteNamedAction goDetails
						text:$search.showdetails
						tooltip:$search.showdetailstooltip
						disabled:StringPredicate(selectedPermissionUid) { when IsEmpty then True }	
						image:%browsing_16.link
					}
					Button {
						actions: IntCase(Count permissionData_count)	{
										when > NonEmpty(ConfigurationVariable "search_folder_analyticserrorthreshold", Constant search_folder_analyticserrorthreshold) then [
											Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_folder_analyticserrorthreshold", Constant search_folder_analyticserrorthreshold))
										]
										when > NonEmpty(ConfigurationVariable "search_folder_analyticswarningthreshold", Constant search_folder_analyticswarningthreshold) then [
											Confirm $search.analyticswarningthreshold(Count permissionData_count),
											GoTo Page sharedfolderSearchAnalyticsPage with  SerializeSearch permissionSearch to search
												
										]
										otherwise [
											GoTo Page sharedfolderSearchAnalyticsPage with  SerializeSearch permissionSearch to search
										]
									}
						text:$search.applyanalytics
						tooltip:$search.applyanalyticstooltip
						image:%report_16.analytics
						feature:sharedfoldersearch_analytics
						disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
					}
					Button {
						actions:	TransferData permissionData(uid) to (uids), 
									Dialog fragmentPermissionBulkAddTag(uids to uids),
									Flash $search.flashaddingatag
						text:$search.addingatag
						image:%collection_16.tag
						feature:sharedfoldersearch_updatetags
					}
					Button {
						actions:	TransferData permissionData(uid) to (uids), 
									Dialog fragmentPermissionBulkRemoveTag(uids to uids, SerializeSearch permissionSearch to permissionSearch),
									Flash $search.flashremovingatag
						text:$search.removingatag
						image:%collection_16.tag
						feature:sharedfoldersearch_updatetags
					}
					Button {
						actions:	TransferData permissionData(uid) to (uids), 
									Dialog fragmentPermissionBulkRemoveAllTags(uids to uids),
									Flash $search.flashremovingalltag
						text:$search.removingalltag
						image:%collection_16.tag
						feature:sharedfoldersearch_updatetags
					}
				}
			}
		}
	}
}


sharedfolderSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity:Permission
		simple-mode-rule: br_sharedfolder_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "sharedfolder" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
	ButtonGroup {
		align:Right
		Button {
			actions:GoTo BackInHistoryTruncate
			text:$search.back
			image:%browsing_16.back
		}
	}
}