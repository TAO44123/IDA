import "/webportal/pages/styles/default_mixins.page"
import "/webportal/pages/resources/pages_nls.page"


demoPage = Page {
	title:$demo.label
	feature: demomenu
	
	demoPages = Dataset {
		pages: Pages {tags: "demo"}
	}
	
	Tiles {
		mixins: buttonPage
		columns: 2
		tile-height: 80
				
		TileGroup{
			iterate-on: demoPages
			initial-sort: ^priority
			Tile{
				Button {
					actions: GoTo Dynamic ( Current type , Current name ) 
					image: Current largeIcon
					text: Current title
				}
			}
		}
	}
	
}
