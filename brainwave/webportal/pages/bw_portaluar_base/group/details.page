import "/webportal/pages/bw_fragments/group/details.page"
import "/webportal/pages/bw_fragments/group/accounts.page"
import "/webportal/pages/bw_fragments/group/perjob.page"
import "/webportal/pages/bw_fragments/group/perorg.page"
import "/webportal/pages/bw_fragments/group/analytics.page"
import "/webportal/pages/bw_fragments/group/controls.page"
import "/webportal/pages/bw_fragments/group/rights.page"
import "/webportal/pages/bw_fragments/group/cyberarkrights.page"
import "/webportal/pages/bw_fragments/group/fsrights.page"
import "/webportal/pages/bw_fragments/group/decisionhistory.page"
import "/webportal/pages/bw_fragments/group/parentgroups.page"
import "/webportal/pages/bw_fragments/group/childgroups.page"
import "/webportal/pages/bw_fragments/custom/groupExtendedDetails.page"

import "/webportal/pages/bw_fragments/lib/icons.page"
