
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pickers.page"
import "/webportal/pages/resources/mappings.page"

import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/styles.page"

import "/webportal/pages/resources/constants.page"

import "/webportal/pages/bw_fragments/group/resources.page"

groupSearchPage_withtrends = UserVariable {
		initial:False
		type:Boolean
		persistent:True
}

groupSearchPage_highlightnew = Style {
	foreground:white
	background:Color green
}

groupSearchPage = Page {
	title: $search.group.title
	tags: "group" , "conceptsearch" priority 150
	icon: %concept_32.group
	large-icon: %concept_48.group
	description: $searchlabel.group

	initialUid = Parameter {
		type: String
		hidden: True
	}
	
	useNavigatorMode = Parameter {
		type: Boolean
		hidden: True
		default: True
	}
	
	paramInitialIndex = Parameter {
		type: Integer
		hidden: True
	}
	
	groupSearch = SearchDefinition {
		entity: Group
		simple-mode-rule: br_group_simple_search
	}
	
	initialIndex = Variable {
		type: Integer
	}

	nbanalytics = Variable {
		type:Integer
	}
	
	selectedGroupUid = Variable {
		type: String
	}

	showAnalytics = Variable {type:String initial:'0'}
	uids =  Variable {type:String multivalued:True}
	groupanalytics = Dataset {
		pages: Pages{tags: "group" and "searchresults" }
		count-variable:nbanalytics
	}

	reftimeslot = Record {
		view:br_gettimeslotuid
		timeslot:FromPage(-1)
	}

	groupData = Dataset {
		search: Search {
			definition: groupSearch
			view: br_group_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, UserVariable groupSearchPage_withtrends to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}
	groupData_count = Dataset {
		search: Search {
			definition: groupSearch
			view: br_group_searchpoint_trend with reftimeslot.timeslotuid to reftimeslotuid, False to withtrends
		}
		timeout-configuration: TimeoutConfiguration  [{
			short-timeout:Default 
			long-timeout:Default
		}]
	}

	goDetails = NamedAction (
		GoTo Activity Group Detail with selectedGroupUid to paramGroupUid
	)

	// Search section
	Group {
		layout: Layout { grab: horizontal True vertical False indent: horizontal 5 vertical 0 }
		SearchEdition {
			definition: groupSearch
			layout: Layout { grab: horizontal True vertical False }
			completion-view:[
				Repository as br_repository_searchpoint
			]
			simple-mode-columns: 2
			rule-mode-enabled:FeaturePredicate groupsearch_rulemode
			simple-mode-layout: SimpleModeLayout {
				repository { label: $prepository.displayname break: True },
				code { label: $group.code },
				name { label: $group.displayname }
			}
		}
	}
	Group {
		layout: Layout { grab: horizontal True vertical True }
		PaginatedTable {
			data: groupData
			layout: Layout { grab: horizontal True vertical True }
			configurable: True
			persist-configuration: True
			initial-selection: initialUid using uid
			initial-selection-index: paramInitialIndex
			selection-index: initialIndex
			page-size:1000
			show-count-button: True
			Column {
				column: uid
				hidden: True
				selection: selectedGroupUid
			}
			Column {
				column: code
				header: $group.code
				width: 100%
				sortable:True
				initially-masked: True
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: displayname
				header: $group.displayname
				width: 100%
				sortable:True
				initially-masked: False
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: repository_displayname
				header: $prepository.displayname
				width: 50%
				sortable:True
				initially-masked: False
			}
			Column {
				column: repository_code
				header: $prepository.code
				width: 50%
				sortable:True
				initially-masked: True
			}
			Column {
				column: comment
				header: $group.comment
				width: 100%
				initially-masked: True
			}
			Column {
				column: grouptype
				header: $group.grouptype
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: dynamic
				header: $group.dynamic
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: filter
				header: $group.filter
				width: 100%
				initially-masked: True
			}
			Column {
				column: sid
				header: $group.sid
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: guid
				header: $group.guid
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: creationdate
				header: $group.creationdate
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: modificationdate
				header: $group.modificationdate
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: lastmodifiedby
				header: $group.lastmodifiedby
				width: 100%
				initially-masked: True
				sortable:True
			}
			Column {
				column: isnew
				text:Transform Current isnew using booleanDisplayMapping
				header: $searchlabel.isnew
				width: 100px
				styling:BooleanStyling(Current isnew) { when True then groupSearchPage_highlightnew when False then default }				
				initially-masked: True
			}
			Column {
				column:nbaccount
				text:Transform Current nbaccount using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.group.nbaccount.header
				image:TemplateImageSelection(Eval "(''+current.prevnbaccount).equals('null')?956487965:(current.nbaccount-current.prevnbaccount)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbaccount using mayBeNullMapping,Transform Current prevnbaccount using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbidentity
				text:Transform Current nbidentity using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.group.nbidentity.header
				image:TemplateImageSelection(Eval "(''+current.prevnbidentity).equals('null')?956487965:(current.nbidentity-current.prevnbidentity)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbidentity using mayBeNullMapping,Transform Current prevnbidentity using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbdirectaccount
				text:Transform Current nbdirectaccount using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.group.nbdirectaccounts.header
				image:TemplateImageSelection(Eval "(''+current.prevnbdirectaccount).equals('null')?956487965:(current.nbdirectaccount-current.prevnbdirectaccount)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbdirectaccount using mayBeNullMapping,Transform Current prevnbdirectaccount using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbdirectidentity
				text:Transform Current nbdirectidentity using bwf_defaultsTo0
				initially-masked: False
				sortable:True
				header:$search.group.nbdirectidentity.header
				image:TemplateImageSelection(Eval "(''+current.prevnbdirectidentity).equals('null')?956487965:(current.nbdirectidentity-current.prevnbdirectidentity)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbdirectidentity using mayBeNullMapping,Transform Current prevnbdirectidentity using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbapplication
				text:Transform Current nbapplication using bwf_defaultsTo0
				initially-masked: True
				sortable:True
				header:$search.group.nbapplication.header
				image:TemplateImageSelection(Eval "(''+current.prevnbapplication).equals('null')?956487965:(current.nbapplication-current.prevnbapplication)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbapplication using mayBeNullMapping,Transform Current prevnbapplication using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
			Column {
				column:nbshare
				feature:unstructureddata_license
				text:Transform Current nbshare using bwf_defaultsTo0
				initially-masked: True
				sortable:True
				header:$search.group.nbshare.header
				image:TemplateImageSelection(Eval "(''+current.prevnbshare).equals('null')?956487965:(current.nbshare-current.prevnbshare)") using bwf_trend
				tooltip:$search.application.ratiotooltip(Transform Current nbshare using mayBeNullMapping,Transform Current prevnbshare using mayBeNullMapping)
				align:Left
				fixed-width:True
				width:100px
			}
		}
		Grid {
			columns:GridColumn,GridColumn { width: grow }
			layout: Layout { grab:horizontal True vertical False hint: height 38 }
			GridRow {
				GridCell {
					Checkbox {
						variable:UserVariable groupSearchPage_withtrends
						text:$search.showkpitrends
						tooltip:$search.showkpitrends.tooltip
					}
				}			
				GridCell {
					ButtonGroup {
						nb-inline:2
						align:Right
						Button {
							actions:ExecuteNamedAction goDetails
							text:$search.showdetails
							tooltip:$search.showdetailstooltip
							disabled:StringPredicate(selectedGroupUid) { when IsEmpty then True }	
							image:%browsing_16.link
						}
						Button {
							actions: IntCase(Count groupData_count)	{
											when > NonEmpty(ConfigurationVariable "search_group_analyticserrorthreshold", Constant search_group_analyticserrorthreshold) then [
												Message Error $search.analyticserrorthreshold(NonEmpty(ConfigurationVariable "search_group_analyticserrorthreshold", Constant search_group_analyticserrorthreshold))
											]
											when > NonEmpty(ConfigurationVariable "search_group_analyticswarningthreshold", Constant search_group_analyticswarningthreshold) then [
												Confirm $search.analyticswarningthreshold(Count groupData_count),
												GoTo Page groupSearchAnalyticsPage with  SerializeSearch groupSearch to search
													
											]
											otherwise [
												GoTo Page groupSearchAnalyticsPage with  SerializeSearch groupSearch to search
											]
										}
							text:$search.applyanalytics
							tooltip:$search.applyanalyticstooltip
							image:%report_16.analytics
							feature:groupsearch_analytics
							disabled: IntPredicate ( nbanalytics )  { when = 0 then True otherwise False }
						}
						Button {
							actions:	TransferData groupData(uid) to (uids), 
										Dialog fragmentGroupBulkAddTag(uids to uids),
										Flash $search.flashaddingatag
							text:$search.addingatag
							image:%collection_16.tag
							feature:groupsearch_updatetags
						}
						Button {
							actions:	TransferData groupData(uid) to (uids), 
										Dialog fragmentGroupBulkRemoveTag(uids to uids, SerializeSearch groupSearch to groupSearch),
										Flash $search.flashremovingatag
							text:$search.removingatag
							image:%collection_16.tag
							feature:groupsearch_updatetags
						}
						Button {
							actions:	TransferData groupData(uid) to (uids), 
										Dialog fragmentGroupBulkRemoveAllTags(uids to uids),
										Flash $search.flashremovingalltag
							text:$search.removingalltag
							image:%collection_16.tag
							feature:groupsearch_updatetags
						}
					}
				}
			}
		}
	}
}

groupSearchAnalyticsPage = Page {
	title:$search.applyanalytics

	search = SearchDefinition {
		entity:Group
		simple-mode-rule: br_group_simple_search
	}

	analytics = Dataset {
		pages: Pages{tags: "group" and "searchresults" }
	}

	ConditionalGroup {
		IntCondition(Count analytics) {
			when =0 then [
				Header {
					value:$search.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:analytics
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with SerializeSearch search to search save-state				
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
	ButtonGroup {
		align:Right
		Button {
			actions:GoTo BackInHistoryTruncate
			text:$search.back
			image:%browsing_16.back
		}
	}
}