/* Import other pages here */
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/bw_fragments/permission/resources.page"
import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/dialogs.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_controls_browser/resources/constants.page"
import "/webportal/pages/bw_fragments/share/details/shareDetails.page"
import "/webportal/pages/bw_fragments/sharedfolder/details/sharedfolderDetails.page"
import "/webportal/pages/bw_controls_browser/resources/mappings.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for permission without root causes
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>selectedPermUid</b> (out) the selected permission UID</li>
 * </ul>
 * </span>
 */
bw_control_browser_permission_details_table = PageFragment {
	
	/* Variables here */
	controlCode = Parameter { type: String }
	// Type of entity (Account, Perm, ... or Right, Share, etc.)
	type = Parameter { type: String }
	selectedPermUid = Variable { type: String }
	selectedPermUids = Variable { type: String multivalued: True }
	initialIndex = Variable { type: Integer }
	useExceptions = Variable { type: Boolean }
	controlType = Variable { type: String }
	updateRequired = Variable { type: Boolean }
	// View filters
	filterApplicationUid = Variable { type: String multivalued: True }
	filterTags = Variable { type: String multivalued: True }
	// Variables for filtering, from view
	app_uid = Variable { type: String multivalued: True }
	app_displayname = Variable { type: String multivalued: True }
	// Tab selection
	isActive = Variable { type: Boolean initial: False }
	
	/* Datasets and records here */
	permissionData = Dataset {
		view: bw_control_browser_get_permission_discrepancies with
			controlCode to controlCode,
			False to getRootCause,
			useExceptions to useExceptions,
			filterApplicationUid to app_uid unless-empty,
			filterTags to tags unless-empty
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	applications = Dataset {
		columns:
			app_uid,
			app_displayname
	}
	
	tags = Dataset {
		view: bw_controls_browser_permissionTags with
			controlCode to controlCode
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	updateApps = NamedAction (
		TransferData permissionData ( app_uid, app_displayname )
			to ( app_uid, app_displayname ),
		MultivaluedDistinct app_uid and ( app_displayname )
	)
	
	updateFilters = NamedAction (
		ExecuteNamedAction updateApps
	)
	
	goDetails = NamedAction (
		StringCase ( type ) {
			when Constant _Permission then [
				Dialog bwf_permissionDetailsDialog (
					selectedPermUid to inuid,
					True to inshowaccounts,
					True to inshowapplications,
					True to inshowcontrols,
					True to inshowshares,
					True to inshowACLs,
					True to inshowgroups,
					True to inshowowner
				)
			] when Constant _Folder then [
				Dialog bwf_permissionDetailsDialog (
					selectedPermUid to inuid,
					True to inshowaccounts,
					True to inshowperjob,
					True to inshowperorg,
					True to inshowfolders,
					True to inshowacls,
					True to inshowshares
				)
			]  when Constant _Sharedfolder then [
				Dialog bwf_permissionDetailsDialog (
					selectedPermUid to inuid,
					True to inshowaccounts,
					True to inshowperjob,
					True to inshowperorg,
					True to inshowfolders,
					True to inshowacls,
					True to inshowshares
				)
			] otherwise [
				// Just in case, default is permission
				Dialog bwf_permissionDetailsDialog (
					selectedPermUid to inuid,
					True to inshowaccounts,
					True to inshowapplications,
					True to inshowcontrols,
					True to inshowshares,
					True to inshowACLs,
					True to inshowgroups,
					True to inshowowner
				)
			]
		}
	)
	
	reload = NamedAction (
		ReloadData ( permissionData )
	)
	
	/* Page content */
	// Filters
	Group {
		title: $bw_control_browser.filter
		layout: Layout { grab: horizontal True vertical False }
		Flow {
			disposition: Horizontal
			Group {
				Combo {
					variable: filterTags
					label: Label {
						break: True
						value: $bw_control_browser.tag
						tooltip: $bw_control_browser.tag.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: tags
						text: Current bwa_permissiontags_tag
						value: Current bwa_permissiontags_tag
					}
					disabled:
						IntPredicate ( Count tags ) {
							when < 1 then True
						}
				}
			}
			Group {
				Combo {
					variable: filterApplicationUid
					label:
					 Label {
						break: True
						value: Transform type using app_type_mapping
						tooltip: Transform type using app_type_mapping_tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: applications
						text: Current app_displayname
						value: Current app_uid
					}
					disabled:
						IntPredicate ( Count applications ) {
							when < 1 then True
						}
				}
			}
			Group {
				Spacer {
					height: Fill
				}
				ButtonGroup {
					align: Center
					Button {
						text: $bw_control_browser.clear
						tooltip: $bw_control_browser.clear.tooltip
						image: %collection_16.delete
						presentation: Link
						actions:
							Unset filterApplicationUid,
							Unset filterTags
					}
				}
			}
		}
	}
	Table {
		data: permissionData
		double-click:
			ExecuteNamedAction goDetails
		layout: Layout { grab: horizontal True vertical True }
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_permission_details_table"
		selection-index: initialIndex
		show-filter: True
		show-count: True
		// Disabled as no buttons available yet
//		checkboxes:
//			uid to selectedPermUids
		Column {
			column: uid
			hidden: True
			selection: selectedPermUid
		}
		Column {
			column: displayname
			header: $permission.displayname
			width: 100%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: code
			header: $permission.code
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissionalias
			header: $permission.permissionalias
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissiontype
			header: $permission.permissiontype
			width: 50%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: sensitivitylevel
			text: Transform Current sensitivitylevel using bwfPermissionSensitivityLevelMapping
			header: $permissionextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: sensitivityreason
			header: $permissionextNLS.sensitivityreason
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
		Column {
			column: description
			header: $permissionextNLS.description
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_code
			header: $papplication.code
			width: 50%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: app_displayname
			header: Transform type using app_type_mapping
			width: 50%
			sortable: True
			filterable: True
			initially-masked: False
		}
		Column {
			column: app_category
			header: $papplicationextNLS.category
			width: 50%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivitylevel
			text: Transform Current app_sensitivitylevel using bwfApplicationSensitivityLevelMapping
			header: $papplicationextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivityreason
			header: $papplicationextNLS.sensitivityreason
			width: 100%
			filterable: True
			sortable: True			
			initially-masked: True
		}
		Column {
			column: app_description
			header: $papplicationextNLS.description
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
	}
	ButtonGroup {
		layout: Layout { align: horizontal End vertical End }
		Button {
			actions:
				StringCase ( selectedPermUids ) {
					when IsEmpty then [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedPermUid to targetuids,
							controlType to controlresulttype
						)	
					] otherwise [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedPermUids to targetuids,
							controlType to controlresulttype
						)
					]
				},
				Set True to updateRequired,
				ExecuteNamedAction reload,
				Unset selectedPermUids
			presentation: Button
			text: $detailspages.addexception
			tooltip: $detailspages.addexceptionTt
			image: %collection_16.add_user
			feature: bw_control_browser_exceptions
			disabled:
				AndPredicate {
					StringPredicate ( selectedPermUid ) {
						when IsEmpty then True
					}
					StringPredicate ( selectedPermUids ) {
						when IsEmpty then True
					}
				}
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for permission with  root cause
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>includedPermissionUid</b> (in) filter the control discrepancies to just the selected Uids </li>
 * <li><b>includedRootcauseUid</b> (in) filter the control root causes to just the selected Uids </li>
 * <li><b>selectedPermUid</b> (out) the selected permission UID</li>
 * </ul>
 * </span>
 */
bw_control_browser_permission_details_table_with_root_cause = PageFragment {
	
	/* Variables here */
	controlCode = Parameter { type: String }
	selectedPermUid = Variable { type: String }
	includedRootCauseUid = Variable { type: String multivalued: True }
	includedPermissionUid = Variable { type: String multivalued: True }
	initialIndex = Variable { type: Integer }
	// Tab selection
	isActive = Variable { type: Boolean initial: False }
	
	/* Datasets and records here */
	permissionData = Dataset {
		view: bw_control_browser_get_permission_discrepancies with
			controlCode to controlCode,
			True to getRootCause,
			includedRootCauseUid to includedRootCauseUid,
			includedPermissionUid to includedPermissionUid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	goDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog (
			selectedPermUid to inuid,
			True to inshowaccounts,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares,
			True to inshowACLs,
			True to inshowgroups,
			True to inshowowner
		)
	)
	
	/* Page content */
	PaginatedTable {
		data: permissionData
		double-click:
			ExecuteNamedAction goDetails
		layout: Layout { grab: horizontal True vertical True }
		configurable: True
		persist-configuration: True
		selection-index: initialIndex
		page-size:1000
		show-filter: True
		Column {
			column: uid
			hidden: True
			selection: selectedPermUid
		}
		Column {
			column: code
			header: $permission.code
			width: 100%
			sortable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: displayname
			header: $permission.displayname
			width: 100%
			sortable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissionalias
			header: $permission.permissionalias
			width: 100%
			sortable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissiontype
			header: $permission.permissiontype
			width: 50%
			sortable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: sensitivitylevel
			text: Transform Current sensitivitylevel using bwfPermissionSensitivityLevelMapping
			header: $permissionextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: sensitivityreason
			header: $permissionextNLS.sensitivityreason
			width: 100%
			initially-masked: True
		}
		Column {
			column: description
			header: $permissionextNLS.description
			width: 100%
			initially-masked: True
		}
		Column {
			column: app_code
			header: $papplication.code
			width: 50%
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_displayname
			header: $application.concept
			width: 50%
			sortable: True
			initially-masked: False
		}
		Column {
			column: app_category
			header: $papplicationextNLS.category
			width: 50%
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivitylevel
			text: Transform Current app_sensitivitylevel using bwfApplicationSensitivityLevelMapping
			header: $papplicationextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivityreason
			header: $papplicationextNLS.sensitivityreason
			width: 100%
			initially-masked: True
		}
		Column {
			column: app_description
			header: $papplicationextNLS.description
			width: 100%
			initially-masked: True
		}
		Column {
			column: Rootcause_displayname
			header: $rootcause.displayname
			width: 100%
			initially-masked: False
		}
		Column {
			column: Rootcause_permissiontype
			header: $rootcause.type
			width: 100%
			initially-masked: True
		}
		Column {
			column: app_root_displayname
			header: $rootcause.application
