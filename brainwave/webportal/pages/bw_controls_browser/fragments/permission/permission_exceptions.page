/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/resources.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/bw_fragments/permission/resources.page"
import "/webportal/pages/bw_fragments/application/resources.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control exceptions for permissions
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>hasExceptions</b> (out) a integer holding the number of root causes for the control</li>
 * <li><b>selectedPermUid</b> (out) the selected permission UID</li>
 * <li><b>selectedPermUids</b> (out) the selected permissions UIDs</li>
 * </ul>
 * </span>
 */
bw_control_browser_permission_exceptions = PageFragment {
	
	/* Variables here */
	controlCode = Variable { type: String }
	nbExceptions = Variable { type: Integer }
	selectedPermUid = Variable { type: String }
	selectedPermUids = Variable { type: String multivalued: True }
	
	/* Datasets and records here */
	exceptions = Dataset {
		view: bw_control_browser_permission_exceptions with
			controlCode to controlcode
		count-variable: nbExceptions
		disabled:
			StringPredicate ( controlCode ) {
				when IsEmpty then True
			}
	}
	
	goDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog (
			selectedPermUid to inuid,
			True to inshowaccounts,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares,
			True to inshowACLs,
			True to inshowgroups,
			True to inshowowner
		)
	)
	
	reload = NamedAction (
		ReloadData ( exceptions )
	)
	
	/* Page content */
	Table {
		data: exceptions
		show-filter: True
		show-count: True
		hide-header: False
		layout: Layout {
			grab: horizontal True vertical True
		}
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_permission_exceptions"
		checkboxes:
			uid to selectedPermUids
		Column {
			column: uid
			hidden: True
			selection: selectedPermUid
		}
		Column {
			column: code
			header: $permission.code
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: displayname
			header: $permission.displayname
			width: 100%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissionalias
			header: $permission.permissionalias
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: permissiontype
			header: $permission.permissiontype
			width: 50%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: sensitivitylevel
			text: Transform Current sensitivitylevel using bwfPermissionSensitivityLevelMapping
			header: $permissionextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: sensitivityreason
			header: $permissionextNLS.sensitivityreason
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
		Column {
			column: description
			header: $permissionextNLS.description
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_code
			header: $papplication.code
			width: 50%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: app_displayname
			header: $application.concept
			width: 50%
			sortable: True
			filterable: True
			initially-masked: False
		}
		Column {
			column: app_category
			header: $papplicationextNLS.category
			width: 50%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivitylevel
			text: Transform Current app_sensitivitylevel using bwfApplicationSensitivityLevelMapping
			header: $papplicationextNLS.sensitivitylevel
			width: 100%
			sortable: True
			initially-masked: True
		}
		Column {
			column: app_sensitivityreason
			header: $papplicationextNLS.sensitivityreason
			width: 100%
			filterable: True
			sortable: True			
			initially-masked: True
		}
		Column {
			column: app_description
			header: $papplicationextNLS.description
			width: 100%
			filterable: True
			sortable: True
			initially-masked: True
		}
		Column {
			column: ctrl_validfromdate
			header: $controlexception.fromdate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validuntildate
			header: $controlexception.untildate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_reason
			header: $controlexception.^reason
			sortable: True
			filterable: True
			width: 100%
		}
	}
}
