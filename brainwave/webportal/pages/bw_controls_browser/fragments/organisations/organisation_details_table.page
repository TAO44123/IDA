/* Import other pages here */
import "/webportal/pages/bw_fragments/organisation/details/organisationDetails.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/dialogs.page"
import "/webportal/pages/bw_fragments/lib/icons.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for organisation with root causes
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>includedOrganisationUid</b> (in) filter the control discrepancies to just the selected Uids </li>
 * <li><b>includedRootcauseUid</b> (in) filter the control root causes to just the selected Uids </li>
 * <li><b>selectedOrganisationUid</b> (out) the selected organisation UID</li>
 * </ul>
 * </span>
 */
bw_control_browser_organisation_details_table_with_root_cause = PageFragment {
	
	/* Variables here */
	controlCode = Variable { type: String }
	selectedOrganisationUid = Variable { type: String }
	selectedOrganisationUids = Variable { type: String multivalued: True }
	includedRootcauseUid = Variable { type: String multivalued: True }
	includedOrganisationUid = Variable { type: String multivalued: True }	
	initialIndex = Variable { type: Integer }
	useExceptions = Variable { type: Boolean }
	// Tab selection
	isActive = Variable { type: Boolean initial: False }
	
	/* Datasets and records here */
	organisationData = Dataset {
		view: bw_control_browser_get_organisations_discrepancies_on_control with
			controlCode to controlCode,
			True to getRootCause, 
			includedRootcauseUid to includedRootcauseUid,
			includedOrganisationUid to includedOrganisationUid,
			useExceptions to useExceptions
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	goDetails = NamedAction (
		Dialog bwf_organisationDetailsDialog (
			selectedOrganisationUid to inuid,
			True to inshowaccounts,
			True to inshowaccountsfororganisation,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares,
			True to inshowACLs,
			True to inshowgroups,
			True to inshowowner,
			True to inshowmanagers
		)
	)
	
	/* Page content */
	Table {
		data: organisationData
		double-click:
			ExecuteNamedAction goDetails
		layout: Layout { grab: horizontal True vertical True }
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_organisation_details_table_with_root_cause"
		selection-index: initialIndex
		show-filter: True
		show-count: True
		// Disabled as no buttons available yet
//		checkboxes:
//			uid to selectedOrganisationUids
		Column {
			column: uid
			hidden: True
			selection: selectedOrganisationUid
		}
		Column {
			column: shortname
			header: $organisation.shortname
			width: 100%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: displayname
			header: $organisation.displayname
			width: 100%
			sortable:True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: code
			header: $organisation.code
			width: 100%
			sortable:True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: perm_displayname
			header: $rootcause.displayname
			width: 100%
			sortable: True
			filterable: True
			initially-masked: False
		}
		Column {
			column: perm_permissiontype
			header: $rootcause.type
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: app_displayname
			header: $rootcause.application
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for organisation without root causes
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>selectedOrganisationUid</b> (out) the selected organisation UID</li>
 * </ul>
 * </span>
 */
bw_control_browser_organisation_details_table = PageFragment {
	
	/* Variables here */
	controlCode = Variable { type: String }
	selectedOrganisationUid = Variable { type: String }
	selectedOrganisationUids = Variable { type: String multivalued: True }
	initialIndex = Variable { type: Integer }
	useExceptions = Variable { type: Boolean }
	controlType = Variable { type: String }
	updateRequired = Variable { type: Boolean }
	// View filters
	filterTags = Variable { type: String multivalued: True }
	// Tab selection
	isActive = Variable { type: Boolean initial: False }
	
	/* Datasets and records here */
	organisationData = Dataset {
		view: bw_control_browser_get_organisations_discrepancies_on_control with
			controlCode to controlCode,
			False to getRootCause,
			useExceptions to useExceptions,
			filterTags to tags unless-empty
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	tags = Dataset {
		view: bw_controls_browser_organizationTags with
			controlCode to controlCode
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	goDetails = NamedAction (
		Dialog bwf_organisationDetailsDialog (
			selectedOrganisationUid to inuid,
			True to inshowaccounts,
			True to inshowaccountsfororganisation,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares,
			True to inshowACLs,
			True to inshowgroups,
			True to inshowowner,
			True to inshowmanagers
		)
	)
	
	reload = NamedAction (
		ReloadData ( organisationData )
	)
	
	/* Page content */
	// Filters
	Group {
		title: $bw_control_browser.filter
		layout: Layout { grab: horizontal True vertical False }
		Flow {
			disposition: Horizontal
			Group {
				Combo {
					variable: filterTags
					label: Label {
						break: True
						value: $bw_control_browser.tag
						tooltip: $bw_control_browser.tag.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: tags
						text: Current bwa_organisationtags_tag
						value: Current bwa_organisationtags_tag
					}
					disabled:
						IntPredicate ( Count tags ) {
							when < 1 then True
						}
				}
			}
			Group {
				Spacer {
					height: Fill
				}
				ButtonGroup {
					align: Center
					Button {
						text: $bw_control_browser.clear
						tooltip: $bw_control_browser.clear.tooltip
						image: %collection_16.delete
						presentation: Link
						actions:
							Unset filterTags
					}
				}
			}
		}
	}
	Table {
		data: organisationData
		double-click:
			ExecuteNamedAction goDetails
		layout: Layout { grab: horizontal True vertical True }
		configurable: True
		persist-configuration: True
		selection-index: initialIndex
		show-filter: True
		show-count: True
		// Disabled as no buttons available yet
//		checkboxes:
//			uid to selectedOrganisationUids
		Column {
			column: uid
			hidden: True
			selection: selectedOrganisationUid
		}
		Column {
			column: shortname
			header: $organisation.shortname
			width: 100%
			sortable:True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: displayname
			header: $organisation.displayname
			width: 100%
			sortable:True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: code
			header: $organisation.code
			width: 100%
			sortable:True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
	}
	ButtonGroup {
		layout: Layout { align: horizontal End vertical End }
		Button {
			actions:
				StringCase ( selectedOrganisationUids ) {
					when IsEmpty then [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedOrganisationUid to targetuids,
							controlType to controlresulttype
						)	
					] otherwise [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedOrganisationUids to targetuids,
							controlType to controlresulttype
						)
					]
				},
				Set True to updateRequired,
				ExecuteNamedAction reload,
				Unset selectedOrganisationUids
			presentation: Button
			text: $detailspages.addexception
			tooltip: $detailspages.addexceptionTt
			image: %collection_16.add_user
			feature: bw_control_browser_exceptions
			disabled:
				AndPredicate {
					StringPredicate ( selectedOrganisationUid ) {
						when IsEmpty then True
					}
					StringPredicate ( selectedOrganisationUids ) {
						when IsEmpty then True
					}
				}
		}
	}
}
