/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/resources.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control exceptions for applications
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>hasExceptions</b> (out) a integer holding the number of root causes for the control</li>
 * <li><b>selectedApplicationUid</b> (out) the selected application UID</li>
 * <li><b>selectedApplicationUids</b> (out) the selected application UIDs</li>
 *  * </ul>
 * </span>
 */
bw_control_browser_application_exceptions = PageFragment {	
	
	/* Variables here */
	controlCode = Variable { type: String }
	nbExceptions = Variable { type: Integer }
	selectedApplicationUid = Variable { type: String }
	selectedApplicationUids = Variable { type: String multivalued: True }
	
	/* Datasets and records here */
	viewDataset = Dataset {
		view: bw_control_browser_application_exceptions with
			controlCode to controlcode
		count-variable: nbExceptions
		disabled:
			StringPredicate ( controlCode ) {
				 when IsEmpty then True
			}
	}
	
	reload = NamedAction (
		ReloadData ( viewDataset )
	)
	
	/* Page content */
	Table {
		data: viewDataset
		show-filter: True
		show-count: True
		hide-header: False
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_application_exceptions"
		checkboxes:
			uid to selectedApplicationUids
		layout: Layout {
			grab: horizontal True vertical True
		}
		Column {
			column: code
			header: $application.code
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: displayname
			header: $application.displayname
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: applicationtype
			header: $application.applicationtype
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: repositoryrecorduid
			header: $application.repositoryrecorduid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: deletedaction
			header: $application.deletedaction
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: importaction
			header: $application.importaction
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: ctrl_issuername
			header: $controlexception.issuername
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validfromdate
			header: $controlexception.fromdate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validfromday
			header: $controlexception.fromdate
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: ctrl_validuntildate
			header: $controlexception.untildate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validuntilday
			header: $controlexception.untildate
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: recorduid
			header:$application.recorduid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: ctrl_reason
			header: $controlexception.^reason
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: uid
			header: $application.uid
			sortable: True
			filterable: True
			hidden: True
			width: 100%
			selection: selectedApplicationUid
		}
	}
}
