/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/resources.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control exceptions for assets
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>hasExceptions</b> (out) a integer holding the number of root causes for the control</li>
 * <li><b>selectedAssetUid</b> (out) the selected asset UID</li>
 * <li><b>selectedAssetUids</b> (out) the selected assets UIDs</li>
 * </ul>
 * </span>
 */
bw_control_browser_asset_exceptions = PageFragment {	
	
	/* Variables here */
	controlCode = Variable { type: String }
	nbExceptions = Variable { type: Integer }
	selectedAssetUid = Variable { type: String }
	selectedAssetUids = Variable { type: String multivalued: True }
	
	/* Datasets and records here */
	viewDataset = Dataset {
		view: bw_control_browser_asset_exceptions with
			controlCode to controlcode
		count-variable: nbExceptions
		disabled:
			StringPredicate ( controlCode ) {
				 when IsEmpty then True
			}
	}
	
	reload = NamedAction (
		ReloadData ( viewDataset )
	)
	
	/* Page content */
	Table {
		data: viewDataset
		show-filter: True
		show-count: True
		hide-header: False
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_asset_exceptions"
		checkboxes:
			uid to selectedAssetUids
		layout: Layout {
			grab: horizontal True vertical True
		}
		Column {
			column: code
			header: $asset.code
			sortable: True
			filterable: True
			width: 100%
			initially-masked:True
		}
		Column {
			column: displayname
			header: $asset.displayname
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: recorduid
			header: $asset.recorduid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: uid
			header: $asset.uid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
			selection: selectedAssetUid
		}
		Column {
			column: categoryrecorduid
			header: $asset.categoryrecorduid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: categoryuid
			header: $asset.categoryuid
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: categorycode
			header: $asset.categorycode
			sortable: True
			filterable: True
			width: 100%
			initially-masked:True
		}
		Column {
			column: importaction
			header: $asset.importaction
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: categorydisplayname
			header: $asset.categorydisplayname
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: deletedaction
			header: $asset.deletedaction
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: ctrl_issuername
			header: $controlexception.issuername
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validfromdate
			header: $controlexception.fromdate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validfromday
			header: $controlexception.fromdate
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: ctrl_validuntildate
			header: $controlexception.untildate
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: ctrl_validuntilday
			header: $controlexception.untildate
			sortable: True
			filterable: True
			width: 100%
			hidden: True
		}
		Column {
			column: ctrl_reason
			header: $controlexception.^reason
			sortable: True
			filterable: True
			width: 100%
		}
	}
}
