			sortable:True
			initially-masked: False
		}
		Column {
			column: repo_code
			header: $prepository.code
			width: 50%
			sortable:True
			initially-masked: True
		}
		Column {
			column: comment
			header: $group.comment
			width: 100%
			initially-masked: True
		}
		Column {
			column: grouptype
			header: $group.grouptype
			width: 100%
			initially-masked: True
			sortable:True
		}
		Column {
			column: dynamic
			header: $group.dynamic
			width: 100%
			initially-masked: True
			sortable:True
		}
		Column {
			column: filter
			header: $group.filter
			width: 100%
