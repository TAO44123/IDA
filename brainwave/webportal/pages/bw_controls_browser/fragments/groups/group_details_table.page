/* Import other pages here */
import "/webportal/pages/bw_fragments/group/details/groupDetails.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/dialogs.page"
import "/webportal/pages/bw_fragments/lib/icons.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for groups without root causes
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>selectedGroupUid</b> (out) the selected groups UID</li>
 * </ul>
 * </span>
 */
bw_control_browser_group_details_table = PageFragment {
	
	/* Variables here */
	controlCode = Variable { type: String }
	selectedGroupUid = Variable { type: String }
	selectedGroupUids = Variable { type: String multivalued: True }
	initialIndex = Variable { type: Integer }
	useExceptions = Variable { type: Boolean }
	controlType = Variable { type: String }
	updateRequired = Variable { type: Boolean }
	// View filters
	filterRepositoryUid = Variable { type: String multivalued: True }
	filterTags = Variable { type: String multivalued: True }
	// Variables for filtering, from view
	repo_uid = Variable { type: String multivalued: True }
	repo_displayname = Variable { type: String multivalued: True }
	// Tab selection
	isActive = Variable { type: Boolean initial: False }
	
	/* Datasets and records here */
	groupData = Dataset {
		view: bw_control_browser_get_groups_discrepancies_on_control with
			controlCode to controlCode,
			False to getRootCause,
			useExceptions to useExceptions,
			filterRepositoryUid to repo_uid unless-empty,
			filterTags to tags unless-empty
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	repositories = Dataset {
		columns:
			repo_uid,
			repo_displayname
	}
	
	tags = Dataset {
		view: bw_controls_browser_groupTags with
			controlCode to controlCode
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	updateRepos = NamedAction (
		TransferData groupData ( repo_uid, repo_displayname )
			to ( repo_uid, repo_displayname ),
		MultivaluedDistinct repo_uid and ( repo_displayname )
	)
	
	updateFilters = NamedAction (
		ExecuteNamedAction updateRepos
	)
	
	goDetails = NamedAction (
		Dialog bwf_groupDetailsDialog (
			selectedGroupUid to inuid,
			True to inshowaccounts,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares
		)
	)
	
	reload = NamedAction (
		ReloadData ( groupData )
	)
	
	/* Page content */
	// Filters
	Group {
		title: $bw_control_browser.filter
		layout: Layout { grab: horizontal True vertical False }
		Flow {
			disposition: Horizontal
			Group {
				Combo {
					variable: filterTags
					label: Label {
						break: True
						value: $bw_control_browser.tag
						tooltip: $bw_control_browser.tag.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: tags
						text: Current bwa_grouptags_tag
						value: Current bwa_grouptags_tag
					}
					disabled:
						IntPredicate ( Count tags ) {
							when < 1 then True
						}
				}
			}
			Group {
				Combo {
					variable: filterRepositoryUid
					label: Label {
						break: True
						value: $repository.concept
						tooltip: $bw_control_browser.repository.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: repositories
						text: Current repo_displayname
						value: Current repo_uid
					}
					disabled:
						IntPredicate ( Count repositories ) {
							when < 1 then True
						}
				}
			}
			Group {
				Spacer {
					height: Fill
				}
				ButtonGroup {
					align: Center
					Button {
						text: $bw_control_browser.clear
						tooltip: $bw_control_browser.clear.tooltip
						image: %collection_16.delete
						presentation: Link
						actions:
							Unset filterRepositoryUid,
							Unset filterTags
					}
				}
			}
		}
	}
	Table {
		data: groupData
		double-click:
			ExecuteNamedAction goDetails
		layout: Layout { grab: horizontal True vertical True }
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_group_details_table"
		selection-index: initialIndex
		show-filter: True
		show-count: True
		// Disabled as no buttons available yet
//		checkboxes:
//			uid to selectedGroupUids
		Column {
			column: uid
			hidden: True
			selection: selectedGroupUid
		}
		Column {
			column: displayname
			header: $group.displayname
			width: 100%
			sortable: True
			filterable: True
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: code
			header: $group.code
			width: 100%
			sortable: True
			filterable: True
			initially-masked: True
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: repo_displayname
			header: $prepository.displayname
			width: 50%
			sortable: True
			filterable: True
			initially-masked: False
		}
		Column {
			column: repo_code
			header: $prepository.code
			width: 50%
			sortable: True
			filterable: True
			initially-masked: True
		}
		Column {
			column: comment
			header: $group.comment
			width: 100%
			initially-masked: True
			filterable: True
			sortable: True
		}
		Column {
			column: grouptype
			header: $group.grouptype
			width: 100%
			initially-masked: True
			sortable: True
			filterable: True
		}
		Column {
			column: dynamic
			header: $group.dynamic
			width: 100%
			initially-masked: True
			sortable: True
		}
		Column {
			column: filter
			header: $group.filter
			width: 100%
			initially-masked: True
			filterable: True
		}
		Column {
			column: sid
			header: $group.sid
			width: 100%
			initially-masked: True
			sortable: True
		}
		Column {
			column: guid
			header: $group.guid
			width: 100%
			initially-masked: True
			sortable: True
		}
		Column {
			column: creationdate
			header: $group.creationdate
			width: 100%
			initially-masked: True
			sortable: True
		}
		Column {
			column: modificationdate
			header: $group.modificationdate
			width: 100%
			initially-masked: True
			sortable: True
		}
		Column {
			column: lastmodifiedby
			header: $group.lastmodifiedby
			width: 100%
			initially-masked: True
			sortable: True
		}
	}
	ButtonGroup {
		layout: Layout { align: horizontal End vertical End }
		Button {
			actions:
				StringCase ( selectedGroupUids ) {
					when IsEmpty then [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedGroupUid to targetuids,
							controlType to controlresulttype
						)
					] otherwise [
						Dialog createControlExceptionDialog (
							controlCode to controlcode,
							selectedGroupUids to targetuids,
							controlType to controlresulttype
						)
					]
				},
				Set True to updateRequired,
				ExecuteNamedAction reload,
				Unset selectedGroupUids
			presentation: Button
			text: $detailspages.addexception
			tooltip: $detailspages.addexceptionTt
			image: %collection_16.add_user
			feature: bw_control_browser_exceptions
			disabled:
				AndPredicate {
					StringPredicate ( selectedGroupUid ) {
						when IsEmpty then True
					}
					StringPredicate ( selectedGroupUids ) {
						when IsEmpty then True
					}
				}
		}
	}
}

/**
