			initially-masked: False
		}
		Column {
			column: hrcode
			header: $identity.hrcode
			width: 100%
			initially-masked: False
			actions: ExecuteNamedAction goDetails
		}
		Column {
			column: givenname
			header: $identity.givenname
			width: 100%
			initially-masked: False
