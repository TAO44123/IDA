				image: %collection_16.add_user
				feature: bw_control_browser_exceptions
				disabled:
					AndPredicate {
						StringPredicate ( selectedAccUid ) {
							when IsEmpty then True
						}
						StringPredicate ( selectedAccUids ) {
							when IsEmpty then True
						}
					}
			}
		}
		Table {
			data: accountData
			double-click:
