/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for accounts without root causes
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>selectedAccUid</b> (out) the selected account UID</li>
 * <li><b>selectedAccRecorduid</b> (out) the selected account recorduid </li>
 * </ul>
 * </span>
 */
bw_control_browser_accountWithRights_details_table = PageFragment {
	
	/* Variables here */
	selectedAccUid = Variable { type: String }
	selectedKeysUids = Variable { type: String multivalued: True }
	selectedAccUids = Variable { type: String multivalued: True }
	selectedPermUids = Variable { type: String multivalued: True }
	selectedPerimUids = Variable { type: String multivalued: True }
	selectedAccRecorduid = Variable { type: String }
	initialIndex = Variable { type: Integer }
	controlCode = Variable { type: String }
	useExceptions = Variable { type: Boolean }
	updateRequired = Variable { type: Boolean }
	controlType = Variable { type: String }
	// Table selection
	isActive = Variable { type: Boolean initial: False }
	applicationUid = Variable { type: String }
	permissionUid = Variable { type: String }
	// View filters
	filterRepositoryUid = Variable { type: String multivalued: True }
	filterApplicationUid = Variable { type: String multivalued: True }
	filterPermissionUid = Variable { type: String multivalued: True }
	filterTags = Variable { type: String multivalued: True }
	// Variables for filtering, from view
	repo_uid = Variable { type: String multivalued: True }
	repo_displayname = Variable { type: String multivalued: True }
	app_uid = Variable { type: String multivalued: True }
	app_displayname = Variable { type: String multivalued: True }
	perm_uid = Variable { type: String multivalued: True }
	perm_displayname = Variable { type: String multivalued: True }
	
	/* Datasets and records here */
	accountData = Dataset {
		view: bw_controls_browser_get_accWithRights_discrepenncies_on_control_bv with
			controlCode to controlcode,
			useExceptions to useExceptions,
			filterRepositoryUid to repo_uid unless-empty,
			filterApplicationUid to app_uid unless-empty,
			filterPermissionUid to perm_uid unless-empty,
			filterTags to tags unless-empty
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	repositories = Dataset {
		columns:
			repo_uid,
			repo_displayname
	}
	
	applications = Dataset {
		columns:
			app_uid,
			app_displayname
	}
	
	permissions = Dataset {
		columns:
			perm_uid,
			perm_displayname
	}
	
	tags = Dataset {
		view: bw_controls_browser_accountTags with
			controlCode to controlCode
		disabled:
			OrPredicate {
				Not BooleanPredicate ( isActive )
				StringPredicate ( controlCode ) {
					when IsEmpty then True
				}
			}
	}
	
	updatePerms = NamedAction (
		TransferData accountData ( perm_uid, perm_displayname )
			to ( perm_uid, perm_displayname ),
		MultivaluedDistinct perm_uid and ( perm_displayname )
	)
	
	updateApps = NamedAction (
		TransferData accountData ( app_uid, app_displayname )
			to ( app_uid, app_displayname ),
		MultivaluedDistinct app_uid and ( app_displayname )
	)
	
	updateRepos = NamedAction (
		TransferData accountData ( repository_uid, repository_displayname )
			to ( repo_uid, repo_displayname ),
		MultivaluedDistinct repo_uid and ( repo_displayname )
	)
	
	updateFilters = NamedAction (
		ExecuteNamedAction updateRepos,
		ExecuteNamedAction updateApps,
		ExecuteNamedAction updatePerms
	)
	
	goDetails = NamedAction (
		Dialog bwf_accountDetailsDialog (
			selectedAccUid to inuid,
			True to inshowaccounts,
			True to inshowaccountsfororganisation,
			True to inshowapplications,
			True to inorganisationuid, 
			True to inshowcontrols,
			True to inshowshares,
			True to inshowACLs,
			True to inshowgroups,
			True to inshowowner
		)
	)
	
	goAppDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog (
			applicationUid to inuid,
			True to inshowperjob,
			True to inshowperorg
		)
	)
	
	goPermDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog (
			permissionUid to inuid,
			True to inshowperjob,
			True to inshowperorg
		)
	)
	
	reload = NamedAction (
		ReloadData ( accountData )
	)
	
	/* Page content */
	// Filters
	Group {
		title: $bw_control_browser.filter
		layout: Layout { grab: horizontal True vertical False }
		Flow {
			disposition: Horizontal
			Group {
				Combo {
					variable: filterTags
					label: Label {
						break: True
						value: $bw_control_browser.tag
						tooltip: $bw_control_browser.tag.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: tags
						text: Current bwa_accounttags_tag
						value: Current bwa_accounttags_tag
					}
					disabled:
						IntPredicate ( Count tags ) {
							when < 1 then True
						}
				}
			}
			Group {
				Combo {
					variable: filterRepositoryUid
					label: Label {
						break: True
						value: $repository.concept
						tooltip: $bw_control_browser.repository.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: repositories
						text: Current repo_displayname
						value: Current repo_uid
					}
					disabled:
						IntPredicate ( Count repositories ) {
							when < 1 then True
						}
				}
			}
			Group {
				Combo {
					variable: filterApplicationUid
					label: Label {
						break: True
						value: $application.concept
						tooltip: $bw_control_browser.application.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
					options: Dynamic {
						data: applications
						text: Current app_displayname
						value: Current app_uid
					}
					disabled:
						IntPredicate ( Count applications ) {
							when < 1 then True
						}
				}
			}
			Group {
				Combo {
					variable: filterPermissionUid
					label: Label {
						break: True
						value: $permission.concept
						tooltip: $bw_control_browser.permission.tooltip
					}
					multi-selection: True
					allow-none: True
					layout: Layout { grab: horizontal False vertical False hint: width 200 }
