				image: %collection_16.delete
				feature: iasreview_license
				disabled:
					StringPredicate ( selectedKeysUids ) {
						when IsEmpty then True
					}
			}
			Button {
				actions:
					StringCase ( selectedAccUids ) {
						when IsEmpty then [
							Dialog createControlExceptionDialog (
								controlCode to controlcode,
								selectedAccUid to targetuids,
								controlType to controlresulttype
							)
						] otherwise [
							Dialog createControlExceptionDialog (
								controlCode to controlcode,
								selectedAccUids to targetuids,
								controlType to controlresulttype
							)
