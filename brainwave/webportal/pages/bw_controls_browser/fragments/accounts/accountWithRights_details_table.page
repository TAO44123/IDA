						data: permissions
						text: Current perm_displayname
						value: Current perm_uid
					}
					disabled:
						IntPredicate ( Count permissions ) {
							when < 1 then True
						}
				}
			}
			Group {
				Spacer {
					height: Fill
				}
				ButtonGroup {
					align: Center
					Button {
						text: $bw_control_browser.clear
						tooltip: $bw_control_browser.clear.tooltip
						image: %collection_16.delete
						presentation: Link
						actions:
							Unset filterRepositoryUid,
							Unset filterTags,
							Unset filterApplicationUid,
							Unset filterPermissionUid
					}
				}
			}
		}
	}
	Group {
		ButtonGroup {
			align: Center
			uniform: True
			Button {
				actions:
					Dialog bw_iasremediation_rights_create (
						selectedAccUids to accountUids,
						selectedPerimUids to perimeterUids,
						selectedPermUids to permissionUids
