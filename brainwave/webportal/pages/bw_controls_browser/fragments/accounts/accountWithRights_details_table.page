/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control discrepancies for accounts
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>includedAccUid</b> (in) filter the control discrepancies to just the selected Uids </li>
 * <li><b>includedPermUid</b> (in) filter the control root causes to just the selected Uids </li>
 * <li><b>selectedAccUid</b> (out) the selected account UID</li>
 * <li><b>selectedAccRecorduid</b> (out) the selected account recorduid </li>
 * </ul>
 * </span>
 */

bw_control_browser_account_details_table_with_root_cause = PageFragment {
	
	/* Variables here */
	includedAccUid = Variable { type: String multivalued: True }
	selectedKeys = Variable { type: String multivalued: True }
	selectedAccUid = Variable { type: String }
	selectedAccUids = Variable { type: String multivalued: True }
	selectedPerimUids = Variable { type: String multivalued: True }
	selectedPermsUids = Variable { type: String multivalued: True }
	selectedAccRecorduid = Variable { type: String }
	includedPermUid = Variable { type: String multivalued: True }
	initialIndex = Variable { type: Integer }
	controlCode = Variable { type: String }
	// Refresh
	updateRequired = Variable { type: Boolean }

	/* Datasets and records here */
	accountData = Dataset {
		view: bw_controls_browser_get_acc_discrepenncies_on_control_root_bv with
