/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/workflow/bw_exception_manager/resources/resources.page"

/**
 * <span style="white-space: pre-line">
 * Build and display the tables of a designed control exceptions for accounts
 * 
 * <u>Parameters:</u><ul>
 * <li><b>controlCode</b> (in) the designed control control code</li>
 * <li><b>hasExceptions</b> (out) a integer holding the number of root causes for the control</li>
 * <li><b>selectedAccUid</b> (out) the selected account UID</li>
 * <li><b>selectedAccRecorduid</b> (out) the selected account recorduid </li>
 * </ul>
 * </span>
 */
bw_control_browser_account_exceptions = PageFragment {
	
	/* Variables here */
	controlCode = Variable { type: String }
	nbExceptions = Variable { type: Integer }
	selectedAccountUid = Variable { type: String }
	selectedAccountUids = Variable { type: String multivalued: True }
	
	/* Datasets and records here */
	exceptions = Dataset {
		view: bw_control_browser_account_exceptions with
			controlCode to controlcode
		count-variable: nbExceptions
		disabled:
			StringPredicate ( controlCode ) {
				when IsEmpty then True
			}
	}
	
	reload = NamedAction (
		ReloadData ( exceptions )
	)
	
	/* Page content */
	Table {
		data: exceptions
		show-filter: True
		show-count: True
		hide-header: False
		layout: Layout {
			grab: horizontal True vertical True
		}
		configurable: True
		persist-configuration: True
		persist-configuration-key: "bw_control_browser_account_exceptions"
		checkboxes:
			uid to selectedAccountUids
		Column {
			column: login
			header: $account.login
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: recorduid
			header: $account.recorduid
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: ctrl_controlcode
			header: $controlresult.controlcode
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: ctrl_validuntilday
			header: $controlexception.add.label.enddate
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
		}
		Column {
			column: uid
			header: $account.uid
			sortable: True
			filterable: True
			width: 100%
			initially-masked: True
			selection: selectedAccountUid
		}
		Column {
			column: identifier
			header: $account.identifier
			sortable: True
