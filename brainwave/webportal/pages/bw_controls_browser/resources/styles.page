
base_pageMixin = Mixin {
   Text {
     compact: True
   }
}

header = Mixin {
	Text {
		compact: True
		styling: simpleLabel
		layout: Layout { align: vertical Center horizontal Fill }
	}
	Group {
	}
}

infotext = Style {
	size: 12px
}

simpleLabel = Style {
	bold: True
	size: 14px
	foreground: RGB(80, 80, 80)
}

KPI = Style {
	bold: True
	size: 20px
	foreground: grey
}

Tag = Style {
	bold: True
	size: 12px
	foreground: navy
}
