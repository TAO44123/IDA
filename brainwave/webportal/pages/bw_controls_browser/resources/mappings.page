import "/webportal/pages/bw_controls_browser/resources/constants.page"
import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_cloud_pam/subscription/safepickers.page"

share = StringMapping {
	when Constant _Filesystem then $bw_control_browser.share
	when IsEmpty then $bw_control_browser.na
	otherwise $application.concept
}

sharefolder = StringMapping {
	when Constant _Filesystem then $bw_control_browser.sharedFolder
	when IsEmpty then $bw_control_browser.na
	otherwise $permission.concept
}

creatediscrepancieslabel = StringMapping {
	when Constant _Account then $bw_control_browser.discrepancies.accounts
	when Constant _Application then $bw_control_browser.discrepancies.applications
	when Constant _Permission then $bw_control_browser.discrepancies.permissions
	when Constant _Asset then $bw_control_browser.discrepancies.assets
	when Constant _Group then $bw_control_browser.discrepancies.groups
	when Constant _Organisation then $bw_control_browser.discrepancies.organisations
	when Constant _Organization then $bw_control_browser.discrepancies.organisations
	when Constant _Identity then $bw_control_browser.discrepancies.identities
	when Constant _Share then $bw_control_browser.discrepancies.shares
	when Constant _Sharedfolder then $bw_control_browser.discrepancies.sharedFolders
	otherwise current
}

type = StringMapping {
	when Constant _Account then $account.concept
	when Constant _Application then $application.concept
	when Constant _Permission then $permission.concept
	when Constant _Asset then $asset.concept
	when Constant _Group then $group.concept
	when Constant _Organisation then $organisation.concept
	when Constant _Organization then $organisation.concept
	when Constant _Identity then $identity.concept
	when Constant _Share then $bw_control_browser.share
	when Constant _Sharedfolder then $bw_control_browser.sharedFolder
	when Constant _Right then $bw_control_browser.rights
	when Constant _Rights then $bw_control_browser.rights
	when Constant _Folder then $bw_control_browser.folder
	when Constant _FolderRight then $bw_control_browser.folderRights
	when Constant _Risk then $bw_control_browser.risk
	when Constant _Quality then $bw_control_browser.quality
	when Constant _GPO then $bw_control_browser.gpo
	when Constant _Privilege then $bw_control_browser.privilege
	when Constant _LocalAdmin then $bw_control_browser.localAdmin
	when Constant _Safe then $picker.safe.dislayname
	when Constant _Vault then $picker.vault.dislayname
	when Constant _Credential then $picker.cred
	otherwise $bw_control_browser.na
}

concept = StringImageTemplate {
	when Constant _Account then %concept_16.account
	when Constant _Application then %concept_16.application
	when Constant _Permission then %concept_16.permission
	when Constant _Asset then %concept_16.asset
	when Constant _Group then %concept_16.group
	when Constant _Organisation then %concept_16.organisation
	when Constant _Organization then %concept_16.organisation
	when Constant _Identity then %concept_16.identity
	when Constant _Share then %concept_16.share
	when Constant _Sharedfolder then %concept_16.folder
	when Constant _Folder then %concept_16.folder
	when Constant _FolderRight then %concept_16.folderRight
	when Constant _Rights then %concept_16.right
	when Constant _Right then %concept_16.right
	when Constant _Risk then %status.risk
	when Constant _Quality then %status.check
	when Constant _GPO then %browsing.information
	when Constant _Privilege then %collection.graph
	when Constant _LocalAdmin then %collection.user
	when Constant _Safe then %safeimage_16.safe
	when Constant _Vault then %safeimage_16.vault
	when Constant _Credential then %safeimage_16.credentials
	otherwise %browsing.help
}

number = IntMapping {
	when InvalidInteger then 0
	otherwise current
}

perms_type_mapping = StringMapping {
	when Constant _Folder then $bw_control_browser.folders
	otherwise $bw_control_browser.permissions
}

apps_type_mapping = StringMapping {
	when Constant _Share then $bw_control_browser.shares
	otherwise $bw_control_browser.applications
}

app_type_mapping = StringMapping {
	when Constant _Folder then $bw_control_browser.share
	when Constant _Share then $bw_control_browser.share
	otherwise $application.concept
}

app_type_mapping_tooltip = StringMapping {
	when Constant _Folder then $bw_control_browser.share.tooltip
	when Constant _Share then $bw_control_browser.share.tooltip
	otherwise $bw_control_browser.application.tooltip
}

repo_type_mapping = StringMapping {
	when Constant _Share then $bw_control_browser.server
	otherwise $repository.concept
}

repo_type_mapping_tooltip = StringMapping {
	when Constant _Share then $bw_control_browser.server.tooltip
	otherwise $bw_control_browser.repository.tooltip
}
