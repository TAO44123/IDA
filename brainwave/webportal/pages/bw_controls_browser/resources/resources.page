import "/webportal/pages/bw_controls_browser/resources/NLS.page"
import "/webportal/pages/bw_fragments/lib/icons.page"

evolutionWarningIcons = IntImageTemplate {
	when < 0 then %trend_16.low
	when = 0 then %trend_16.equals
	when > 0 then %trend_16.high
}

sensitivityIcon16 = IntImageTemplate {
	when =1 then %controllevel.level1
	when =2 then %controllevel.level2
	when =3 then %controllevel.level3
	when =4 then %controllevel.level4
	when =0 then %controllevel.level0
	when InvalidInteger then %browsing.help
	otherwise %browsing.help
}

managedText = BooleanMapping{
	when False then $managedText_NLS._0
	when True then $managedText_NLS._1
}

sensitivityText = IntMapping {
	when =0 then $sensitivityText_NLS._0
	when =1 then $sensitivityText_NLS._1
	when =2 then $sensitivityText_NLS._2
	when =3 then $sensitivityText_NLS._3
	when =4 then $sensitivityText_NLS._3
	otherwise $sensitivityText_NLS._empty
}

// to use when displaying comma separated lists, so that empty lists do not display as "not set", but as "no levels selected"
sensitivityTextForList = IntMapping {
	when =0 then $sensitivityText_NLS._0
	when =1 then $sensitivityText_NLS._1
	when =2 then $sensitivityText_NLS._2
	when =3 then $sensitivityText_NLS._3
	when =4 then $sensitivityText_NLS._3
	otherwise    ""
}
