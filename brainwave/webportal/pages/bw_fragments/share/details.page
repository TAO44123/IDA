			GridCell {
				Group {
					title:$fragmentShareDetailsNLS.classification
					Text {
						value:share.applicationfamily
						label:$fragmentShareDetailsNLS.family
						hidden:StringPredicate(share.applicationfamily) { when IsEmpty then True }
						compact:True
					}
					Text {
						value:share.repositorydisplayname
						label:$fragmentShareDetailsNLS.fileserver
						compact:True
						hidden: // hide if not ShareFolder family, or it's in default repo (FileShare)
							OrPredicate {
								StringPredicate (share.applicationfamily) { when "SharedFolders" then False otherwise True }
								StringPredicate (share.repositorycode) { when "FileShare" then True otherwise False }
							}
					}
					Text {
						value:share.category
						label:$fragmentShareDetailsNLS.category
						compact:True
