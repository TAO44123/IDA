/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/bw_fragments/share/resources.page"
import "/webportal/pages/bw_fragments/cmdbci/details/cmdbciDetails.page"

fragmentShareDetailsNLS = NLS {
	category [en "Category" fr "Catégorie"]
	family [en "Family" fr "Famille"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	nbaccounts [en "Number of active accounts" fr "Nombre de comptes actifs"]
	nbfolders [en "Number of folders" fr "Nombre de répertoires"]
	nbfoldersTooltip [en "Number of folders with ACL (maximum depth of 5 levels)" fr "Nombre de répertoires avec des ACLs (profondeur maximale de 5 niveaux)"]
	expertise [en "Expertise" fr "Responsabilité"]
	managers [en "Managers" fr "Responsables"]
	updatemetadata [en "Update application description" fr "Mise à jour de la description de l'application"]
	addowner [en "Add a new application owner" fr "Ajout d'un nouveau responsable d'application"]
	deleteowner [en "Delete selected application owner" fr "Suppression du responsable d'application"]
	auditowner [en "Application owner updates audit trail" fr "Piste d'audit des changements de reponsable de l'application"]
	kpis [en "KPIs" fr "KPIs"]
	access [en "Access rights" fr "Droits d''accès"]
	classification [en "Classification" fr "Classification"]
	nomanagers [en "No manager set" fr "Pas de responsable configuré"]

	managetags [en "Manage tags" fr "Gérer les labels"]

	cmdbDetailsTooltip [en "Show CMDB CI detail" fr "Afficher le détail de l'élement CMDB"]
	cmdbfield [en "Associated CMDB CI" fr "Elément CMDB associé"]
	
	fileserver [en "Server" fr "Serveur"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected share details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update application description (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentShareDetails = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	
	share = Record {
		view: bwf_shareDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevshare = Record {
		view: bwf_shareDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}
	managers = Dataset {
		view: bwf_applicationmanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	applicationcis = Record {
		view: bwf_applicationcis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// compact mode
	Text {
		value:share.code
		label:$application.code	
		compact:True
		hidden:SameValuePredicate(share.code, share.displayname)
	}
	Text {
		value:share.displayname
		label:$application.displayname
		compact:True
		commands:Commands { position: After orientation: Horizontal 
						Command{	actions:Dialog bwfApplicationDetailsMetadata_Dialog(inuid to paramApplicationUid,
																						share.sensitivityreason to sensitivityreason, 
																						share.description to description, 
																						share.category to category,
																						share.applicationtype to applicationtype), 
											ReloadData (share)
		                        	icon:%collection_16.pencil
		                        	disabled:Not BooleanPredicate(incanupdatedescription)
		                        	feature:sharedetails_updatemetadata
		                        	tooltip:$fragmentShareDetailsNLS.updatemetadata
		                       }
		                  }
	}
	Text {
		value: @srv_truncatestring (share.description to string, 200 to maxlength)
		tooltip: share.description
		label:$application.description
		lines:3
		compact:True
		hidden:StringPredicate(share.description) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentShareDetailsNLS.kpis
	}
	Separator {
		width:1
	}
	
	Text {
		value:share.bwa_applicationanalytics_nbaccount
		label:$search.application.nbaccounts
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbaccount using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbaccount using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbaccount, prevshare.bwa_applicationanalytics_nbaccount)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:share.bwa_applicationanalytics_nbidentity
		label:$search.application.nbidentities
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbidentity using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbidentity using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbidentity, prevshare.bwa_applicationanalytics_nbidentity)) using bwf_trend
				width:16
			}
		}
	}
	
	Text {
		value:Transform share.bwa_applicationanalytics_nbmanagedfolder using bwf_defaultsTo0
		label:$search.share.nbmanagedfolder_compact
		compact:True
		align:Right
		hidden:AndPredicate {
			IntPredicate(share.bwa_applicationanalytics_nbmanagedfolder) { when >0 then False otherwise True }
			IntPredicate(prevshare.bwa_applicationanalytics_nbmanagedfolder) { when >0 then False otherwise True }
		}
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbmanagedfolder using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbmanagedfolder using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbmanagedfolder, prevshare.bwa_applicationanalytics_nbmanagedfolder)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:share.bwa_applicationanalytics_nbfolder
		label:$search.share.nbfolder
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbfolder using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbfolder using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbfolder, prevshare.bwa_applicationanalytics_nbfolder)) using bwf_trend
				width:16
			}
		}
	}

	Header {
		value:$fragmentShareDetailsNLS.access
	}
	Separator {
		width:1
	}
	Text {
		value:Transform share.bwa_applicationanalytics_nbreadaccess using bwf_defaultsTo0
		label:$search.share.nbreadaccess_compact
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbreadaccess using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbreadaccess using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbreadaccess, prevshare.bwa_applicationanalytics_nbreadaccess)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform share.bwa_applicationanalytics_nbwriteaccess using bwf_defaultsTo0
		label:$search.share.nbwriteaccess_compact
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbwriteaccess using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbwriteaccess using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbwriteaccess, prevshare.bwa_applicationanalytics_nbwriteaccess)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform share.bwa_applicationanalytics_nbfullcontrolaccess using bwf_defaultsTo0
		label:$search.share.nbfullcontrolaccess_compact
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbfullcontrolaccess using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbfullcontrolaccess using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbfullcontrolaccess, prevshare.bwa_applicationanalytics_nbfullcontrolaccess)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform share.bwa_applicationanalytics_nbusage using bwf_defaultsTo0
		label:$search.share.nbusage
		compact:True
		align:Right
		hidden:AndPredicate {
			IntPredicate(share.bwa_applicationanalytics_nbusage) { when >0 then False otherwise True }
			IntPredicate(prevshare.bwa_applicationanalytics_nbusage) { when >0 then False otherwise True }
		}
		tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbusage using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbusage using mayBeNullMapping)
		decorator:Decorator {
			width:60
			after:Image {
				image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbusage, prevshare.bwa_applicationanalytics_nbusage)) using bwf_trend
				width:16
			}
		}
	}

	Header {
		value:$fragmentShareDetailsNLS.classification
	}
	Separator {
		width:1
	}
	Text {
		value:share.applicationfamily
		label:$fragmentShareDetailsNLS.family
		hidden:StringPredicate(share.applicationfamily) { when IsEmpty then True }
		compact:True
	}
	Text {
		value:share.repositorydisplayname
		label:$fragmentShareDetailsNLS.fileserver
		compact:True
		hidden: // hide if not ShareFolder family, or it's in default repo (FileShare)
			OrPredicate {
				StringPredicate (share.applicationfamily) { when "SharedFolders" then False otherwise True }
				StringPredicate (share.repositorycode) { when "FileShare" then True otherwise False }
			}
	}
	Text {
		value:share.category
		label:$fragmentShareDetailsNLS.category
		compact:True
	}
	Text {
		value:Transform share.sensitivitylevel using bwfApplicationSensitivityLevelMapping
		label:$fragmentShareDetailsNLS.sensitivitylevel
		compact:True
	}
	Text {
		value:share.sensitivityreason
		label:$fragmentShareDetailsNLS.sensitivityreason
		compact:True
	}
	Text {
		value:applicationcis.label
		compact:True
		label:$fragmentShareDetailsNLS.cmdbfield
		hidden:StringPredicate(applicationcis.ci_uid) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentShareDetailsNLS.managers
	}
	Separator {
		width:1
	}

	ConditionalGroup {
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$fragmentShareDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfShareDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramApplicationUid),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdateowners)
	                        	feature:sharedetails_updatemanager
	                        	tooltip:$fragmentShareDetailsNLS.addowner
	                       }
					}
				}
			]
			otherwise [
				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical False hint:height 116 }
					configurable:True
					label:Label { break:True }
					commands:Commands { position: After orientation: Vertical
									Command{	
											actions:Dialog bwfShareDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerType, 
																										inuid to paramApplicationUid),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:Not BooleanPredicate(incanupdateowners)
				                        	feature:sharedetails_updatemanager
				                        	tooltip:$fragmentShareDetailsNLS.addowner
				                       }
									Command{	
											actions:Dialog bwfApplicationDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode, 
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramApplicationUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdateowners)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:sharedetails_updatemanager
				                        	tooltip:$fragmentShareDetailsNLS.deleteowner
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Application" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdateowners)
				                        	feature:sharedetails_updatemanager
				                        	tooltip:$fragmentShareDetailsNLS.auditowner
				                       }
				                  }
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column: ManagerLinkRecorduid
						hidden: True
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
			
			
					Column {
						column:comment
						header:$bwfManagement.comment
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
				}
			]
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the selected share details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update application description (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentShareFullDetails = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	
	share = Record {
		view: bwf_shareDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevshare = Record {
		view: bwf_shareDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}
	managers = Dataset {
		view: bwf_applicationmanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	applicationcis = Record {
		view: bwf_applicationcis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tags = Dataset {
		view:bwf_applicationtags with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tagsasString = Record {
  		 view: bwa_applicationtagsasastring with inuid to uid
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// standard
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		// Share card
		Group {
			Text {
				value: share.displayname
				styling: bigTitleStyle
				layout: Layout{indent:horizontal 0 vertical 0 }
				label: Label { break: False value: $application.displayname }
				compact: True
			}
			Text {
				value: share.code
				compact: True
				label: Label { break: False value: $application.code }
				hidden:
					SameValuePredicate ( share.code, share.displayname )
			}
			Text {
				value: @srv_truncatestring (tagsasString.tag to string, 300 to maxlength)
				tooltip: tagsasString.tag
				label: Label { break: False value: $application.tags }
				compact: True
				layout: Layout { grab: horizontal True vertical False }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog fragmentApplicationTagsEditor (
									inuid to uid,
									incanupdatetags to canupdatetags
								), 
								ReloadData (share),
								ReloadData (tags),
								ReloadData (tagsasString)
							icon: %collection_16.tag
							feature: sharedetails_updatetags
							disabled:
								Not BooleanPredicate ( incanupdatetags )
							tooltip: $fragmentShareDetailsNLS.managetags
						}
					}
			}
			Text {
				value: @srv_truncatestring (share.description to string, 200 to maxlength)
				tooltip: share.description
				label: Label { break: False value: $application.description }
				compact:True
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog bwfApplicationDetailsMetadata_Dialog (
									inuid to paramApplicationUid,
									share.sensitivityreason to sensitivityreason, 
									share.description to description, 
									share.category to category,
									share.applicationtype to applicationtype
								),
								ReloadData (share)
							icon: %collection_16.pencil
							disabled:
								Not BooleanPredicate ( incanupdatedescription )
							feature: sharedetails_updatemetadata
							tooltip: $fragmentShareDetailsNLS.updatemetadata
						}
					}
			}
		}
	}
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 200 }
		GridRow {
			GridCell {
				Group {
					title:$fragmentShareDetailsNLS.kpis
					Text {
						value:share.bwa_applicationanalytics_nbaccount
						label:$search.application.nbaccounts
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbaccount using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbaccount using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbaccount, prevshare.bwa_applicationanalytics_nbaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:share.bwa_applicationanalytics_nbidentity
						label:$search.application.nbidentities
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbidentity using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbidentity using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbidentity, prevshare.bwa_applicationanalytics_nbidentity)) using bwf_trend
								width:16
							}
						}
					}
					
					Text {
						value:Transform share.bwa_applicationanalytics_nbmanagedfolder using bwf_defaultsTo0
						label:$search.share.nbmanagedfolder_compact
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(share.bwa_applicationanalytics_nbmanagedfolder) { when >0 then False otherwise True }
							IntPredicate(prevshare.bwa_applicationanalytics_nbmanagedfolder) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbmanagedfolder using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbmanagedfolder using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbmanagedfolder, prevshare.bwa_applicationanalytics_nbmanagedfolder)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:share.bwa_applicationanalytics_nbfolder
						label:$search.share.nbfolder
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform share.bwa_applicationanalytics_nbfolder using mayBeNullMapping, Transform prevshare.bwa_applicationanalytics_nbfolder using mayBeNullMapping)
						decorator:Decorator {
							width:60
							after:Image {
								image:TemplateImageSelection (Difference(share.bwa_applicationanalytics_nbfolder, prevshare.bwa_applicationanalytics_nbfolder)) using bwf_trend
								width:16
							}
						}
					}
				}
