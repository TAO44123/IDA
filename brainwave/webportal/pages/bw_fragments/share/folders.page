/**
 * <span style="white-space: pre-line">
 * Display the selected shared folders for a given share as a tree with lazy loading
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the share uid</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * </span>
 */
fragmentShareFoldersTree = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	outpermissionuid = Variable
	outpermissioncode = Variable
	outpermissionname = Variable

	tree = HierarchicalData {
		roots-view: bwf_sharerootfolders with inuid to uid
		children-view:bwf_sharechildfolders with inuid to uid
		attribute:permissionuid
		parameter:permissionparentuid
		max-level: 9
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid, 
												True to inshowaccounts,
												True to inshowacls,
												True to inshowperjob,
												True to inshowperorg,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	Tree {
		data:tree
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		double-click:ExecuteNamedAction goDetails
		persist-configuration:True
		expand-level:1
		
		
		Column {
			column:permissiondisplayname
			header:$fragmentFolderNLS.displayname
			selection:outpermissionname
			width:100%
			sortable:True
			filterable:True
			
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}
		Column {
			column:permissioncode
			header:$fragmentFolderNLS.code
			selection:outpermissioncode
			width:100%
			sortable:True
			filterable:True
			initially-masked:True
			
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}
		Column {
			column:permissionpermissiontype
			header:$fragmentFolderNLS.type
			width:140px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:permissiondescription
			header:$fragmentFolderNLS.description
			width:260px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:permissionsensitivitylevel
			header:$fragmentFolderNLS.sensitivitylevel
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}

		Column {
			header:$fragmentFolderNLS.fsnbread
			column:permissionfsnbread
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.fsnbwrite
			column:permissionfsnbwrite
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.fsnbcontrol
			column:permissionfsnbcontrol
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.inherited
			column:permissioninherited
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.lastaccessdate
			column:permissionlastaccessdate
			width:128px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.lastmodifydate
			column:permissionlastmodifydate
			width:128px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.numberoffiles
			column:permissionnumberoffiles
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			header:$fragmentFolderNLS.totalsize
			column:permissiontotalsize
			width:96px
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:nbaccounts
			header:$fragmentShareFoldersNLS.nbaccount
			sortable:True
			filterable:True
		}
		Column {
			column:permissionuid
			hidden:True
			selection:outpermissionuid
		}
	}
}


fragmentShareFoldersSelectionNLS =NLS {
	direct [en "Folders list" fr "Liste des répertoires"]
	hierarchy [en "Folders hierarchy" fr "hiérarchie des répertoires"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected shared folders for a given share in various forms
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the share uid</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incancompare </b>optional, boolean value, true to enable comparison button (false by default)</li>
 * <li><b>infolderdepth </b>optional, integer value, folder depth (1 by default)</li>
 * <li><b>inaclonly </b>optional, boolean value, show only entries with ACLs attached to them (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outpermissionuid</b>, selected permission uid</li>
 * <li><b>outpermissioncode</b>, selected permission code</li>
 * <li><b>outpermissionname</b>, selected permission name</li>
 * </ul>
 * </span>
 */
fragmentShareFoldersSelection = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	incancompare = Variable { type:Boolean initial:False }

	infolderdepth = Variable { multivalued:False type:Integer initial:1 }
	inaclonly = Variable { multivalued:False type:Boolean initial:False }

	outpermissionuid = Variable
	outpermissioncode = Variable
	outpermissionname = Variable

	selection = Variable { private:True }

	Combo {
		variable:selection
		layout: Layout { hint: width 300 }
		options:Static {
			Option { value:"list" text:$fragmentShareFoldersSelectionNLS.direct }
			Option { value:"hierarchy" text:$fragmentShareFoldersSelectionNLS.hierarchy }
		}
	}

	ConditionalGroup {
		StringCondition(selection) {
			when "list" then [
				IncludeFragment (fragmentShareFolders with 	value-of inuid to inuid, 
																		value-of incanshowdetails to incanshowdetails,
																		value-of infolderdepth to infolderdepth,
																		value-of inaclonly to inaclonly,
																		value-of incancompare to incancompare,
																	outpermissionuid binds-to outpermissionuid, 
																	outpermissioncode binds-to outpermissioncode,
																	outpermissionname binds-to outpermissionname,
																	value-of Eval "inenabled.get()&&selection.get().equals('list')" to inenabled
																	) 
			]	
			when "hierarchy" then [
				IncludeFragment (fragmentShareFoldersTree with value-of inuid to inuid, 
																		value-of incanshowdetails to incanshowdetails,
																	outpermissionuid binds-to outpermissionuid, 
																	outpermissioncode binds-to outpermissioncode,
																	outpermissionname binds-to outpermissionname,
																	value-of Eval "inenabled.get()&&selection.get().equals('hierarchy')" to inenabled
																	) 
			]	
		}
	}	
}