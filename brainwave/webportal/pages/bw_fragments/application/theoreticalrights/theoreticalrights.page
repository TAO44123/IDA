/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"

fragmentApplicationTheoreticalRightsNLS = NLS {
	nbidentity [en "Nb identities" fr "Nb identités"]
	trends [en "Changes" fr "Changements"]
	showdetails [en "Show selected right account list" fr "Afficher la liste des comptes pour la permission sélectionnée"]
	subtitle [en '{1} ({0}) identities' fr 'Identités disposant de {1} ({0})']
}

/**
 * <span style="white-space: pre-line">
 * Display theoretical rights for a given application (perms + identities)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outidentityuid </b>the selected identityu</li>
 * <li><b>outidentityname </b>the selected identity name</li>
 * <li><b>outpermissionuid </b>the selected permission</li>
 * <li><b>outpermissionname </b>the selected permission name</li>
 * <li><b>outapplicationname </b>the selected application name</li>
 * <li><b>outrolename </b>the selected role</li>
 * </ul>
 * </span>
 */
 
fragmentApplicationTheoreticalRightsList = PageFragment {
	feature:iam_license
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable { type: String }
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	outidentityuid = Variable
	outidentityname = Variable
	outpermissionuid = Variable
	outpermissionname = Variable
	outapplicationname = Variable
	outrolename = Variable
	
	/* Dataset here */
	innerdata = Dataset {
		view: bwf_applicationtheoreticalrights with inuid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	hasoverallocation = Dataset {
		view: bwf_applicationoverallocationsperms with inuid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	data = Dataset {
		join: Join {
			primary-dataset:innerdata
			secondary-dataset:hasoverallocation
			primary-column:perm_uid
			secondary-column:perm_uid
			primary-optional:False
			secondary-prefix:over_
			secondary-cardinality:optional
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid, 
												True to inshowtheoretical,
												False to inshowaccounts,
												True to inshowoverallocated
												)
			]
			when False then [
			
			]
		}
	)
	
	ConditionalGroup {
		IntCondition ( Count data ) {
			when < 1 then [
				Text {
					value: $bwf_theoreticalrightsNLS.noTR
					compact: True
				}
			] otherwise [
				Group {
					// title: $bwf_theoreticalrightsNLS.TR
					Table {
						data: data
						layout: Layout { grab: horizontal True vertical True }
						configurable: True
						show-count: True
						show-filter: True
						persist-configuration:True
						double-click:ExecuteNamedAction goDetails
						
						
						Column {
							column:perm_uid
							hidden:True
							selection:outpermissionuid
						}
						Column {
							column: over_hasoverallocations
							text:''
							header: ''
							width: 28px
							sortable: True
							image:TemplateImageSelection(Current over_hasoverallocations) using bwf_warning
						}
						Column {
							column: perm_code
							initially-masked: False
							header: $ppermission.code
							width: 100%
							sortable: True
							filterable: True
							actions: ExecuteNamedAction goDetails
							actions-disabled: Not BooleanPredicate(incanshowdetails)
							tooltip: $search_page.showdetails
						}
						Column {
							column: perm_displayname
							selection: outpermissionname
							initially-masked: False
							header: $ppermission.displayname
							width: 100%
							sortable: True
							filterable: True
							actions: ExecuteNamedAction goDetails
							actions-disabled: Not BooleanPredicate(incanshowdetails)
							tooltip: $search_page.showdetails
						}
						Column {
							column: perm_permissiontype
							initially-masked: True
							header: $ppermission.permissiontype
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: role
							selection: outrolename
							initially-masked: False
							header: $bwf_theoreticalrightsNLS.role
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: comment
							initially-masked: True
							header: $bwf_theoreticalrightsNLS.comment
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: uid
							hidden:True
							selection:outidentityuid
						}
						Column {
							column: hrcode
							initially-masked: False
							header: $identity.hrcode
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: fullname
							initially-masked: False
							header: $identity.fullname
							width: 100%
							sortable: True
							filterable: True
							selection:outidentityname
						}
						Column {
							column: mail
							initially-masked: True
							header: $identity.mail
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: internal
							initially-masked: True
							header: $identity.internal
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: jobtitledisplayname
							initially-masked: True
							header: $identity.jobtitledisplayname
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: org_shortname
							initially-masked: True
							header: $porganisation.shortname
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: org_displayname
							initially-masked: False
							header: $organisation.concept
							width: 100%
							sortable: True
							filterable: True
						}
					}
				}
			]
		}
	}
}


/**
 * Display theoretical rights for a given application: permissions with a counter (nb identities)
 * 
 * @param inuid the identity uid
 * @param inenabled optional, boolean value, true to enable fragment (true by default)
  * @param incanshowdetails optional, boolean value, true to enable button to show details (false by default)
 * @param outpermissioncode the selected permission
 * @param outpermissionname the selected permission
 * @param outrolename the selected role
 * @param outhastheoreticalrights true if has theoretical rights (always active)
 */
 
fragmentApplicationTheoreticalRightsMasterDetails = PageFragment {
	feature:iam_license
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable { type: String }
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inshowdetails = Variable { multivalued:False type:Boolean initial:False }

	outpermissionuid = Variable
	outpermissioncode = Variable
	outpermissionname = Variable
	
	/* Dataset here */
	master = Dataset {
		view: bwf_applicationtheoreticalrightspermswprb with inuid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid, 
												True to inshowtheoretical,
												False to inshowaccounts,
												True to inshowoverallocated
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition ( Count master ) {
			when < 1 then [
				Text {
					value: $bwf_theoreticalrightsNLS.noTR
					compact: True
				}
			] otherwise [
				Group {
					Table {
						data: master
						layout: Layout { grab: horizontal True vertical True }
						configurable: True
						show-count: True
						show-filter: True
						double-click:ExecuteNamedAction goDetails
						persist-configuration:True
						
						
						Column {
							column: perm_uid
							hidden:True
							selection:outpermissionuid
						}
						Column {
							column: over_hasoverallocations
							text:''
							header: ''
							width: 28px
							sortable: True
							image:TemplateImageSelection(Current over_hasoverallocations) using bwf_warning	
						}
						Column {
							column: perm_code
							selection:outpermissioncode
							initially-masked: True
							header: $permission.concept
							width: 100%
							sortable: True
							filterable: True
							actions: ExecuteNamedAction goDetails
							actions-disabled: Not BooleanPredicate(incanshowdetails)
							tooltip: $search_page.showdetails
						}
						Column {
							column: perm_displayname
							selection:outpermissionname
							initially-masked: False
							header: $ppermission.displayname
							width: 100%
							sortable: True
							filterable: True
							actions: ExecuteNamedAction goDetails
							actions-disabled: Not BooleanPredicate(incanshowdetails)
							tooltip: $search_page.showdetails
						}
						Column {
							column: perm_permissiontype
							initially-masked: True
							header: $ppermission.permissiontype
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: nbidentity
							text:Transform Current nbidentity using bwf_defaultsTo0
							align:Right
							header: $fragmentApplicationTheoreticalRightsNLS.nbidentity
							sortable: True
							filterable: True
							width: 10%
						}												
						Column {
							column: trends
							header: $bw_fragment.trends
							text:Transform Current trends using bwf_trendStatusColumn 
							styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
							image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
							tooltip:$bwf_trendStatusColumnNLS.tooltip
	
							sortable: True
							filterable: True
							width: 10%
						}												
					}
				}
			]
		}
	}
}