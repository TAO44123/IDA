bwfApplicationSensitivityLevel_NLS = NLS {
	notclassified [en "Not classified" fr "Non classifié"]
	low [en "Low" fr "Faible"]
	medium [en "Medium" fr "Moyen"]
	high [en "High" fr "Elevé"]
	extreme [en "Highest" fr "Extrême"]
}

bwfApplicationSensitivityLevelMapping = StringMapping {
	when "0" then $bwfApplicationSensitivityLevel_NLS.notclassified
	when "1" then $bwfApplicationSensitivityLevel_NLS.low
	when "2" then $bwfApplicationSensitivityLevel_NLS.medium
	when "3" then $bwfApplicationSensitivityLevel_NLS.high
	when "4" then $bwfApplicationSensitivityLevel_NLS.extreme
	otherwise $bwfApplicationSensitivityLevel_NLS.notclassified

}


