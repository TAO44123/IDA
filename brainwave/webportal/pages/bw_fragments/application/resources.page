	width:500
	height:150
 	buttons:[CancelButton OkButton {
			actions:
				Set uids to task.uids,
				TaskComplete task
			}
		]

	uids = Variable { multivalued:True }
	
	task = TaskRecord(create "bwa_bulkremoveallapplicationtag")

	Header {
		value:$fragmentApplicationTagsEditorNLS.removeallconfirmation(SizeOf uids)
	}
}

/**
 * Remove a tag from selected applications
 * 
 * @param uids application uids
 */
fragmentApplicationBulkRemoveTag = Dialog {
	title:$fragmentApplicationTagsEditorNLS.removetitle
	width:500
	height:150
 	buttons:[CancelButton OkButton {
			disabled:StringPredicate(tag) { when IsEmpty then True }
			actions:
				Set uids to task.uids,
				Set tag to task.tag,
				TaskComplete task
			}
		]

	applicationSearch = SearchDefinition {
		entity: Application
		simple-mode-rule: br_application_simple_search
	}

	uids = Variable { multivalued:True }
	tag = Variable { multivalued:False }

	task = TaskRecord(create "bwa_bulkremoveallapplicationtag")
	taglist = Dataset {
		search: Search {
			definition: applicationSearch
			view:bwa_applicationtagsfromsearch
		}
	}
	
	Combo {
		variable:tag
		allow-none:True
		label:Label { break:True value:$fragmentApplicationTagsEditorNLS.removepicker }
		options:Dynamic {
			data:taglist
			text:Current tag		
			value:Current tag		
		}
	}
}

/*
 * Bulk add a new tag for applications
 * 
 * @param uids selected applications
 */
fragmentApplicationBulkAddTag = Dialog {
	title:$fragmentApplicationTagsEditorNLS.addtitle
	width:400
	height:200
 	buttons:[CancelButton OkButton {
			disabled:
					OrPredicate {
						AndPredicate {
							Not BooleanPredicate(createtag)
							StringPredicate(existingtag) { when IsEmpty then True }
						}
						AndPredicate {
							BooleanPredicate(createtag)
							Not BooleanPredicate(valid)
						}
					}
			actions:
					Confirm $fragmentApplicationTagsEditorNLS.addconfirmation(SizeOf uids),
					BooleanCase(createtag) {
						when True then [
							Set Eval "newtag.get().toUpperCase()" to task.tag
						]
						when False then [
							Set existingtag to task.tag
						]
					},
					Set uids to task.uids,
					TaskComplete task
			}
		]

	uids = Variable

	newtag = Variable {private:True}
	existingtag = Variable {private:True}
	valid = Variable {private:True}
	createtag = Variable { type:Boolean }
		
	task = TaskRecord(create "bwa_bulkaddapplicationtag")
	alltags = Dataset {
		view:bwf_applicationalltags
	}

	Checkbox {
		variable:createtag
		text:$fragmentApplicationTagsEditorNLS.createnewtag
	}

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentApplicationTagsEditorNLS.addsyntaxerror
		validity:valid
		hidden:Not BooleanPredicate(createtag)
	}
	Combo {
		variable:existingtag
		allow-none:False
		options:Dynamic {
			data:alltags
			text:Current tag
			value:Current tag
		}
		hidden:BooleanPredicate(createtag)
	}
}

/*
 * INTERNAL dialog box used by fragmentApplicationTagsEditor
 * 
 * @param 
 */
fragmentApplicationNewTag = Dialog {
	title:$fragmentApplicationTagsEditorNLS.addtitle
	width:400
	height:150
	enter-event:Set Join alltags using "|" to alltagsoneline
 	buttons:[CancelButton OkButton {
			disabled:
				OrPredicate {
					Not BooleanPredicate(valid)
					BooleanPredicate(Eval "alltags.indexOf(newtag.get().toUpperCase())!=-1")
				}
			actions:
				TransferData tags(tag) to (tags),
				MultivaluedAdd Eval "newtag.get().toUpperCase()" to tags,
				 Set tags to task.tags,
					Set uid to task.uid,
					TaskComplete task wait-end,
					Flash $fragmentApplicationTagsEditorNLS.flash
			}
		]

	uid = Variable
	alltags = Variable { multivalued:True }
	newtag = Variable

	alltagsoneline = Variable { multivalued:False private:True }
	valid = Variable { private:True }
	tags = Variable { multivalued:True private:True }

	tags = Dataset {
		view:bwf_applicationtags with uid to uid
	}
	
	task = TaskRecord(create "bwa_updateapplicationtags")

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentApplicationTagsEditorNLS.addsyntaxerror
		validity:valid
	}	
}

/**
 * Edit application tags
 *
 * @param uid application uid
 * @param canupdatetags True to enable tags update (false by default)
 */
fragmentApplicationTagsEditor = Dialog {
	title:$fragmentApplicationTagsEditorNLS.title
	buttons:[	CancelButton 
				OkButton {
					disabled:Not BooleanPredicate(canupdatetags)
					actions:
							BooleanCase(added) {
								when True then [
								]
								when False then [
									Set currenttags to task.tags,
									Set uid to task.uid,
									TaskComplete task wait-end,
									Flash $fragmentApplicationTagsEditorNLS.flash
								]
							}
				} 
			]
	width:450
	height:200
	enter-event:TransferData tags(tag) to (currenttags), TransferData alltags(tag) to (alltags) 
	
	uid = Variable
	canupdatetags = Variable { type:Boolean initial:False }

	currenttags = Variable { multivalued:True private:True }
	alltags = Variable { multivalued:True private:True }
	newtag = Variable {private:True }
	modified = Variable {private:True }
	added = Variable {private:True }
	
	tags = Dataset {
		view:bwf_applicationtags with uid to uid
	}
	alltags = Dataset {
		view:bwf_applicationalltags
	}
	
	atags = Dataset {
		columns:alltags as tag
	}

	task = TaskRecord(create "bwa_updateapplicationtags")

	Combo {
		variable:currenttags
		multi-selection:True
		disabled:Not BooleanPredicate(canupdatetags)
		options:Dynamic {
			data:atags
			text:Current tag
			value:Current tag
		}
		commands:Commands {
			position:After
			orientation:Vertical
			Command {
				actions:Set True to added,
						Dialog fragmentApplicationNewTag(uid to uid, alltags to alltags, newtag from newtag), 
						CloseDialog Ok
				icon:%status_16.add
				disabled:Not BooleanPredicate(canupdatetags)
				tooltip:$fragmentApplicationTagsEditorNLS.newtag
			}
			Command {
				actions:Message "NOP"
				disabled:True
				icon:''
			}
		}
	}	
}


