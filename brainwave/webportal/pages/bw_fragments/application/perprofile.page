/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_htmlwidgets/charts.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"

fragmentApplicationPerProfileNLS = NLS {
	perorg [en "permissions" fr "permissions"]
	tooltip [en "{0} accounts with this permission,\n{1} accounts in total with the application\n(limited to 20 entries)" fr "{0} personnes avec cette permission\nsur un total de {1} personnes qui disposent de cette application\n(limité à 20 entrées)"]

	top20 [en "Top 30" fr "Top 30"]

	axe_nbpeople [en "Accounts with the permission" fr "Comptes avec la permission"]
	axe_jobs [en "Permissions" fr "Permissions"] 

	trends [en "Changes" fr "Changements"]
}

/**
  * <span style="white-space: pre-line">
 * Display for a given application the number of people per permission (Role by default) as a dataviz (top 20)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inPermissionType </b>the permission types (Role by default)</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate details</li>
 * </ul>
 * </span>
 */
fragmentApplicationPerProfile = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inPermissionType = Variable {multivalued:True}
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	perprofile = Dataset {
		view: bwf_applicationnbidentityperprofiles with
			inuid to uid,
			inPermissionType to permissiontype unless-empty, total.nbtotal to total
		limit:30
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				IntPredicate(total.nbtotal) {
					when >0 then False
					otherwise True
				}
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	total = Record {
		view: bwf_applicationnbtotalaccounts with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	Header {
		value:$fragmentApplicationPerProfileNLS.perorg
		styling:bigTitleStyle
		tooltip:$fragmentApplicationPerProfileNLS.top20
	}
	IncludeHTMLWidget {
		layout: Layout { grab:horizontal True vertical True }
		template: barChart
		datasets: perprofile (permissiondisplayname, permissionuid, nbaccounts, label ) to chartdata ( label, code , count , description)
		bindings: 
			value-of $fragmentApplicationPerProfileNLS.axe_nbpeople to xlabel,
			value-of $fragmentApplicationPerProfileNLS.axe_jobs to ylabel,
			value-of True to showxAxesGrid,
			value-of True to showyAxesGrid,
			value-of True to isHorizontal,
			value-of True to isLabelInside,
			value-of True to beginAtZero,
			value-of False to maintainAspectRatio,
			value-of Constant shadesofbluePalette to customColors
		widget-events: {
			when onclick then [
				BooleanCase(incanshowdetails) {
					when True then [
						Dialog fragmentApplicationPerProfileDetailDialog(inuid to inapplicationuid, Current code to inpermissionuid)
					]
					when False then [
					]
				}
			]
		}
	}
	/*
	Text {
		iterate-on:perprofile
		value:Current permissiondisplayname
		layout:Layout{grab:horizontal True vertical True}
		compact:True
		decorator:Decorator{width:200 after:Bar{max-value:total.nbtotal value:Current nbaccounts width:200 higher-is-better:True tooltip:$fragmentApplicationPerProfileNLS.tooltip(Current nbaccounts,total.nbtotal) }  }
		label:Label{ break:True }
	}
	*/
}

fragmentApplicationPerProfileDetailDialog = Dialog {
	title:"Details"
	width:1366
	height:600
	buttons:OkButton

	inapplicationuid = Variable
	inpermissionuid = Variable

	selectedaccount = Variable

	perprofile = Dataset {
		view: bwf_accountperprofile with inpermissionuid to permissionuid
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
	}

	showDetails = NamedAction (
		Dialog bwf_accountDetailsDialog(selectedaccount to inuid, True to inshowapplications, inapplicationuid to inapplicationuids)
	)

	Table {
		data:perprofile
		layout:Layout { grab:horizontal True vertical True }
		show-filter:True
		show-count:True
		configurable:True
		
		Column {
			column:uid
			selection:selectedaccount
			hidden:True
		}
		
		Column {
			column:identifier
			tooltip:Current identifier
			header:$account.identifier
			sortable:True
			filterable:True
			initially-masked:True
			actions:ExecuteNamedAction showDetails
		}
		Column {
			column:login
			header:$account.login
			sortable:True
			filterable:True
			actions:ExecuteNamedAction showDetails
		}
		Column {
			column:username
			tooltip:Current username
			header:$account.username
			sortable:True
			filterable:True
			actions:ExecuteNamedAction showDetails
		}
		Column {
			column:lastlogindate
			header:$account.lastlogindate
			sortable:True
			filterable:True
		}
		Column {
			column:repositorydisplayname
			header:$repository.concept
			sortable:True
			filterable:True
		}
		
		Column {
			column:identityhrcode
			header:$identity.hrcode
			sortable:True
			filterable:True
			actions:ExecuteNamedAction showDetails
		}

		Column {
			column:identityfullname
			tooltip:Current identityfullname
			header:$identity.fullname
			sortable:True
			filterable:True
			width:100%
			actions:ExecuteNamedAction showDetails
		}

		Column {
			column:identityinternal
			text:Transform Current identityinternal using booleanDisplayMapping
			header:$identity.internal
			sortable:True
			filterable:True
		}


		Column {
			column:identitymail
			header:$identity.mail
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:jobtitledisplayname
			tooltip:Current jobtitledisplayname
			header:$identity.jobtitledisplayname
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:organisationshortname
			tooltip:Current organisationshortname
			header:$porganisation.shortname
			initially-masked:True
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:organisationdisplayname
			tooltip:Current organisationdisplayname
			header:$organisation.concept
			sortable:True
			filterable:True
			width:100%
		}

		Column {
			column:organisationorganisationtypedisplayname
			header:$organisation.organisationtypedisplayname
			initially-masked:True
			sortable:True
			filterable:True
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}												
	}
}

