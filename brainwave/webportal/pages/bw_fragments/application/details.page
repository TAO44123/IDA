/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/application/resources.page"
import "/webportal/pages/bw_fragments/cmdbci/details/cmdbciDetails.page"

fragmentApplicationDetailsNLS = NLS {
	family [en "Family" fr "Famille"]
	category [en "Category" fr "Catégorie"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	nbaccounts [en "Number of active accounts" fr "Nombre de comptes actifs"]
	nbidentities [en "Number of identities" fr "Nombre d'identités"]
	nbprofiles [en "Number of profiles" fr "Nombre de profils"]
	expertise [en "Expertise" fr "Responsabilité"]
	managers [en "Managers" fr "Responsables"]
	updatemetadata [en "Update application description" fr "Mise à jour de la description de l'application"]
	addowner [en "Add a new application owner" fr "Ajout d'un nouveau responsable d'application"]
//	deleteowner [en "Delete selected application owner" fr "Suppression du responsable d'application sélectionné"]
	deleteowner [en "Delete selected application owner" fr "Suppression du responsable de l'application"]
	auditowner [en "Application owner updates audit trail" fr "Piste d'audit des changements de reponsable de l'application"]
	nomanagers [en "No manager set" fr "Pas de responsable configuré"]
	kpis [en "KPIs" fr "KPIs"]
	classification [en "Classification" fr "Classification"]

	managetags [en "Manage tags" fr "Gérer les labels"]

	cmdbDetailsTooltip [en "Show CMDB CI detail" fr "Afficher le détail de l'élement CMDB"]
	cmdbfield [en "Associated CMDB CI" fr "Elément CMDB associé"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected application details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update application description (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentApplicationDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	
	application = Record {
		view: bwf_applicationDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevapplication = Record {
		view: bwf_applicationDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}
	managers = Dataset {
		view: bwf_applicationmanagers with inuid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	currentManager = Record {
		view: bwf_applicationmanagers with selectedManager to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	} 
	applicationcis = Record {
		view: bwf_applicationcis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// compact
	Text {
		label:$application.code
		value:application.code
		hidden:SameValuePredicate(application.code, application.displayname)
		compact:True
	}
	Text {
		label:$application.displayname
		value:application.displayname
		compact:True
	}
	Text {
		value: @srv_truncatestring (application.description to string, 200 to maxlength)
		tooltip:application.description
		label:$application.description
		lines:3
		compact:True
		layout: Layout{hint:height 48}
		hidden:StringPredicate(application.description) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentApplicationDetailsNLS.classification
	}
	Separator {
		width:1
	}

	Text {
		value:application.applicationfamily
		label:$fragmentApplicationDetailsNLS.family
		hidden:StringPredicate(application.applicationfamily) { when IsEmpty then True }
		compact:True
	}
	Text {
		value:application.category
		label:$fragmentApplicationDetailsNLS.category
		compact:True
	}
	Text {
		value:Transform application.sensitivitylevel using bwfApplicationSensitivityLevelMapping
		label:$fragmentApplicationDetailsNLS.sensitivitylevel
		compact:True
	}
	Text {
		value:application.sensitivityreason
		label:$fragmentApplicationDetailsNLS.sensitivityreason
		compact:True
	}
	Text {
		value:applicationcis.label
		compact:True
		label:$fragmentApplicationDetailsNLS.cmdbfield
		hidden:StringPredicate(applicationcis.ci_uid) { when IsEmpty then True otherwise False }
	}


	Header {
		value:$fragmentApplicationDetailsNLS.kpis
	}
	Separator {
		width:1
	}
	Text {
		value:Transform application.bwa_applicationanalytics_nbaccount using bwf_defaultsTo0
		label:$search.application.nbaccounts
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbaccount using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbaccount using mayBeNullMapping)
		decorator:Decorator {
			width:100
			after:Image {
				image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbaccount, prevapplication.bwa_applicationanalytics_nbaccount)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform application.bwa_applicationanalytics_nbidentity using bwf_defaultsTo0
		label:$search.application.nbidentities
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbidentity using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbidentity using mayBeNullMapping)
		decorator:Decorator {
			width:100
			after:Image {
				image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbidentity, prevapplication.bwa_applicationanalytics_nbidentity)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform application.bwa_applicationanalytics_nbprofile using bwf_defaultsTo0
		label:$search.application.nbprofile
		compact:True
		align:Right
		tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbprofile using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbprofile using mayBeNullMapping)
		decorator:Decorator {
			width:100
			after:Image {
				image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbprofile, prevapplication.bwa_applicationanalytics_nbprofile)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform application.bwa_applicationanalytics_nbpermission using bwf_defaultsTo0
		label:$search.application.nbpermission
		compact:True
		align:Right
		hidden:SameValuePredicate(application.bwa_applicationanalytics_nbprofile, application.bwa_applicationanalytics_nbpermission)
		tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbpermission using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbpermission using mayBeNullMapping)
		decorator:Decorator {
			width:100
			after:Image {
				image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbpermission, prevapplication.bwa_applicationanalytics_nbpermission)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:Transform application.bwa_applicationanalytics_nbperimeter using bwf_defaultsTo0
		label:$search.application.nbperimeter
		compact:True
		align:Right
		hidden:	AndPredicate {
			IntPredicate(application.bwa_applicationanalytics_nbperimeter) { when >0 then False otherwise True }
			IntPredicate(prevapplication.bwa_applicationanalytics_nbperimeter) { when >0 then False otherwise True }
		}	
		tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbperimeter using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbperimeter using mayBeNullMapping)
		decorator:Decorator {
			width:100
			after:Image {
				image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbperimeter, prevapplication.bwa_applicationanalytics_nbperimeter)) using bwf_trend
				width:16
			}
		}
	}


	Header {
		value:$fragmentApplicationDetailsNLS.managers
	}
	Separator {
		width:1
	}

	ConditionalGroup {
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$fragmentApplicationDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfApplicationDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramApplicationUid),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdateowners)
	                        	feature:applicationdetails_updatemanager
	                        	tooltip:$fragmentApplicationDetailsNLS.addowner
	                       }
					}
				}
			]
			otherwise [

				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical False hint:height 116 }
					label:Label { break:True }
					configurable:True
					commands:Commands { position: After orientation: Vertical
									Command{	
											actions:Dialog bwfApplicationDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerType, 
																										inuid to paramApplicationUid),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:Not BooleanPredicate(incanupdateowners)
				                        	feature:applicationdetails_updatemanager
				                        	tooltip:$fragmentApplicationDetailsNLS.addowner
				                       }
									Command{	
											actions:Dialog bwfApplicationDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode,
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramApplicationUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdateowners)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:applicationdetails_updatemanager 
				                        	tooltip:$fragmentApplicationDetailsNLS.deleteowner
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Application" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdateowners)
				                        	feature:applicationdetails_updatemanager 
				                        	tooltip:$fragmentApplicationDetailsNLS.auditowner
				                       }
				                  }
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column: ManagerLinkRecorduid
						hidden: True 
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
			
			
					Column {
						column:comment
						header:$bwfManagement.comment
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
				}
			]
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the selected application details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the application uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update application description (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentApplicationFullDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	
	application = Record {
		view: bwf_applicationDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevapplication = Record {
		view: bwf_applicationDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}
	managers = Dataset {
		view: bwf_applicationmanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	currentManager = Record {
		view: bwf_applicationmanagers with selectedManager to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	} 

	applicationcis = Record {
		view: bwf_applicationcis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	tags = Dataset {
		view: bwf_applicationtags with inuid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tagsasString = Record {
  		 view: bwa_applicationtagsasastring with inuid to uid
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// standard
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		// Application card
		Group {
			Text {
				value: application.displayname
				styling: bigTitleStyle
				compact: True
				label: Label { break: False value: $application.displayname }
				layout: Layout { grab: horizontal True vertical False }
			}
			Text {
				value:application.code
				label: Label { break: False value: $application.code }
				compact: True
				hidden:
					SameValuePredicate ( application.code, application.displayname )
				layout: Layout { grab:horizontal True vertical False }
			}
			Text {
				value: @srv_truncatestring (tagsasString.tag to string, 300 to maxlength)
				tooltip: tagsasString.tag
				label:Label { break: False value: $application.tags }
				compact: True
				layout: Layout { grab:horizontal True vertical False }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog fragmentApplicationTagsEditor (
									inuid to uid,
									incanupdatetags to canupdatetags
								), 
								ReloadData (application),
								ReloadData (tags),
								ReloadData (tagsasString)
							icon: %collection_16.tag
							feature: applicationdetails_updatetags
							disabled:
								Not BooleanPredicate ( incanupdatetags )
							tooltip: $fragmentApplicationDetailsNLS.managetags
						}
					}
			}
			Text {
				value: @srv_truncatestring (application.description to string, 200 to maxlength)
				tooltip:application.description
				label: Label { break: False value: $application.description }
				compact: True
				layout: Layout { grab:horizontal True vertical False }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog bwfApplicationDetailsMetadata_Dialog (
									inuid to paramApplicationUid,
									application.sensitivitylevel to sensitivitylevel, 
									application.sensitivityreason to sensitivityreason, 
									application.description to description, 
									application.category to category,
									application.applicationtype to applicationtype
								), 
								ReloadData (application)
							icon:%collection_16.pencil
							disabled:
								Not BooleanPredicate ( incanupdatedescription )
							feature: applicationdetails_updatemetadata 
							tooltip: $fragmentApplicationDetailsNLS.updatemetadata
						}
					}
			}
		}
	}
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False }
		GridRow {
			GridCell {
				Group {
					title:$fragmentApplicationDetailsNLS.kpis
					Text {
						value:Transform application.bwa_applicationanalytics_nbaccount using bwf_defaultsTo0
						label:$search.application.nbaccounts
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbaccount using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbaccount using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbaccount, prevapplication.bwa_applicationanalytics_nbaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform application.bwa_applicationanalytics_nbidentity using bwf_defaultsTo0
						label:$search.application.nbidentities
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbidentity using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbidentity using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbidentity, prevapplication.bwa_applicationanalytics_nbidentity)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform application.bwa_applicationanalytics_nbprofile using bwf_defaultsTo0
						label:$search.application.nbprofile
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbprofile using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbprofile using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbprofile, prevapplication.bwa_applicationanalytics_nbprofile)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform application.bwa_applicationanalytics_nbpermission using bwf_defaultsTo0
						label:$search.application.nbpermission
						compact:True
						align:Right
						hidden:SameValuePredicate(application.bwa_applicationanalytics_nbprofile, application.bwa_applicationanalytics_nbpermission)
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbpermission using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbpermission using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbpermission, prevapplication.bwa_applicationanalytics_nbpermission)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform application.bwa_applicationanalytics_nbperimeter using bwf_defaultsTo0
						label:$search.application.nbperimeter
						compact:True
						align:Right
						hidden:	AndPredicate {
							IntPredicate(application.bwa_applicationanalytics_nbperimeter) { when >0 then False otherwise True }
							IntPredicate(prevapplication.bwa_applicationanalytics_nbperimeter) { when >0 then False otherwise True }
						}	
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbperimeter using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbperimeter using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(application.bwa_applicationanalytics_nbperimeter, prevapplication.bwa_applicationanalytics_nbperimeter)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform application.bwa_applicationanalytics_nbbusinessactivity using bwf_defaultsTo0
						label:$search.application.nbbusinessactivity_compact
						feature:sod_license
						compact:True
						align:Right
						hidden:	AndPredicate {
							IntPredicate(application.bwa_applicationanalytics_nbbusinessactivity) { when >0 then False otherwise True }
							IntPredicate(prevapplication.bwa_applicationanalytics_nbbusinessactivity) { when >0 then False otherwise True }
						}	
						tooltip:$search.repository.ratiotooltip(Transform application.bwa_applicationanalytics_nbbusinessactivity using mayBeNullMapping, Transform prevapplication.bwa_applicationanalytics_nbbusinessactivity using mayBeNullMapping)
						decorator:Decorator {
							width:100
