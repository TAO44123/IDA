				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	// standard	
	Grid {
		columns:GridColumn { width: 160 px }, GridColumn { width:grow }
		layout:Layout { grab:horizontal True vertical False hint: height 120 }
		GridRow {
			height:120
			GridCell {
				Header {
					value:''
					styling:bigTitleStyle
					icon:%concept_48.permission
					layout:Layout{align:horizontal Beginning vertical Center grab:horizontal True vertical False}
				}
			}		
			GridCell {
				Header {
					value:permission.displayname
					styling:bigTitleStyle
					commands:Commands { position: After orientation: Horizontal 
									Command{	actions:Dialog bwfPermissionDetailsMetadata_Dialog(inuid to paramPermissionUid,
																									permission.sensitivitylevel to sensitivitylevel,
																									permission.sensitivityreason to sensitivityreason,
																									permission.description to description), 
														ReloadData (permission)
					                        	icon:%collection_16.pencil
					                        	disabled:Not BooleanPredicate(incanupdatedescription)
					                        	feature:permissiondetails_updatemetadata 
					                        	tooltip:$fragmentBusinessActivityDetailsNLS.updatemetadata
					                       }
					                  }
				}
				Header {
					value:permission.code
					hidden:SameValuePredicate(permission.code, permission.displayname)
				}
				Text {
					value:permission.description
					lines:3
					compact:True
					layout: Layout{hint:height 48}
				}
			}		
		}
	}

	Grid {
		columns:GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 220 }
		GridRow {
			GridCell {
				Group {
					title:$fragmentBusinessActivityDetailsNLS.kpis

					Text {
						value:Transform permission.bwa_permissionanalytics_nbaccount using bwf_defaultsTo0
						label:$search.permission.nbaccount
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform permission.bwa_permissionanalytics_nbaccount using mayBeNullMapping, Transform prevpermission.bwa_permissionanalytics_nbaccount using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(permission.bwa_permissionanalytics_nbaccount, prevpermission.bwa_permissionanalytics_nbaccount)) using bwf_trend
								width:16
							}
						}
					}

					Text {
						value:Transform permission.bwa_permissionanalytics_nbidentity  using bwf_defaultsTo0
						label:$search.permission.nbidentity
						compact:True
						align:Right
						tooltip:$search.repository.ratiotooltip(Transform permission.bwa_permissionanalytics_nbidentity using mayBeNullMapping, Transform prevpermission.bwa_permissionanalytics_nbidentity using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(permission.bwa_permissionanalytics_nbidentity, prevpermission.bwa_permissionanalytics_nbidentity)) using bwf_trend
								width:16
							}
						}
					}

					Text {
						value:permission.bwa_permissionanalytics_nbsubpermission
						label:$search.permission.nbsubpermission_compact
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(permission.bwa_permissionanalytics_nbsubpermission) { when >0 then False otherwise True }
							IntPredicate(prevpermission.bwa_permissionanalytics_nbsubpermission) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform permission.bwa_permissionanalytics_nbsubpermission using mayBeNullMapping, Transform prevpermission.bwa_permissionanalytics_nbsubpermission using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(permission.bwa_permissionanalytics_nbsubpermission, prevpermission.bwa_permissionanalytics_nbsubpermission)) using bwf_trend
								width:16
							}
						}
					}

					Text {
						value:permission.bwa_permissionanalytics_nbtheoretical
						label:$search.permission.nbtheoretical_compact
						feature:iam_license
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(permission.bwa_permissionanalytics_nbtheoretical) { when >0 then False otherwise True }
							IntPredicate(prevpermission.bwa_permissionanalytics_nbtheoretical) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform permission.bwa_permissionanalytics_nbtheoretical using mayBeNullMapping, Transform prevpermission.bwa_permissionanalytics_nbtheoretical using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(permission.bwa_permissionanalytics_nbtheoretical, prevpermission.bwa_permissionanalytics_nbtheoretical)) using bwf_trend
								width:16
							}
						}
					}

					Text {
						value:permission.bwa_permissionanalytics_nbusage
						label:$search.permission.nbusage
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(permission.bwa_permissionanalytics_nbusage) { when >0 then False otherwise True }
							IntPredicate(prevpermission.bwa_permissionanalytics_nbusage) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform permission.bwa_permissionanalytics_nbusage using mayBeNullMapping, Transform prevpermission.bwa_permissionanalytics_nbusage using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(permission.bwa_permissionanalytics_nbusage, prevpermission.bwa_permissionanalytics_nbusage)) using bwf_trend
								width:16
							}
						}
					}
				}
			}
			GridCell {
				Group {
					title:$fragmentBusinessActivityDetailsNLS.classification

					Text {
						value:permission.application_displayname
						label:$application.concept
						compact:True
						commands: Command {   
							actions:Dialog bwf_applicationDetailsDialog (permission.application_uid to inuid,
																		True to inshowperorg,
																		True to inshowperjob
											)
							icon:%browsing_16.zoom
						}
					}
					Text {
						value:Transform permission.sensitivitylevel using bwfPermissionSensitivityLevelMapping
						label:$fragmentBusinessActivityDetailsNLS.sensitivitylevel
						compact:True
					}
					Text {
						value:permission.sensitivityreason
						label:$fragmentBusinessActivityDetailsNLS.sensitivityreason
						compact:True
					}
				}
			}
		}
	}
	
	Group {
		title:$fragmentBusinessActivityDetailsNLS.managers
		layout:Layout { grab:horizontal True vertical False hint: height 100 }

		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$fragmentBusinessActivityDetailsNLS.nomanagers			
						commands: Commands {
							position: After orientation: Vertical
							Command{	
								actions:Dialog bwfPermissionDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramPermissionUid),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdateowners)
		                        	feature:permissiondetails_updatemanager
		                        	tooltip:$fragmentBusinessActivityDetailsNLS.addowner
		                       }
						}
					}
				]
				otherwise [
					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical False hint:height 90 }
						configurable:True
						commands:Commands { position: After orientation: Vertical
										Command{	
												actions:Dialog bwfPermissionDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerType, 
																											inuid to paramPermissionUid),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:Not BooleanPredicate(incanupdateowners)
					                        	feature:permissiondetails_updatemanager
					                        	tooltip:$fragmentBusinessActivityDetailsNLS.addowner
					                       }
										Command{	
												actions:Dialog bwfPermissionDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerTypeCode, 
																											selectedManagerLink to paramManagerLinkRecorduid,
																											inuid to paramPermissionUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdateowners)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:permissiondetails_updatemanager 
					                        	tooltip:$fragmentBusinessActivityDetailsNLS.deleteowner
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Permission" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdateowners)
					                        	feature:permissiondetails_updatemanager 
					                        	tooltip:$fragmentBusinessActivityDetailsNLS.auditowner
					                       }
					                  }
						
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column: managerLinkRecorduid 
							hidden: True
							selection: selectedManagerLink
						}
						Column {
							column:expertisedomaincode
							hidden:True
							selection:selectedExpertiseDomain
						}
						Column {
							column:expertisedomaindisplayname
							text:Transform Current expertisedomaincode using bwfManagerTypeMapping
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$bwfManagement.type
							sortable:True
							width:140px
						}
						Column {
							column:hrcode
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$identity.hrcode
							initially-masked:True
							sortable:True
