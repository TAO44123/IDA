/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/repository/resources.page"
import "/webportal/pages/bw_fragments/repository/details.page"
import "/webportal/pages/bw_fragments/cmdbci/details/cmdbciDetails.page"

fragmentServerDetailsNLS = NLS {
	shares [en "Shares" fr "Partages"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected server details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentServerDetails = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevrepository = Record {
		view: bwf_repositoryDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}

	repositorycis = Record {
		view: bwf_repositorycis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	managers = Dataset {
		view: bwf_repositorymanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	

	Text {
		value:repository.code
		label:$server.code
		compact:True
		hidden:SameValuePredicate(repository.code, repository.displayname)
	}
	Text {
		label:$server.displayname
		value:repository.displayname
		compact:True
	}
	Text {
		value: @srv_truncatestring (repository.description to string, 200 to maxlength)
		tooltip: repository.description
		label:$fragmentRepositoryDetailsNLS.description
		lines:3
		compact:True
		layout: Layout{hint:height 48}
		hidden:StringPredicate(repository.description) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentRepositoryDetailsNLS.classification
	}
	Separator {
		width:1
	}

	Text {
		value: Transform repository.repositoryfamily using bwfRepoFamilyType
		label:$fragmentRepositoryDetailsNLS.family
		hidden:StringPredicate(repository.repositoryfamily) { when IsEmpty then True }
		compact:True
	}
	Text {
		value:repository.category
		label:$fragmentRepositoryDetailsNLS.category
		compact:True
	}
	Text {
		value:Transform repository.sensitivitylevel using bwfRepositorySensitivityLevelMapping
		label:$fragmentRepositoryDetailsNLS.sensitivitylevel
		compact:True
	}
	Text {
		value:repository.sensitivityreason
		label:$fragmentRepositoryDetailsNLS.sensitivityreason
		compact:True
	}
	Text {
		value:repositorycis.label
		compact:True
		label:$fragmentRepositoryDetailsNLS.cmdbfield
		hidden:StringPredicate(repositorycis.ci_uid) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentRepositoryDetailsNLS.accountsgroups
	}		
	Separator {
		width:1
	}	

	Text {
		value:repository.bwa_repositoryanalytics_nbaccount
		label:$search.repository.nbaccounts
		align:Right
		compact:True
		tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbaccount using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbaccount using mayBeNullMapping)
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbaccount, prevrepository.bwa_repositoryanalytics_nbaccount)) using bwf_trend
				width:16
			}
		}
	}

	Text {
		value:repository.bwa_repositoryanalytics_nbidentity
		label:$search.repository.nbidentities
		align:Right
		compact:True
		tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbidentity using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbidentity using mayBeNullMapping)
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbidentity, prevrepository.bwa_repositoryanalytics_nbidentity)) using bwf_trend
				width:16
			}
		}
	}

	Text {
		value:repository.bwa_repositoryanalytics_nbgroup
		label:$search.repository.nbgroups
		align:Right
		compact:True
		hidden:AndPredicate {
			IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True }
			IntPredicate(prevrepository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True }
		}
		tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbgroup using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbgroup using mayBeNullMapping)
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbgroup, prevrepository.bwa_repositoryanalytics_nbgroup)) using bwf_trend
				width:16
			}
		}
	}

	Text {
		value:repository.bwa_repositoryanalytics_nbshare
		label:$search.repository.nbshares
		feature: unstructureddata_license
		align:Right
		compact:True
		hidden:AndPredicate {
			IntPredicate(repository.bwa_repositoryanalytics_nbshare) { when >0 then False otherwise True }
			IntPredicate(prevrepository.bwa_repositoryanalytics_nbshare) { when >0 then False otherwise True }
		}
		tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbshare using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbshare using mayBeNullMapping)
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbshare, prevrepository.bwa_repositoryanalytics_nbshare)) using bwf_trend
				width:16
			}
		}
	}

	Text {
		value:repository.bwa_repositoryanalytics_nbusage
		label:$search.repository.nbusage
		align:Right
		compact:True
		hidden:AndPredicate {
			IntPredicate(repository.bwa_repositoryanalytics_nbusage) { when >0 then False otherwise True }
			IntPredicate(prevrepository.bwa_repositoryanalytics_nbusage) { when >0 then False otherwise True }
		}
		tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbusage using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbusage using mayBeNullMapping)
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbusage, prevrepository.bwa_repositoryanalytics_nbusage)) using bwf_trend
				width:16
			}
		}
	}

	Header {
		value:$fragmentRepositoryDetailsNLS.managers
	}
	Separator {
		width:1
	}

	ConditionalGroup {
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$fragmentRepositoryDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfRepositoryDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramRepositoryUid),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdateowners)
	                        	feature:repositorydetails_updatemanager
	                        	tooltip:$fragmentRepositoryDetailsNLS.addowner
	                       }
					}
				}
			]
			otherwise [

				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical False hint:height 116 }
					configurable:True
					label:Label { break:True }
					commands:Commands { position: After orientation: Vertical
									Command{	
											actions:Dialog bwfRepositoryDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerType, 
																										inuid to paramRepositoryUid),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:Not BooleanPredicate(incanupdateowners)
				                        	feature:repositorydetails_updatemanager
				                        	tooltip:$fragmentRepositoryDetailsNLS.addowner
				                       }
									Command{	
											actions:Dialog bwfRepositoryDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode, 
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramRepositoryUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdateowners)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:repositorydetails_updatemanager 
				                        	tooltip:$fragmentRepositoryDetailsNLS.deleteowner
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Repository" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdateowners)
				                        	feature:repositorydetails_updatemanager 
				                        	tooltip:$fragmentRepositoryDetailsNLS.auditowner
				                       }
				                  }
					
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column: managerLinkRecorduid
						hidden: True
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
			
			
					Column {
						column:comment
						header:$bwfManagement.comment
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
				}
			]
		}
	}
}


/**
 * <span style="white-space: pre-line">
 * Display the selected server details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update application description (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentServerFullDetails = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevrepository = Record {
		view: bwf_repositoryDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}

	repositorycis = Record {
		view: bwf_repositorycis with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	serverapp = Record {
		view: bwf_serverapplication with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevserverapp = Record {
		view: bwf_serverapplication with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}

	managers = Dataset {
		view: bwf_repositorymanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	tags = Dataset {
		view: bwf_repositorytags with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tagsasString = Record {
  		 view: bwa_repositorytagsasastring with inuid to uid
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	// standard
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		// Server card
		Group {
			Text {
				value: repository.displayname
				styling: bigTitleStyle
				label: Label { break: False value: $server.displayname }
				compact: True
			}
			Text {
				value: repository.code
				compact: True
				label: Label { break: False value: $server.code }
				hidden:
					SameValuePredicate ( repository.code, repository.displayname )
			}
			Text {
				value: @srv_truncatestring (tagsasString.tag to string, 26 to maxlength)
				tooltip: tagsasString.tag
				label: Label { break: False value: $server.tags }
				compact: True
				layout: Layout { grab:horizontal True vertical False }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog fragmentRepositoryTagsEditor (
									inuid to uid,
									incanupdatetags to canupdatetags
								), 
								ReloadData (repository),
								ReloadData (tags),
								ReloadData (tagsasString)
							icon: %collection_16.tag
							feature: repositorydetails_updatetags
							disabled:
								Not BooleanPredicate ( incanupdatetags )
							tooltip: $fragmentRepositoryDetailsNLS.managetags
						}
					}
			}
			Text {
				value: @srv_truncatestring (repository.description to string, 200 to maxlength)
				tooltip: repository.description
				label: Label { break: False value: $server.description }
				compact: True
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog bwfRepositoryDetailsMetadata_Dialog (
									inuid to paramRepositoryUid,
									repository.sensitivitylevel to sensitivitylevel, 
									repository.sensitivityreason to sensitivityreason, 
									repository.description to description, 
									repository.category to category
								), 
								ReloadData (repository)
							icon: %collection_16.pencil
							disabled:
								Not BooleanPredicate ( incanupdatedescription )
							feature: repositorydetails_updatemetadata 
							tooltip: $fragmentRepositoryDetailsNLS.updatemetadata
						}
					}
			}
		}
	}
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			GridCell {
				Group {
					title:$fragmentRepositoryDetailsNLS.accountsgroups
					Text {
						value:repository.bwa_repositoryanalytics_nbaccount
						label:$search.repository.nbaccounts
						align:Right
						compact:True
						tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbaccount using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbaccount using mayBeNullMapping)
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbaccount, prevrepository.bwa_repositoryanalytics_nbaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:repository.bwa_repositoryanalytics_nbidentity
						label:$search.repository.nbidentities
						align:Right
						compact:True
						tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbidentity using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbidentity using mayBeNullMapping)
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbidentity, prevrepository.bwa_repositoryanalytics_nbidentity)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:repository.bwa_repositoryanalytics_nbgroup
						label:$search.repository.nbgroups
						align:Right
						compact:True
						hidden:AndPredicate {
							IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True }
							IntPredicate(prevrepository.bwa_repositoryanalytics_nbgroup) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbgroup using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbgroup using mayBeNullMapping)
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbgroup, prevrepository.bwa_repositoryanalytics_nbgroup)) using bwf_trend
								width:16
							}
						}
					}
				}
			}
			GridCell {
				Group {
					title:$fragmentRepositoryDetailsNLS.accessrights
					Text {
						value:Transform serverapp.bwa_applicationanalytics_nbdirectaccountright using bwf_defaultsTo0
						label:$search.application.nbdirectaccountright_compact
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(serverapp.bwa_applicationanalytics_nbdirectaccountright) { when >0 then False otherwise True }
							IntPredicate(prevserverapp.bwa_applicationanalytics_nbdirectaccountright) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform serverapp.bwa_applicationanalytics_nbdirectaccountright using mayBeNullMapping, Transform serverapp.bwa_applicationanalytics_nbdirectaccountright using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(serverapp.bwa_applicationanalytics_nbdirectaccountright, serverapp.bwa_applicationanalytics_nbdirectaccountright)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:Transform serverapp.bwa_applicationanalytics_nbdirectidentityright using bwf_defaultsTo0
						label:$search.application.nbdirectidentityright_compact
						compact:True
						align:Right
						hidden:AndPredicate {
							IntPredicate(serverapp.bwa_applicationanalytics_nbdirectidentityright) { when >0 then False otherwise True }
							IntPredicate(prevserverapp.bwa_applicationanalytics_nbdirectidentityright) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform serverapp.bwa_applicationanalytics_nbdirectidentityright using mayBeNullMapping, Transform serverapp.bwa_applicationanalytics_nbdirectidentityright using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(serverapp.bwa_applicationanalytics_nbdirectidentityright, serverapp.bwa_applicationanalytics_nbdirectidentityright)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:repository.bwa_repositoryanalytics_nbshare
						label:$search.server.nbshares
						feature: unstructureddata_license
						align:Right
						compact:True
						hidden:AndPredicate {
							IntPredicate(repository.bwa_repositoryanalytics_nbshare) { when >0 then False otherwise True }
							IntPredicate(prevrepository.bwa_repositoryanalytics_nbshare) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbshare using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbshare using mayBeNullMapping)
						decorator:Decorator {
							width:100
							after:Image {
								image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbshare, prevrepository.bwa_repositoryanalytics_nbshare)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:repository.bwa_repositoryanalytics_nbusage
						label:$search.repository.nbusage
						align:Right
						compact:True
						hidden:AndPredicate {
							IntPredicate(repository.bwa_repositoryanalytics_nbusage) { when >0 then False otherwise True }
							IntPredicate(prevrepository.bwa_repositoryanalytics_nbusage) { when >0 then False otherwise True }
						}
						tooltip:$search.repository.ratiotooltip(Transform repository.bwa_repositoryanalytics_nbusage using mayBeNullMapping, Transform prevrepository.bwa_repositoryanalytics_nbusage using mayBeNullMapping)
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(repository.bwa_repositoryanalytics_nbusage, prevrepository.bwa_repositoryanalytics_nbusage)) using bwf_trend
								width:16
							}
						}
					}
				}
			}
			GridCell {
				Group {
					title:$fragmentRepositoryDetailsNLS.classification
					Text {
						value:Transform repository.repositoryfamily using bwfRepoFamilyType
						label:$fragmentRepositoryDetailsNLS.family
						compact:True
						hidden:StringPredicate(repository.repositoryfamily) { when IsEmpty then True otherwise False }
					}
					Text {
						value:repository.category
						label:$fragmentRepositoryDetailsNLS.category
						compact:True
					}
					Text {
						value:Transform repository.sensitivitylevel using bwfRepositorySensitivityLevelMapping
						label:$fragmentRepositoryDetailsNLS.sensitivitylevel
						compact:True
					}
					Text {
						value:repository.sensitivityreason
						label:$fragmentRepositoryDetailsNLS.sensitivityreason
						compact:True
					}
					Text {
						value:repositorycis.label
						compact:True
						label:$fragmentRepositoryDetailsNLS.cmdbfield
						hidden:StringPredicate(repositorycis.ci_uid) { when IsEmpty then True otherwise False }
						commands: 
							Commands {
							position:Before
							presentation:Icon
							orientation:Vertical
							Command {   
								actions:Dialog bwf_cmdbciDetailsDialog (repositorycis.ci_uid to inuid,
																			True to inshowtopdown,
																			True to inshowbottomup
												)
								icon:%browsing_16.zoom
								tooltip:$fragmentRepositoryDetailsNLS.cmdbDetailsTooltip
							}
						}
					}
				}
			}
		}
	}
	Group {
		title:$fragmentRepositoryDetailsNLS.managers
		layout:Layout { grab:horizontal True vertical False }
		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$fragmentRepositoryDetailsNLS.nomanagers
						commands: Commands {
							position: After orientation: Vertical
							Command{	
									actions:Dialog bwfRepositoryDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																								selectedExpertiseDomain to paramManagerType, 
																								inuid to paramRepositoryUid),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdateowners)
		                        	feature:repositorydetails_updatemanager
		                        	tooltip:$fragmentRepositoryDetailsNLS.addowner
		                       }
						}
					}
				]
				otherwise [

					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical False hint:height 116 }
						configurable:True
						label:Label { break:True }
						commands:Commands { position: After orientation: Vertical
										Command{	
												actions:Dialog bwfRepositoryDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerType, 
																											inuid to paramRepositoryUid),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:Not BooleanPredicate(incanupdateowners)
					                        	feature:repositorydetails_updatemanager
					                        	tooltip:$fragmentRepositoryDetailsNLS.addowner
					                       }
										Command{	
												actions:Dialog bwfRepositoryDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerTypeCode, 
																											selectedManagerLink to paramManagerLinkRecorduid,
																											inuid to paramRepositoryUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdateowners)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:repositorydetails_updatemanager 
					                        	tooltip:$fragmentRepositoryDetailsNLS.deleteowner
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Repository" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdateowners)
					                        	feature:repositorydetails_updatemanager 
					                        	tooltip:$fragmentRepositoryDetailsNLS.auditowner
					                       }
					                  }
						
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column: managerLinkRecorduid
							hidden: True
							selection: selectedManagerLink
						}
						Column {
							column:expertisedomaincode
							hidden:True
							selection:selectedExpertiseDomain
						}
						Column {
							column:expertisedomaindisplayname
							text:Transform Current expertisedomaincode using bwfManagerTypeMapping
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$bwfManagement.type
							sortable:True
							width:140px
						}
						Column {
							column:hrcode
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$identity.hrcode
							initially-masked:True
							sortable:True
						}
						Column {
							column:fullname
							header:$identity.fullname
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							sortable:True
							width:100%
						}
						Column {
							column:internal
							header:$pidentity.internal
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:active
							header:$pidentity.active
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
				
				
						Column {
							column:comment
							header:$bwfManagement.comment
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegation
							header:$bwfManagement.delegated
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegationreason
							header:$bwfManagement.^reason
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:_priority
							header:$bwfManagement.^priority
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:startdate
							header:$bwfManagement.startdate
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:enddate
							header:$bwfManagement.enddate
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
					}
				]
			}
		}
	}

	Spacer {
		height:Fill
	}
}
