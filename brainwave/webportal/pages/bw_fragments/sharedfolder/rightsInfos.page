bwf_SharedFolderRightsInfosDialogNLS = NLS {
	title [en "Access rights memento" fr "Memento du droit d'accès"]
	R	[en "Read" fr "Lecture"]
	W	[en "Write" fr "Ecriture"]
	C	[en "Total Control" fr "Contrôle total"]
}

/**
 * <span style="white-space: pre-line">
 * Displays the meaning of the letters for folder access rights
 * 
 * </span>
 */
bwf_SharedFolderRightsInfosDialog = Dialog {
	title:$bwf_SharedFolderRightsInfosDialogNLS.title
	height:200
	buttons:OkButton
/*
Basic	Meaning	Corresponding action letters
R	Read (Windows)	RGFE
W	Write (Windows)	WGAML
X	Read and Execute/List Folder Content (Windows)	RXGFE
M	Modify (Windows)	RWXGAFEMDL
F	Full Control (Windows)	RWXGASPFEMDL
S	Special (Windows)	any combination not matching any of the above
L	Read (Brainwave)	R
U	Update (Brainwave)	WAMLDS
C	Control (Brainwave)	PO
 */

	Text {
		label:'R'
		value:$bwf_SharedFolderRightsInfosDialogNLS.R
		compact:True
	}
	Text {
		label:'W'
		value:$bwf_SharedFolderRightsInfosDialogNLS.W
		compact:True
	}
	/*
	Text {
		label:'X'
		value:$bwf_SharedFolderRightsInfosDialogNLS.X
		compact:True
	}
	Text {
		label:'M'
		value:$bwf_SharedFolderRightsInfosDialogNLS.M
		compact:True
	}
	Text {
		label:'F'
		value:$bwf_SharedFolderRightsInfosDialogNLS.F
		compact:True
	}
	Text {
		label:'S'
		value:$bwf_SharedFolderRightsInfosDialogNLS.S
		compact:True
	}
	Text {
		label:'L'
		value:$bwf_SharedFolderRightsInfosDialogNLS.L
		compact:True
	}
	Text {
		label:'U'
		value:$bwf_SharedFolderRightsInfosDialogNLS.U
		compact:True
	}
	*/
	Text {
		label:'C'
		value:$bwf_SharedFolderRightsInfosDialogNLS.C
		compact:True
	}
}