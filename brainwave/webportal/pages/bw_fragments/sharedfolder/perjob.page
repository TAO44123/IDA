/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_htmlwidgets/charts.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"


fragmentSharedfolderPerJobNLS = NLS {
	perjob [en "Job with the folder" fr "Métiers avec le répertoire"]
	tooltip [en "{0} identities with this job,\n{1} identities in total with the folder" fr "{0} personnes avec ce métier\nsur un total de {1} personnes qui disposent de ce répertoire"]
	top20 [en "Top 30" fr "Top 30"]

	axe_nbpeople [en "People with the folder" fr "Personnes avec le répertoire"]
	axe_jobs [en "Jobs" fr "Métiers"] 

	trends [en "Changes" fr "Changements"]

	filterlabel [en "Ignore people with read-only access" fr "Ignorer les personnes avec des accès en lecture seule"] 
}

/**
 * <span style="white-space: pre-line">
 * Display the job of the identities with the shared folder
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate details</li>
 * </ul>
 * </span>
 */
fragmentSharedfolderPerJob = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	withwriteaccess = Variable {  multivalued:False type:Boolean initial:False }

	perjob = Dataset {
		view: bwf_sharedfoldernbidentityperjob with inuid to uid, total.totalidentities to total, withwriteaccess to withwriteaccess
		limit:30
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				IntPredicate(total.totalidentities) {
					when >0 then False
					otherwise True
				}
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	total = Record {
		view: bwf_sharedfoldernbtotalidentity with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	Header {
		value:$fragmentSharedfolderPerJobNLS.perjob
		styling:bigTitleStyle
		tooltip:$fragmentSharedfolderPerJobNLS.top20
	}
	Checkbox {
		variable:withwriteaccess
		text:$fragmentSharedfolderPerJobNLS.filterlabel
	}
	IncludeHTMLWidget {
		layout: Layout { grab:horizontal True vertical True }
		template: barChart
		datasets: perjob ( jobtitledisplayname, jobtitleuid, nbidentity, label ) to chartdata ( label, code , count , description)
		bindings: 
			value-of $fragmentSharedfolderPerJobNLS.axe_nbpeople to xlabel,
			value-of $fragmentSharedfolderPerJobNLS.axe_jobs to ylabel,
			value-of True to showxAxesGrid,
			value-of True to showyAxesGrid,
			value-of True to isHorizontal,
			value-of True to isLabelInside,
			value-of True to beginAtZero,
			value-of False to maintainAspectRatio,
			value-of Constant shadesofbluePalette to customColors
		widget-events: {
			when onclick then [
				BooleanCase(incanshowdetails) {
					when True then [
						Dialog fragmentSharedfolderPerJobDetailDialog(Current code to injobuid
															,withwriteaccess to inwithwriteaccess
															,inuid to inpermissionuid
						)
					]
					when False then [
					]
				}
			]
		}
	}
/*
	Text {
		iterate-on:perjob
		value:Current jobtitledisplayname
		compact:True
		decorator:Decorator{width:200 after:Bar{max-value:total.totalidentities  value:Current nbidentity width:200 higher-is-better:True tooltip:$fragmentSharedfolderPerJobNLS.tooltip(Current nbidentity,total.totalidentities) }  }
		label:Label{break:True}
	}
*/
}

fragmentSharedfolderPerJobDetailDialog = Dialog {
	title:"Details"
	width:1366
	height:600
	buttons:OkButton

	inpermissionuid = Variable
	injobuid = Variable
	inwithwriteaccess = Variable {  multivalued:False type:Boolean initial:False }

	selectedidentity = Variable

	perjob = Dataset {
		view: bwf_sharedfolderidentityperjob with inpermissionuid to uid, injobuid to jobuid, inwithwriteaccess to withwriteaccess
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
	}

	showDetails = NamedAction (
		Dialog bwf_identityDetailsDialog(selectedidentity to inuid, True to inshowposition)
	)

	Table {
		data:perjob
		layout:Layout { grab:horizontal True vertical True }
		show-filter:True
		show-count:True
		configurable:True
		
		Column {
			column:uid
			selection:selectedidentity
			hidden:True
		}
		
		Column {
			column:hrcode
			header:$identity.hrcode
			sortable:True
			filterable:True
			actions:ExecuteNamedAction showDetails
		}

		Column {
			column:fullname
			header:$identity.fullname
			sortable:True
			filterable:True
			width:100%
			actions:ExecuteNamedAction showDetails
		}

		Column {
			column:internal
			text:Transform Current internal using booleanDisplayMapping
			header:$identity.internal
			sortable:True
			filterable:True
		}


		Column {
			column:mail
			header:$identity.mail
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:jobtitledisplayname
			header:$identity.jobtitledisplayname
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:organisationshortname
			header:$porganisation.shortname
			sortable:True
			filterable:True
			width:160px
		}

		Column {
			column:organisationdisplayname
			header:$organisation.concept
			sortable:True
			filterable:True
			width:100%
		}

		Column {
			column:organisationorganisationtypedisplayname
			header:$organisation.organisationtypedisplayname
			initially-masked:True
			sortable:True
			filterable:True
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}												
	}
}


