bwf_exchange_helpNLS = NLS {

  //title
  title [en "Exchange Online roles" fr "Rôles Exchange Online"]
  
//Headers
  PermissionHeader [ en "Roles" fr "Rôles"]
  MeaningForFoldersHeader [ en "Meaning for Folders" fr "Signification pour les dossiers"]
  
  //Basic
            
  BasicOwnerLabel [ en "Owner" fr "Owner \nPropriétaire"]
  BasicOwnerDesc [ en "The user is the owner and the contact of the specified folder. He can move the folder, create subfolders, create and read items within the specified folder, and can edit and delete all items in the folder."  
  fr "L'utilisateur est le propriétaire et le contact du répertoire concerné. Il peut déplacer le dossier, créer des sous-dossiers, créer et lire des éléments dans le dossier concerné, modifier et supprimer tous les éléments du dossier."] 
           
  BasicPublishingEditorLabel [ en "Publishing Editor" fr "Publishing Editor"]
  BasicPublishingEditorDesc [ en "The user can create subfolders, can create and read items within the specified folder, and can edit and delete all items in the folder." 
  fr "L'utilisateur peut créer des sous-dossiers, créer et lire des éléments dans le dossier concerné, modifier et supprimer tous les éléments du dossier." ]
            
  BasicEditorLabel [ en "Editor" fr "Editor"]
  BasicEditorDesc [ en "The user can create and read items within the specified folder, and can edit and delete all items in the folder." fr "L'utilisateur peut créer et lire des éléments dans le dossier concerné, modifier et supprimer tous les éléments du dossier."]
                     
  BasicPublishingAuthorLabel [ en "Publishing Author" fr "Publishing Author"]
  BasicPublishingAuthorDesc [ en "The user can create subfolders, create and read items within the specified folder, but can only edit and delete items that he created in the folder."   fr "L'utilisateur peut créer des sous-dossiers, créer et lire des éléments dans le dossier concerné, mais ne peut modifier ou supprimer que les éléments qu'il a créé."]

  BasicAuthorLabel [ en "Author" fr "Author"]
  BasicAuthorDesc [ en "The user can create and read items within the specified folder, but can only edit and delete items that he created in the folder."   fr "L'utilisateur peut créer et lire des éléments dans le dossier concerné, mais ne peut modifier ou supprimer que les éléments qu'il a créé."]
  
  BasicNonEditingAuthorLabel [ en "Non Editing Author" fr "Non Editing Author"]
  BasicNonEditingAuthorDesc [ en "The user can create and read items within the specified folder, but can't edit them."   fr "L'utilisateur peut créer et lire des éléments dans le dossier concerné, mais ne peut pas les modifier."]
  
  BasicContributorLabel [ en "Contributor" fr "Contributor"]
  BasicContributorDesc [ en "The user can create items within the specified folder, but can't read or edit existing items within the folder."   fr "L'utilisateur peut créer des éléments dans le dossier concerné, mais ne peut ni lire ni modifier les éléments présents dans le dossier."]

  BasicReviewerLabel [ en "Reviewer" fr "Reviewer"]
  BasicReviewerDesc [ en "The user can view the specified folder and read items within it, but can't edit items within the folder."   fr "L'utilisateur peut voir le dossier concerné et lire les éléments présents dans le dossier, mais ne peut pas les modifier."]
  
  BasicFolderViewerLabel [ en "None/Folder Viewer" fr "None/Folder Viewer"]
  BasicFolderViewerDesc [ en "The user can view the specified folder, but can't read or edit items within the specified public folder."   fr "L'utilisateur peut voir le dossier concerné, mais ne peut ni lire ni modifier les éléments présents dans le dossier publique concerné."]  
                   
  BasicSpecialLabel [ en "Special Permissions" fr "Special Permissions \nAutorisations spéciales"]
  BasicSpecialDesc [ en "Combination of permissions that do not match any of the above, or additional permissions such as taking ownership.\nCheck 'Show Advanced Permissions' for detail." 
  fr "Combinaison de permissions ne correspondant à aucune des combinaisons ci-dessous, ansi que d'autre permissions telles que l'appropriation.\nCochez 'Montrer les autorisations avancées' pour le détail."]                 
}

