	exchangeonline.description.SendAs [ en "Allows the delegate to send messages as if they came directly from the mailbox or group. There''s no indication that the message was sent by the delegate. " 
										fr "Permet au délégué d''envoyer des messages comme s''ils provenaient directement de la boîte aux lettres ou du groupe. Aucun élément n''indique que le message a été envoyé par le délégué." ]
	exchangeonline.description.SendOnBehalf [ en "Allows the delegate to send messages from the mailbox or group. The From address of these messages clearly shows that the message was sent by the delegate (<Delegate> on behalf of <MailboxOrGroup>). However, replies to these messages are sent to the mailbox or group, not to the delegate. " 
											fr "Permet au délégué d''envoyer des messages à partir de la boîte aux lettres ou du groupe. L''adresse de provenance de ces messages indique clairement que le message a été envoyé par le délégué (« _ <délégué> _ de la part de _ <MailboxOrGroup>_»).Toutefois, les réponses à ces messages sont envoyées à la boîte aux lettres ou au groupe, et non au délégué. " ]
	exchangeonline.description.FullAccess [ en "Allows the delegate to open the mailbox, and view, add and remove the contents of the mailbox. Doesn''t allow the delegate to send messages from the mailbox. " 
											fr "Permet au délégué d''ouvrir la boîte aux lettres et d''afficher, d'ajouter et de supprimer le contenu de la boîte aux lettres. N''autorise pas le délégué à envoyer des messages à partir de la boîte aux lettres. " ]
	exchangeonline.description.ChangeOwner [ en "Allows to change the owner of a mailbox." fr "Permet de changer le propriétaire d''une boîte aux lettres." ]
	exchangeonline.description.ChangePermission [ en "Allows to change the permissions of a mailbox." fr "Permet de changer la permissions d''une boîte aux lettres." ]
	exchangeonline.description.DeleteItem [ en "Allows to delete items of a mailbox." fr "Permet de supprimer des éléments de la boîte aux lettres." ]
	exchangeonline.description.ReadPermission [ en "Allows to read the permissions of a mailbox." fr "Permet de lire les droits d''une boîte aux lettres." ]
	exchangeonline.description.ExternalAccount [ en "Indicates that the delegate account is not part of the same domain." fr "Indique que le compte délégué ne fait pas parti du même domaine." ]
	exchangeonline.description.ReadItems [ en "The user can read items within the specified folder." fr "L''utilisateur peut lire des éléments dans le dossier spécifié." ]
	exchangeonline.description.CreateItems [ en "The user can create items within the specified folder." fr "L''utilisateur peut créer des éléments dans le dossier spécifié." ]
	exchangeonline.description.EditOwnedItems [ en "The user can only edit items that they created in the specified folder." fr "L''utilisateur peut seulement éditer des éléments qu''il a créé dans le dossier spécifié." ]
	exchangeonline.description.DeleteOwnedItems [ en "The user can only delete items that they created from the specified folder." fr "L''utilisateur peut seulement supprimer des éléments qu''il a créé dans le dossier spécifié" ]
	exchangeonline.description.EditAllItems [ en "The user can edit all items in the specified folder." fr "L''utilisateur peut éditer tous les éléments dans le dossier spécifié." ]
	exchangeonline.description.DeleteAllItems [ en "The user can delete all items in the specified folder." fr "L''utilisateur peut supprimer tous les éléments dans le dossier spécifié." ]
	exchangeonline.description.CreateSubfolders [ en "The user can create subfolders in the specified folder." fr "L''utilisateur peut créer des sous-dossiers dans le dossier spécifié." ]
	exchangeonline.description.FolderOwner [ en "The user is the owner of the specified folder. The user can view the folder, move the folder and create subfolders. The user can't read items, edit items, delete items or create items." 
											fr "L''utilisateur est le propriétaire du dossier spécifié. L''utilisateur peut voir le dossier, déplacer de dossier et créer des sous-dossiers. L''utilisateur ne peut pas lire les éléments, editer les éléments, supprimer les éléments ou créer des éléments." ]
	exchangeonline.description.FolderContact [ en "The user is the contact for the specified public folder." fr "L''utilisateur est le contact pour le dossier public spécifié." ]
	exchangeonline.description.FolderVisible [ en "The user can view the specified folder, but can't read or edit items within the specified public folder." fr "The user can view the specified folder, but can't read or edit items within the specified public folder." ]
	exchangeonline.description.AvailabilityOnly [ en "View only availability data." fr "Voir seulement les données en disponibilité." ]
	exchangeonline.description.LimitedDetails [ en "View availability data with subject and location." fr "Voir seulement les données en disponibilité avec le sujet et le lieu." ]
}


