	sharepointonline.description.UseRemoteAPIs [en "Use Simple Object Access Protocol (SOAP), Web DAV, or SharePoint Designer interfaces to access the website. " fr "Utiliser les interfaces SOAP (Simple Object Access Protocol), WebDAV ou SharePoint Designer pour accéder au site web. "]
	sharepointonline.description.UseClientIntegration [en "Use Client Integration Features" fr "Use Client Integration Features"]
	sharepointonline.description.Open [en "Open a website, list, or folder to access items inside that container. " fr "Ouvrir un site web, une liste ou un dossier pour accéder aux éléments qu'ils contiennent. "]
	sharepointonline.description.EditMyUserInfo [en "Allow a user to change personal information, such as adding a picture. " fr "Autoriser un utilisateur à modifier ses informations personnelles, en ajoutant une photo par exemple. "]
	sharepointonline.description.AnonymousSearchAccessWebLists [en "AnonymousSearchAccessWebLists" fr "AnonymousSearchAccessWebLists"]
	sharepointonline.description.ManageLists [en "Create and delete lists, add or remove columns in a list, and add or remove public views of a list. " fr "Créer et supprimer des listes, ajouter ou supprimer des colonnes dans une liste et ajouter ou supprimer des affichages publics dans une liste. "]
	sharepointonline.description.CancelCheckout [en "Discard or check in a document that is checked out to another user. " fr "Supprimer ou archiver un document qui a été extrait par un autre utilisateur. "]
	sharepointonline.description.AddListItems [en "Add items to lists, add documents to document libraries, and add web discussion comments. " fr "Ajouter des éléments à des listes, ajouter des documents à des bibliothèques de documents et ajouter des commentaires de discussions sur le web. "]
	sharepointonline.description.EditListItems [en "Edit items in lists, edit documents in document libraries, edit web discussion comments in documents, and customize Web Part Pages in document libraries. " fr "Modifier des éléments dans des listes, modifier des documents dans des bibliothèques de documents, modifier des commentaires de discussions sur le web dans des documents et personnaliser des pages de composants WebPart dans des bibliothèques de documents. "]
	sharepointonline.description.DeleteListItems [en "Delete items from a list, documents from a document library, and web discussion comments in documents. " fr "Supprimer des éléments dans une liste, des documents dans une bibliothèque de documents et des commentaires de discussions sur le web dans des documents. "]
	sharepointonline.description.ViewListItems [en "View items in lists, documents in document libraries, and web discussion comments. " fr "Afficher des éléments dans des listes, des documents dans des bibliothèques de documents et des commentaires de discussions sur le web. "]
	sharepointonline.description.ApproveItems [en "Approve a minor version of a list item or document. " fr "Approuver une version mineure d'un élément de liste ou d'un document. "]
	sharepointonline.description.OpenItems [en "View the source of documents that use server-side file handlers. " fr "Afficher la source des documents qui utilise des gestionnaires de fichiers côté serveur. "]
	sharepointonline.description.ViewVersions [en "View past versions of a list item or document. " fr "Afficher les versions antérieures d'un élément de liste ou d'un document. "]
	sharepointonline.description.DeleteVersions [en "Delete past versions of a list item or document. " fr "Supprimer les versions antérieures d'un élément de liste ou d'un document. "]
	sharepointonline.description.CreateAlerts [en "Create e-mail alerts. " fr "Créer des alertes de courrier. "]
	sharepointonline.description.ViewFormPages [en "View documents and views in a list or document library. " fr "Afficher des documents et des vues dans une liste ou une bibliothèque de documents. "]
	sharepointonline.description.AnonymousSearchAccessList [en "AnonymousSearchAccessList" fr "AnonymousSearchAccessList"]
	
