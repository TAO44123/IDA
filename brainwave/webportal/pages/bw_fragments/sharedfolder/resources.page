				fr 'Veuillez mettre à jour la description associée à cette permission'
				]
	done [en "Your request to update description has been received successfully" fr "Votre demande de modification de la description a bien été enregistrée"]
	edit [en "Edit" fr "Edition"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	sensitivityreasonvalid [en "Please enter a valid explanation" fr "Veuillez saisir une raison"]
	managed [en "Managed folder" fr "Répertoire sous gestion"]
}

/**
 * Update folder description
 * 
 * @param paramSharedFolderUid sharedfolder uid
 */
bwfSharedFolderDetailsMetadata_Dialog = Dialog {
	title: $bwfSharedFolderDetailsMetadata_Dialog_NLS.title
	buttons:[
	
		OkButton {
			disabled:
				OrPredicate {
					StringPredicate(changed) {when '1' then False otherwise True}
					AndPredicate {
						IntPredicate(sensitivitylevel) { when >0 then True otherwise False }
						Not BooleanPredicate(reasonisvalid) 
					}
					StringPredicate(description) { when IsEmpty then True otherwise False }
				}
			actions:Set description to task.description,
					Set sensitivityreason to task.sensitivityreason,
					Set sensitivitylevel to task.sensitivitylevel,
					Set paramPermissionUid to task.permission,
					Set ismanaged to task.managed,
					TaskComplete task wait-end,
					Flash $bwfSharedFolderDetailsMetadata_Dialog_NLS.done
		} 
	
		CancelButton
	]
	
	width:800
	height:280
	
	/* Parameters here */
	paramPermissionUid = Variable {type:String multivalued:False}

	description = Variable
	sensitivitylevel = Variable
	sensitivityreason = Variable
	ismanaged = Variable { type:Boolean }
	
	selecteddescription = Variable { private:True }
	changed = Variable{type:String initial:'0' private:True }
	reasonisvalid = Variable

	task = TaskRecord (create "bwf_updatepermissionmetadata")
	

	Header {
		value:$bwfSharedFolderDetailsMetadata_Dialog_NLS.description
		styling:subtitleStyle
	}
	Separator
	Combo {
		variable:sensitivitylevel
		label:$bwfSharedFolderDetailsMetadata_Dialog_NLS.sensitivitylevel
		modify-event:Set '1' to changed, IntCase(sensitivitylevel) { when =0 then [ Set '-' to sensitivityreason] }
		options:Static {
			Option {
				text:Transform "0" using bwfPermissionSensitivityLevelMapping
				value:0
			}
			Option {
				text:Transform "1" using bwfPermissionSensitivityLevelMapping
				value:1
			}
			Option {
				text:Transform "2" using bwfPermissionSensitivityLevelMapping
				value:2
			}
			Option {
				text:Transform "3" using bwfPermissionSensitivityLevelMapping
				value:3
			}
			Option {
				text:Transform "4" using bwfPermissionSensitivityLevelMapping
				value:4
			}
		}
	}
	Edit {
		variable:sensitivityreason
		label:$bwfSharedFolderDetailsMetadata_Dialog_NLS.sensitivityreason
		modify-event:Set '1' to changed
		not-empty:True
		match:'[0-9a-zA-z].+'
		validity:reasonisvalid
		error-tooltip:$bwfSharedFolderDetailsMetadata_Dialog_NLS.sensitivityreasonvalid
		hidden:IntPredicate(sensitivitylevel) { when =0 then True otherwise False }
		limit:1000
	}
	Checkbox {
		label:$bwfSharedFolderDetailsMetadata_Dialog_NLS.managed
		variable:ismanaged
		modify-event:Set '1' to changed
	}
	Edit {
		variable:description
		label:$bwfSharedFolderDetailsMetadata_Dialog_NLS.descriptionlabel
		multi-lines:True
		limit:1000
		layout:Layout{grab: horizontal True vertical False hint:height 64}
		modify-event:Set '1' to changed
		not-empty:True
	}	
}

bwf_sharedfolderexplorerhelpdialog = Dialog {
