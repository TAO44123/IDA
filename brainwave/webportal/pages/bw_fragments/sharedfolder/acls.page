rightTemplate = StringImageTemplate {
	when "2" then %status_16_red.cross
	when "1" then %status_16_green.tick
}

/**
 * <span style="white-space: pre-line">
 * Display the selected shared folder ACLs
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details through GUI</li>
 * </ul>
 * </span>
 */
fragmentSharedfolderAcls = PageFragment {
	feature: unstructureddata_license
	enter-event:
		ExecuteNamedAction reload

	/* Parameters here */
		
	inuid = Variable { type: String }
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	/* Variables here */
	showAdvanced = Variable { type: Boolean multivalued: False initial: False private:True}  // == hideBasic
	selectedgroupacluid = Variable { private:True }
	selectedAccountUid = Variable { private:True }
	selectedGroupUidinTree = Variable { private:True }
	permissionchain = Variable { multivalued: True }

	/* Dataset here */
	parents = Dataset {
		view: bwf_getfolderparents with
			inuid to uid
	}
	groupacls = HierarchicalData {
		roots-view: bwf_getfilesdisplayname with
			permissionchain to uid
		children-view: bwf_fileexplorergetfilesharegroupacls
		parameter: uid
		attribute: permission_uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	groupstree = HierarchicalData {
		roots-view: bwf_fileexplorergetgrouproot with selectedgroupacluid to uid
		children-view:bwf_fileexplorergetgroupchildof
		attribute: recorduid
		max-level: 5
		parameter:parentrecorduid
	}
	getaccountsingroup = Dataset {
		view: bwf_fileexplorergetaccountsingroup with
			selectedGroupUidinTree to uid
	}
	accountacls = HierarchicalData {
		roots-view: bwf_getfilesdisplayname with
			permissionchain to uid
		children-view: bwf_fileexplorergetfileshareaccountacls
		parameter: uid
		attribute: permission_uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	reload = NamedAction (
		TransferData parents ( parent_uid ) to ( permissionchain ),
		MultivaluedAdd inuid to permissionchain
	)
	
	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedAccountUid to inuid, 
												True to inshowowner,
												False to inshowgroups,
												False to inshowapplications,
												False to inshowshares,
												False to inshowcontrols,
												False to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	/* Layout here */
	TabFolder {
		TabItem {
			text: $fragmentSharedfolderAclsNLS.tabs.aclsdetails.labels.groupacls
			Flow {
			   disposition: Vertical
			   ConditionalGroup {
			   BooleanCondition( showAdvanced)
			   {
			   when False then [
			    // Basic Group ACL
			     Tree {
						data:groupacls
						layout:Layout {grab:horizontal True vertical True}
						configurable:True
						persist-configuration:True
						expand-level: 3
						commands:Commands{position:After orientation:Vertical presentation:Icon Command{actions:Dialog bwf_sharedfolderexplorerhelpdialog( showAdvanced to showAdvanced) icon:%browsing_16.zoom tooltip: $fragmentSharedfolderAclsNLS.tooltips.links.rightsexplained} Command{actions:Message 'todo' icon:'' disabled:True}}
						Column { header: $fragmentSharedfolderAclsNLS.folder column: permission_code width: 200px initially-masked: False }
						Column {column:order width:32px initially-masked:True 	}
						Column { column:negative initially-masked:True }
						Column { column:action 	initially-masked:True }
						Column { column:BASIC_FULLCONTROL header:$bwf_sharedfolder_rights.fullcontrolright  width: 80px image:TemplateImageSelection(Current BASIC_FULLCONTROL) using rightTemplate text:'' } 
						Column { column:BASIC_MODIFY header:$bwf_sharedfolder_rights.modifyright width:60px image:TemplateImageSelection(Current BASIC_MODIFY) using rightTemplate text:''} 
						Column { column:BASIC_READEXECUTE header:$bwf_sharedfolder_rights.readexecuteright width: 100px  image:TemplateImageSelection(Current BASIC_READEXECUTE) using rightTemplate text:''} 
						Column { column:BASIC_READ header:$bwf_sharedfolder_rights.readright width:50px image:TemplateImageSelection(Current BASIC_READ) using rightTemplate text:''} 
						Column { column:BASIC_WRITE header:$bwf_sharedfolder_rights.writeright width:50px image:TemplateImageSelection(Current BASIC_WRITE) using rightTemplate text:''} 
									Column { column: action header: $bwf_sharedfolder_rights.specialright 
									   width: 60px  image:TemplateImageSelection( @bwf_jsHasSpecialPermission(Current action to action, Current negative to negative)) using rightTemplate
									  text: ''}  		
						Column { column:uid selection:selectedgroupacluid hidden:True 	}
						Column { column:displayname header: $group.displayname width:240px }
						Column { column:code header: $pgroup.code width:300px }
						Column { column:repositorycode 	header: $prepository.code initially-masked:True 	}
						Column { column:repositorydisplayname  header: $prepository.displayname }
					}
					]
					when True then [
					// Advanced group ACL
					  	Tree {
						data:groupacls
						layout:Layout {grab:horizontal True vertical True}
						configurable:True
						expand-level: 3
						commands:Commands{position:After orientation:Vertical presentation:Icon Command{actions:Dialog bwf_sharedfolderexplorerhelpdialog icon:%browsing_16.zoom tooltip: $fragmentSharedfolderAclsNLS.tooltips.links.rightsexplained } Command{actions:Message 'todo' icon:'' disabled:True}}
						Column { header: $fragmentSharedfolderAclsNLS.folder column: permission_code width: 200px initially-masked: False }
						Column {
							column:order
							width:32px
						}
						Column {
							column:negative
							initially-masked:True
						}
						Column {
							column:action
							initially-masked:True
						}
						Column { column:READ_DATA header:'R' width:30px image:TemplateImageSelection(Current READ_DATA) using rightTemplate text:''}
						Column { column:WRITE_DATA header:'W' width:30px image:TemplateImageSelection(Current WRITE_DATA) using rightTemplate text:''}
						Column { column:APPEND_DATA header:'A' width:30px image:TemplateImageSelection(Current APPEND_DATA) using rightTemplate text:''}
						Column { column:READ_EXTENDED_ATTRIBUTES header:'F' width:30px image:TemplateImageSelection(Current READ_EXTENDED_ATTRIBUTES) using rightTemplate text:''}
						Column { column:WRITE_EXTENDED_ATTRIBUTES header:'M' width:30px image:TemplateImageSelection(Current WRITE_EXTENDED_ATTRIBUTES) using rightTemplate text:''}
						Column { column:EXECUTE header:'X' width:30px image:TemplateImageSelection(Current EXECUTE) using rightTemplate text:''}
						Column { column:DELETE_CHILD header:'S' width:30px image:TemplateImageSelection(Current DELETE_CHILD) using rightTemplate text:''}
						Column { column:READ_ATTRIBUTES header:'E' width:30px image:TemplateImageSelection(Current READ_ATTRIBUTES) using rightTemplate text:''}
						Column { column:WRITE_ATTRIBUTES header:'L' width:30px image:TemplateImageSelection(Current WRITE_ATTRIBUTES) using rightTemplate text:''}
						Column { column:DELETE header:'D' width:30px image:TemplateImageSelection(Current DELETE) using rightTemplate text:''}
						Column { column:READ_CONTROL header:'G' width:30px image:TemplateImageSelection(Current READ_CONTROL) using rightTemplate text:''}
						Column { column:WRITE_DAC header:'P' width:30px image:TemplateImageSelection(Current WRITE_DAC) using rightTemplate text:''}
						Column { column:WRITE_OWNER header:'O' width:30px image:TemplateImageSelection(Current WRITE_OWNER) using rightTemplate text:''}
						Column {	column:uid selection:selectedgroupacluid 	hidden:True 	}
						Column { column:displayname header:$group.displayname width:240px }
						Column { column:code header:$pgroup.code width:300px }
						Column { column:repositorycode header:$prepository.code	initially-masked:True 	}
						Column { column:repositorydisplayname header:$prepository.displayname }
				   	  }
					]
				  }
	            }									
				ConditionalGroup {
					StringCondition(selectedgroupacluid) {
						when IsEmpty then [
							Text {
								value: $fragmentSharedfolderAclsNLS.tabs.aclsdetails.message.selectACL
								compact:True
							}
						]
						otherwise [
							Group {
								title: $fragmentSharedfolderAclsNLS.tabs.aclsdetails.labels.groupdetails
								Splitter {
									disposition:Horizontal
									Group {
										Tree {
											data:groupstree
											expand-level:3
											//double-click:GoTo Activity Permission(sharedfolder) Detail  with selectedSharedfolder to paramSharedfolderUid
											layout:Layout {grab: horizontal True vertical True}
											configurable:True
											Column { column:displayname	header:$group.concept width:100%  filterable:True	}
											Column { column:code header:$group.code width:100% filterable:True }
											Column { column:uid hidden:True selection:selectedGroupUidinTree }
										}
									}
									ConditionalGroup {
										StringCondition(selectedGroupUidinTree) { when IsEmpty then [
											Text {
												value: $fragmentSharedfolderAclsNLS.tabs.aclsdetails.message.selectgroup
												compact:True
											}
										]
										otherwise [
											Table {
												data:getaccountsingroup
												show-filter:True
												show-count:True
												configurable:True
												persist-configuration:True
												layout:Layout{grab: horizontal True vertical True}
												double-click:ExecuteNamedAction goDetails
												

												Column { column:uid hidden:True selection:selectedAccountUid } 
												Column { column:identifier header:$account.identifier sortable:True filterable:True initially-masked:True 
													actions: ExecuteNamedAction goDetails
													actions-disabled: Not BooleanPredicate(incanshowdetails)
													tooltip: $search_page.showdetails
												} 
												Column { column:login header:$account.login sortable:True filterable:True 
													actions: ExecuteNamedAction goDetails
													actions-disabled: Not BooleanPredicate(incanshowdetails)
													tooltip: $search_page.showdetails
												} 
												Column { column:givenname header:$account.givenname sortable:True filterable:True initially-masked:True 
													actions: ExecuteNamedAction goDetails
													actions-disabled: Not BooleanPredicate(incanshowdetails)
													tooltip: $search_page.showdetails
												} 
												Column { column:surname header:$account.surname sortable:True filterable:True initially-masked:True 
													actions: ExecuteNamedAction goDetails
													actions-disabled: Not BooleanPredicate(incanshowdetails)
													tooltip: $search_page.showdetails
												} 
												Column { column:username header:$account.username sortable:True filterable:True } 
												Column { column:mail header:$account.mail sortable:True filterable:True initially-masked:True } 
												Column { column:disabled header:$account.disabled sortable:True filterable:True initially-masked:True } 
												Column { column:creationdate header:$account.creationdate sortable:True initially-masked:True } 
												Column { column:lastlogindate header:$account.lastlogindate sortable:True initially-masked:True } 
												Column { column:passwordlastsetdate header:$account.passwordlastsetdate sortable:True initially-masked:True } 
												Column { column:passwordcantchange header:$account.passwordcantchange sortable:True initially-masked:True } 
												Column { column:passwordnotrequired header:$account.passwordnotrequired sortable:True initially-masked:True } 
												Column { column:notnormalaccount header:$account.notnormalaccount sortable:True initially-masked:True } 
												Column { column:logincount header:$account.logincount sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationtype header:$preconciliation.type sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationreconciliationdate header:$preconciliation.reconciliationdate sortable:True initially-masked:True } 
												Column { column:reconciliationreliability header: $fragmentSharedfolderAclsNLS.columns.reconciliationreliability sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationnoownercode header:$preconciliation.noownercode sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationcomment header:$preconciliation.comment sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationrulename header:$preconciliation.rulename sortable:True filterable:True initially-masked:True } 
												Column { column:reconciliationdescription header:$preconciliation.description sortable:True filterable:True initially-masked:True } 
												Column { column:identityuid hidden:True } 
												Column { column:identityhrcode header:$pidentity.hrcode sortable:True filterable:True } 
												Column { column:identityfullname header:$pidentity.fullname sortable:True filterable:True } 
												Column { column:identitymail header:$pidentity.mail sortable:True filterable:True initially-masked:True } 
												Column { column:identityinternal header:$pidentity.internal sortable:True filterable:True initially-masked:True } 
												Column { column:identityactive header:$pidentity.active sortable:True filterable:True initially-masked:True } 
												Column { column:identitydeparturedate header:$pidentity.departuredate sortable:True initially-masked:True } 
												Column { column:identitybwa_identityanalyticsdata_joborg header:$pidentity.joborg sortable:True filterable:True initially-masked:True } 
											}
										]
										}
									}
								}											
							}
						]
					}
				}
			}
		}
		TabItem {
			text:$fragmentSharedfolderAclsNLS.tabs.aclsdetails.labels.accoutnacls
			
					  ConditionalGroup {
					   BooleanCondition(showAdvanced){
					   when False then 
					   // Basic Account ACL
					    Tree {
							data:accountacls
							layout:Layout {grab:horizontal True vertical True}
							configurable:True
							expand-level: 3
							persist-configuration:True
							double-click:ExecuteNamedAction goDetails
							
							commands: Commands {
								position:After
								presentation:Icon
								orientation:Vertical
								Command {
									actions: Dialog bwf_sharedfolderexplorerhelpdialog( showAdvanced to showAdvanced)
									icon:%browsing_16.zoom 
									tooltip:$fragmentSharedfolderAclsNLS.tooltips.links.rightsexplained
								}
								Command {
									actions:ExecuteNamedAction goDetails
									icon:%browsing_16.zoom
									tooltip:'Shows selected account details'
									disabled:
										OrPredicate {
											Not BooleanPredicate(incanshowdetails)
											StringPredicate(selectedAccountUid) { when IsEmpty then True otherwise False }
										}
								}
							}
							Column { header: $fragmentSharedfolderAclsNLS.folder column: permission_code width: 200px initially-masked: False }

							Column {column:order width:32px  initially-masked:True}
							Column { column:negative 	initially-masked:True 	}
							Column { column:action 	initially-masked:True }
							Column { column:BASIC_FULLCONTROL header:$bwf_sharedfolder_rights.fullcontrolright  width: 80px image:TemplateImageSelection(Current BASIC_FULLCONTROL) using rightTemplate text:'' } 
							Column { column:BASIC_MODIFY header:$bwf_sharedfolder_rights.modifyright width:60px image:TemplateImageSelection(Current BASIC_MODIFY) using rightTemplate text:''} 
							Column { column:BASIC_READEXECUTE header:$bwf_sharedfolder_rights.readexecuteright width: 100px  image:TemplateImageSelection(Current BASIC_READEXECUTE) using rightTemplate text:''} 
							Column { column:BASIC_READ header:$bwf_sharedfolder_rights.readright width:50px image:TemplateImageSelection(Current BASIC_READ) using rightTemplate text:''} 
							Column { column:BASIC_WRITE header:$bwf_sharedfolder_rights.writeright width:50px image:TemplateImageSelection(Current BASIC_WRITE) using rightTemplate text:''} 
	//									Column { column: action header: $bwf_sharedfolder_rights.specialright
	//									   width: 60px  image:TemplateImageSelection( @jsHasSpecialPermission(Current action to action, Current negative to negative)) using rightTemplate
	//									  text: ''}  		
							Column { column:identifier header:$account.identifier sortable:True filterable:True initially-masked:True } 
							Column { column:login header:$account.login sortable:True filterable:True } 
							Column { column:givenname header:$account.givenname sortable:True filterable:True initially-masked:True } 
							Column { column:surname header:$account.surname sortable:True filterable:True initially-masked:True } 
							Column { column:username header:$account.username sortable:True filterable:True } 
							Column { column:mail header:$account.mail sortable:True filterable:True initially-masked:True } 
							Column { column:disabled header:$account.disabled sortable:True filterable:True initially-masked:True } 
							Column { column:creationdate header:$account.creationdate sortable:True initially-masked:True } 
							Column { column:lastlogindate header:$account.lastlogindate sortable:True initially-masked:True } 
							Column { column:passwordlastsetdate header:$account.passwordlastsetdate sortable:True initially-masked:True } 
							Column { column:passwordcantchange header:$account.passwordcantchange sortable:True initially-masked:True } 
							Column { column:passwordnotrequired header:$account.passwordnotrequired sortable:True initially-masked:True } 
							Column { column:notnormalaccount header:$account.notnormalaccount sortable:True initially-masked:True } 
							Column { column:logincount header:$account.logincount sortable:True filterable:True initially-masked:True } 
							Column { column:reconciliationtype header:$preconciliation.type sortable:True filterable:True initially-masked:True } 
							Column { column:reconciliationreconciliationdate header:$preconciliation.reconciliationdate sortable:True initially-masked:True } 
							Column { column:reconciliationreliability header: $fragmentSharedfolderAclsNLS.columns.reconciliationreliability sortable:True filterable:True initially-masked:True } 
							Column { column:reconciliationnoownercode header:$preconciliation.noownercode sortable:True filterable:True initially-masked:True } 
							Column { column:reconciliationcomment header:$preconciliation.comment sortable:True filterable:True initially-masked:True } 
							Column { column:reconciliationrulename header:$preconciliation.rulename sortable:True filterable:True initially-masked:True } 
