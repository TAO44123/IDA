fragmentSharedfolderAccountsNLS = NLS {
	noownercode [en "technical account" fr "compte technique"]
	trends [en "Changes" fr "Changements"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected shared folder accounts
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentSharedfolderAccounts = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	accounts = Dataset {
		view: bwf_sharedfolderaccounts with inuid to uid
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												True to inshowACLs,
												False to inshowgroups,
												False to inshowapplications,
												False to inshowshares,
												False to inshowcontrols,
												False to inshowdecisionhistory,
												inuid to insharedfolderuid
												)
			]
			when False then [
			
			]
		}
	)

	Table {
		data:accounts
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		show-count:True
		show-filter:True
		double-click:ExecuteNamedAction goDetails
		persist-configuration:True
		
		Column {
			column:uid
			hidden:True
			selection:outaccountuid
		}
		
		Column {
			column:right
			header:$right.concept
			sortable:True
			filterable:True
			actions:Dialog bwf_SharedFolderRightsInfosDialog
		}

		Column {
			column:login
			header:$account.login
			sortable:True
			filterable:True
			selection:outaccountlogin
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:givenname
			header:$account.givenname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:surname
			header:$account.surname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:username
			header:$account.username
			sortable:True
			filterable:True
			width:160px
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:disabled
			header:$account.disabled
			sortable:True
			filterable:True
			initially-masked:True
		}

		Column {
			column:creationdate
			header:$account.creationdate
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:lastlogindate
			header:$account.lastlogindate
			sortable:True
			filterable:True
		}
		Column {
			column:repositoryuid
			hidden:True
			selection:outrepositoryuid
		}
		Column {
			column:repositorydisplayname
			header:$repository.concept
			sortable:True
			filterable:True
			selection:outrepositoryname
		}
		Column {
			column:noownercode
			sortable:True
			filterable:True
			header:$fragmentSharedfolderAccountsNLS.noownercode
		}
		Column {
			column:identityhrcode
			sortable:True
			filterable:True
			header:$pidentity.hrcode
			initially-masked:True
		}
		Column {
			column:identityfullname
			sortable:True
			filterable:True
			header:$pidentity.fullname
			width:100%
		}
		Column {
			column:identitymail
			sortable:True
			filterable:True
			header:$pidentity.mail
			initially-masked:True
		}
		Column {
			column:identityinternal
			sortable:True
			filterable:True
			header:$pidentity.internal
			initially-masked:True
		}
		Column {
			column:identityactive
			sortable:True
			filterable:True
			header:$pidentity.active
			initially-masked:True
		}
		Column {
			column:identitybwa_identityanalyticsdata_joborg
			initially-masked:True
			sortable:True
			filterable:True
			width:240px
			header:$pidentity.joborg
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}												
	}
}

fragmentSharedfolderAccountsForOrgNLS = NLS {
	directfilter [en "Accounts whom owners are direct members of {0}" fr "Comptes dont les membres sont des membres directs de {0}"]
	subfilter [en "Accounts whom owners are direct or indirect members of {0}" fr "Comptes dont les membres sont des membres directs ou indirects de {0}"]
}


/**
 * <span style="white-space: pre-line">
 * Display the selected shared folder accounts for a given organisation
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentSharedfolderAccountsForOrg = PageFragment {
	feature:unstructureddata_license

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inorganisationuid = Variable { multivalued:False }
	inonlydirectselection = Variable { multivalued:False type:Boolean}
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	accounts = Dataset {
		view: bwf_sharedfolderaccountsfororg with
			inuid to uid,
			inorganisationuid to organisationuid,
			inonlydirectselection to directonly
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	organisation = Record {
		view: br_organisationDetail with inorganisationuid to uid
	}


	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												True to inshowACLs,
												False to inshowgroups,
												False to inshowapplications,
												False to inshowshares,
												False to inshowcontrols,
												False to inshowdecisionhistory,
												inuid to insharedfolderuid
												)
			]
			when False then [
			
			]
		}
	)

	Header {
		value:$fragmentSharedfolderAccountsForOrgNLS.directfilter(organisation.displayname)
		hidden:Not BooleanPredicate(inonlydirectselection)
	}
	Header {
		value:$fragmentSharedfolderAccountsForOrgNLS.subfilter(organisation.displayname)
		hidden:BooleanPredicate(inonlydirectselection)
	}
	Table {
		data:accounts
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		show-count:True
		show-filter:True
		double-click:ExecuteNamedAction goDetails
		persist-configuration:True
		
		Column {
			column:uid
			hidden:True
			selection:outaccountuid
		}
		
		Column {
			column:right
			header:$right.concept
			sortable:True
			filterable:True
			actions:Dialog bwf_SharedFolderRightsInfosDialog
		}

		Column {
			column:login
			header:$account.login
			sortable:True
			filterable:True
			selection:outaccountlogin
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:givenname
			header:$account.givenname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:surname
			header:$account.surname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:username
			header:$account.username
			sortable:True
			filterable:True
			width:160px
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:disabled
			header:$account.disabled
			sortable:True
			filterable:True
			initially-masked:True
		}

		Column {
			column:creationdate
			header:$account.creationdate
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:lastlogindate
			header:$account.lastlogindate
			sortable:True
			filterable:True
		}
		Column {
			column:repositoryuid
			hidden:True
			selection:outrepositoryuid
		}
		Column {
			column:repositorydisplayname
			header:$repository.concept
			sortable:True
			filterable:True
			selection:outrepositoryname
		}
		Column {
			column:noownercode
			sortable:True
			filterable:True
			header:$fragmentSharedfolderAccountsNLS.noownercode
		}
		Column {
			column:identityhrcode
			sortable:True
			filterable:True
			header:$pidentity.hrcode
			initially-masked:True
		}
		Column {
			column:identityfullname
			sortable:True
			filterable:True
			header:$pidentity.fullname
			width:100%
		}
		Column {
			column:identitymail
