/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/bw_fragments/identity/resources.page"
import "/webportal/pages/bw_fragments/lib/styles.page"
import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/bw_fragments/lib/kpis.page"
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"

fragmentIdentityDetailsNLS = NLS {
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	managetags [en "Manage tags" fr "Gérer les labels"]

	updatemetadata [en "Update identity description" fr "Mise à jour de la description de l'identité"]
}

identities_mawriskinfo_max_nbrisks = UserVariable { type: Integer initial: "notset" }
identities_maxriskinfo_max_riskrank = UserVariable { type: Integer initial: "notset" }
identities_mawriskinfo_max_risklevel = UserVariable { type: Integer initial: "notset" }
fragmentIdentityMaxRiskInfo = PageFragment {
	enter-event: IntCase ( UserVariable identities_mawriskinfo_max_risklevel ) {
		when InvalidInteger then [
			Set maxriskinfo.bwa_identityanalytics_aggnbrisks to UserVariable identities_mawriskinfo_max_nbrisks,
			Set maxriskinfo.bwa_identityanalytics_aggriskrank to UserVariable identities_maxriskinfo_max_riskrank,
			Set maxriskinfo.bwa_identityanalytics_aggmaxrisklevel to UserVariable identities_mawriskinfo_max_risklevel
		]
	}
	maxriskinfo = Record {
		view: bwf_identitymaxriskinfo
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the identity details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inshowrisks </b>optional, boolean value, true to show risks indicators (false by default)</li>
 * </ul>
 * </span>
 */
fragmentIdentityDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable { type: String }
	inenabled = Variable { multivalued: False type: Boolean initial: True }
	inshowrisks = Variable { multivalued: False type: Boolean initial: False }
	incanupdatemanagers = Variable { multivalued:False type:Boolean initial:False }
	nbAllocations = Variable { type: Integer }
	
	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	tmpselectedManager = Variable { private:True multivalued:True }
	tmpselectedManagerLink = Variable { private: True multivalued:True }
	tmpselectedExpertiseDomain = Variable { private:True multivalued:True }
	
	/* Datasets here */
	owner = Record {
		view: bwf_identitydetails with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevowner = Record {
		view: bwf_identitydetails with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:
			FromPage ( -1 )
	}
	managers = Dataset {
		view: bwf_identitymanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	
	ownerorgsandjobs = Dataset {
		view: bwf_identityorgandjobs with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		count-variable: nbAllocations
	}
	
	ownerorgandjob = Record {
		view: bwf_identityorgandjobs with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	// IDENTITY INFORMATION
	// ////////////////////////////////
	// Compact mode
	Text {
		value: owner.hrcode
		label: $identity.hrcode
		compact: True
	}
	Text {
		value: owner.fullname
		label: $identity.fullname
		compact: True
	}
	Text {
		value: owner.mail
		label: $identity.mail
		compact: True
	}
	Text {
		value: Transform owner.internal using booleanDisplayMapping
		label: $identity.internal // Internal
		compact: True
	}
	Text {
		value: Transform owner.active using booleanDisplayMapping
		label: $identity.active // Active
		compact: True
		decorator:
			Decorator {
				width: 32
				after:
					Image {
						image: TemplateImageSelection ( owner.active ) using bw_fragments_baderBoolImageMapping
						width: 16
					}
				gap: 16
			}
	}
	Text {
		value: SubString(0,10) owner.arrivaldate
		label: $identity.arrivaldate
		compact: True
		tooltip: owner.arrivaldate
		styling:DateStyling(owner.arrivaldate) {
			when DateAfter Date(PageTimeslot.CommitDate) then bwf_warningNG
			otherwise default
		}
	}
	Text {
		value: SubString(0,10) owner.departuredate
		label: $identity.departuredate
		compact: True
		tooltip: owner.departuredate 
		styling:DateStyling(owner.departuredate) {
			when DateBefore Date(PageTimeslot.CommitDate) then bwf_warningNG
			otherwise default
		}
	}

	Header {
		value:$identity.directboss // Direct Line Manager
	}
	Separator {
		width:1
	}
	ConditionalGroup {
		layout:Layout { grab:horizontal True vertical False }
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$bw_fragment_identityDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdatemanagers)
	                        	feature:identitydetails_updatemanager
	                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
	                       }
					}
				}
			]
			when =1 then [
				Text {
					iterate-on: managers
					value: Concat(Current fullname, ' (', Current expertisedomaindisplayname, ')') 	
					compact:True		

					commands:Commands { position: After orientation: Horizontal
									Command{	
											actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:True
				                        	feature:identitydetails_updatemanager
				                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
				                       }
									Command{
											actions:
												TransferData managers(uid, expertisedomaincode, ManagerLinkRecorduid) to (tmpselectedManager, tmpselectedExpertiseDomain, tmpselectedManagerLink), // complex stuff to fulfill selectedManager as a workaround because "Current uid" does not work
													Set ElementAt 1 of tmpselectedManager to selectedManager,
													Set ElementAt 1 of tmpselectedExpertiseDomain to selectedExpertiseDomain,
													Set ElementAt 1 of tmpselectedManagerLink to selectedManagerLink,
													Dialog bwfIdentityDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode,
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramIdentityUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdatemanagers)
				                        		}
				                        	feature:identitydetails_updatemanager 
				                        	tooltip:$bw_fragment_identityDetailsNLS.deletemanager
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Identity" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdatemanagers)
				                        	feature:identitydetails_updatemanager 
				                        	tooltip:$bw_fragment_identityDetailsNLS.auditmanager
				                       }
				                  }
				}
			]
			otherwise [
				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical True }
					label:Label { break:True }
					configurable:True
					persist-configuration:True
					hide-header:True
					commands:Commands { position: After orientation: Horizontal
									Command{	
											actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:True
				                        	feature:identitydetails_updatemanager
				                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
				                       }
									Command{	
											actions:Dialog bwfIdentityDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																									selectedExpertiseDomain to paramManagerTypeCode,
																									selectedManagerLink to paramManagerLinkRecorduid,
																									inuid to paramIdentityUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdatemanagers)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:identitydetails_updatemanager 
				                        	tooltip:$bw_fragment_identityDetailsNLS.deletemanager
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Identity" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdatemanagers)
				                        	feature:identitydetails_updatemanager 
				                        	tooltip:$bw_fragment_identityDetailsNLS.auditmanager
				                       }
				                  }
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column: ManagerLinkRecorduid
						hidden: True 
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						initially-masked:True
						sortable:True
					}
					Column {
						column:comment
						header:$bwfManagement.comment
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						initially-masked:True
						sortable:True
					}
				}
			]
		}
	}


	Header {
		value:$bw_fragment.allocation
	}
	Separator {
		width:1
	}					
	ConditionalGroup {
		layout:Layout { grab:horizontal True vertical False }
		IntCondition ( nbAllocations ) {
			when > 1 then [
				Text {
					iterate-on:ownerorgsandjobs
					value: $bw_fragment_identityDetailsNLS.jobandorgs ( Current jobtitledisplayname, Current organisationdisplayname )
					label: $bw_fragment_identityDetailsNLS.jobandorganisation
					compact: True
				}
			] when = 1 then [
				// Only one allocation
				Text {
					value: $bw_fragment_identityDetailsNLS.jobandorgs ( ownerorgandjob.jobtitledisplayname, ownerorgandjob.organisationdisplayname )
					label: $bw_fragment_identityDetailsNLS.jobandorganisation
					compact: True
				}
			] otherwise [
				Text {
					value: $bw_fragment.non.allocation
					compact: True
				}
			]
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the identity details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inshowrisks </b>optional, boolean value, true to show risks indicators (false by default)</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update account description (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentIdentityFullDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable { type: String }
	inenabled = Variable { multivalued: False type: Boolean initial: True }
	inshowrisks = Variable { multivalued: False type: Boolean initial: False }
	incanupdatemanagers = Variable { multivalued:False type:Boolean initial:False }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }
	nbAllocations = Variable { type: Integer }
	
	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	

	tmpselectedManager = Variable { private:True multivalued:True }
	tmpselectedManagerLink = Variable { private: True multivalued:True }
	tmpselectedExpertiseDomain = Variable { private:True multivalued:True }

	/* Datasets here */
	owner = Record {
		view: bwf_identitydetails with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevowner = Record {
		view: bwf_identitydetails with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:
			FromPage ( -1 )
	}
	managers = Dataset {
		view: bwf_identitymanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tags = Dataset {
		view: bwf_identitytags with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tagsasString = Record {
		view: bwa_identitytagsasastring with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	

	
	ownerorgsandjobs = Dataset {
		view: bwf_identityorgandjobs with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		count-variable: nbAllocations
	}
	
	ownerorgandjob = Record {
		view: bwf_identityorgandjobs with
			inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	// IDENTITY INFORMATION
	// ////////////////////////////////
	// Standard mode
	
	IncludeFragment { fragment: fragmentIdentityMaxRiskInfo inline: True }
	
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		// Identity card
		Group {
			Text {
				value: owner.hrcode
				label: Label { styling:bigTitleStyle value: $identity.hrcode }
				compact: True
				styling: bigTitleStyle
				hidden:
					StringPredicate ( owner.hrcode ) {
						when IsEmpty then True
					}
			}
			Text {
				value: owner.givenname
				label: Label { styling:bigTitleStyle value: $identity.givenname }
				compact: True
				hidden:
					StringPredicate ( owner.fullname ) {
						when IsEmpty then False
						otherwise True
					}
			}
			Text {
				value: owner.surname
				label: Label { styling:bigTitleStyle value: $identity.surname }
				compact: True
				hidden:
					StringPredicate ( owner.fullname ) {
						when IsEmpty then False
						otherwise True
					}
			}
			Text {
				value: owner.fullname
				label: Label { styling:bigTitleStyle value: $identity.fullname }
				compact: True
				styling: bigTitleStyle
			}
			Text {
				value: Transform owner.sensitivitylevel using bwfIdentitySensitivityLevelMapping
				tooltip: owner.sensitivityreason
				label: Label{ break: False value: $fragmentIdentityDetailsNLS.sensitivitylevel }
				compact: True
			}
			Text {
				value: @srv_truncatestring (tagsasString.tag to string, 26 to maxlength)
				tooltip: tagsasString.tag
				label: Label { break: False value: $identity.tags }
				compact: True
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog fragmentIdentityTagsEditor (
									inuid to uid, incanupdatetags to canupdatetags
								), 
								ReloadData (owner),
								ReloadData (tags),
								ReloadData (tagsasString)
							icon: %collection_16.tag
							feature: identitydetails_updatetags
							disabled:
								Not BooleanPredicate ( incanupdatetags )
							tooltip: $fragmentIdentityDetailsNLS.managetags
						}
					}
			}
			Text {
				value: @srv_truncatestring (owner.description to string, 200 to maxlength)
				tooltip: owner.description
				label: Label { break: False value: $identity.description }
				compact: True
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog bwfIdentityDetailsMetadata_Dialog (
									inuid to paramIdentityUid,
									owner.sensitivitylevel to sensitivitylevel,
									owner.sensitivityreason to sensitivityreason,
									owner.description to description
								), 
								ReloadData (owner)
							icon: %collection_16.pencil
							disabled:
								Not BooleanPredicate ( incanupdatedescription )
							feature: accountdetails_updatemetadata
							tooltip: $fragmentIdentityDetailsNLS.updatemetadata
						}
					}
			}
		}
		// Indicators
		Group {
			Grid {
				columns: GridColumn {}, GridColumn {}, GridColumn {}
				GridRow {
					height: 46
					GridCell {
						IncludeFragment {
							fragment: bw_fragments_detailKPI with
								value-of $bwf_identityNLS.riskrank to title,
								value-of owner.bwa_identityanalytics_aggriskrank to count,
								value-of UserVariable identities_maxriskinfo_max_riskrank to maxValue,
								value-of owner.bwa_identityanalytics_aggriskrank to currentTrend,
								value-of prevowner.bwa_identityanalytics_aggriskrank to previousTrend,
								value-of inuid to inuid,
								value-of inshowrisks to inshowrisks
						}
					}
					GridCell {
						IncludeFragment {
							fragment: bw_fragments_detailKPI with
								value-of $bwf_identityNLS.maxrisk to title,
								value-of owner.bwa_identityanalytics_aggmaxrisklevel to count,
								value-of UserVariable identities_mawriskinfo_max_risklevel to maxValue,
								value-of owner.bwa_identityanalytics_aggmaxrisklevel to currentTrend,
								value-of prevowner.bwa_identityanalytics_aggmaxrisklevel to previousTrend,
								value-of inuid to inuid,
								value-of inshowrisks to inshowrisks,
								value-of True to hasThresholds
						}
					}
					GridCell {
						IncludeFragment {
							fragment: bw_fragments_detailKPI with
								value-of $bwf_identityNLS.nbrisk to title,
								value-of owner.bwa_identityanalytics_aggnbrisks to count,
								value-of UserVariable identities_mawriskinfo_max_nbrisks to maxValue,
								value-of owner.bwa_identityanalytics_aggnbrisks to currentTrend,
								value-of prevowner.bwa_identityanalytics_aggnbrisks to previousTrend,
								value-of inuid to inuid,
								value-of inshowrisks to inshowrisks
						}
					}
				}
			}
		}
	}
	Flow {
		disposition: Horizontal
		Group {
			title: $bw_fragment.status
			Flow {
				disposition: Horizontal
				Group {
					Text {
						value: owner.employeetypedisplayname
						label: $bw_fragment_identityDetailsNLS.employeetype
						compact: True
					}
					Text {
						value: Transform owner.active using booleanDisplayMapping
						label: $identity.active // Active
						compact: True
						decorator:
							Decorator {
								width: 32
								after:
									Image {
										image: TemplateImageSelection ( owner.active ) using bw_fragments_baderBoolImageMapping
										width: 16
									}
								gap: 16
							}
					}
					Text {
						value: SubString(0,10) owner.arrivaldate
						label: $identity.arrivaldate
						compact: True
						tooltip: owner.arrivaldate
						styling:DateStyling(owner.arrivaldate) {
							when DateAfter Date(PageTimeslot.CommitDate) then bwf_warningNG
							otherwise default
						}
					}
				}
				Group {
					// Layout
					Text {
						value: ''
						compact: True
					}
					Text {
						value: Transform owner.internal using booleanDisplayMapping
						label: $identity.internal // Internal
						compact: True
					}
					Text {
						value: SubString(0,10) owner.departuredate
						label: $identity.departuredate
						compact: True
						tooltip: owner.departuredate 
						styling:DateStyling(owner.departuredate) {
							when DateBefore Date(PageTimeslot.CommitDate) then bwf_warningNG
							otherwise default
						}
					}
				}
			}
		}
		Group {
			title: $bw_fragment.about // Contact?
			Flow {
				disposition: Horizontal
				Grid {
					columns:GridColumn,GridColumn
					GridRow {
						GridCell {
							span:2

							Text {
								value: owner.mail
								label: $identity.mail
								compact: True
							}
						}
					}
					GridRow {
						GridCell {
							Text {
								value: owner.titledisplayname // Title
								label: $identity.titledisplayname
								compact: True
							}
							Text {
								value: owner.nickname
								label: $identity.nickname
								compact: True
							}
							Text {
								value: owner.mobile
								label: $identity.mobile
								compact: True
							}
						}
						GridCell {
							Text {
								value: owner.middlename
								label: $identity.middlename
								compact: True
							}
							Text {
								value: owner.altname
								label: $identity.altname
								compact: True
							}
							Text {
								value: owner.phone
								label: $identity.phone
								compact: True
							}
						}
					}
				}
			}
		}
	}
	Group {
		title: $identity.directboss // Direct Line Manager
		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$bw_fragment_identityDetailsNLS.nomanagers			
						commands: Commands {
							position: After orientation: Vertical
							Command{	
									actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdatemanagers)
		                        	feature:identitydetails_updatemanager
		                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
		                       }
						}
					}
				]
				when =1 then [
					Text {
						iterate-on: managers
						value: Concat(Current fullname, ' (', Current expertisedomaindisplayname, ')') 	
						compact:True		

						commands:Commands { position: After orientation: Horizontal
										Command{	
												actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:True
					                        	feature:identitydetails_updatemanager
					                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
					                       }
										Command{	
												actions:
												TransferData managers(uid, expertisedomaincode, ManagerLinkRecorduid) to (tmpselectedManager, tmpselectedExpertiseDomain, tmpselectedManagerLink), // complex stuff to fulfill selectedManager as a workaround because "Current uid" does not work
													Set ElementAt 1 of tmpselectedManager to selectedManager,
													Set ElementAt 1 of tmpselectedExpertiseDomain to selectedExpertiseDomain,
													Set ElementAt 1 of tmpselectedManagerLink to selectedManagerLink,
													Dialog bwfIdentityDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode,
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramIdentityUid),
													ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdatemanagers)
					                        		}
					                        	feature:identitydetails_updatemanager 
					                        	tooltip:$bw_fragment_identityDetailsNLS.deletemanager
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Identity" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdatemanagers)
					                        	feature:identitydetails_updatemanager 
					                        	tooltip:$bw_fragment_identityDetailsNLS.auditmanager
					                       }
					                  }
					}
				]
				otherwise [
					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical True }
						label:Label { break:True }
						configurable:True
						persist-configuration:True
						hide-header:True
						commands:Commands { position: After orientation: Horizontal
										Command{	
												actions:Dialog bwfIdentityDetailsAddManager_Dialog(	inuid to paramIdentityUid ),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:True
					                        	feature:identitydetails_updatemanager
					                        	tooltip:$bw_fragment_identityDetailsNLS.addmanager
					                       }
										Command{	
												actions:Dialog bwfIdentityDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode,
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramIdentityUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdatemanagers)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:identitydetails_updatemanager 
					                        	tooltip:$bw_fragment_identityDetailsNLS.deletemanager
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Identity" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdatemanagers)
					                        	feature:identitydetails_updatemanager 
					                        	tooltip:$bw_fragment_identityDetailsNLS.auditmanager
					                       }
					                  }
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column: ManagerLinkRecorduid
							hidden: True 
							selection: selectedManagerLink
						}
						Column {
							column:expertisedomaincode
							hidden:True
							selection:selectedExpertiseDomain
						}
						Column {
							column:expertisedomaindisplayname
							text:Transform Current expertisedomaincode using bwfManagerTypeMapping
							header:$bwfManagement.type
							sortable:True
							width:140px
						}
						Column {
							column:hrcode
							header:$identity.hrcode
							initially-masked:True
							sortable:True
						}
						Column {
							column:fullname
							header:$identity.fullname
							sortable:True
							width:100%
						}
						Column {
							column:internal
							header:$pidentity.internal
							initially-masked:True
							sortable:True
						}
						Column {
							column:active
							header:$pidentity.active
							initially-masked:True
							sortable:True
						}
						Column {
							column:comment
							header:$bwfManagement.comment
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegation
							header:$bwfManagement.delegated
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegationreason
							header:$bwfManagement.^reason
							initially-masked:True
							sortable:True
						}
						Column {
							column:_priority
							header:$bwfManagement.^priority
							initially-masked:True
							sortable:True
						}
						Column {
							column:startdate
							header:$bwfManagement.startdate
							initially-masked:True
							sortable:True
						}
						Column {
							column:enddate
							header:$bwfManagement.enddate
							initially-masked:True
							sortable:True
						}
					}
				]
			}
		}
	}
	Group {
		title: $bw_fragment.allocation
		
		ConditionalGroup {
			IntCondition ( nbAllocations ) {
				when > 1 then [
					Text {
						iterate-on:ownerorgsandjobs
						value: $bw_fragment_identityDetailsNLS.jobandorgs ( Current jobtitledisplayname, Current organisationdisplayname )
						label: $bw_fragment_identityDetailsNLS.jobandorganisation
						compact: True
					}
				] when = 1 then [
					// Only one allocation
					Text {
						value: $bw_fragment_identityDetailsNLS.jobandorgs ( ownerorgandjob.jobtitledisplayname, ownerorgandjob.organisationdisplayname )
						label: $bw_fragment_identityDetailsNLS.jobandorganisation
						compact: True
					}
				] otherwise [
					Text {
						value: $bw_fragment.non.allocation
						compact: True
					}
				]
			}
		}
	}
}
