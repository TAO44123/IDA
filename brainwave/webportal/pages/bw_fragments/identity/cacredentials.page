/* Import other pages here */
import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/preferences/globalpreferences.page"

fragmentIdentityCACredentialsNLS = NLS {
	empty [en "Identity doesn't have access to CyberArk credentials" fr "Cette identité n'a pas d'accès à des secrets CyberArk"]
	description [en "description" fr "description"]
	safe [ en "Safe" fr "Safe"]
	user [ en "User" fr "Utilisateur"]
	credential [ en "Credential" fr "Secret"]
	platform [ fr "Plateforme" en "Platform" ]
		
}


fragmentIdentityCACredentials = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	enter-event: Set nb_credential.nb_credentials to outnbcredentials
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	intype = Variable {multivalued: True}
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	outaccountuid = Variable
	outaccountlogin = Variable
	outpermissionuid = Variable
	outpermissionname = Variable
	
	outapplicationuid = Variable
	
	outcredentialuid = Variable
	outsafeuid = Variable
	
	outnbcredentials = Variable
	
	/* Dataset here */
	nb_credential = Record {
		view: bwf_cahascredentials with inuid to uid
		disabled:Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))		 
	}
	
	credentials = Dataset {
		//TODO: missing view / error with view? 
		view: bwf_identitycacredentials with inuid to uid
		trend: Trend { 
			join-column: key
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		disabled:
			OrPredicate {
				Not FeaturePredicate All(pam_license, Any(governance_license, compliance_license))		 
				IntPredicate(outnbcredentials){when = 0 then True otherwise False}
			}
		//count-variable: outnbcredentials	
	}
	
	goToDetailsCredential = NamedAction (
		GoTo Activity CACredential Detail with outcredentialuid to paramSecretUid save-state
	)
	goToDetailsSafe = NamedAction (
		GoTo Activity CASafe Detail with outsafeuid to paramSafeUid save-state
	)
	
	Table {
		data:credentials
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		show-count:True
		show-filter:True
		persist-configuration:True
		
		Column {
			column:accountuid
			hidden:True
			selection:outaccountuid
		}
		Column {
			column:credentialuid
			hidden:True
			selection:outcredentialuid
		}
		Column {
			column:safeuid
			hidden:True
			selection:outsafeuid
		}
		Column {
			column:safedisplayname
			header: $fragmentIdentityCACredentialsNLS.safe
			width: 100%
			actions: ExecuteNamedAction goToDetailsSafe
		}
		Column {
			column:accountlogin
			header:$fragmentIdentityCACredentialsNLS.user
			sortable:True
			filterable:True
			selection:outaccountlogin
			width: 100%
		}
		
		Column { 
			column: credentialcustom3
			header: $fragmentIdentityCACredentialsNLS.platform
			sortable:True
			filterable:True
			width: 100%
			actions: ExecuteNamedAction goToDetailsCredential
		}
		Column {
			column:credentialdisplayname
			header: $fragmentIdentityCACredentialsNLS.credential
			sortable:True
			filterable:True
			width: 100%
			actions: ExecuteNamedAction goToDetailsCredential
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}
	}
			
		
	
}
