 * 
 * @param uids identity uids
 */
fragmentIdentityBulkRemoveAllTags = Dialog {
	title:$fragmentIdentityTagsEditorNLS.removealltitle
	width:500
	height:150
 	buttons:[CancelButton OkButton {
			actions:
				Set uids to task.uids,
				TaskComplete task
			}
		]

	uids = Variable { multivalued:True }
	
	task = TaskRecord(create "bwa_bulkremoveallidentitytag")

	Header {
		value:$fragmentIdentityTagsEditorNLS.removeallconfirmation(SizeOf uids)
	}
}

/**
 * Remove a tag from selected identities
 * 
 * @param uids identity uids
 */
fragmentIdentityBulkRemoveTag = Dialog {
	title:$fragmentIdentityTagsEditorNLS.removetitle
	width:500
	height:150
 	buttons:[CancelButton OkButton {
			disabled:StringPredicate(tag) { when IsEmpty then True }
			actions:
				Set uids to task.uids,
				Set tag to task.tag,
				TaskComplete task
			}
		]

	identitySearch = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}

	uids = Variable { multivalued:True }
	tag = Variable { multivalued:False }

	task = TaskRecord(create "bwa_bulkremoveallidentitytag")
	taglist = Dataset {
		search: Search {
			definition: identitySearch
			view:bwa_identitytagsfromsearch
		}
	}
	
	Combo {
		variable:tag
		allow-none:True
		label:Label { break:True value:$fragmentIdentityTagsEditorNLS.removepicker }
		options:Dynamic {
			data:taglist
			text:Current tag		
			value:Current tag		
		}
	}
}

/*
 * Bulk add a new tag for identities
 * 
 * @param uids selected identities
 */
fragmentIdentityBulkAddTag = Dialog {
	title:$fragmentIdentityTagsEditorNLS.addtitle
	width:400
	height:200
 	buttons:[CancelButton OkButton {
			disabled:
					OrPredicate {
						AndPredicate {
							Not BooleanPredicate(createtag)
							StringPredicate(existingtag) { when IsEmpty then True }
						}
						AndPredicate {
							BooleanPredicate(createtag)
							Not BooleanPredicate(valid)
						}
					}
			actions:
					Confirm $fragmentIdentityTagsEditorNLS.addconfirmation(SizeOf uids),
					BooleanCase(createtag) {
						when True then [
							Set Eval "newtag.get().toUpperCase()" to task.tag
						]
						when False then [
							Set existingtag to task.tag
						]
					},
					Set uids to task.identities,
					TaskComplete task
			}
		]

	uids = Variable

	newtag = Variable {private:True}
	existingtag = Variable {private:True}
	valid = Variable {private:True}
	createtag = Variable { type:Boolean }
		
	task = TaskRecord(create "bwa_bulkaddidentitytag")
	alltags = Dataset {
		view:bwf_identityalltags
	}

	Checkbox {
		variable:createtag
		text:$fragmentIdentityTagsEditorNLS.createnewtag
	}

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentIdentityTagsEditorNLS.addsyntaxerror
		validity:valid
		hidden:Not BooleanPredicate(createtag)
	}
	Combo {
		variable:existingtag
		allow-none:False
		options:Dynamic {
			data:alltags
			text:Current tag
			value:Current tag
		}
		hidden:BooleanPredicate(createtag)
	}
}

/*
 * INTERNAL dialog box used by fragmentIdentityTagsEditor
 * 
 * @param 
 */
fragmentIdentityNewTag = Dialog {
	title:$fragmentIdentityTagsEditorNLS.addtitle
	width:400
	height:150
	enter-event:Set Join alltags using "|" to alltagsoneline
 	buttons:[CancelButton OkButton {
			disabled:
				OrPredicate {
					Not BooleanPredicate(valid)
					BooleanPredicate(Eval "alltags.indexOf(newtag.get().toUpperCase())!=-1")
				}
			actions:
				TransferData tags(tag) to (identitytags),
				MultivaluedAdd Eval "newtag.get().toUpperCase()" to identitytags,
				 Set identitytags to task.tags,
					Set uid to task.identity,
					TaskComplete task wait-end,
					Flash $fragmentIdentityTagsEditorNLS.flash
			}
		]

	uid = Variable
	alltags = Variable { multivalued:True }
	newtag = Variable

	alltagsoneline = Variable { multivalued:False private:True }
	valid = Variable { private:True }
	identitytags = Variable { multivalued:True private:True }

	tags = Dataset {
		view:bwf_identitytags with uid to uid
	}
	
	task = TaskRecord(create "bwa_updateidentitytags")

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentIdentityTagsEditorNLS.addsyntaxerror
		validity:valid
	}	
}

/**
 * Edit identity tags
 *
 * @param uid identity uid
 * @param canupdatetags True to enable tags update (false by default)
 */
fragmentIdentityTagsEditor = Dialog {
	title:$fragmentIdentityTagsEditorNLS.title
	buttons:[	CancelButton 
				OkButton {
					disabled:Not BooleanPredicate(canupdatetags)
					actions:
							BooleanCase(added) {
								when True then [
								]
								when False then [
									Set currenttags to task.tags,
									Set uid to task.identity,
									TaskComplete task wait-end,
									Flash $fragmentIdentityTagsEditorNLS.flash
								]
							}
				} 
			]
	width:450
	height:200
	enter-event:TransferData tags(tag) to (currenttags), TransferData alltags(tag) to (alltags) 
	
	uid = Variable
	canupdatetags = Variable { type:Boolean initial:False }

	currenttags = Variable { multivalued:True private:True }
	alltags = Variable { multivalued:True private:True }
	newtag = Variable {private:True }
	modified = Variable {private:True }
	added = Variable {private:True }
	
	tags = Dataset {
		view:bwf_identitytags with uid to uid
	}
	alltags = Dataset {
		view:bwf_identityalltags
	}
	
	atags = Dataset {
		columns:alltags as tag
	}

	task = TaskRecord(create "bwa_updateidentitytags")

	Combo {
		variable:currenttags
		multi-selection:True
		disabled:Not BooleanPredicate(canupdatetags)
		options:Dynamic {
			data:atags
			text:Current tag
			value:Current tag
		}
		commands:Commands {
			position:After
			orientation:Vertical
			Command {
				actions:Set True to added,
						Dialog fragmentIdentityNewTag(uid to uid, alltags to alltags, newtag from newtag), 
						CloseDialog Ok
				icon:%status_16.add
				disabled:Not BooleanPredicate(canupdatetags)
				tooltip:$fragmentIdentityTagsEditorNLS.newtag
			}
			Command {
				actions:Message "NOP"
				disabled:True
				icon:''
			}
		}
	}	
}

