}

bwfIdentitySensitivityLevelMapping = StringMapping {
	when "0" then $bwfIdentitySensitivityLevel_NLS.notclassified
	when "1" then $bwfIdentitySensitivityLevel_NLS.low
	when "2" then $bwfIdentitySensitivityLevel_NLS.medium
	when "3" then $bwfIdentitySensitivityLevel_NLS.high
	when "4" then $bwfIdentitySensitivityLevel_NLS.extreme
	otherwise $bwfIdentitySensitivityLevel_NLS.notclassified

}

/**
 * Update identity description
 * 
 * @param paramIdentityUid identity uid
 */
bwfIdentityDetailsMetadata_Dialog = Dialog {
	title: $bwfIdentityDetailsMetadata_Dialog_NLS.title
	enter-event:Set sensitivitylevel to initialsensitivitylevel
	buttons:[
	
		OkButton {
			disabled:
				OrPredicate {
					StringPredicate(changed) {when '1' then False otherwise True}
					AndPredicate {
						IntPredicate(sensitivitylevel) { when >0 then True otherwise False }
						Not BooleanPredicate(reasonisvalid) 
					}
					StringPredicate(description) { when IsEmpty then True otherwise False }
				}
			actions:Set description to task.description,
					Set sensitivityreason to task.sensitivityreason,
					Set sensitivitylevel to task.sensitivitylevel,
					Set paramIdentityUid to task.uid,
					Set Eval "sensitivitylevel.get()!=initialsensitivitylevel.get() && sensitivitylevel.get()!=0" to task.manualsensitivitylevel, // if value is changed, flag it as a manual sensitivity level
					TaskComplete task wait-end,
					Flash $bwfIdentityDetailsMetadata_Dialog_NLS.done
		} 
	
		CancelButton
	]
	
	width:800
	height:270
	
	/* Parameters here */
	paramIdentityUid = Variable {type:String multivalued:False}

	description = Variable
	initialsensitivitylevel = Variable
	sensitivitylevel = Variable
	sensitivityreason = Variable
	ismanaged = Variable { type:Boolean }
	
	selecteddescription = Variable { private:True }
	changed = Variable{type:String initial:'0' private:True }
	reasonisvalid = Variable

	task = TaskRecord (create "bwf_updateidentitymetadata")
	

	Header {
		value:$bwfIdentityDetailsMetadata_Dialog_NLS.description
		styling:subtitleStyle
	}
	Separator
	Combo {
		variable:sensitivitylevel
		label:$bwfIdentityDetailsMetadata_Dialog_NLS.sensitivitylevel
		modify-event:Set '1' to changed, IntCase(sensitivitylevel) { when =0 then [ Set '-' to sensitivityreason] }
		options:Static {
			Option {
				text:Transform "0" using bwfIdentitySensitivityLevelMapping
				value:0
			}
			Option {
				text:Transform "1" using bwfIdentitySensitivityLevelMapping
				value:1
			}
			Option {
				text:Transform "2" using bwfIdentitySensitivityLevelMapping
				value:2
			}
			Option {
				text:Transform "3" using bwfIdentitySensitivityLevelMapping
				value:3
			}
			Option {
				text:Transform "4" using bwfIdentitySensitivityLevelMapping
				value:4
			}
		}
	}
	Edit {
		variable:sensitivityreason
		label:$bwfIdentityDetailsMetadata_Dialog_NLS.sensitivityreason
		modify-event:Set '1' to changed
		not-empty:True
		match:'[0-9a-zA-z].+'
		validity:reasonisvalid
		limit:2000
		error-tooltip:$bwfIdentityDetailsMetadata_Dialog_NLS.sensitivityreasonvalid
		hidden:IntPredicate(sensitivitylevel) { when =0 then True otherwise False }
	}
	Edit {
		variable:description
		label:$bwfIdentityDetailsMetadata_Dialog_NLS.descriptionlabel
		multi-lines:True
		limit:2000
		layout:Layout{grab: horizontal True vertical False hint:height 64}
		modify-event:Set '1' to changed
		not-empty:True
	}	
}

/**
 * Add identity manager
 * 
 */
bwfIdentityDetailsAddManager_Dialog = Dialog {
	title: $bwfIdentityDetailsManager_Dialog_NLS.title
	enter-event:IntCase(Count managertypes) { when >0 then [ TransferData managertypes(expertisedomaincode, expertisedomaindisplayname) to (managertypeslist, managertypeslistlabel) ] }
	buttons:[ 
				OkButton {
						disabled:StringPredicate(newmanagerUid) { when IsEmpty then True otherwise False }
						actions:
							Confirm $bwfIdentityDetailsManager_Dialog_NLS.newmanagerconfirm( Transform newManager.hrcode using mayBeNullMapping, newManager.fullname, Transform newManagertype using bwfManagerTypeMapping, identity.fullname),
							Set newManagertype to task.managertype,
							Set paramIdentityUid to task.identity,
							Set newmanagerUid to task.manager,
							Set newcomment to task.comments,
							Set delegation to task.delegation,
							Set _priority to task.delegationpriority,
							Set _reason to task.delegationreason,
							Set Date(startdate).valueLDAP to task.delegationbegindate,
							Set Date(enddate).valueLDAP to task.delegationenddate,
							Set 'create' to task.action,
							TaskComplete task wait-end,
							Flash Information $bwfIdentityDetailsManager_Dialog_NLS.confirmupdate
						}
				CancelButton
			]
	width:800
	height:430
	
	/* Parameters here */
	paramIdentityUid = Variable {type:String multivalued:False}
	newManagertype = Variable {type:String multivalued:False private:True}
	newmanagerUid = Variable {type:String multivalued:False private:True}
	newcomment = Variable {type:String multivalued:False private:True initial:' '}

	delegation = Variable {type:Boolean multivalued:False private:True initial:False}
	_priority = Variable {type:Integer multivalued:False private:True initial:0}
	_reason = Variable {type:String multivalued:False private:True initial:' '}
	startdate = Variable {type:Date multivalued:False private:True initial:Date.value}
	enddate = Variable {type:Date multivalued:False private:True initial:Date.offset(10 years).value}
	
	managertypeslist = Variable {type:String multivalued:True initial:['manager'] private:True}
	managertypeslistlabel = Variable {type:String multivalued:True initial:['manager'] private:True}
	
	/* Datasets and records here */
	// Record for concept details
	managertypes = Dataset {
		view:bwf_identitylinemanagertypes
	}
	managertypeslistDS = Dataset {
		columns:managertypeslist, managertypeslistlabel
	}
	
	identity = Record {
		view: br_identityDetail with paramIdentityUid to uid
	}
	
	newManager = Record {
		view: br_identityDetail with newmanagerUid to uid
	}

	task = TaskRecord (create "bwf_updateidentitymanager")
	
	
	/* Page content */
	
	Header {
		value:$bwfIdentityDetailsManager_Dialog_NLS.title
		styling:bigTitleStyle
	}
	Separator {
	}
	Combo {
		label:$bw_fragment_updatemanagerNLS.managertype
		variable:newManagertype
		layout:Layout { grab:horizontal False vertical False hint:width 280 }
		disabled:IntPredicate(Count managertypeslistDS) { when =1 then True }
		options:Dynamic {
			data:managertypeslistDS
			text:Current managertypeslistlabel
			value:Current managertypeslist
		}
	}
	Text {
		label:$bw_fragment_updatemanagerNLS.manager
		value:newManager.fullname
		layout:Layout { grab:horizontal False vertical False hint:width 280 }
		commands: Command {	
				actions:Dialog identityPicker(newmanagerUid from outUid)
            	icon:%concept_16.manager
            	tooltip:$bw_fragment_updatemanagerNLS.managertooltip
           }
	}
	Edit {
		label:$bw_fragment_updatemanagerNLS.comments
		variable:newcomment
	}
		Checkbox {
			variable:delegation
			label:$bw_fragment_updatemanagerNLS.delegatedmanager
			tooltip:$bw_fragment_updatemanagerNLS.delegatedmanagertooltip
			text:$bw_fragment_updatemanagerNLS.isdelegated
		}
	Group {
		title:$bw_fragment_updatemanagerNLS.delegationdetails
		Edit {
			variable:_reason
			label:$bw_fragment_updatemanagerNLS._reason
			tooltip:$bw_fragment_updatemanagerNLS._reasontooltip
			disabled:Not BooleanPredicate(delegation)
		}
		Spinner {
			variable:_priority
			label:$bw_fragment_updatemanagerNLS._priority
		layout:Layout { grab:horizontal False vertical False hint:width 130 }
			tooltip:$bw_fragment_updatemanagerNLS._prioritytooltip
			minimum:0
			maximum:9
			disabled:Not BooleanPredicate(delegation)
		}
		/*
		DateTime {
			variable:startdate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updatemanagerNLS.begindate
			type:Date
			tooltip:$bw_fragment_updatemanagerNLS.begindatetooltip
			disabled:Not BooleanPredicate(delegation)
		}	
		DateTime {
			variable:enddate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updatemanagerNLS.enddate
			tooltip:$bw_fragment_updatemanagerNLS.enddatetooltip
			type:Date
			disabled:Not BooleanPredicate(delegation)
		}
		*/
	}
}

