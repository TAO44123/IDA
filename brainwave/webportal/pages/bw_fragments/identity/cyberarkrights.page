/**
 * <span style="white-space: pre-line">
 * Display the CyberArk Vaults rights for a given identity
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>intype </b>the permission types (Role by default)</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate permissions details list through GUI</li>
 * <li><b>inapplicationuids </b>optional filter to display only some applications</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outapplicationuid </b>the selected application uid</li>
 * <li><b>outapplicationname </b>the selected application name</li>
 * <li><b>outpermissionuid </b>the selected permission uid  </li>
 * <li><b>outpermissionname </b>the selected permission name</li>
 * </ul>
 * </span>
 */
fragmentIdentityCAVaultsRights360 = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
