fragmentIdentityCAGraphRights360 = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	inuid = Variable
	innbsafes = Variable { type: Integer }
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	outSelectionType = Variable

	outSelectedcode = Variable
	outSelectedlabel = Variable
	outSelectedGroup = Variable
	
	outFromNode = Variable
	outToNode = Variable
	
	accountuid = Variable
	lastreconrecorduid = Variable

	dataviz = Dataset {
		view:bwcpam_tree_identity_ca with inuid to identity_uid, innbsafes to nbsafes
		disabled:OrPredicate{
			Not BooleanPredicate(inenabled)
			StringPredicate(inuid) {
				when IsEmpty then True
				otherwise False
			}
		}
	}
	
	lastrecon = Record {
		view: br_reconciliation_recent with accountuid to accountuid
	}

	IncludeHTMLWidget {
		layout: Layout { grab:horizontal True vertical True }
		template: network
		datasets:dataviz(target_uid, target_code, target_family, target_tooltip, source_uid, node, edge) to chartdata(code, label, group, description, parentcode, nodeattributes, edgeattributes)
		bindings:
			value-of False to hierarchical,
			value-of 'box' to shape,
			value-of 'LR' to hierarchical_direction,// UD, DU, LR, RL
			value-of 2000 to textboxsize,
			value-of True to navigationButtons
		widget-events: {
			when onclick then [
				Set 'node' to outSelectionType,
				Set Current code to outSelectedcode,
				Set Current label to outSelectedlabel,
				Set Current group to outSelectedGroup,
				Set '' to outFromNode,
				Set '' to outToNode,
				StringCase ( Current group ) {
					when "GROUP" then [ 
						Dialog bwf_groupDetailsDialog ( Current code to inuid )
					]
					when "ACCOUNT" then [ 
						Set Current code to accountuid,
						Set lastrecon.recorduid to lastreconrecorduid, ReloadData ( lastrecon ),
						Dialog bwf_accountDetailsDialog ( Current code to inuid , True to incanreconcile ),
						ReloadData ( lastrecon ),
						BooleanCase using SameValuePredicate ( lastrecon.recorduid , lastreconrecorduid ) in {
							when False then [
								ReloadData ( dataviz )
							]
							when True then []
						}
					]
					when "IDENTITY" then [ 
						Dialog bwf_identityDetailsDialog ( Current code to inuid )
					]
					when "ca_safe" then [ 
						Dialog bwf_casafeDetailsDialog ( Current code to inuid )
					]
					when "ca_vault" then [ 
						Dialog bwf_cavaultDetailsDialog ( Current code to inuid )
					]
					when "NBSAFES" then [ 
						Dialog nbSafesDetailsDialog ( Current parentcode to inuid )
					]
					when "NBSAFESACCOUNT" then [ 
						Dialog nbSafesAccountDetailsDialog ( Current parentcode to inuid )
					]
				}
			]
			when onedgeclick then [
				Set 'edge' to outSelectionType,
				Set Current _from to outFromNode,
				Set Current _to to outToNode,
				Set '' to outSelectedcode,
				Set '' to outSelectedlabel,
				Set '' to outSelectedGroup
			]
		}
	}
}

