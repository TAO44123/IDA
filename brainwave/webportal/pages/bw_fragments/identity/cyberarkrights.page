	intype = Variable {multivalued: True}
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inapplicationuids = Variable {multivalued: True}

	outapplicationuid = Variable
	outapplicationname = Variable
	outpermissionuid = Variable
	outpermissionname = Variable
	
	nbvaults = Variable
	
	application = Record {
		view:bwf_applicationDetail with inapplicationuids to uid
	}
	
	appsbyidentity = Dataset {
		view: bwf_cavaultsbyidentity
		with inuid to uid, inapplicationuids to applicationuids unless-empty
		trend: Trend { 
			join-column: uniqappid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			//  value-column: trend
			value-column: const
			
		}
		//disabled: Not BooleanPredicate(inenabled)
		count-variable: nbvaults
	}
	
	permsbyidentity = Dataset {
		view: bwf_capermsbyidentity
		with outapplicationuid to application_uid, inuid to id_uid
		trend: Trend { 
			join-column: perm_uid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: trend
		}
		disabled: Not BooleanPredicate(inenabled)
	}
	
	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid,
													False to inshowaccounts, 
													True to inshowperjob,
													True to inshowperorg
												  )
			]
			when False then [
			
			]
		}
	)

	Header {
		hidden:StringPredicate(inapplicationuids) { when IsEmpty then True otherwise False }
		value:$fragmentIdentityCAVAultsRights360NLS.filteredto(application.displayname)
	}
	ConditionalGroup {
		IntCondition(Count appsbyidentity) {
			when =0 then [
				Header {
					value:$fragmentIdentityCAVaultsRightsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [

				Grid {
					layout: Layout fill: Both 								
					columns: GridColumn { width: 300px }, GridColumn { width: 400px } 
									
					GridRow {
					height:grow
						GridCell {
							Table {	
							data: appsbyidentity
							layout: Layout { grab: horizontal True vertical True }
							label: Label { break: True }
							show-filter: True
							show-count: True
			
							Column {
								column: app_uid
								hidden: True
								selection: outapplicationuid
								}
							Column {
								column: app_displayname
								selection: outapplicationname
								header: $fragmentIdentityCAVAultsRights360NLS.vault
								sortable: True
								filterable: True
								width: 30%
								}
							Column {
								column: acc_login
								header: $account.login
								sortable: True
								filterable: True
								width: 100%
								}
							Column {
						column: trends
								header: $bw_fragment.trends
								text:Transform Current trends using bwf_trendStatusColumn 
								styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
								image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
								tooltip:$bwf_trendStatusColumnNLS.tooltip
		
								sortable: True
								filterable: True
								width: 10%
								}												
							} // End of table
					
					}		
					// Groups by identity and application
					GridCell {
					
					       // Permissions by identity 
					    ConditionalGroup {
					    	IntCondition(application.bwa_applicationanalytics_nbperimeter) {
								when >0 then [
									Table {
										data: permsbyidentity
										layout: Layout { grab: horizontal True vertical True }
										label: Label { break: True }
										show-filter: True
										show-count: True
										configurable:True
										double-click:ExecuteNamedAction goDetails
										
																											
										Column {
											column: perm_uid
											header: $fragmentIdentityCAVAultsRights360NLS.profilecode
											hidden: True
											selection: outpermissionuid
										}
										Column {
											column: acc_login
											header: $account.login
											sortable: True
											filterable: True
											width: 50%
										}
										Column {
											column: perm_permissiontype
											header: $fragmentIdentityCAVAultsRights360NLS.type
											initially-masked:True
											sortable: True
											filterable: True
											width: 5%
										}
										Column {
											column: perm_code
											header: $fragmentIdentityCAVAultsRights360NLS.profilecode
											initially-masked:True
											sortable: True
											filterable: True
											width: 100%
											actions: ExecuteNamedAction goDetails
											actions-disabled: Not BooleanPredicate(incanshowdetails)
											tooltip: $search_page.showdetails
										}
										Column {
											column: perm_displayname
											selection: outpermissionname
											header: $fragmentIdentityCAVAultsRights360NLS.profilename
											sortable: True
											filterable: True
											width: 100%
											actions: ExecuteNamedAction goDetails
											actions-disabled: Not BooleanPredicate(incanshowdetails)
											tooltip: $search_page.showdetails
										}
										Column {
											column: perm_description
											header: $fragmentIdentityCAVAultsRights360NLS.profiledescription
											sortable: True
											filterable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: perm_sensitivitylevel
											header: $fragmentIdentityCAVAultsRights360NLS.sensitivitylevel
											sortable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: perm_sensitivityreason
											header: $fragmentIdentityCAVAultsRights360NLS.sensitivityreason
											sortable: True
											filterable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: action
											header: $fragmentIdentityCAVAultsRights360NLS.action
											sortable: True
											filterable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: limit
											header: $fragmentIdentityCAVAultsRights360NLS.limit
											sortable: True
											filterable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: perimetercode
											header: $fragmentIdentityCAVAultsRights360NLS.perimetercode
											sortable: True
											filterable: True
											width: 100%
											initially-masked:True
										}
										Column {
											column: perimeterdisplayname
											header: $fragmentIdentityCAVAultsRights360NLS.perimetername
											sortable: True
