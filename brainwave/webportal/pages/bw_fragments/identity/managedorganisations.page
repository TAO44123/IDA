/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/styles/styles.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/organisation/details/organisationDetails.page"
import "/webportal/pages/bw_fragments/preferences/globalpreferences.page"

fragmentIdentityManagedOrganisationsNLS = NLS {
	expertisedomain [en "expertise domain" fr "domaine expertise"]
	type [en "organisation type" fr "type organisation"]
	empty [en "Identity does not manage organisations" fr "Cette identité ne gère pas d'organisations"]
}

/**
 * <span style="white-space: pre-line">
 * Display the identity managed organisations in a table
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate organisation details list through GUI</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outselectedorganisationuid </b>selected resource</li>
 * <li><b>outnbmanagedorganisations </b>nb of managed organisations</li>
 * </ul>
 * </span>
 */
fragmentIdentityManagedOrganisations = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outselectedorganisationuid = Variable
	outnbmanagedorganisations = Variable

	ownedOrganisations = Dataset {
		view: bwf_managedorganisations with inuid to uid
		trend: Trend { 
			join-column: organisationuid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		count-variable: outnbmanagedorganisations
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_organisationDetailsDialog(outselectedorganisationuid to inuid, 
												True to inshowsuborganisationtree,
												True to inshowteam,
												True to inshowowner
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition(Count ownedOrganisations) {
			when =0 then [
				Header {
					value:$fragmentIdentityManagedOrganisationsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
			
				Table {
					data: ownedOrganisations
					layout: Layout { grab: horizontal True vertical True }
					label: Label { break: True }
					configurable: True
					show-filter: True
					show-count: True						
					persist-configuration:True
					double-click:ExecuteNamedAction goDetails
					
			
					Column {
						column: organisationuid
						hidden: True
						selection: outselectedorganisationuid
					}
			
					Column {
						column: expertisedomaindisplayname
 						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
 						header: $fragmentIdentityManagedOrganisationsNLS.expertisedomain
						sortable: True
						filterable: True
						width: 20%
					}									
			
					Column {
						column: organisationorganisationtypedisplayname
						header: $fragmentIdentityManagedOrganisationsNLS.type
						initially-masked:True
						sortable: True
						filterable: True
						width: 20%
					}									
					Column {
						column: organisationcode
						header: $organisation.code
						initially-masked:True
						sortable: True
						filterable: True
						width: 60%
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column: organisationshortname
						header: $organisation.shortname
						sortable: True
						filterable: True
						width: 20%
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column: organisationdisplayname
						header: $organisation.displayname
						sortable: True
						filterable: True
						width: 100%
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}									


					Column {
						column: trends
						header: $bw_fragment.trends
						text:Transform Current trends using bwf_trendStatusColumn 
						styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
						image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
						tooltip:$bwf_trendStatusColumnNLS.tooltip

						sortable: True
						filterable: True
						width: 10%
					}												
				}
			]
		}
	}
}