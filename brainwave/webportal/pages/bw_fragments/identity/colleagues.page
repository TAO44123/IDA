fragmentIdentityColleaguesSelectionNLS = NLS {
	direct [en "direct colleagues" fr "collègues directs"]
	_all [en "all colleagues" fr "tous les collègues"]
}
/**
 * <span style="white-space: pre-line">
 * Display the identity colleagues in a table in various forms
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate identity details list through GUI</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outcolleagueuid </b>the selected colleague uid</li>
 * <li><b>outcolleaguefullname </b>the selected colleague fullname </li>
 * </ul>
 * </span>
 */
fragmentIdentityColleaguesSelection = PageFragment {
	enter-event: ExecuteNamedAction updateActiveFlags
	
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outcolleagueuid = Variable
	outcolleaguefullname = Variable

	selection = Variable { private:True initial:'direct' }

	active_direct = Variable { initial:False multivalued:False type:Boolean }
	active_all = Variable { initial:False multivalued:False type:Boolean }

	updateActiveFlags = NamedAction (
		StringCase(selection) {
			when "direct" then [
				Set True to active_direct
			]		
			when "all" then [
				Set True to active_all
			]		
		}
	)

	Combo {
		variable:selection
		layout: Layout { hint: width 300 }
		modify-event:ExecuteNamedAction updateActiveFlags
		options:Static {
			Option { value:"direct" text:$fragmentIdentityColleaguesSelectionNLS.direct }
			Option { value:"all" text:$fragmentIdentityColleaguesSelectionNLS._all }
		}
	}
	ConditionalGroup {
		StringCondition(selection) {
			when "direct" then [
				IncludeFragment (fragmentIdentityColleagues with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of inenabled to inenabled, 
																	outcolleagueuid binds-to outcolleagueuid, 
																	outcolleaguefullname binds-to outcolleaguefullname,
																	value-of Eval "inenabled.get()&&active_direct.get()" to inenabled
																	) 
			]	
			when "all" then [
				IncludeFragment (fragmentIdentityAllColleagues with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of inenabled to inenabled, 
																	outcolleagueuid binds-to outcolleagueuid, 
																	outcolleaguefullname binds-to outcolleaguefullname,
																	value-of Eval "inenabled.get()&&active_all.get()" to inenabled
																	) 
			]	
		}
	}
}