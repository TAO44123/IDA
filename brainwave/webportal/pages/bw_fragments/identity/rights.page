	}
	permissions = HierarchicalData {
		view:bwf_identitypermhierarchywbuckets with inuid to uid, outapplicationuid to applicationuid, infilterbyapplications to applicationuids unless-empty, inlist1uid to list1uid, inlist2uid to list2uid
		initial:parentuid IsNull
		connect:parent uid to child parentuid
		disabled:Not BooleanPredicate(inenabled)
	}

	ConditionalGroup {
		IntCondition(Count application) {
			when =0 then [
				Header {
					value:$fragmentIdentityRightsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Grid {
					columns: GridColumn { width: grow}, GridColumn
					layout: Layout { grab: horizontal True vertical True}
					GridRow {
						hidden: IntPredicate(SizeOf application.uid) { when <= 1 then True otherwise False }
						GridCell {
							Combo {
								layout: Layout {grab: horizontal False vertical True}
								variable:outapplicationuid
								allow-none:True
								options:Dynamic {
									data:application
									text:Current displayname
									value:Current uid
								}
								label: $application.concept
								hidden: IntPredicate(SizeOf application.uid) { when <= 1 then True otherwise False }
							}
						}
						GridCell {
						}
					}
					GridRow {
						height: grow
						GridCell {
							Tree {
								data:permissions
								configurable:True
								show-filter:True
								persist-configuration:True
								expand-level:9
								layout:Layout {grab: horizontal True vertical True }
								Column {
									column:code
									header:$ppermission.code
									sortable:True
									filterable:True
									width:100%
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
								Column {
									column:displayname
									header:$ppermission.displayname
									sortable:True
									filterable:True
									width:100%
									selection:outpermissionname
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
								Column {
									column:applicationdisplayname
									header:$application.concept
									sortable:True
									filterable:True
									width:100%
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
								Column {
									column:accountuid
									hidden:True
									selection:outaccountuid
								}
								Column {
									column:uid
									hidden:True
									selection:outpermissionuid
								}
								Column {
									column:accountlogin
									header:$account.login
									sortable:True
									filterable:True
									selection:outaccountlogin
									width:100%
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
								Column {
									column:accountusername
									header:$account.username
									sortable:True
									filterable:True
									initially-masked:True
									width:100%
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
								Column {
									column:accountlastlogindate
									header:$account.lastlogindate
									sortable:True
									filterable:True
									initially-masked:True
									width:100%
									styling:StylingTemplateSelection (Current isinlist) using fragmentIdentityRightsHierarchywSoDColorsStyle
								}
							}
						}
						GridCell {
							Text { value: "" compact: True}
							Text {
								label: inlist1name
								value: "       "
								styling:fragmentIdentityRightsHierarchywSoDColors1
							}
							Text {
								label: inlist2name
								value: "       "
								styling:fragmentIdentityRightsHierarchywSoDColors2
							}
						}
					}
				}
			]
		}
	}
