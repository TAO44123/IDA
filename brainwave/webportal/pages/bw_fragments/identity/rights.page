/**
 * <span style="white-space: pre-line">
 * Display the rights for a given identity
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>intype </b>the permission types (Role by default)</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid  </li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outpermissionuid </b>the selected permission uid  </li>
 * <li><b>outpermissionname </b>the selected permission name</li>
 * <li><b>outapplicationuid </b>the selected application uid</li>
 * </ul>
 * </span>
 */
fragmentIdentityRights = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	intype = Variable {multivalued: True}
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	outaccountuid = Variable
	outaccountlogin = Variable
	outpermissionuid = Variable
	outpermissionname = Variable
	
	outapplicationuid = Variable
	
	/* Dataset here */
	application = Dataset {
		view: bwf_identityapplications with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	permissions = Dataset {
		view: bwf_identityapprights with
			outapplicationuid to applicationuid,
			inuid to uid,
			intype to permissiontype unless-empty
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	ConditionalGroup {
		IntCondition(Count application) {
			when =0 then [
				Header {
					value:$fragmentIdentityRightsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [

				Combo {
					variable:outapplicationuid
					options:Dynamic {
						data:application
						text:Current displayname
						value:Current uid
					}
					label:Label{break:True value:$application.concept}
				}
				Table {
					data:permissions
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					label:Label{break:True value:$permission.concept}
					persist-configuration:True
					
					Column {
						column:accountuid
						hidden:True
						selection:outaccountuid
					}
					Column {
						column:uid
						hidden:True
						selection:outpermissionuid
					}
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						selection:outaccountlogin
						width:128px
					}
					Column {
						column:accountusername
						header:$account.username
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}
					Column {
						column:action
						header:$right.action
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
					Column {
						column:limit
						header:$right.limit
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
					Column {
						column:code
						header:$ppermission.code
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
					Column {
						column:displayname
						header:$ppermission.displayname
						sortable:True
						filterable:True
						width:160px
						selection:outpermissionname
					}
					Column {
						column:description
						header:$fragmentIdentityRightsNLS.description
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
				}
			]
		}
	}
}

