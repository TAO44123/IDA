/**
 * <span style="white-space: pre-line">
 * Display all the rights for a given identity in a form of a hierarchy
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>infilterbyapplications </b>application uids in order to filter the results for some applications only</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid  </li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outpermissionuid </b>the selected permission uid  </li>
 * <li><b>outpermissionname </b>the selected permission name</li>
 * <li><b>outapplicationuid </b>the selected application uid</li>
 * </ul>
 * </span>
 */
fragmentIdentityRightsHierarchy = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	infilterbyapplications = Variable {multivalued: True}
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	outaccountuid = Variable
	outaccountlogin = Variable
	outpermissionuid = Variable
	outpermissionname = Variable
	
	outapplicationuid = Variable
	
	/* Dataset here */
	application = Dataset {
		view:bwf_identityapplications with inuid to uid
		 disabled:Not BooleanPredicate(inenabled)
		 includes:OrPredicate {
		 	StringPredicate(infilterbyapplications) { when IsEmpty then True otherwise False }
		 	MultivaluedPredicate(infilterbyapplications contains Current uid)
		 }
	}
	permissions = HierarchicalData {
		view:bwf_identitypermhierarchy with inuid to uid, outapplicationuid to applicationuids unless-empty
		initial:parentuid IsNull
		connect:parent uid to child parentuid
		disabled:Not BooleanPredicate(inenabled)
	}

	ConditionalGroup {
		IntCondition(Count application) {
			when =0 then [
				Header {
					value:$fragmentIdentityRightsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Combo {
					variable:outapplicationuid
					allow-none:True
					options:Dynamic {
						data:application
						text:Current displayname
						value:Current uid
					}
					label:Label{break:True value:$application.concept}
				}
				Tree {
					data:permissions
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					label:Label{break:True value:$permission.concept}
					persist-configuration:True
					expand-level:9
					Column {
						column:code
						header:$ppermission.code
						sortable:True
						filterable:True
						width:160px
					}
					Column {
						column:displayname
						header:$ppermission.displayname
						sortable:True
						filterable:True
						width:100%
						selection:outpermissionname
					}
					Column {
						column:applicationdisplayname
						header:$application.concept
						sortable:True
						filterable:True
						width:160px
					}
					Column {
						column:accountuid
						hidden:True
						selection:outaccountuid
					}
					Column {
						column:uid
						hidden:True
						selection:outpermissionuid
					}
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						selection:outaccountlogin
						width:128px
					}
					Column {
						column:accountusername
						header:$account.username
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}
				}
			]
		}
	}
}

