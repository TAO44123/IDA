/**
 * <span style="white-space: pre-line">
 * Display the identity team giving an option to choose the links used to display the team
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inindirecteam </b>shows also indirect team (False by defaut)</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate identity details list through GUI</li>
 * <li><b>inshowdetailpage </b>if incanshowdetails is true, can ask to jump to the identity detail page instead of displaying infos as a dialog box</li>
 * <li><b>incancompare</b> optional, boolean value, true to enable comparison button (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outcolleagueuid </b>the selected colleague uid</li>
 * <li><b>outcolleaguefullname </b>the selected colleague fullname </li>
 * </ul>
 * </span>
 */
fragmentIdentityTeamSelection = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inshowdetailpage = Variable { multivalued:False type:Boolean initial:False }
	inindirectteam = Variable { multivalued:False type:Boolean initial:False }
	incancompare = Variable { type:Boolean initial:False }
	outcolleagueuid = Variable
	outcolleaguefullname = Variable
	orgteam_count = Variable
	team_count = Variable
	initialteamlink = Variable { multivalued:False initial:"identitymanager" }
	
	team = Dataset {
		view: bwf_identityteam with
			inuid to uid,
			False to indirectteam
		//disabled: Not BooleanPredicate(inenabled)
		count-variable: team_count
	}
	orgteamcount = Dataset {
		view: bwf_identityorgteam with
			inuid to uid,
			False to indirectteam
		//disabled: Not BooleanPredicate(inenabled)
		count-variable: orgteam_count
	}
	
	Combo {
		variable: initialteamlink
		allow-none: False
		layout: Layout { hint: width 300 }
		label: $fragmentIdentityTeamNLS.joinlabel
		options: Static {
			Option {
				text: $fragmentIdentityTeamNLS.joinoption.identitymanager
				value: "identitymanager"
			}
			Option {
				text: $fragmentIdentityTeamNLS.joinoption.orgmanager
				value: "orgmanager"
			}
		}
		hidden: IntPredicate ( orgteam_count ) { when > 0 then False otherwise True }
	}
							
	ConditionalGroup {
		StringCondition(initialteamlink) {
			when "identitymanager" then [
				IncludeFragment {
					fragment: fragmentIdentityManagerTeam
					with 	value-of inuid to inuid,
							value-of inenabled to inenabled,
							value-of incanshowdetails to incanshowdetails,
							value-of inindirectteam to inindirectteam,
							value-of incancompare to incancompare,
							value-of inshowdetailpage to inshowdetailpage,
							outcolleagueuid binds-to outcolleagueuid,
							outcolleaguefullname binds-to outcolleaguefullname
				}
			]									
			when "orgmanager" then [
				IncludeFragment {
					fragment: fragmentIdentityOrganisationManagerTeam
					with 	value-of inuid to inuid,
							value-of inenabled to inenabled,
							value-of incanshowdetails to incanshowdetails,
							value-of inindirectteam to inindirectteam,
							value-of incancompare to incancompare,
							value-of inshowdetailpage to inshowdetailpage,
							outcolleagueuid binds-to outcolleagueuid,
							outcolleaguefullname binds-to outcolleaguefullname
				}
			]								
		}
	}
}

fragmentIdentityTeamNLS = NLS {
	employeetype [en "Employee Type" fr "Type de contrat"]
	jobandorgs [en "{0} in {1}" fr "{0} au sein de {1}"]
	jobandorganisation [en "Job and Organization" fr "métier et organisation"]
 	label [en "Whole team" fr "Toute l'équipe"]
 	joinlabel [ en "Search team" fr "Recherche de l'équipe" ]
 	joinoption.identitymanager [ en "as a line manager" fr "en tant que responsable hiérarchique"]
 	joinoption.orgmanager [ en "as an organization manager" fr "en tant que responsable de l'organisation" ]
 	tooltip [en "Shows the whole team: both direct and indirect reports" fr "Montre toute l'équipe, à la fois l'équipe directe et l'équipe indirecte"]
	empty [en "Identity doesn't have team members" fr "Cette identité n'a pas d'équipe"]
	trends [en "Changes" fr "Changements"]

	comparewith [en "compare {0} with ..." fr "comparer {0} avec ..."]
}


/**
 * <span style="white-space: pre-line">
 * Display the identity team in a table using the computed identitymanager links
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inindirecteam </b>shows also indirect team (False by defaut)</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate identity details list through GUI</li>
 * <li><b>inshowdetailpage </b>if incanshowdetails is true, can ask to jump to the identity detail page instead of displaying infos as a dialog box</li>
 * <li><b>incancompare</b> optional, boolean value, true to enable comparison button (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outcolleagueuid </b>the selected colleague uid</li>
 * <li><b>outcolleaguefullname </b>the selected colleague fullname </li>
 * </ul>
 * </span>
 */
fragmentIdentityManagerTeam = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inshowdetailpage = Variable { multivalued:False type:Boolean initial:False }
	inindirectteam = Variable { multivalued:False type:Boolean initial:False }
	incancompare = Variable { type:Boolean initial:False }
	outcolleagueuid = Variable
	outcolleaguefullname = Variable
	selectedExpertiseDomainUID = Variable
	
	selectedUids = Variable { type: String multivalued: True}
	compareFrom = Variable { type: String multivalued: False}
	compareTo = Variable { type: String multivalued: True}

	/* Datasets here */
	team = Dataset {
		view: bwf_identityteam with
			inuid to uid,
			inindirectteam to indirectteam,
			selectedExpertiseDomainUID to expertisedomain unless-empty
		trend: Trend { 
			join-column: uid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	mgnteam_expertisedomain = Dataset {
		view: bwf_identityteamexpertisedomain with
			inuid to uid,
			inindirectteam to indirectteam
	}
	
	comparisonIdentity = Record {
		view: br_identityDetail with compareFrom to uid
		disabled:
			StringPredicate(compareFrom) { when IsEmpty then True }
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				BooleanCase(inshowdetailpage) {
					when True then [
						GoTo Activity Identity Detail with outcolleagueuid to paramIdentityUid save-state					
					
					]
					when False then [
						Dialog bwf_identityDetailsDialog(outcolleagueuid to inuid, 
														True to inshowowner,
														True to inshowaccounts,
														True to inshowapplications,
														True to inshowbusinessactivities,
														True to inshowcontrols,
														True to inshowdecisionhistory,
														True to inshowoverallocated,
														True to inshowposition,
														True to inshowshares,
														True to inshowtheoretical
														)
					]
				}
			]
			when False then [
			
			]
		}
	)

	
	ConditionalGroup {
		IntCondition(Count team) {
			when =0 then [
				Header {
					value:$fragmentIdentityTeamNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
			
				ConditionalGroup {
					BooleanCondition(incancompare) {
						when True then [
							Grid {
								columns: GridColumn { }, GridColumn, GridColumn { width:grow }, GridColumn { width:250 }
								layout:Layout { grab:horizontal True vertical False }
								gap: 10
								GridRow {
									GridCell {
										Checkbox {
											variable:inindirectteam
											text:$fragmentIdentityTeamNLS.label
											tooltip:$fragmentIdentityTeamNLS.tooltip
											label:Label {break:True}
										}
									}
									GridCell {
										Combo {
											variable: selectedExpertiseDomainUID
											allow-none: True
											label: $identity.expertisedomaindisplayname
											options: Dynamic {
												data: mgnteam_expertisedomain
												text: Current expertisedomaindisplayname
												value: Current expertisedomainuid
											}
										}
									}
									GridCell {
									}
									GridCell {
										Button {
											actions:
												Set ElementAt 1 of selectedUids to compareFrom,
												Set selectedUids to compareTo,
												MultivaluedRemove compareFrom from compareTo,
												GoTo Page bwc_readonly_identity_comparison with compareFrom to uid, compareTo to uids  save-state 
											text:$fragmentIdentityTeamNLS.comparewith(NonEmpty(comparisonIdentity.fullname,' '))
											disabled:IntPredicate(SizeOf selectedUids) { when <2 then True otherwise False }
											presentation:Button
										}
									}
								}
							}
							Table {
								data:team
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								show-filter:True
								show-count:True
								persist-configuration:True
								double-click:ExecuteNamedAction goDetails
								checkboxes:uid to selectedUids
								checkboxes-changed-event:Set ElementAt 1 of selectedUids to compareFrom
								disabled:Not BooleanPredicate(incancompare)
								
								Column {
									column:uid
									hidden:True
									selection:outcolleagueuid
								}
								
								Column {
									column:hrcode
									sortable:True
									filterable:True
									header:$identity.hrcode
									width:128px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:givenname
									sortable:True
									filterable:True
									header:$identity.givenname
									initially-masked:True
									width:128px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:surname
									sortable:True
									filterable:True
									header:$identity.surname
									initially-masked:True
									width:128px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:fullname
									sortable:True
									filterable:True
									header:$identity.fullname
									width:160px
									selection:outcolleaguefullname
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:mail
									sortable:True
									filterable:True
									header:$identity.mail
									initially-masked:True
									width:160px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:phone
									sortable:True
									filterable:True
									header:$identity.phone
									initially-masked:True
									width:128px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:mobile
									sortable:True
									filterable:True
									header:$identity.mobile
									initially-masked:True
									width:128px
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								
								Column {
									column:internal
									text:Transform Current internal using booleanDisplayMapping
									sortable:True
									filterable:True
									header:$identity.internal
									width:96px
								}
								
								Column {
									column:arrivaldate
									sortable:True
									filterable:True
									header:$identity.arrivaldate
									initially-masked:True
									width:128px
								}
								
								Column {
									column:departuredate
									sortable:True
									filterable:True
									header:$identity.departuredate
									initially-masked:True
									width:128px
								}
								
								Column {
									column:jobtitlecode
									sortable:True
									filterable:True
									header:$identity.jobtitlecode
									initially-masked:True
									width:128px
								}
								
								Column {
									column:jobtitledisplayname
									sortable:True
									filterable:True
									header:$identity.jobtitledisplayname
									width:160px
								}
						
								Column {
									column:organisationcode
									sortable:True
									filterable:True
									header:$porganisation.code
									width:128px
									initially-masked:True
								}
								Column {
									column:organisationshortname
									sortable:True
									filterable:True
									header:$porganisation.shortname
									width:128px
									initially-masked:True
								}
								Column {
									column:organisationdisplayname
									sortable:True
									filterable:True
									header:$porganisation.displayname
									width:100%
								}
			
								Column {
									column:bwa_identityanalytics_aggriskrank
									sortable:True
									header:$bwf_identityNLS.riskrank
									width:120px
									initially-masked:True
								}
								Column {
									column:bwa_identityanalytics_aggmaxrisklevel
									sortable:True
									header:$bwf_identityNLS.maxrisk
									image:TemplateImageSelection(Current bwa_identityanalytics_aggmaxrisklevel) using bwf_identityriskimage
									width:120px
									initially-masked:True
								}
								Column {
									column:bwa_identityanalytics_aggnbrisks
									sortable:True
									header:$bwf_identityNLS.nbrisk
									width:120px
									initially-masked:True
								}
			
								Column {
									column: trends
									header: $bw_fragment.trends
									text:Transform Current trends using bwf_trendStatusColumn 
									styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
