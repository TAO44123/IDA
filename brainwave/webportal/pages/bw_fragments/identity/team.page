									tooltip:$bwf_trendStatusColumnNLS.tooltip
			
									sortable: True
									filterable: True
									width: 10%
								}												
							}
						]
						when False then [
							Checkbox {
								variable:inindirectteam
								text:$fragmentIdentityTeamNLS.label
								tooltip:$fragmentIdentityTeamNLS.tooltip
								label:Label {break:True}
							}
							Table {
								data:team
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								show-filter:True
								show-count:True
								double-click:ExecuteNamedAction goDetails
								disabled:BooleanPredicate(incancompare)
								
								Column {
									column:uid
