							OrPredicate {
								// cannot reassign if you are displaying multiple campaigns at once...
								StringPredicate ( infilterbycampaign ) {
									when IsEmpty then True
								}
								// self delegation must be enabled in the selected campaign
								StringPredicate ( selectedcampaign.selfdelegation ) {
									when "1" then False
									otherwise True
								}
								// cannot reassign more than 1000 entries at once due to a SQL limitation
								IntPredicate ( SizeOf selectedentries ) {
									when >999 then True
								}
								// no entries selected? nothing to reassign
								IntPredicate ( SizeOf selectedentries ) {
									when =0 then True
								} 
