fragmentIdentityApplicationRightsToBeReviewedComment = Dialog {
	title:$fragmentIdentityApplicationRightsToBeReviewedComment.title
	enter-event:IntCase(iscommentinreasons) { when =0 then [Set comment to customcomment] otherwise [Set comment to selectedcomment] }
	height:250
	buttons:[
			OkButton {
				disabled:AndPredicate {
					StringPredicate(customcomment) { when IsEmpty then True }
					StringPredicate(selectedcomment) { when IsEmpty then True }
				}
				actions:Set NonEmpty(selectedcomment, customcomment) to comment
			}
			CancelButton
	]
	
	comment = Variable
	customcomment = Variable
	selectedcomment = Variable
	iscommentinreasons = Variable
	
	reasons = Dataset {
		values:[
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.notused,text->$fragmentIdentityApplicationRightsToBeReviewedComment.notused),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.notneeded,text->$fragmentIdentityApplicationRightsToBeReviewedComment.notneeded),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.overallocated,text->$fragmentIdentityApplicationRightsToBeReviewedComment.overallocated),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.leaver,text->$fragmentIdentityApplicationRightsToBeReviewedComment.leaver),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.mover,text->$fragmentIdentityApplicationRightsToBeReviewedComment.mover),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.sodproblem,text->$fragmentIdentityApplicationRightsToBeReviewedComment.sodproblem),
			(val->$fragmentIdentityApplicationRightsToBeReviewedComment.unknown,text->$fragmentIdentityApplicationRightsToBeReviewedComment.unknown)
		]
	}

	commentinreasons = Dataset {
		union: Union {
			datasets:reasons
			discriminator-column:discr
		}
		
		includes:SameValuePredicate(Current val, comment)
		count-variable:iscommentinreasons
	}
	
	Header {
		value:$fragmentIdentityApplicationRightsToBeReviewedComment.header
		styling:bigTitleStyle
	}
	Separator {
		width:1
		color:blue
	}
	Header {
		value:$fragmentIdentityApplicationRightsToBeReviewedComment.subheader
	}
	Combo {
		label: Label { value:$fragmentIdentityApplicationRightsToBeReviewedComment.selectedreason }
		variable:selectedcomment
		allow-none:True
		modify-event:StringCase(selectedcomment) { when IsEmpty then [] otherwise [ Unset customcomment ] }
		options:Dynamic {
			data:reasons
			text:Current text
			value:Current val
		}
	}
	
	Edit {
		label: Label { value:$fragmentIdentityApplicationRightsToBeReviewedComment.customcomment }
		variable:customcomment
		limit:4000
		disabled:StringPredicate(selectedcomment) { when IsEmpty then False otherwise True }
	}
}

