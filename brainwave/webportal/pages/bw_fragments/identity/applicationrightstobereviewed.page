	when Constant bw_reviewOrigin_lineManager then $fragmentIdentityApplicationRightsToBeReviewedNLS.linemanager
	when Constant bw_reviewOrigin_applicationOwner then $fragmentIdentityApplicationRightsToBeReviewedNLS.applicationowner
	when Constant bw_reviewOrigin_permissionOwner then $fragmentIdentityApplicationRightsToBeReviewedNLS.permissionowner
	when Constant bw_reviewOrigin_accountOwner then $fragmentIdentityApplicationRightsToBeReviewedNLS.accountowner
	when Constant bw_reviewOrigin_groupOwner then $fragmentIdentityApplicationRightsToBeReviewedNLS.groupowner
	when Constant bw_reviewOrigin_repositoryOwner then $fragmentIdentityApplicationRightsToBeReviewedNLS.repositoryowner
