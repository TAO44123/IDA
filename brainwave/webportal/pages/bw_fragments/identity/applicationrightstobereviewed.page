fragmentIdentityApplicationRightsReassignDlg = Dialog {
	title: $fragmentIdentityApplicationRightsReassign.title
	width: 800
	height: 600
	buttons:
		[
			ActionButton {
		     text: $fragmentIdentityApplicationRightsReassign.checkReviewer
		     close: False
		     disabled: Eval " outUid.isEmpty()"
				actions: 	
		          Set outUid to reviewerToCheck, 
					 IntCase ( nbCheckedSelfEntries ) {
						when >0 then [
							Message Error $fragmentIdentityApplicationRightsReassign.error,
							Unset reviewerToCheck,
							Set False to reviewerOk
						]
						otherwise [
						  Message Information $fragmentIdentityApplicationRightsReassign.checkReviewerOk1( outDisplayname),
						  Set True to reviewerOk
						] 
					}
		   }
		   OkButton {
		      disabled: Not BooleanPredicate ( reviewerOk)
		   }
			CancelButton
		]
	enter-event: 
		Set origin.reviewerorigin to originstr,
		Set Eval "(nbreviewersorigin.get() == 1 && originstr.get().equals('linemanager'))?'tolinemanager':''" to canreassignto,
		StringCase ( canreassignto ) {
			when IsEmpty then [
				Set Eval "(nbreviewersorigin.get() == 1 && (originstr.get().equals('applicationowner') || originstr.get().equals('safeowner')) && nbselectedapplications.get() == 1 )?'toapplicationowner':''" to canreassignto
			]
		}
		
	inprincipal = Variable { initial: Principal.uid }
	inselectedentries = Variable { multivalued: True }

	outUid = Variable { type: String }
	outDisplayname = Variable { type: String }
	outHrCode =  Variable { type: String }
	outEmail = Variable { type: String }

	nbreviewersorigin = Variable { type: Integer }
	nbselectedapplications = Variable { type: Integer }
	originstr = Variable { type: String }

	reassignmenttype = Variable { type: String }
	canreassignto = Variable { type: String initial: False }
		
	nbCheckedSelfEntries = Variable { type: Integer}
	reviewerToCheck = Variable { }
	reviewerOk = Variable { type: Boolean initial: False}
	
	checkreassignwithidentity = Dataset {
		view: bwf_identityapplicationreviewentriesbyidentity with
			inselectedentries to ticketreviewrecorduids,
			reviewerToCheck to identityuid unless-empty
		timeslot: ValidatedTimeslot.UID
		count-variable: nbCheckedSelfEntries
	}

	// used for delegation	
	origin = Record {
		view: bwf_identitygetreviewersorigin with
			inselectedentries to recorduids
		timeslot: ValidatedTimeslot.UID
		disabled:
			IntPredicate ( SizeOf inselectedentries ) {
				when >999 then True
			}
	}
	
	reviewersorigin = Dataset {
		view: bwf_identitygetreviewersorigin with
			inselectedentries to recorduids
		timeslot: ValidatedTimeslot.UID
		disabled:
			IntPredicate ( SizeOf inselectedentries ) {
				when >999 then True
			}
		count-variable: nbreviewersorigin
	}
	
	selectedapplication = Record {
		view: bwf_identitygetreviewapplications with
			inselectedentries to recorduids
		timeslot: ValidatedTimeslot.UID
		disabled:
			IntPredicate ( SizeOf inselectedentries ) {
				when >999 then True
			}
	}
	
	selectedapplications = Dataset {
		view: bwf_identitygetreviewapplications with
			inselectedentries to recorduids
		timeslot: ValidatedTimeslot.UID
		disabled:
			IntPredicate ( SizeOf inselectedentries ) {
				when >999 then True
			}
		count-variable: nbselectedapplications
	}

	lmlist = Dataset {
		view: bwf_identitycomputedmanagedteam with
			inprincipal to principaluid
		timeslot: ValidatedTimeslot.UID
		disabled:
			Not SameValuePredicate ( canreassignto, Constant bw_reassignTo_lineManager )
	}
	
	applist = Dataset {
		view: bwf_identityapplicationbusinessowners with
			inprincipal to principaluid,
			selectedapplication.uid to uid
		timeslot: ValidatedTimeslot.UID
		disabled:
			Not SameValuePredicate ( canreassignto, Constant bw_reassignTo_applicationOwner )
	}
	
	list = Dataset {
		union: Union {
			datasets: lmlist, applist
			discriminator-column: discr
		}
	}
	

	ConditionalGroup {
		StringCondition ( canreassignto ) {
			when IsEmpty then [
				Header {
					value: $fragmentIdentityApplicationRightsReassign.header_notfound
					layout: Layout { grab: horizontal True vertical True }
				}
			] otherwise [	
				ConditionalGroup {
					IntCondition ( Count list ) {
						when >0 then [
							Header {
								value: $fragmentIdentityApplicationRightsReassign.header_reassign
								
							}
							Separator {
								width: 1
								color: blueNG
							}
							Table {
								data: list
								layout: Layout { grab: horizontal True vertical True }
								show-filter: True
								Column {
									column: uid
									hidden: True
									selection: outUid
								}
								Column {
									column: hrcode
									header: $identity.hrcode
									selection: outHrCode
									sortable: True
									filterable: True
									width: 50%
								}
								Column {
									column: fullname
									header: $identity.fullname
									sortable: True
									filterable: True
									selection: outDisplayname
									width: 100%
								}
								Column {
									column: mail
									header: $identity.mail
									selection: outEmail
									sortable: True
									filterable: True
									width: 100%
								}
							}
						] otherwise [
							Header {
								value: $fragmentIdentityApplicationRightsReassign.header_notfound
								layout: Layout { grab: horizontal True vertical True }
							}
						]			
					}
				}	
			]
		}
	}	
}

