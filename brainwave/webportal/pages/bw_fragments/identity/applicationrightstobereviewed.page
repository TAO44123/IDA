 * Display the application rights to be reviewed for a given identity as a crosstab
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (false by default)</li>
 * <li><b>infilterbycampaign </b>optional, filter for a given campaign (recorduid) (disabled by default)</li>
 * <li><b>infilterreviewed </b>optional, boolean value, filter already reviewed entries (true by default)</li>
 * </ul>
 * </span>
 */
fragmentIdentityApplicationRightsToBeReviewedCrosstab = PageFragment {
	enter-event:
		TransferData campaignsinperimeter(key) to (includedcampaigns)
	feature:iasreview_license
	
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable { type: String }
	incanshowdetails = Variable { initial: True type: Boolean }	
	inenabled = Variable { type: Boolean initial: False changed-event: Unset selectedentries }
	infilterbycampaign = Variable  { type: String }
	infilterreviewed = Variable { type: Boolean initial: True }
	infilterdelegated = Variable { type: Boolean initial: False }

	outapplicationuid = Variable { type: String }
	outpermissionuid = Variable { type: String }
	outidentityuid = Variable { type: String }
	outaccountuid = Variable { type: String }

	selectedentries = Variable { type: String multivalued: True }
	selectedentry = Variable { type: String }
	selectedreviewcomment = Variable { type: String }
	
	updatestatus = Variable { type: Boolean }
	statustowrite = Variable { type: String }
	updatecomment = Variable { type: Boolean }
	commenttowrite = Variable { type: String }
	
	includedcampaigns = Variable { type: String multivalued: True }

	newrevieweruid = Variable { type: String }
	newreviewername = Variable { type: String }
	
	ct_selectedpermissions = Variable { type: String multivalued: True }
	ct_selectedperimeters = Variable { type: String multivalued: True }
	ct_selectedaccounts = Variable { type: String multivalued: True }
	
	// used to extract the full list of "active" campaigns (non finalized campaigns)
	campaignsinperimeter = Dataset {
		view: bwaccess360r_accessreviewcampaignsongoing
		timeslot: ValidatedTimeslot.UID
	}

	// entries to review
	review = Dataset {
		view: bwf_identityapplicationaccessrightsreview with
			inuid to revieweruid, 
			infilterbycampaign to campaignid unless-empty, 
			includedcampaigns to includedcampaigns, 
			infilterreviewed to notreviewedonly,
			infilterdelegated to filteraccountable
		limit: 10000 // limited to 10000 for perf reasons
		timeslot: ValidatedTimeslot.UID
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	reviewselection = Dataset {
		view: bwf_identityapplicationaccessrightsreview with
			inuid to revieweruid, 
			infilterbycampaign to campaignid unless-empty, 
			includedcampaigns to includedcampaigns, 
			infilterreviewed to notreviewedonly,
			infilterdelegated to filteraccountable
		limit: 10000 // limited to 10000 for perf reasons
		timeslot: ValidatedTimeslot.UID
		includes:
			OrPredicate {
				AndPredicate {
					StringPredicate ( ct_selectedperimeters ) {
						when IsEmpty then True
					}  		
					MultivaluedPredicate ( ct_selectedaccounts contains Current accountuid )  		
					MultivaluedPredicate ( ct_selectedpermissions contains Current permissionuid )
				}
				AndPredicate {
					StringPredicate ( ct_selectedperimeters ) {
						when IsEmpty then False
						otherwise True
					}  		
					MultivaluedPredicate ( ct_selectedaccounts contains Current accountuid )  		
					MultivaluedPredicate ( ct_selectedpermissions contains Current permissionuid )
					MultivaluedPredicate ( ct_selectedperimeters contains Current rightperimeteruid )
				}
			}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	

	// infos	
	selectedcampaign = Record {
		view: bwaccess360_accessreviewcampaigns with
			infilterbycampaign to campaignid
		timeslot: ValidatedTimeslot.UID
		disabled:
			StringPredicate ( infilterbycampaign ) {
				when IsEmpty then True
			}
	}
	
	task = TaskRecord ( create "bwaccess360_writeAccessRightsReviewTickets" in-timeslot ValidatedTimeslot.UID )
	reassigntask = TaskRecord ( create "bwaccess360_reassignAccessRightsReviewTickets" in-timeslot ValidatedTimeslot.UID )

	goPermissionDetails = NamedAction (
		BooleanCase ( incanshowdetails ) {
			when True then [
				Dialog bwf_permissionDetailsDialog (
					outpermissionuid to inuid,
					True to inshowperjob,
					True to inshowperorg
				)
			] when False then [ ]
		}
	)
	
	goAccountDetails = NamedAction (
		BooleanCase ( incanshowdetails ) {
			when True then [
				Dialog bwf_accountDetailsDialog (
					outaccountuid to inuid, 
					True to inshowowner,
					True to inshowcontrols,
					True to inshowdecisionhistory
				)
			] when False then [ ]
		}
	)

	writeBulkStatus = NamedAction (
		Set selectedentries to task.ticketreviewrecorduid,
		Set [statustowrite repeat SizeOf selectedentries] to task.status,
		Set [commenttowrite repeat SizeOf selectedentries] to task.comment,
		Set [Date.valueLDAP repeat SizeOf selectedentries] to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 120,
		Flash Concat(SizeOf selectedentries, $fragmentIdentityApplicationRightsToBeReviewedNLS.writeBulkStatus.flash),
		Unset selectedentries,
		ReloadData (review)
	)

	writeStatus = NamedAction (
		Set selectedentry to task.ticketreviewrecorduid,
		Set statustowrite  to task.status,
		Set commenttowrite to task.comment,
		Set Date.valueLDAP to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 30,
		Flash $fragmentIdentityApplicationRightsToBeReviewedNLS.writeStatus.flash,
		ReloadData (review)
	)

	// action buttons		
	Grid {
		columns: GridColumn { width: grow }, GridColumn, GridColumn
		layout: Layout { grab: horizontal True vertical False hint: height 48 }
		GridRow {
			GridCell {
				ButtonGroup {
					nb-inline: 3
					layout: Layout { align: horizontal Beginning vertical Center }
					Button {
						actions:	
							Set Constant bw_reviewStatusCode_ok to statustowrite,
							Set True to updatestatus,
							Set False to updatecomment,
							ExecuteNamedAction writeBulkStatus
						image: "16/famfamfam_silk_icons_v013/accept.png"
						text: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkapproval.text
						tooltip: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkapproval.tooltip
						disabled:
							IntPredicate ( SizeOf selectedentries ) {
								when =0 then True
							}
					}
					Button {
						actions:
							Set Constant bw_reviewStatusCode_revoke to statustowrite,
							Set True to updatestatus,
							Set True to updatecomment,
							Dialog fragmentIdentityApplicationRightsToBeReviewedComment (
								commenttowrite from comment
							),
							ExecuteNamedAction writeBulkStatus
						image: "16/famfamfam_silk_icons_v013/delete.png"
						text: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkrevocation.text
						tooltip: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkrevocation.tooltip
						disabled:
							IntPredicate ( SizeOf selectedentries ) {
								when =0 then True
							}
					}
					Button {
						actions:
							Set False to updatestatus,
							Set True to updatecomment,
							Dialog fragmentIdentityApplicationRightsToBeReviewedComment (
								commenttowrite from comment
							),
							ExecuteNamedAction writeBulkStatus 
						image: "16/famfamfam_silk_icons_v013/comment.png"
						text: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkcomment.text
						tooltip: $fragmentIdentityApplicationRightsToBeReviewedNLS.bulkcomment.tooltip
						disabled:
							IntPredicate ( SizeOf selectedentries ) {
								when =0 then True
							}
					}
					Button {
						actions:
							Dialog fragmentIdentityApplicationRightsToBeReviewedFilters (
								inuid to inuid,
								includedcampaigns to includedcampaigns,
								infilterbycampaign to outfilterbycampaign,
								infilterreviewed to outfilterreviewed,
								infilterdelegated to outfilterdelegated,
								infilterbycampaign from outfilterbycampaign,
								infilterbycampaign from outfilterbycampaign,
								infilterdelegated from outfilterdelegated
							)
						text: $fragmentIdentityApplicationRightsToBeReviewedFilters.text
						image: "16/famfamfam_silk_icons_v013/cog.png"
					}
					Button {
						actions:	Set "update" to statustowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									Dialog fragmentIdentityApplicationRightsToBeUpdatedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus
						image:"16/famfamfam_silk_icons_v013/pencil.png"
						text:$fragmentIdentityApplicationRightsToBeReviewedNLS.bulkupdate.text
						tooltip:$fragmentIdentityApplicationRightsToBeReviewedNLS.bulkupdate.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:	
							Dialog fragmentIdentityApplicationRightsReassignDlg (
								selectedentries to inselectedentries,
								newrevieweruid from outUid,
								newreviewername from outDisplayname
							),
							Confirm Concat ( $fragmentIdentityApplicationRightsReassign.confirm, SizeOf selectedentries, $fragmentIdentityApplicationRightsReassign.confirmmiddle, newreviewername, $fragmentIdentityApplicationRightsReassign.confirmend ),
							Set newrevieweruid to reassigntask.reviewer,
							Set selectedentries to reassigntask.ticketreviewrecorduids,
							TaskComplete reassigntask wait-end timeout-seconds 120,
							Flash Concat(SizeOf selectedentries, $fragmentIdentityApplicationRightsReassign.flash, newreviewername),
							Unset selectedentries,
							Set True to infilterdelegated,
							ReloadData (review)
						image: "16/audit/identity_16.png"
						text: $fragmentIdentityApplicationRightsReassign.text
						tooltip: $fragmentIdentityApplicationRightsReassign.tooltip
						feature: iasreview_selfmanagement
						disabled:
							OrPredicate {
								// cannot reassign if you are displaying multiple campaigns at once...
								StringPredicate ( infilterbycampaign ) {
									when IsEmpty then True
								}
								// self delegation must be enabled in the selected campaign
								StringPredicate ( selectedcampaign.selfdelegation ) {
									when "1" then False
									otherwise True
								}
								// cannot reassign more than 1000 entries at once due to a SQL limitation
								IntPredicate ( SizeOf selectedentries ) {
									when >999 then True
								}
								// no entries selected? nothing to reassign
								IntPredicate ( SizeOf selectedentries ) {
									when =0 then True
								} 
							}
					}
				}
			}
			GridCell {
				Header {
					value: $fragmentIdentityApplicationRightsToBeReviewedNLS.displayallentries
					hidden:
						BooleanPredicate ( infilterreviewed )
					styling: italicStyle
				}			
			}
			GridCell {
				Header {
					value: Concat ( $fragmentIdentityApplicationRightsToBeReviewedNLS.filterforcampaign, selectedcampaign.title )
					hidden:
						StringPredicate ( infilterbycampaign ) {
							when IsEmpty then True
						}
					layout: Layout { grab: horizontal False vertical False hint: width 400 align: horizontal End vertical Center }
					tooltip: selectedcampaign.description
					styling: italicStyle
					align: Right
				}			
			}
		}
	}
	ConditionalGroup {
		IntCondition ( Count review ) {
			when >0 then [
				CrossTable {
					data: review
					cluster-sortable: True
					default-configurable: True
					multi-selection: True
					show-filter: True
					swappable: True
					cluster-keep-sort-on-change: True
					user-configurable: True
					persist-configuration: True
					layout: Layout {
						grab: horizontal True vertical True
						cell-width: 30px
					}
					selection-changed-event:
						TransferData reviewselection ( reviewrecorduid ) to ( selectedentries )
					configuration-changed-event:
						Unset ct_selectedaccounts,
						Unset ct_selectedperimeters,
						Unset ct_selectedpermissions
					columns:
						Dim {
							value: applicationuid
							label: applicationdisplayname
							header: $application.concept
						},					
						Dim {
							value: permissioncode
							label: permissioncode
							header: $ppermission.code
							initially-masked:True
							tooltip: permissioncode
						},					
						Dim {
							value: permissionuid
							label: permissiondisplayname
							header: $permission.concept
							selection: ct_selectedpermissions
							header-click: outpermissionuid
							tooltip: permissiondisplayname
						},					
						Dim {
							value: rightperimeteruid
							label: rightperimeterdisplayname
							header: $right.perimeterdisplayname
							initially-masked: True
							selection: ct_selectedperimeters
							tooltip: rightperimeterdisplayname
						}					
					rows:
						Dim {
							value: identityjoborg
							label: identityjoborg
							header: $identity.joborg
							initially-masked: True
							tooltip: identityjoborg
						},			
						Dim {
							value: identityinternal
							label: identityinternal
							header: $identity.internal
							initially-masked: True
						},			
						Dim {
							value: identityhrcode
							label: identityhrcode
							header: $identity.hrcode
							initially-masked: True
							tooltip: identityhrcode
						},			
						Dim {
							value: identityuid
							label: identityfullname
							header: $identity.concept
							initially-masked: True
							tooltip: identityfullname
						},			
						Dim {
							value: accountusername
							label: accountusername
							header: $account.concept
							tooltip: accountusername
						},			
						Dim {
							value: accountuid
							label: accountlogin
							header: $account.login
							width: 160px
							initially-masked: False
							selection: ct_selectedaccounts
							header-click: outaccountuid
							tooltip: accountlogin
						}			
					cell-content:
						CellContent { 
							text: ""
							comment: Current reviewcomment
							image: TemplateImageSelection(LowerCase Current reviewstatus) using bwReviewStatusIcon
							align: Center
							cluster-value: "X"
							styling: StylingTemplateSelection ( Current accountmaxrisklevel ) using riskstyling
						}
					column-header-click:
						ExecuteNamedAction goPermissionDetails
					row-header-click:
						ExecuteNamedAction goAccountDetails
				}
			] otherwise [
				Header {
					value: $fragmentIdentityApplicationRightsToBeReviewedNLS.header
					layout: Layout { grab: horizontal True vertical False align: horizontal Center vertical Beginning }
				}
				Image {
					image: "bw_access360/fireworks.svg"
					image-size: 300 300
					layout: Layout { grab: horizontal True vertical True align: horizontal Center vertical Beginning }
				}	
			]		
		}
	}
}