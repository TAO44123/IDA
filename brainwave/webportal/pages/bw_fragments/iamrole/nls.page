fragmentRolesReassignDlg = NLS {
	title [en "Pick a new reviewer" fr "Choix d'un nouvel acteur"]	
	header_notfound [
	   en "Sorry but we found nobody to reassign those entries to.\nYou can try to reduce the volume of entries to reassign\nKeep in mind that:\n- If you are reviewing entries as a line manager you can only reassign entries to your team\n- If you are reviewing entries as a resource owner you can only reassign entries to other resource owners\n- You cannot reassign entries when you are the default reviewer" 
	   fr "Nous n'avons pas pu trouver un acteur à qui réassigner ces entrées.\nVous pouvez essayer de réduire le nombre d'entrées à réassigner\nIl ne faut pas oublier que :\n- Si vous revoyez ces entrées en tant que responsable hiérarchique,\n vous ne pouvez les réassigner qu'aux personnes de votre équipe\n- Si vous revoyez ces entrées en tant que responsable de ressource,\n vous ne pouvez les réassigner qu'aux autres responsables de ressources\n- Vous ne pouvez pas réassigner les entrées sur lesquelles vous êtes acteur par défaut"
	]
	header_reassign [
	   en "Pick a new reviewer for the selected entries:\n- among the members of your team, if you are reviewing entries as a line manager\n- among other resource owners, if you are reviewing entries as a resource owner"
	   fr "Choisissez un nouvel acteur pour les entrées sélectionnées:\n- parmi les membres de votre équipe, si vous revoyez ces entrées en tant que responsable hiérarchique\n- parmi les autres responsables de ressources, si vous revoyez ces entrées en tant que responsable de ressource"
	]
	error [
	   en "One cannot review his own access rights.\nPlease chose another reviewer or refine your selection" 
	   fr "Une personne ne peut pas revoir ses propres accès.\nVeuillez choisir un autre acteur ou raffiner votre sélection"]
	checkReviewer  [ en "Check reviewer" fr "Vérifier"]
	checkReviewerOk1 [ 
	  en "{0} can review the selected entries.\n Close this message then click Ok to validate your choice." 
	  fr "{0} peut revoir les entrées sélectionnées\n. Fermez ce message et cliquez Ok pour valider votre choix."
	]
	confirm [en "Are you sure that you want to reassign " fr "Vous êtes sûr de vouloir réassigner "]
	confirmmiddle [en " entries to " fr " entrées à "]
	confirmend [en "\nThis cannot be undone" fr "\nCela ne peut être annulé"]
	text [en "Ask for help to" fr "Demander de l'aide à"]
	tooltip [en "Ask a peer to review those entry on behalf of you \nRACI principles are enforced, you remain accountable" fr "Demander à un collègue de revoir ces entrées sous votre responsabilité \nles principes RACI sont appliqués, vous restez responsable"]
	flash [en " Ask to " fr " aide demandée à "]
}