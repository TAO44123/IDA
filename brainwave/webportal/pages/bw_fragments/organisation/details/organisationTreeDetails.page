import "/webportal/pages/bw_fragments/organisation/hierarchygraph.page"

bwf_organisationTreeDetailsDialogNLS = NLS {
	title [en 'Organisation tree' fr "Arborescence organisationnelle"]
}

/**
 * <span style="white-space: pre-line">
 * Organisation tree as a dialog box
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>root organisation uid</li>
 * </ul>
 * </span>
 */
bwf_organisationTreeDetailsDialog = Dialog {
	title:$bwf_organisationTreeDetailsDialogNLS.title
	width:1366
	height:720
	buttons:OkButton
	
	inuid = Variable
	
	IncludeFragment {
		fragment:fragmentOrganisationHierarchyGraph with value-of inuid to inuid, value-of True to inenabled, value-of False to incanshowdetails
	}

}