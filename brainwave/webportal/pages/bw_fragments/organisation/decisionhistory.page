/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/organisation/resources.page"
import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/fragments.page"

fragmentOrganisationDecisionHistoryNLS = NLS {
	directonly [en "only this organisation" fr "seulement cette organisation"]
}

/**
 * <span style="white-space: pre-line">
 * Display decision history for the given organisation (and sub-orgs)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid</b> the organisation uid</li>
 * <li><b>inenabled</b> optional, boolean value, true to enable fragment (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outnbdecision </b>nb of decisions</li>
 * <li><b>outdecisionrecorduid</b> optional, selected decision</li>
 * </ul>
 * </span>
 */
fragmentOrganisationDecisionHistory = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:False 
				// read once when disabled to avoid side effects when filtering
				changed-event:IntCase(outnbdecision) { when =-1 then [ Set Count data to outnbdecision ] 
				}
	}
	inonlydirectselection = Variable { multivalued:False }

	outdecisionrecorduid = Variable
	outnbdecision = Variable { initial:-1 multivalued:False type: Integer }

	statusToFilter  = Variable { type: String multivalued:True private:True }
	
	/* Dataset here */
	data = Dataset {
		view: bwf_organisationalldecisionhistory with
			inuid to uid,
			statusToFilter to statustofilter,
			inonlydirectselection to directonly
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	Grid {
		layout: Layout { grab: horizontal True vertical False hint: height 60 }
		columns: GridColumn, GridColumn, GridColumn { width:grow }
		GridRow {
			GridCell {
				IncludeFragment {
					layout: Layout { grab: horizontal True vertical False }
					fragment: bw_fragments_review_status_selector with
						statusToFilter binds-to statusToFilter
				}
			}
			GridCell {
				Checkbox {
					variable:inonlydirectselection
					text:$fragmentOrganisationDecisionHistoryNLS.directonly
					tooltip:$bwfOrganisation.directonlytooltip
				}
			}
			GridCell {
			}
		}
	}
	ConditionalGroup {
		IntCondition(outnbdecision) {
			when <=0 then [
				Header {
					value:$fragmentDecisionHistoryNLS.empty
					styling:bigTitleStyle
				}
			]
			otherwise [
				Table {
					data: data
					layout: Layout { grab: horizontal True vertical True }
					configurable: True
					show-filter: True
					show-count: True
					persist-configuration: True
					persist-configuration-key: "fragmentOrganisationDecisionHistory"
					Column {
						column:recorduid
						selection:outdecisionrecorduid
						hidden:True
					}
					Column {
						column:identityhrcode
						header:$identity.hrcode
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:identityfullname
						header:$identity.fullname
						width:160px
						sortable:True
						filterable:True
					}
					Column {
						column:accountlogin
						header:$account.login
						width:160px
						sortable:True
						filterable:True
					}
					Column {
						column:accountusername
						header:$paccount.username
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:repositorydisplayname
						header:$repository.concept
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:permissioncode
						header:$ppermission.code
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:permissiondisplayname
						header:$ppermission.displayname
						width:160px
						sortable:True
						filterable:True
					}
					Column {
						column:permissionpermissiontype
						header:$ppermission.permissiontype
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:applicationdisplayname
						header:$application.concept
						width:160px
						sortable:True
						filterable:True
					}
					Column {
						column:status
						text:Transform Current status using bwf_defaultreviewstatus
						header:$fragmentDecisionHistoryNLS.status
						width:130px
						sortable:True
						filterable:True
					}
					Column {
						column:actiondate
						header:$fragmentDecisionHistoryNLS.date
						width:100%
						sortable:True
						filterable:True
					}
					Column {
						column:accountablefullname
						header:$fragmentDecisionHistoryNLS.by
						width:100%
						sortable:True
						filterable:True
					}
					Column {
						column:comment
						header:$fragmentDecisionHistoryNLS.comment
						width:100%
						sortable:True
						filterable:True
					}
					Column {
						column:validfromdate
						header:$fragmentDecisionHistoryNLS.valid_from
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:validtodate
						header:$fragmentDecisionHistoryNLS.valid_to
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:remediationstatus
						header:$fragmentDecisionHistoryNLS.remediation_status
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:remediationsubmissiondate
						header:$fragmentDecisionHistoryNLS.remediation_submitted_on
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:remediationclosedate
						header:$fragmentDecisionHistoryNLS.remediation_closed_on
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:remediationexternalreference
						header:$fragmentDecisionHistoryNLS.remediation_ref
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:campaigninstancetitle
						header:$fragmentDecisionHistoryNLS.campaign_instance
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:campaigninstancestatus
						header:$fragmentDecisionHistoryNLS.campaign_status
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:campaigninstanceclosedate
						header:$fragmentDecisionHistoryNLS.campaign_close_date
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
					Column {
						column:campaigntitle
						header:$fragmentDecisionHistoryNLS.campaign
						width:100%
						initially-masked:True
						sortable:True
						filterable:True
					}
				}	
			 ]
		 }
	 }
}