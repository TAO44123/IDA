/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_fragments/organisation/resources.page"
import "/webportal/pages/bw_fragments/preferences/globalpreferences.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

fragmentOrganisationApplicationsNLS = NLS {
	directonly [en "only this organisation" fr "seulement cette organisation"]
	hierarchy [en "organisation hierarchy" fr "hiérarchie des organisations"]
	employeetype [en "Employee type" fr "Type de contrat"]
	nbidentities [en "Nb identities" fr "Nb identités"]
	trends [en "Changes" fr "Changements"]
	deleted [ en "Deleted" fr "Supprimé" ]
	modified [ en "Modified" fr "Modifié" ]
	new [ en "New" fr "Nouveau" ]
	nochanged [ en "none" fr "non" ]
	removed [en "Removed" fr "Supprimé"]
	identical [en "Identical" fr "Identique"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected organisation applications
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid</b> the organisation uid</li>
 * <li><b>inenabled</b> optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * </span>
 */
fragmentOrganisationApplications = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	inonlydirectselection = Variable { multivalued:False type:Boolean initial:True}
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	outapplicationuid = Variable
	outidentityuid = Variable
	
	/* Datasets and records here */
	applications = Dataset {
		view: bwf_org_applications with
			inuid to uid unless-empty,
			inonlydirectselection to directonly
		trend: Trend { 
			join-column: uid
			exclude-new: False
			include-removed: BooleanPredicate ( UserVariable global_tabletrends_includeremoved )
			exclude-same: False
			status-column-name:trends
			timeslot: FromPage(-1)
			value-column: val
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	goApplicationDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outapplicationuid to inuid,
													True to inshowperorg,
													True to inshowperjob,
													True to inshowaccountsfororganisation,
													inuid to inorganisationuid,
													inonlydirectselection to inonlydirectselection
				)
			]
			when False then [
			
			]
		}
	)
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Checkbox {
		variable:inonlydirectselection
		text:$fragmentOrganisationApplicationsNLS.directonly
		tooltip:$bwfOrganisation.directonlytooltip
	}
	Table {
		data: applications
		layout:Layout{grab:horizontal True vertical True}
		show-count:True
		show-filter:True
		configurable:True
		double-click:ExecuteNamedAction goApplicationDetails
		persist-configuration:True
		
		commands: Commands {
			position:After
			presentation:Icon
			Command {
				actions:Message "nop"
				icon:""
				disabled:True
			}
			Command {
				actions:ExecuteNamedAction goApplicationDetails
				icon:%browsing_16.zoom
				disabled:
					OrPredicate {
						Not BooleanPredicate(incanshowdetails)
						StringPredicate(outapplicationuid) { when IsEmpty then True otherwise False }
					}
			}
		}
		
		Column {
			column:uid
			hidden:True
			selection:outapplicationuid
		}
		Column {
			column:code
			header:$application.code
			sortable:True
			filterable:True
			width:128px
			
			actions: ExecuteNamedAction goApplicationDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}
		Column {
			column:displayname
			header:$application.concept
			sortable:True
			filterable:True
			width:100%
			
			actions: ExecuteNamedAction goApplicationDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}
		Column {
			column:val
			text:Transform Current val using bwf_defaultsTo0
			align:Right
			width:110px
			header:$fragmentOrganisationApplicationsNLS.nbidentities
			sortable:True
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}
	}
	
}
