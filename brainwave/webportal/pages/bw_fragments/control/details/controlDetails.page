import "/webportal/pages/bw_fragments/control/details.page"
import "/webportal/pages/bw_fragments/control/analysis.page"

bwf_controlDetailsDialogNLS = NLS {
	title [ en "Control Details" fr "Détails du contrôle"]
	control [en "Control" fr "Contrôle"]
	analysis [en "Analysis" fr "Analyse"]
	sod [en "SoD" fr "SoD"]
}

bwf_controlDetailsDialog = Dialog {
	title: $bwf_controlDetailsDialogNLS.title
	width: 1366
	height: 720
	buttons:
		OkButton
	
	incontrolcode = Variable { type: String }
	inresulttype = Variable { initial: 1 }
	inorganisationuid = Variable { type: String }
	inidentityuid = Variable { type: String }
	inaccountuid = Variable { type: String }
	ingroupuid = Variable { type: String }
	inapplicationuid = Variable { type: String }
	inpermissionuid = Variable { type: String }
	tab = Variable { type: String }
	
	currentControl = Record {
		view: bwf_controldetails with
			incontrolcode to controlcode
		disabled:
			StringPredicate ( incontrolcode ) {
				when IsEmpty then True
			}
	}
	
	TabFolder {
		border: False
		TabItem  {
			text: $bwf_controlDetailsDialogNLS.control
			activation-event:
				Set 'control'to tab
			IncludeFragment ( fragmentControlDetails with
				value-of incontrolcode to incontrolcode,
				inresulttype binds-to inresulttype,
				value-of Eval "tab.get().equals('control')" to inenabled
			)
		}
		TabItem  {
			text: $bwf_controlDetailsDialogNLS.analysis
			activation-event:
				Set 'analysis'to tab
			hidden:
				Eval "currentControl.controltype != 1 || currentControl.controlentity != 'Organisation' || inorganisationuid.isEmpty()"
			IncludeFragment ( fragmentControlAnalysisOrganisationType1 with
				value-of incontrolcode to incontrolcode,
				value-of inorganisationuid to inentityyuid,
				value-of Eval "currentControl.controltype == 1 && currentControl.controlentity == 'Organisation' && tab.get().equals('analysis') && !inorganisationuid.isEmpty()" to inenabled
			)
		}
		TabItem  {
			text: $bwf_controlDetailsDialogNLS.analysis
			activation-event:
				Set 'analysis'to tab
			hidden:
				Eval "currentControl.controltype != 9 || currentControl.controlentity != 'Organisation' || inorganisationuid.isEmpty()"
			IncludeFragment ( fragmentControlAnalysisOrganisationType9 with
				value-of incontrolcode to incontrolcode,
				value-of inorganisationuid to inentityyuid,
