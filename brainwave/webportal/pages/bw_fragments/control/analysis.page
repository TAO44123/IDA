/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"

fragmentControlAnalysis_NLS = NLS {
	impact [en "Permissions impacted" fr "Permissions impactées" ]
	impact_sod [ en "Separation of duties" fr "Séparation des tâches" ]
	sod.list1 [ en "First set of Permisions" fr "Premier ensemble de permissions" ]
	sod.list2 [ en "Second set of Permissions" fr "Second ensemble de permissions"]
	org.directonly [en "only this organisation" fr "seulement cette organisation"]
}

fragmentControlAnalysisIdentityType1 = PageFragment {
	/* Variables here */
	incontrolcode = Variable { type: String }
	inentityyuid = Variable { type: String }
	inenabled = Variable { type: Boolean initial: True }
	incanshowdetails =  Variable { type: Boolean initial: True }
	
	outSelectedApplication = Variable { type: String }
	outSelectedApplicationType = Variable { type: String }
	outSelectedPermission = Variable { type: String }
	
	rootcauseIdentity = Dataset {
		view: bwf_identityrootcause with
			inentityyuid to uid,
			incontrolcode to controlcode
		disabled:
			OrPredicate {
				Not BooleanPredicate (inenabled)
				StringPredicate ( inentityyuid ) {
					when IsEmpty then True
				}
			}
	}
	
	currentIdentity = Record {
		view: bwf_identitydetails with
			inentityyuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate (inenabled)
				StringPredicate ( inentityyuid ) {
					when IsEmpty then True
				}
			}
	}
	
	goDetailsPermission = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
						Dialog bwf_permissionDetailsDialog(outSelectedPermission to inuid)
			]
			when False then []
		}
	)
	
	goDetailsApplication = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outSelectedApplication to inuid)
			]
			when False then []
		}
	)
	
	Group {
		title: $identity.concept
		layout: Layout { grab: horizontal True vertical False }
		Text {
			value: currentIdentity.fullname
			label: $identity.fullname
			compact: True
		}
		Text {
			value: currentIdentity.hrcode
			label: $identity.hrcode
			compact: True
		}
	}
	Group {
		title: $fragmentControlAnalysis_NLS.impact
		layout: Layout { grab: horizontal True vertical True }
		Table {
			data: rootcauseIdentity 
			show-count: True
			show-filter: True
			layout: Layout { grab: horizontal True vertical True }
			Column {
				column: applicationuid
				hidden: True
				selection: outSelectedApplication
			}
			Column {
				column: permissionuid
				hidden: True
				selection: outSelectedPermission
			}
			Column { 
				header: $papplication.displayname
				column: applicationdisplayname
				width: 100% 
				sortable: True
				filterable: True
				actions: ExecuteNamedAction goDetailsApplication
				actions-disabled: Not BooleanPredicate(incanshowdetails)
			}
			Column { 
				header: $papplication.code
				column: applicationcode
				width: 100% 
				sortable: True
				filterable: True
				actions: ExecuteNamedAction goDetailsApplication
				actions-disabled: Not BooleanPredicate(incanshowdetails)
			}
			Column { 
				header: $ppermission.displayname
				column: permissiondisplayname
				width: 100% 
				sortable: True
				filterable: True
				actions: ExecuteNamedAction goDetailsPermission
				actions-disabled: Not BooleanPredicate(incanshowdetails)
			}
			Column { 
				header: $ppermission.code
				column: permissioncode
				width: 100% 
				sortable: True
				filterable: True
				actions: ExecuteNamedAction goDetailsPermission
				actions-disabled: Not BooleanPredicate(incanshowdetails)
			}
			Column {
				column: applicationapplicationtype
				hidden: True
				selection: outSelectedApplicationType
			}
		}
	}
}

