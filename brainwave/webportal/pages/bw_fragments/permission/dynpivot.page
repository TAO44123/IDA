/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"

fragmentPermissionDynPivotNLS = NLS {
	perorg [en "Identities origin" fr "Origine des personnes"]
	nbidentities [en "nb identities" fr "nb identités"]
}

/**
 * <span style="white-space: pre-line">
 * Display the origin of the identities with the permission as a dynamic crosstable
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * </span>
 */
fragmentPermissionDynPivot = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	data = Dataset {
		view: bwf_permissionnbidentitydimensions with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	DynamicCrossTable {
		label:Label{value:$fragmentPermissionDynPivotNLS.perorg break:True layout:Layout{align:horizontal Beginning vertical Beginning } }
		data:data
		layout:Layout { cell-width:50px }
		dimensions:
			Dim {
				value: activestatus
				header: $identity.active
			},
			Dim {
				value: internalstatus
				header: $identity.internal
			},
			Dim {
				value: jobtitlecode
				header: $identity.jobtitlecode
			},
			Dim {
				value: jobtitledisplayname
				header: $identity.jobtitledisplayname
			},
			Dim {
				value: organisationshortname
				header: $organisation.shortname
			},
			Dim {
				value: organisationdisplayname
				header: $organisation.concept
			},
			Dim {
				value: organisationorganisationtypedisplayname
				header: $organisation.organisationtypedisplayname
			}
		measures:
			Measure {
				value: nbidentity
				header: $fragmentPermissionDynPivotNLS.nbidentities
			}
	}
}
