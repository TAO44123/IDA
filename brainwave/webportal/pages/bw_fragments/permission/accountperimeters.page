/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"

fragmentPermissionAccountPerimetersNLS = NLS {
	noownercode [en "technical account" fr "compte technique"]
	trends [en "Changes" fr "Changements"]
	filterto [en "Results filtered to {0}" fr "Résultats filtrés sur {0}"]
	tooltip [en "This tile presents the active accounts associated with a given permission\nyou can right-clic on the table to show/hide additional information"
			 fr "Cette tuile présente les comptes actifs associés à une permission donnée\nvous pouvez faire un clic droit sur la table pour afficher des colonnes supplémentaires"
			]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected permission accounts with their perimeters
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inrepositoryuid </b>optional, filter results for a given repository</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentPermissionAccountPerimeters = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inrepositoryuid = Variable
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	accountperimeters = Dataset {
		view: bwf_permissionaccountperimeters with
			inuid to uid,
			inrepositoryuid to repositoryuid unless-empty
		trend: Trend {
		 	join-column:right_uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		 }
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												False to inshowgroups,
												False to inshowapplications,
												False to inshowshares,
												False to inshowcontrols,
												False to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	Header {
		value:$fragmentPermissionAccountPerimetersNLS.filterto(repository.displayname)
		hidden:StringPredicate(inrepositoryuid) { when IsEmpty then True otherwise False }
	}
	Table {
		data:accountperimeters
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		show-count:True
		show-filter:True
		double-click:ExecuteNamedAction goDetails
		persist-configuration:True
		
		
		Column {
			column:uid
			hidden:True
			selection:outaccountuid
		}
		
		Column {
			column:right_perimetercode
			sortable:True
			filterable:True
			header:$right.perimetercode
			initially-masked:True
		}
		Column {
			column:right_perimeterdisplayname
			sortable:True
			filterable:True
			header:$right.perimeterdisplayname
		}
		Column {
			column:right_action
			sortable:True
			filterable:True
			header:$right.action
			initially-masked:True
		}
		Column {
			column:right_limit
			sortable:True
			filterable:True
			header:$right.limit
			initially-masked:True
		}
		
		Column {
			column:login
			header:$account.login
			sortable:True
			filterable:True
			selection:outaccountlogin
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:givenname
			header:$account.givenname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:surname
			header:$account.surname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:username
			header:$account.username
			sortable:True
			filterable:True
			width:160px
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:disabled
			header:$account.disabled
			sortable:True
			filterable:True
			initially-masked:True
		}

		Column {
			column:creationdate
			header:$account.creationdate
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:lastlogindate
			header:$account.lastlogindate
			sortable:True
			filterable:True
		}
		Column {
			column:repositoryuid
			hidden:True
			selection:outrepositoryuid
		}
		Column {
			column:repositorydisplayname
			header:$repository.concept
			sortable:True
			filterable:True
			selection:outrepositoryname
		}
		Column {
			column:noownercode
			sortable:True
			filterable:True
			header:$fragmentPermissionAccountPerimetersNLS.noownercode
		}
		Column {
			column:identityhrcode
			sortable:True
			filterable:True
			header:$pidentity.hrcode
			initially-masked:True
		}
		Column {
			column:identityfullname
			sortable:True
			filterable:True
			header:$pidentity.fullname
			width:100%
		}
		Column {
			column:identitymail
			sortable:True
			filterable:True
			header:$pidentity.mail
			initially-masked:True
		}
		Column {
			column:identityinternal
			sortable:True
			filterable:True
			header:$pidentity.internal
			initially-masked:True
		}
		Column {
			column:identityactive
			sortable:True
			filterable:True
			header:$pidentity.active
			initially-masked:True
		}
		Column {
			column:identitybwa_identityanalyticsdata_joborg
			initially-masked:True
			filterable:True
			sortable:True
			header:$pidentity.joborg
			width:160px
		}
		Column {
			column: trends
			header: $bw_fragment.trends
			text:Transform Current trends using bwf_trendStatusColumn 
			styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
			image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
			tooltip:$bwf_trendStatusColumnNLS.tooltip

			sortable: True
			filterable: True
			width: 10%
		}												
	}
}

fragmentPermissionAccountsForOrgNLS = NLS {
	directfilter [en "Accounts whom owners are direct members of {0}" fr "Comptes dont les membres sont des membres directs de {0}"]
	subfilter [en "Accounts whom owners are direct or indirect members of {0}" fr "Comptes dont les membres sont des membres directs ou indirects de {0}"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected permission accounts for a given organisation
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inorganisationuid </b>the organisation uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentPermissionAccountsForOrg = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inorganisationuid = Variable { multivalued:False }
	inonlydirectselection = Variable { multivalued:False type:Boolean}
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	accounts = Dataset {
		view: bwf_permissionaccountsfororg with
			inuid to uid,
			inorganisationuid to organisationuid,
			inonlydirectselection to directonly
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		 }
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	organisation = Record {
		view: br_organisationDetail with inorganisationuid to uid
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												False to inshowgroups,
												False to inshowapplications,
												False to inshowshares,
												False to inshowcontrols,
												False to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	Header {
		value:$fragmentPermissionAccountsForOrgNLS.directfilter(organisation.displayname)
		hidden:Not BooleanPredicate(inonlydirectselection)
	}
	Header {
		value:$fragmentPermissionAccountsForOrgNLS.subfilter(organisation.displayname)
		hidden:BooleanPredicate(inonlydirectselection)
	}
	Table {
		data:accounts
		layout:Layout {grab: horizontal True vertical True}
		configurable:True
		show-count:True
		show-filter:True
		double-click:ExecuteNamedAction goDetails
		persist-configuration:True
		
		
		Column {
			column:uid
			hidden:True
			selection:outaccountuid
		}
		
		Column {
			column:login
			header:$account.login
			sortable:True
			filterable:True
			selection:outaccountlogin
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:givenname
			header:$account.givenname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:surname
			header:$account.surname
			sortable:True
			filterable:True
			initially-masked:True
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:username
			header:$account.username
			sortable:True
			filterable:True
			width:160px
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}

		Column {
			column:disabled
			header:$account.disabled
			sortable:True
			filterable:True
			initially-masked:True
		}

		Column {
			column:creationdate
			header:$account.creationdate
			sortable:True
			filterable:True
			initially-masked:True
		}
		Column {
			column:lastlogindate
			header:$account.lastlogindate
			sortable:True
			filterable:True
		}
		Column {
			column:repositoryuid
			hidden:True
			selection:outrepositoryuid
		}
		Column {
			column:repositorydisplayname
			header:$repository.concept
			sortable:True
			filterable:True
			selection:outrepositoryname
		}
		Column {
			column:noownercode
			sortable:True
