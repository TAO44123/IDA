			] otherwise [
				Group {
//					title: $bwf_theoreticalrightsNLS.overAllocs
					Table {
						data: data
						layout: Layout { grab: horizontal True vertical True }
						configurable: True
						show-count: True
						show-filter: True
						persist-configuration:True

						Column {
							column: controlcode
							hidden: True
							header: $controlresult.controlcode
						}
						Column {
							column: controlrisklevel
							header: $bwf_theoreticalrightsNLS.risklevel
							width: 96px
							sortable: True
							filterable: True
							image: TemplateImageSelection(Current controlrisklevel) using bwf_controllevel
							initially-masked: True
						}
						Column {
							column: controldisplayname
							header: $controlresult.controldisplayname
							width: 100%
							sortable: True
							filterable: True
							initially-masked: True
						}
						Column {
							column: controldescription
							initially-masked: True
							header: $controlresult.controldescription
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: controlriskinfo
							initially-masked: True
							header: $bwf_theoreticalrightsNLS.riskinfo
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: controlsuggestedmitogation
							initially-masked: True
							header: $bwf_theoreticalrightsNLS.suggestedmitigation
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: uid
							selection: outidentity
							hidden:True
						}
						Column {
							column: hrcode
							header: $identity.hrcode
							width: 100%
							sortable: True
							filterable: True
						}
						Column {
							column: fullname
							header: $identity.fullname
							width: 100%
							sortable: True
							filterable: True
							selection:outidentityname
						}
						Column {
							column: mail
							header: $identity.mail
							width: 100%
							sortable: True
							filterable: True
							initially-masked:True
						}
						Column {
							column: internal
							header: $identity.internal
							width: 100%
							sortable: True
							filterable: True
							initially-masked:True
						}
						Column {
							column: active
							header: $identity.active
							width: 100%
							sortable: True
							filterable: True
							initially-masked:True
						}
						Column {
							column: trends
							header: $bw_fragment.trends
							text:Transform Current trends using bwf_trendStatusColumn 
							styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
							image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
							tooltip:$bwf_trendStatusColumnNLS.tooltip
	
							sortable: True
							filterable: True
							width: 10%
						}												
