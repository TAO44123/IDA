/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/styles/styles.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/sharedfolder/details/sharedfolderDetails.page"
import "/webportal/pages/bw_fragments/share/details/shareDetails.page"

fragmentPermissionUsagesNLS = NLS {
	empty [en "No usages available" fr "Pas d'usages disponible"]
}

/**
 * <span style="white-space: pre-line">
 * Display the usages for a given permission
 *
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the permission uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * </span>
 */
fragmentPermissionUsages = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	selectedAccount = Variable { private:True }
	selectedIdentity = Variable { private:True }
	selectedPermission = Variable { private:True }
	selectedApplication = Variable { private:True }

	// Record for concept details
	account = Record {
		view: bwf_accountDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	usages = Dataset {
		view: bwf_permissionusages with inuid to permission
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	perm = Record {
		view: br_permissionDetail with selectedPermission to uid
	}
	app = Record {
		view: br_applicationDetail with selectedApplication to uid
	}

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedAccount to inuid, 
												True to inshowowner
												)
			]
			when False then [
			]
		}
	)
	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
						Dialog bwf_permissionDetailsDialog(selectedPermission to inuid,
														True to inshowperorg,
														True to inshowperjob
														)
			]
			when False then [
			]
		}
	)
	goApplicationDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
						Dialog bwf_applicationDetailsDialog(selectedApplication to inuid,
														True to inshowperorg,
														True to inshowperjob
														)
			]
			when False then [
			]
		}
	)

	ConditionalGroup {
		IntCondition(Count usages) {
			when =0 then [
				Header {
					value:$fragmentPermissionUsagesNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Table {
					data:usages
					layout:Layout { grab:horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True

					// usage
					Column {
						column:aggregate
						header:$usage.aggregate
						sortable:True
						filterable:True
						width:160px
					}				
					Column {
						column:displayname
						header:$pusage.displayname
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}				
					Column {
						column:counter
						header:$usage.counter
						align:Right
						sortable:True
						filterable:True
						width:96px
					}				
					Column {
						column:firstdate
						header:$usage.firstdate
						sortable:True
						filterable:True
						width:100px
					}				
					Column {
						column:lastdate
						header:$usage.lastdate
						sortable:True
						filterable:True
						width:100px
					}				

					
					// account
					Column {
						column:accountidentifier
						header:$account.identifier
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
						actions:ExecuteNamedAction goAccountDetails
					}				
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						width:128px
						actions:ExecuteNamedAction goAccountDetails
					}				
					Column {
						column:accountusername
						header:$account.username
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
						actions:ExecuteNamedAction goAccountDetails
					}				
					Column {
						column:accountmail
						header:$account.mail
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}				
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						initially-masked:True
						width:128px
					}				
					Column {
						column:accountdisabled
						header:$account.disabled
						sortable:True
						initially-masked:True
						width:96px
					}				
					Column {
						column:accountservice
						header:$account.service
						sortable:True
						initially-masked:True
						width:96px
					}				
					Column {
						column:repositorydisplayname
						header:$repository.concept
						sortable:True
						filterable:True
						width:128px
					}				

					// identity
					Column {
						column:identityhrcode
						header:$pidentity.hrcode
						sortable:True
						filterable:True
						initially-masked:True
						width:96px
					}				
					Column {
						column:identityfullname
						header:$pidentity.fullname
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}				
					Column {
						column:identitymail
						header:$pidentity.mail
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
					}				
					Column {
						column:identityinternal
						sortable:True
						filterable:True
						header:$pidentity.internal
						initially-masked:True
					}
					Column {
						column:identityactive
						sortable:True
						filterable:True
						header:$pidentity.active
						initially-masked:True
					}
					Column {
						column:identitybwa_identityanalyticsdata_joborg
						initially-masked:True
						filterable:True
						sortable:True
						header:$pidentity.joborg
						width:160px
					}

					// permission
					Column {
						column:permissioncode
						header:$ppermission.code
						sortable:True
						filterable:True
						width:160px
						actions:ExecuteNamedAction goPermissionDetails
					}				
					Column {
						column:permissiondisplayname
						header:$ppermission.displayname
						sortable:True
						filterable:True
						initially-masked:True
						width:160px
						actions:ExecuteNamedAction goPermissionDetails
					}				
					Column {
						column:permissionpermissiontype
						header:$ppermission.permissiontype
						sortable:True
						filterable:True
						initially-masked:True
						width:100px
					}				

					// application
					Column {
						column:applicationdisplayname
						header:$application.concept
						sortable:True
						filterable:True
						width:100px
						actions:ExecuteNamedAction goApplicationDetails
					}	
					
					// uids
					Column {
						column:accountuid
						selection:selectedAccount
						hidden:True
					}			
					Column {
						column:identityuid
						selection:selectedIdentity
						hidden:True
					}			
					Column {
						column:applicationuid
						selection:selectedApplication
						hidden:True
					}			
					Column {
						column:permissionuid
						selection:selectedPermission
						hidden:True
					}			
				}
			]
		}
	}
}