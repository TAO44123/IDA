bwfPermissionSensitivityLevel_NLS = NLS {
	notclassified [en "Not classified" fr "Non classifié"]
	low [en "Low" fr "Faible"]
	medium [en "Medium" fr "Moyen"]
	high [en "High" fr "Elevé"]
	extreme [en "Highest" fr "Extrême"]
}

bwfPermissionSensitivityLevelMapping = StringMapping {
	when "0" then $bwfPermissionSensitivityLevel_NLS.notclassified
	when "1" then $bwfPermissionSensitivityLevel_NLS.low
	when "2" then $bwfPermissionSensitivityLevel_NLS.medium
	when "3" then $bwfPermissionSensitivityLevel_NLS.high
	when "4" then $bwfPermissionSensitivityLevel_NLS.extreme
	otherwise $bwfPermissionSensitivityLevel_NLS.notclassified

}


