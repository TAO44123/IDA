/**
 * Add permission manager
 * 
 */
bwfPermissionDetailsAddManager_Dialog = Dialog {
	title: $bwfPermissionDetailsManager_Dialog_NLS.title
	buttons:[ 
				OkButton {
						disabled:StringPredicate(newmanagerUid) { when IsEmpty then True otherwise False }
						actions:
							Confirm $bwfPermissionDetailsManager_Dialog_NLS.newmanagerconfirm( Transform newManager.hrcode using mayBeNullMapping, newManager.fullname,Transform newManagertype using bwfManagerTypeMapping, permission.displayname),
							Set newManagertype to task.managertype,
							Set paramPermissionUid to task.permission,
							Set newmanagerUid to task.manager,
							Set newcomment to task.comments,
							Set delegation to task.delegation,
							Set _priority to task.delegationpriority,
							Set _reason to task.delegationreason,
							Set Date(startdate).valueLDAP to task.delegationbegindate,
							Set Date(enddate).valueLDAP to task.delegationenddate,
							Set 'create' to task.action,
							TaskComplete task wait-end,
							Flash Information $bwfPermissionDetailsManager_Dialog_NLS.confirmupdate
						}
				CancelButton
			]
	width:800
	height:430
	
	/* Parameters here */
	paramPermissionUid = Variable {type:String multivalued:False}

	newManagertype = Variable {type:String multivalued:False initial:'businessowner' private:True}
	newmanagerUid = Variable {type:String multivalued:False private:True}
	newcomment = Variable {type:String multivalued:False private:True initial:' '}

	delegation = Variable {type:Boolean multivalued:False private:True initial:False}
	_priority = Variable {type:Integer multivalued:False private:True initial:0}
	_reason = Variable {type:String multivalued:False private:True initial:' '}
	startdate = Variable {type:Date multivalued:False private:True initial:Date.value}
	enddate = Variable {type:Date multivalued:False private:True initial:Date.offset(10 years).value}
	
	/* Datasets and records here */
	// Record for concept details
	permission = Record {
		view: br_permissionDetail with paramPermissionUid to uid
	}
	
	newManager = Record {
		view: br_identityDetail with newmanagerUid to uid
	}

	task = TaskRecord (create "bwf_updatepermissionmanager")
	
	
	/* Page content */
	
	Header {
		value:$bwfPermissionDetailsManager_Dialog_NLS.title
		styling:bigTitleStyle
	}
	Separator {
	}
	Combo {
		label:$bw_fragment_updateownerNLS.managertype
		variable:newManagertype
		layout:Layout { grab:horizontal False vertical False hint:width 160 }
		options:Static {
			Option {
				text:$bw_fragment_updateownerNLS.businessowner
				value:'businessowner'
			}
			Option {
				text:$bw_fragment_updateownerNLS.technicalowner
				value:'technicalowner'
			}
			Option {
				text:$bw_fragment_updateownerNLS.reviewer
				value:'areviewer'
			}
		}
	}
	Text {
		label:$bw_fragment_updateownerNLS.manager
		value:newManager.fullname
		layout:Layout { grab:horizontal False vertical False hint:width 260 }
		commands: Command {	
				actions:Dialog identityPicker(newmanagerUid from outUid)
            	icon:%concept_16.manager
            	tooltip:$bw_fragment_updateownerNLS.managertooltip
           }
	}
	Edit {
		label:$bw_fragment_updateownerNLS.comments
		variable:newcomment
	}
		Checkbox {
			variable:delegation
			label:$bw_fragment_updateownerNLS.delegatedmanager
			tooltip:$bw_fragment_updateownerNLS.delegatedmanagertooltip
			text:$bw_fragment_updateownerNLS.isdelegated
		}
	Group {
		title:$bw_fragment_updateownerNLS.delegationdetails
		Edit {
			variable:_reason
			label:$bw_fragment_updateownerNLS._reason
			tooltip:$bw_fragment_updateownerNLS._reasontooltip
			disabled:Not BooleanPredicate(delegation)
		}
		Spinner {
			variable:_priority
			label:$bw_fragment_updateownerNLS._priority
		layout:Layout { grab:horizontal False vertical False hint:width 130 }
			tooltip:$bw_fragment_updateownerNLS._prioritytooltip
			minimum:0
			maximum:9
			disabled:Not BooleanPredicate(delegation)
		}
		/*
		DateTime {
			variable:startdate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updateownerNLS.begindate
			type:Date
			tooltip:$bw_fragment_updateownerNLS.begindatetooltip
			disabled:Not BooleanPredicate(delegation)
		}	
		DateTime {
			variable:enddate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updateownerNLS.enddate
			tooltip:$bw_fragment_updateownerNLS.enddatetooltip
			type:Date
			disabled:Not BooleanPredicate(delegation)
		}
		* 
		*/
	}
}

