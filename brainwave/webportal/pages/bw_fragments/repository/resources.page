/**
 * Update repository description
 * 
 * @param paramRepositoryUid repository uid
 */
bwfRepositoryDetailsMetadata_Dialog = Dialog {
	title: $bwfRepositoryDetailsMetadata_Dialog_NLS.title
	enter-event:	TransferData categories(category) to (categoryList), 
					Set repository.description to description,
					Set repository.sensitivityreason to sensitivityreason,
					Set repository.category to category,
					Set repository.sensitivitylevel to sensitivitylevel
	buttons:[
	
		OkButton {
			disabled:
				OrPredicate {
					StringPredicate(changed) {when '1' then False otherwise True}
					AndPredicate {
						IntPredicate(sensitivitylevel) { when >0 then True otherwise False }				
						Not BooleanPredicate(reasonisvalid) 
					}
					StringPredicate(description) { when IsEmpty then True otherwise False }
				}
			actions:Set description to task.description,
					Set sensitivityreason to task.sensitivityreason,
					Set category to task.category,
					Set sensitivitylevel to task.sensitivitylevel,
					Set paramRepositoryUid to task.repository,
					TaskComplete task wait-end,
					Flash $bwfRepositoryDetailsMetadata_Dialog_NLS.done
		} 
	
		CancelButton
	]
	
	width:800
	height:300
	
	/* Parameters here */
	paramRepositoryUid = Variable {type:String multivalued:False}

	description = Variable
	sensitivitylevel = Variable
	sensitivityreason = Variable
	category = Variable
	
	selecteddescription = Variable { private:True }
	newcategory = Variable { private:True }
	changed = Variable{type:String initial:'0' private:True }
	categoryList = Variable {type:String multivalued:True}
	reasonisvalid = Variable

	repository = Record {
		view: br_repositoryDetail with paramRepositoryUid to uid
	}
	categories = Dataset {
		view:bwf_repositorycategory
	}
	categoryCombo = Dataset {
		columns:categoryList
	}

	task = TaskRecord (create "bwf_updaterepositorymetadata")
	

	Header {
		value:$bwfRepositoryDetailsMetadata_Dialog_NLS.description
		styling:subtitleStyle
	}
	Separator
	Combo {
		variable:category
		label:$bwfRepositoryDetailsMetadata_Dialog_NLS.category
		allow-none:True
		options:Dynamic {
			data:categoryCombo
			text:Current categoryList
			value:Current categoryList
		}
		modify-event:Set '1' to changed
		commands:Commands {
			position:After
			Command {
				actions:Dialog bwfRepositoryDetailsText_Dialog(newcategory from text), MultivaluedAdd newcategory to categoryList, Set newcategory to category, Set '1' to changed
				
				icon:'16/famfamfam_silk_icons_v013/add_black.png'
				tooltip:$bwfRepositoryDetailsMetadata_Dialog_NLS.addcategory
			}
		}
	}
	Combo {
		variable:sensitivitylevel
		label:$bwfRepositoryDetailsMetadata_Dialog_NLS.sensitivitylevel
		modify-event:Set '1' to changed, IntCase(sensitivitylevel) { when =0 then [ Set '-' to sensitivityreason] }
		options:Static {
			Option {
				text:Transform "0" using bwfRepositorySensitivityLevelMapping
				value:0
			}
			Option {
				text:Transform "1" using bwfRepositorySensitivityLevelMapping
				value:1
			}
			Option {
				text:Transform "2" using bwfRepositorySensitivityLevelMapping
				value:2
			}
			Option {
				text:Transform "3" using bwfRepositorySensitivityLevelMapping
				value:3
			}
			Option {
				text:Transform "4" using bwfRepositorySensitivityLevelMapping
				value:4
			}
		}
	}
	Edit {
		variable:sensitivityreason
		label:$bwfRepositoryDetailsMetadata_Dialog_NLS.sensitivityreason
		modify-event:Set '1' to changed
		not-empty:True
		match:'[0-9a-zA-z].+'
		validity:reasonisvalid
		error-tooltip:$bwfRepositoryDetailsMetadata_Dialog_NLS.sensitivityreasonvalid
		hidden:IntPredicate(sensitivitylevel) { when =0 then True otherwise False }
	}
	Edit {
		variable:description
		label:$bwfRepositoryDetailsMetadata_Dialog_NLS.descriptionlabel
		multi-lines:True
		layout:Layout{grab: horizontal True vertical False hint:height 64}
		modify-event:Set '1' to changed
		not-empty:True
	}	
}

/**
 * Add repository manager
 * 
 */
bwfRepositoryDetailsAddManager_Dialog = Dialog {
	title: $bwfRepositoryDetailsManager_Dialog_NLS.title
	buttons:[ 
				OkButton {
						disabled:StringPredicate(newmanagerUid) { when IsEmpty then True otherwise False }
						actions:
							Confirm $bwfRepositoryDetailsManager_Dialog_NLS.newmanagerconfirm( Transform newManager.hrcode using mayBeNullMapping, newManager.fullname, Transform newManagertype using bwfManagerTypeMapping,  repository.displayname),
							Set newManagertype to task.managertype,
							Set paramRepositoryUid to task.repository,
							Set newmanagerUid to task.manager,
							Set newcomment to task.comments,
							Set delegation to task.delegation,
							Set _priority to task.delegationpriority,
							Set _reason to task.delegationreason,
							Set Date(startdate).valueLDAP to task.delegationbegindate,
							Set Date(enddate).valueLDAP to task.delegationenddate,
							Set 'create' to task.action,
							TaskComplete task wait-end,
							Flash Information $bwfRepositoryDetailsManager_Dialog_NLS.confirmupdate
						}
				CancelButton
			]
	width:800
	height:430
	
	/* Parameters here */
	paramRepositoryUid = Variable {type:String multivalued:False}

	newManagertype = Variable {type:String multivalued:False initial:'businessowner' private:True}
	newmanagerUid = Variable {type:String multivalued:False private:True}
	newcomment = Variable {type:String multivalued:False private:True initial:' '}

	delegation = Variable {type:Boolean multivalued:False private:True initial:False}
	_priority = Variable {type:Integer multivalued:False private:True initial:0}
	_reason = Variable {type:String multivalued:False private:True initial:' '}
	startdate = Variable {type:Date multivalued:False private:True initial:Date.value}
	enddate = Variable {type:Date multivalued:False private:True initial:Date.offset(10 years).value}
	
	/* Datasets and records here */
	// Record for concept details
	repository = Record {
		view: br_repositoryDetail with paramRepositoryUid to uid
	}
	
	newManager = Record {
		view: br_identityDetail with newmanagerUid to uid
	}

	task = TaskRecord (create "bwf_updaterepositorymanager")
	
	
	/* Page content */
	
	Header {
		value:$bwfRepositoryDetailsManager_Dialog_NLS.title
		styling:bigTitleStyle
	}
	Separator {
	}
	Combo {
		label:$bw_fragment_updateownerNLS.managertype
		variable:newManagertype
		layout:Layout { grab:horizontal False vertical False hint:width 160 }
		options:Static {
			Option {
				text:$bw_fragment_updateownerNLS.businessowner
				value:'businessowner'
			}
			Option {
				text:$bw_fragment_updateownerNLS.technicalowner
				value:'technicalowner'
			}
			Option {
				text:$bw_fragment_updateownerNLS.reviewer
				value:'areviewer'
			}
		}
	}
	Text {
		label:$bw_fragment_updateownerNLS.manager
		value:newManager.fullname
		layout:Layout { grab:horizontal False vertical False hint:width 260 }
		commands: Command {	
				actions:Dialog identityPicker(newmanagerUid from outUid)
            	icon:%concept_16.manager
            	tooltip:$bw_fragment_updateownerNLS.managertooltip
           }
	}
	Edit {
		label:$bw_fragment_updateownerNLS.comments
		variable:newcomment
	}
		Checkbox {
			variable:delegation
			label:$bw_fragment_updateownerNLS.delegatedmanager
			tooltip:$bw_fragment_updateownerNLS.delegatedmanagertooltip
			text:$bw_fragment_updateownerNLS.isdelegated
		}
	Group {
		title:$bw_fragment_updateownerNLS.delegationdetails
		Edit {
			variable:_reason
			label:$bw_fragment_updateownerNLS._reason
			tooltip:$bw_fragment_updateownerNLS._reasontooltip
			disabled:Not BooleanPredicate(delegation)
		}
		Spinner {
			variable:_priority
			label:$bw_fragment_updateownerNLS._priority
		layout:Layout { grab:horizontal False vertical False hint:width 130 }
			tooltip:$bw_fragment_updateownerNLS._prioritytooltip
			minimum:0
			maximum:9
			disabled:Not BooleanPredicate(delegation)
		}
		/*
		DateTime {
			variable:startdate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updateownerNLS.begindate
			type:Date
			tooltip:$bw_fragment_updateownerNLS.begindatetooltip
			disabled:Not BooleanPredicate(delegation)
		}	
		DateTime {
			variable:enddate
			layout:Layout { grab:horizontal False vertical False hint:width 160 }
			label:$bw_fragment_updateownerNLS.enddate
			tooltip:$bw_fragment_updateownerNLS.enddatetooltip
			type:Date
			disabled:Not BooleanPredicate(delegation)
		}
		* 
		*/
	}
}

