			actions:
				Set uids to task.uids,
				TaskComplete task
			}
		]

	uids = Variable { multivalued:True }
	
	task = TaskRecord(create "bwa_bulkremoveallrepositorytag")

	Header {
		value:$fragmentRepositoryTagsEditorNLS.removeallconfirmation(SizeOf uids)
	}
