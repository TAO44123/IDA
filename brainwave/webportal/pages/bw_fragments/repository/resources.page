bwfRepositorySensitivityLevel_NLS = NLS {
	notclassified [en "Not classified" fr "Non classifié"]
	low [en "Low" fr "Faible"]
	medium [en "Medium" fr "Moyen"]
	high [en "High" fr "Elevé"]
	extreme [en "Highest" fr "Extrême"]
}

bwfRepositoryTypeMapping_NLS = NLS {
	AD [ en "Active Directory" fr "Active Directory" ]
	AAD [ en "Entra ID" fr "Entra ID" ]
	ca_vault [ en "CyberArk Vault" fr "CyberArk Vault" ]
	Server [ en "Server" fr "Serveur" ]
}

bwfRepositoryFamilyTypeMapping_NLS = NLS {
	AD [ en "Active Directory" fr "Active Directory" ]
	Azure [ en "Entra ID" fr "Entra ID" ]
	AdminRoles [ en "Entra ID Admin Roles" fr "Entra ID rôles admin" ]
	SPO [ en "Sharepoint Online" fr "Sharepoint Online" ]
	WinServer [ en "Windows Server" fr "Serveur Windows" ]
}

bwfRepositorySensitivityLevelMapping = StringMapping {
	when "0" then $bwfRepositorySensitivityLevel_NLS.notclassified
	when "1" then $bwfRepositorySensitivityLevel_NLS.low
	when "2" then $bwfRepositorySensitivityLevel_NLS.medium
	when "3" then $bwfRepositorySensitivityLevel_NLS.high
	when "4" then $bwfRepositorySensitivityLevel_NLS.extreme
	otherwise $bwfRepositorySensitivityLevel_NLS.notclassified

}

bwfRepoType = StringMapping {
	when "AD" then $bwfRepositoryTypeMapping_NLS.AD
	when "AAD" then $bwfRepositoryTypeMapping_NLS.AAD
	when "ca_vault" then $bwfRepositoryTypeMapping_NLS.ca_vault
	when "Server" then $bwfRepositoryTypeMapping_NLS.Server
	
}

bwfRepoFamilyType= StringMapping {
	when "AD" then $bwfRepositoryFamilyTypeMapping_NLS.AD
	when "Azure" then $bwfRepositoryFamilyTypeMapping_NLS.Azure
	when "AdminRoles" then $bwfRepositoryFamilyTypeMapping_NLS.AdminRoles
	when "SPO" then $bwfRepositoryFamilyTypeMapping_NLS.SPO
	when "Windows Server" then $bwfRepositoryFamilyTypeMapping_NLS.WinServer
}



