													Confirm Concat($fragmentRepositoryAccountsReassign.confirm,SizeOf selectedentries, $fragmentRepositoryAccountsReassign.confirmmiddle,newreviewername,$fragmentRepositoryAccountsReassign.confirmend),
													Set newrevieweruid to reassigntask.reviewer,
