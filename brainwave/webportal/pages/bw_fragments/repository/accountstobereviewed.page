/**
 * <span style="white-space: pre-line">
 * Display the repository accounts to be reviewed for a given identity as a crosstab
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (false by default)</li>
 * <li><b>infilterbycampaign </b>optional, filter for a given campaign (recorduid) (disabled by default)</li>
 * <li><b>infilterreviewed </b>optional, boolean value, filter already reviewed entries (true by default)</li>
 * <li><b>infilterdelegated </b>optional, boolean value, filter delegated entries (true by default)</li>
 * </ul>
 * </span>
 */
fragmentRepositoryAccountsToBeReviewedCrosstab = PageFragment {
	enter-event: 	TransferData campaignsinperimeter(key) to (includedcampaigns)
										
	feature:iasreview_license
	
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	incanshowdetails = Variable { initial:True type:String }	
	inenabled = Variable { multivalued:False type:Boolean initial:False	changed-event:Unset selectedentries }
	infilterbycampaign = Variable 
	infilterreviewed = Variable { type:Boolean initial:True	}
	infilterdelegated = Variable { type: Boolean initial: False }

	outrepositoryuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable

	selectedentries = Variable { multivalued:True }
	selectedentry = Variable
	selectedreviewcomment = Variable
	
	updatestatus = Variable { type:Boolean }
	statustowrite = Variable
	updatecomment = Variable { type:Boolean }
	commenttowrite = Variable
	
	includedcampaigns = Variable { multivalued:True }

	newrevieweruid = Variable
	newreviewername = Variable
	
	entriestocheck = Variable { multivalued:True }
	identitytocheck = Variable
	
	
	ct_selectedrepositories = Variable { multivalued:True }
	ct_selectedidentities = Variable { multivalued:True }
	ct_selectedaccounts = Variable { multivalued:True }
	
	// used to extract the full list of "active" campaigns (non finalized campaigns)
	campaignsinperimeter = Dataset {
		view: bwaccess360r_accessreviewcampaignsongoing
	}

	// entries to review
	review = Dataset {
		view: bwf_repositoryaccountsreview with
			inuid to revieweruid, 
			infilterbycampaign to campaignid unless-empty, 
			includedcampaigns to includedcampaigns, 
			infilterreviewed to notreviewedonly,
			infilterdelegated to filteraccountable
			limit:10000 // limited to 10000 for perf reasons
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	reviewselection = Dataset {
		view: bwf_repositoryaccountsreview with
			inuid to revieweruid, 
			infilterbycampaign to campaignid unless-empty, 
			includedcampaigns to includedcampaigns, 
			infilterreviewed to notreviewedonly,
			infilterdelegated to filteraccountable
			limit:10000 // limited to 10000 for perf reasons

		includes:
			OrPredicate {
				AndPredicate {
					StringPredicate(ct_selectedaccounts) { when IsEmpty then True otherwise False }  		
					MultivaluedPredicate (ct_selectedidentities contains Current identityuid)  		
					MultivaluedPredicate (ct_selectedrepositories contains Current repositoryuid)
				}
				AndPredicate {
					StringPredicate(ct_selectedaccounts) { when IsEmpty then False otherwise True }  		
					MultivaluedPredicate (ct_selectedaccounts contains Current accountuid)  		
					MultivaluedPredicate (ct_selectedrepositories contains Current repositoryuid)
				}
			}		
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	checkreassignwithidentity = Dataset {
		view: bwf_identityapplicationreviewentriesbyidentity with
			entriestocheck to ticketreviewrecorduids,
			identitytocheck to identityuid
	}

	// infos	
	selectedcampaign = Record {
		view:bwaccess360_accessreviewcampaigns with infilterbycampaign to campaignid
		disabled:StringPredicate(infilterbycampaign) { when IsEmpty then True otherwise False }
	}
	
	task = TaskRecord( create "bwaccess360_writeAccessRightsReviewTickets")
	reassigntask = TaskRecord( create "bwaccess360_reassignAccessRightsReviewTickets")

	goRepositoryDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_repositoryDetailsDialog(outrepositoryuid to inuid)
			]
			when False then [
			
			]
		}
	)
	
	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}
	)

	writeBulkStatus = NamedAction (
		Set selectedentries to task.ticketreviewrecorduid,
		Set [statustowrite repeat SizeOf selectedentries] to task.status,
		Set [commenttowrite repeat SizeOf selectedentries] to task.comment,
		Set [Date.valueLDAP repeat SizeOf selectedentries] to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 120,
		Flash Concat(SizeOf selectedentries, $fragmentRepositoryAccountsToBeReviewedNLS.writeBulkStatus.flash),
		Unset selectedentries,
		ReloadData (review)
	)

	writeStatus = NamedAction (
		Set selectedentry to task.ticketreviewrecorduid,
		Set statustowrite  to task.status,
		Set commenttowrite to task.comment,
		Set Date.valueLDAP to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 30,
		Flash $fragmentRepositoryAccountsToBeReviewedNLS.writeStatus.flash,
		ReloadData (review)
	)

	// action buttons		
	Grid {
		columns:GridColumn { width:grow }, GridColumn, GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 48 }
		GridRow {
			GridCell {
				ButtonGroup {
					nb-inline:3
					layout:Layout { align:horizontal Beginning vertical Center }
					Button {
						actions:	Set "ok" to statustowrite,
									Set True to updatestatus,
									Set False to updatecomment,
									ExecuteNamedAction writeBulkStatus
									 
						image:"16/famfamfam_silk_icons_v013/accept.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkapproval.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkapproval.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:	Set "revoke" to statustowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									Dialog fragmentRepositoryAccountsToBeReviewedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus
						image:"16/famfamfam_silk_icons_v013/delete.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkrevocation.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkrevocation.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:
									Set False to updatestatus,
									Set True to updatecomment,
									Dialog fragmentRepositoryAccountsToBeReviewedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus 
						image:"16/famfamfam_silk_icons_v013/comment.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkcomment.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkcomment.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:Dialog fragmentRepositoryAccountsToBeReviewedFilters(
															inuid to inuid,
															includedcampaigns to includedcampaigns,
															infilterbycampaign to outfilterbycampaign,
															infilterreviewed to outfilterreviewed,
															infilterdelegated to outfilterdelegated,
															infilterbycampaign from outfilterbycampaign,
															infilterbycampaign from outfilterbycampaign,
															infilterbycampaign from outfilterbycampaign,
															infilterdelegated from outfilterdelegated
						)
						text:$fragmentRepositoryAccountsToBeReviewedFilters.text
						image:"16/famfamfam_silk_icons_v013/cog.png"
					}
					Button {
						actions:	Set "update" to statustowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									Dialog fragmentRepositoryAccountsToBeUpdatedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus
						image:"16/famfamfam_silk_icons_v013/pencil.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkupdate.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkupdate.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:	
									Dialog fragmentRepositoryAccountsReassignDlg(selectedentries to inselectedentries, newrevieweruid from outUid, newreviewername from outDisplayname),
									StringCase(newrevieweruid) {
										when Not IsEmpty then [
											Set selectedentries to entriestocheck,
											Set newrevieweruid to identitytocheck,
											IntCase(Count checkreassignwithidentity) {
												when >0 then [
													Message Error $fragmentRepositoryAccountsReassign.error
												]
												otherwise [
													Confirm Concat($fragmentRepositoryAccountsReassign.confirm,SizeOf selectedentries, $fragmentRepositoryAccountsReassign.confirmmiddle,newreviewername,$fragmentRepositoryAccountsReassign.confirmend),
													Set newrevieweruid to reassigntask.reviewer,
													Set selectedentries to reassigntask.ticketreviewrecorduids,
													TaskComplete reassigntask wait-end timeout-seconds 120,
													Flash Concat(SizeOf selectedentries, $fragmentRepositoryAccountsReassign.flash, newreviewername),
													Unset selectedentries,
													Set True to infilterdelegated,
													ReloadData (review)
												]
											}
										]
									}
						image:"16/audit/identity_16.png"
						text:$fragmentRepositoryAccountsReassign.text
						tooltip:$fragmentRepositoryAccountsReassign.tooltip
						feature:iasreview_selfmanagement
						disabled:
								OrPredicate {
									StringPredicate(infilterbycampaign) { when IsEmpty then True otherwise False } // cannot reassign if you are displaying multiple campaigns at once...
									StringPredicate(selectedcampaign.selfdelegation) { when "1" then False otherwise True } // self delegation must be enabled in the selected campaign
									IntPredicate(SizeOf selectedentries) { when >999 then True } // cannot reassign more than 1000 entries at once due to a SQL limitation
									IntPredicate(SizeOf selectedentries) { when =0 then True } // no entries selected? nothing to reassign 
								}
					}
				}
			}
			GridCell {
				Header {
					value:$fragmentRepositoryAccountsToBeReviewedNLS.displayallentries
					hidden:BooleanPredicate(infilterreviewed)
					styling:italicStyle
				}			
			}
			GridCell {
				Header {
					value:Concat($fragmentRepositoryAccountsToBeReviewedNLS.filterforcampaign, selectedcampaign.title)
					hidden:StringPredicate(infilterbycampaign) { when IsEmpty then True otherwise False }
					layout:Layout { grab:horizontal False vertical False hint:width 400 align:horizontal End vertical Center }
					tooltip:selectedcampaign.description
					styling:italicStyle
					align:Right
				}			
			}
		}
	}	

	ConditionalGroup {
		IntCondition(Count review) {
			when >0 then [
				CrossTable {
					data:review
					cluster-sortable:True
					default-configurable:True
					multi-selection:True
					show-filter:True
					swappable:True
					cluster-keep-sort-on-change:True
					user-configurable:True
					persist-configuration:True
					layout: Layout {
						grab:horizontal True
						vertical True
						cell-width: 30px
					}
					selection-changed-event:TransferData reviewselection(reviewrecorduid) to (selectedentries)
					configuration-changed-event:
											Unset ct_selectedaccounts, 
											Unset ct_selectedidentities,
											Unset ct_selectedrepositories
					
					columns:
						Dim { value:repositoryrepositorytype label:repositoryrepositorytype header:$repository.repositorytype tooltip:repositoryrepositorytype initially-masked:True },					
						Dim { value:repositoryrepositoryfamily  label:repositoryrepositoryfamily  header:$repository.repositoryfamily tooltip:repositoryrepositoryfamily initially-masked:True },					
						Dim { value:repositoryuid label:repositorydisplayname header:$repository.concept selection:ct_selectedrepositories header-click:outrepositoryuid tooltip:repositorydisplayname }					

					rows:
						Dim { value:identityjoborg label:identityjoborg header:$identity.joborg initially-masked: True tooltip:identityjoborg },			
						Dim { value:identityinternal label:identityinternal header:$identity.internal initially-masked: True },			
						Dim { value:identityhrcode label:identityhrcode header:$identity.hrcode initially-masked: True tooltip:identityhrcode },			
						Dim { value:identityuid label:identityfullname header:$identity.concept initially-masked: False selection:ct_selectedidentities tooltip:identityfullname },			
						Dim { value:accountusername label:accountusername header:$account.concept initially-masked: True tooltip:accountusername },			
						Dim { value:accountuid label:accountlogin header:$account.login width:160px initially-masked: False  selection:ct_selectedaccounts header-click:outaccountuid tooltip:accountlogin }			
				
					cell-content:CellContent { 
						text: ""
						comment: NonEmpty(Current reviewcomment, Current accountlogin)
						image: TemplateImageSelection(LowerCase Current reviewstatus) using bwReviewStatusIcon
						align: Center
						cluster-value: "X"
						styling:StylingTemplateSelection(Current accountmaxrisklevel) using riskstyling
					}

					column-header-click:
						ExecuteNamedAction goRepositoryDetails
					row-header-click:
						ExecuteNamedAction goAccountDetails
				}
			]
			otherwise [
				Header {
					value:$fragmentRepositoryAccountsToBeReviewedNLS.header
					layout:Layout { grab: horizontal True vertical False align:horizontal Center vertical Beginning }
				}		
				Image {
					image:"bw_access360/fireworks.svg"
					image-size:300 300
					layout:Layout { grab: horizontal True vertical True align:horizontal Center vertical Beginning }
				}	
			]		
		}
	}
}
