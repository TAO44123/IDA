/**
 * <span style="white-space: pre-line">
 * Display the application rights to be reviewed for a given identity in a grouped table
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the identity uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (false by default)</li>
 * <li><b>infilterbycampaign </b>optional, filter for a given campaign (recorduid) (disabled by default)</li>
 * <li><b>infilterreviewed </b>optional, boolean value, filter already reviewed entries (true by default)</li>
 * <li><b>infilterdelegated </b>optional, boolean value, filter delegated entries (true by default)</li>
 * </ul>
 * </span>
 */
fragmentRepositoryAccountsToBeReviewedGroupedColumn = PageFragment {
	enter-event: 	TransferData campaignsinperimeter(key) to (includedcampaigns)
										
	feature:iasreview_license
	
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	incanshowdetails = Variable { initial:True type:String }	
	inenabled = Variable { multivalued:False type:Boolean initial:False	changed-event:Unset selectedentries }
	infilterbycampaign = Variable 
	infilterreviewed = Variable { type:Boolean initial:True	}
	infilterdelegated = Variable { type: Boolean initial: False }

	outidentityuid = Variable
	outaccountuid = Variable

	selectedentries = Variable { multivalued:True }
	selectedentry = Variable
	selectedreviewcomment = Variable
	
	updatestatus = Variable { type:Boolean }
	statustowrite = Variable
	updatecomment = Variable { type:Boolean }
	commenttowrite = Variable
	
	includedcampaigns = Variable { multivalued:True }

	newrevieweruid = Variable
	newreviewername = Variable
	
	entriestocheck = Variable { multivalued:True }
	identitytocheck = Variable
	
	groupedbycolumn = Variable
	
	// used to extract the full list of "active" campaigns (non finalized campaigns)
	campaignsinperimeter = Dataset {
		view: bwaccess360r_accessreviewcampaignsongoing
	}

	// entries to review
	treereview = HierarchicalData {
		view: bwf_repositoryaccountsreviewgroupedby with
			inuid to revieweruid, groupedbycolumn to groupedby,
			infilterbycampaign to campaignid unless-empty, 
			includedcampaigns to includedcampaigns, 
			infilterreviewed to notreviewedonly,
			infilterdelegated to filteraccountable
		initial: isheader = '1'
		connect:parent id to child parentid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	checkreassignwithidentity = Dataset {
		view: bwf_identityapplicationreviewentriesbyidentity with
			entriestocheck to ticketreviewrecorduids,
			identitytocheck to identityuid
	}

	// infos	
	selectedcampaign = Record {
		view:bwaccess360_accessreviewcampaigns with infilterbycampaign to campaignid
		disabled:StringPredicate(infilterbycampaign) { when IsEmpty then True otherwise False }
	}
	
	task = TaskRecord( create "bwaccess360_writeAccessRightsReviewTickets")
	reassigntask = TaskRecord( create "bwaccess360_reassignAccessRightsReviewTickets")

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												True to inshowcontrols,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowowner,
												True to inshowapplications,
												True to inshowgroups,
												True to inshowshares,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}
	)

	writeBulkStatus = NamedAction (
		Call fragmentRepositoryAccountsToBeReviewed_cleanup(selectedentries to intArray, task.ticketreviewrecorduid from result),
		//Set @fragmentIdentityApplicationRightsToBeReviewed_cleanup(selectedentries to intArray) to task.ticketreviewrecorduid,
		Set [statustowrite repeat SizeOf task.ticketreviewrecorduid] to task.status,
		Set [commenttowrite repeat SizeOf task.ticketreviewrecorduid] to task.comment,
		Set [Date.valueLDAP repeat SizeOf task.ticketreviewrecorduid] to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		TaskComplete task wait-end timeout-seconds 120,
		Flash Concat(SizeOf task.ticketreviewrecorduid, $fragmentRepositoryAccountsToBeReviewedNLS.writeBulkStatus.flash),
		Unset selectedentries,
		ReloadData (treereview)
	)

	// action buttons		
	Grid {
		columns:GridColumn{ width:grow }, GridColumn, GridColumn, GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 48 }
		GridRow {
			GridCell {
				ButtonGroup {
					nb-inline:3
					layout:Layout { align:horizontal Beginning vertical Center }
					Button {
						actions:	Set "ok" to statustowrite,
									Set True to updatestatus,
									Set False to updatecomment,
									ExecuteNamedAction writeBulkStatus
									 
						image:"16/famfamfam_silk_icons_v013/accept.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkapproval.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkapproval.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:	Set "revoke" to statustowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									Dialog fragmentRepositoryAccountsToBeReviewedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus
						image:"16/famfamfam_silk_icons_v013/delete.png"
						text:$fragmentRepositoryAccountsToBeReviewedNLS.bulkrevocation.text
						tooltip:$fragmentRepositoryAccountsToBeReviewedNLS.bulkrevocation.tooltip
						disabled:IntPredicate(SizeOf selectedentries) { when =0 then True }
					}
					Button {
						actions:
									Set False to updatestatus,
									Set True to updatecomment,
									Dialog fragmentRepositoryAccountsToBeReviewedComment(commenttowrite from comment),
									ExecuteNamedAction writeBulkStatus 
