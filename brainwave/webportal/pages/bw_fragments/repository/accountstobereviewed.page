fragmentRepositoryAccountsReassignDlg = Dialog {
	title:$fragmentRepositoryAccountsReassign.title
	width:800
	height:600
	buttons:[
ActionButton {
		     text: $fragmentRepositoryAccountsReassign.checkReviewer
		     close: False
		     disabled: Eval " outUid.isEmpty()"
				actions: 	
		          Set outUid to reviewerToCheck, 
					 IntCase ( nbCheckedSelfEntries ) {
						when >0 then [
							Message Error $fragmentRepositoryAccountsReassign.error,
							Unset reviewerToCheck,
							Set False to reviewerOk
						]
						otherwise [
						  Message Information $fragmentRepositoryAccountsReassign.checkReviewerOk1( outDisplayname),
						  Set True to reviewerOk
						] 
					}
		   }
		   OkButton {
		      disabled: Not BooleanPredicate ( reviewerOk)
		   }
			CancelButton
	]
	enter-event: 
		Set origin.reviewerorigin to originstr,
		Set Eval "(nbreviewersorigin.get() == 1 && originstr.get().equals('linemanager'))?'tolinemanager':''" to canreassignto,
		StringCase(canreassignto) {
			when IsEmpty then [
				Set Eval "(nbreviewersorigin.get() == 1 && originstr.get().equals('repositoryowner') && nbselectedrepositories.get() == 1 )?'torepositoryowner':''" to canreassignto
			]
		}
		
	inprincipal = Variable { initial:Principal.uid }
	inselectedentries = Variable { multivalued:True }

	outUid = Variable
	outDisplayname = Variable
	outHrCode =  Variable { type: String }
	outEmail = Variable { type: String }

	nbreviewersorigin = Variable { type: Integer }
	nbselectedrepositories = Variable { type: Integer }
	originstr = Variable { type: String }

	reassignmenttype = Variable { type: String }
	canreassignto = Variable { type: String initial: False }
		
	nbCheckedSelfEntries = Variable { type: Integer}
	reviewerToCheck = Variable { }
	reviewerOk = Variable { type: Boolean initial: False}
	
	checkreassignwithidentity = Dataset {
		view: bwf_identityapplicationreviewentriesbyidentity with
			inselectedentries to ticketreviewrecorduids,
			reviewerToCheck to identityuid unless-empty
		timeslot: ValidatedTimeslot.UID
		count-variable: nbCheckedSelfEntries
	}

	// used for delegation	
	origin = Record {
		view:bwf_identitygetreviewersorigin with inselectedentries to recorduids
		disabled:IntPredicate(SizeOf inselectedentries) { when >999 then True }
	}
	reviewersorigin = Dataset {
		view:bwf_identitygetreviewersorigin with inselectedentries to recorduids
		disabled:IntPredicate(SizeOf inselectedentries) { when >999 then True }
		count-variable:nbreviewersorigin
	}
	selectedrepository = Record {
		view:bwf_identitygetreviewrepositories with inselectedentries to recorduids
		disabled:IntPredicate(SizeOf inselectedentries) { when >999 then True }
	}
	selectedrepositories = Dataset {
		view:bwf_identitygetreviewrepositories with inselectedentries to recorduids
		disabled:IntPredicate(SizeOf inselectedentries) { when >999 then True }
		count-variable:nbselectedrepositories
	}

	lmlist = Dataset {
		view:bwf_identitycomputedmanagedteam with inprincipal to principaluid 
		disabled:StringPredicate(canreassignto) { when "tolinemanager" then False otherwise True } 
	}
	repolist = Dataset {
		view:bwf_identityrepositorybusinessowners with inprincipal to principaluid, selectedrepository.uid to uid 
		disabled:StringPredicate(canreassignto) { when "torepositoryowner" then False otherwise True } 
	}
	
	list = Dataset {
		union:Union {
			datasets:lmlist, repolist
			discriminator-column:discr
		}
	}

	ConditionalGroup {
		StringCondition(canreassignto) {
			when IsEmpty then [
				Header { value:$fragmentRepositoryAccountsReassign.header_notfound
						layout: Layout { grab: horizontal True vertical True }
				}
			]
			otherwise [	
				ConditionalGroup {
					IntCondition(Count list) {
						when >0 then [
							Header {
								value:$fragmentRepositoryAccountsReassign.header_reassign
								
							}
							Separator {
								width:1
								color:blueNG
							}
							Table {
								data:list
								layout: Layout { grab: horizontal True vertical True }
								show-filter:True
								
								Column {
									column:uid
									hidden:True
									selection:outUid
								}
								Column {
									column:hrcode
									header:$identity.hrcode
									sortable:True
									filterable:True
									width:50%
								}
								Column {
									column:fullname
									header:$identity.fullname
									sortable:True
									filterable:True
									selection:outDisplayname
									width:100%
								}
								Column {
									column:mail
									header:$identity.mail
									sortable:True
									filterable:True
									width:100%
								}
							}
						]
						otherwise [
							Header { value:$fragmentRepositoryAccountsReassign.header_notfound 
									layout: Layout { grab: horizontal True vertical True }
							}
						]					
					}
				}	
			]
		}
	}	
}

