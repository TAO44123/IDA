									StringPredicate(selectedcampaign.selfdelegation) { when "1" then False otherwise True } // self delegation must be enabled in the selected campaign
									IntPredicate(SizeOf selectedentries) { when >999 then True } // cannot reassign more than 1000 entries at once due to a SQL limitation
