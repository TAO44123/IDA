						text: $fragmentRepositoryAccountsToBeReviewedNLS.bulkreassign.text
						tooltip: $fragmentRepositoryAccountsToBeReviewedNLS.bulkreassign.tooltip
						disabled:
							IntPredicate ( SizeOf selectedentries ) {
								when =0 then True
							}
					}
					Button {
						actions:	
									Dialog fragmentRepositoryAccountsReassignDlg(selectedentries to inselectedentries, newrevieweruid from outUid, newreviewername from outDisplayname),
									StringCase(newrevieweruid) {
										when Not IsEmpty then [
											Set selectedentries to entriestocheck,
											Set newrevieweruid to identitytocheck,
											IntCase(Count checkreassignwithidentity) {
												when >0 then [
													Message Error $fragmentRepositoryAccountsReassign.error
												]
