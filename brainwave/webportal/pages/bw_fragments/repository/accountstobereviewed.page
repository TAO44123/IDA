fragmentRepositoryAccountsToBeReviewedComment = Dialog {
	title:$fragmentRepositoryAccountsToBeReviewedComment.title
	enter-event:IntCase(iscommentinreasons) { when =0 then [Set comment to customcomment] otherwise [Set comment to selectedcomment] }
	height:250
	buttons:[
			OkButton {
				disabled:AndPredicate {
					StringPredicate(customcomment) { when IsEmpty then True }
					StringPredicate(selectedcomment) { when IsEmpty then True }
				}
				actions:Set NonEmpty(selectedcomment, customcomment) to comment
			}
			CancelButton
	]
	
	comment = Variable
	customcomment = Variable
	selectedcomment = Variable
	iscommentinreasons = Variable
	
	reasons = Dataset {
		values:[
			(val->$fragmentRepositoryAccountsToBeReviewedComment.notused,text->$fragmentRepositoryAccountsToBeReviewedComment.notused),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.notneeded,text->$fragmentRepositoryAccountsToBeReviewedComment.notneeded),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.overallocated,text->$fragmentRepositoryAccountsToBeReviewedComment.overallocated),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.leaver,text->$fragmentRepositoryAccountsToBeReviewedComment.leaver),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.mover,text->$fragmentRepositoryAccountsToBeReviewedComment.mover),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.sodproblem,text->$fragmentRepositoryAccountsToBeReviewedComment.sodproblem),
			(val->$fragmentRepositoryAccountsToBeReviewedComment.unknown,text->$fragmentRepositoryAccountsToBeReviewedComment.unknown)
		]
	}

	commentinreasons = Dataset {
		union: Union {
			datasets:reasons
			discriminator-column:discr
		}
		
		includes:SameValuePredicate(Current val, comment)
		count-variable:iscommentinreasons
	}
	
	Header {
		value:$fragmentRepositoryAccountsToBeReviewedComment.header
		styling:bigTitleStyle
	}
	Separator {
		width:1
		color:blue
	}
	Header {
		value:$fragmentRepositoryAccountsToBeReviewedComment.subheader
	}
	Combo {
		label: Label { value:$fragmentRepositoryAccountsToBeReviewedComment.selectedreason }
		variable:selectedcomment
		allow-none:True
		modify-event:StringCase(selectedcomment) { when IsEmpty then [] otherwise [ Unset customcomment ] }
		options:Dynamic {
			data:reasons
			text:Current text
			value:Current val
		}
	}
	
	Edit {
		label: Label { value:$fragmentRepositoryAccountsToBeReviewedComment.customcomment }
		variable:customcomment
		limit:4000
		disabled:StringPredicate(selectedcomment) { when IsEmpty then False otherwise True }
	}
}

