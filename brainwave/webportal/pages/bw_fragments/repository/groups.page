									column:creationdate
									width:160px
									initially-masked:True
									header:$group.creationdate
									filterable:True
									sortable:True
								}
								Column {
									column:modificationdate
									width:160px
									initially-masked:True
									header:$group.modificationdate
									filterable:True
									sortable:True
								}
								Column {
									column:lastmodifiedby
									width:160px
									initially-masked:True
									header:$fragmentRepositoryGroupsNLS.lastmodifiedby
									filterable:True
									sortable:True
								}
								Column {
									column:dynamic
