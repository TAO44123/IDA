	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
	}

	groups = HierarchicalData {
		view: bwf_repositorygroupswparents with inuid to uid
		initial:parentuid IsNull
		connect:parent uid to child parentuid
		max-level: 9
		disabled:
		 	OrPredicate {
				Not BooleanPredicate(inenabled)
				IntPredicate(lazyloading) { when =0 then False otherwise True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}		 	
		 	}
	}

	groups_lazy = HierarchicalData {
		roots-view: bwf_repositoryrootgroups with inuid to uid
		attribute:uid
		children-view: bwf_repositorychildgroups with inuid to uid
		parameter:parentuid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate(inenabled)
				IntPredicate(lazyloading) { when =1 then False otherwise True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}		 	
		 	}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowshares,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition(repository.bwa_repositoryanalytics_nbgroup) {
			when =0 then [
				Header {
					value:$fragmentRepositoryGroupsNLS.empty
					styling:bigTitleStyle
				}
			]
			otherwise [
				ConditionalGroup {
					IntCondition(lazyloading) {
						when =1 then [
							Tree {	
								data:groups_lazy
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								persist-configuration:True
								double-click:ExecuteNamedAction goDetails
								disabled:IntPredicate(lazyloading) { when =1 then False otherwise True }
							
								Column {
									column:uid
									hidden:True
									selection:outgroupuid
								}
								
								Column {
									column:displayname
									width:240px
									header:$pgroup.displayname
									filterable:True
									sortable:True
									selection:outgroupname
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:code
									width:160px
									initially-masked:True
									header:$pgroup.code
									filterable:True
									sortable:True
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:repositorydisplayname
									width:160px
									initially-masked:True
									header:$repository.concept
									filterable:True
									sortable:True
								}
								Column {
									column:comment
									width:100%
									header:$pgroup.comment
									filterable:True
									sortable:True
								}
								Column {
									column:nbdirectaccounts
									text:Transform Current nbdirectaccounts using bwf_defaultsTo0
									align:Right
									width:140px
									header:$fragmentRepositoryGroupsNLS.nbdirectaccounts
									filterable:True
									sortable:True
								}
								Column {
									column:nbaccounts
									text:Transform Current nbaccounts using bwf_defaultsTo0
									align:Right
									width:140px
									header:$fragmentRepositoryGroupsNLS.nballaccounts
									filterable:True
									sortable:True
								}
							}
						]
						when =0 then [
							Tree {	
								data:groups
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								show-filter:True
								persist-configuration:True
								double-click:ExecuteNamedAction goDetails
								disabled:IntPredicate(lazyloading) { when =0 then False otherwise True }
							
								Column {
									column:uid
									hidden:True
									selection:outgroupuid
								}
								
								Column {
									column:displayname
									width:240px
									header:$pgroup.displayname
									filterable:True
									sortable:True
									selection:outgroupname
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:code
									width:160px
									initially-masked:True
									header:$pgroup.code
									filterable:True
									sortable:True
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:comment
									width:100%
									header:$pgroup.comment
									filterable:True
									sortable:True
								}
								Column {
									column:nbdirectaccounts
									text:Transform Current nbdirectaccounts using bwf_defaultsTo0
									align:Right
									width:140px
									header:$fragmentRepositoryGroupsNLS.nbdirectaccounts
									filterable:True
									sortable:True
								}
								Column {
									column:nbaccounts
									text:Transform Current nbaccounts using bwf_defaultsTo0
									align:Right
									width:140px
									header:$fragmentRepositoryGroupsNLS.nballaccounts
									filterable:True
									sortable:True
								}
							}
						]
					}
				}
			]
		}
	}
}

fragmentRepositoryGroupsSelectionNLS = NLS {
	direct [en "groups" fr "groupes"]
	directnb [en "groups with accounts number" fr "groupes avec le nombre de comptes"]
	hierarchy [en "groups hierarchy" fr "hiérarchie de groupes"]
	hierarchynb [en "groups hierarchy with accounts number" fr "hiérarchie de groupes avec le nombre de comptes"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected repository groups in various forms
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incancompare </b>optional, boolean value, true to enable group comparison (false by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outgroupuid </b>the selected group uid</li>
 * <li><b>outgroupcode </b>the selected group code</li>
 * <li><b>outgroupname </b>the selected group display name</li>
 * </ul>
 * </span>
 */
fragmentRepositoryGroupsSelection = PageFragment {
	enter-event:ExecuteNamedAction updateActiveFlags,
				MultivaluedAdd "directnb" to selectionkey,
				MultivaluedAdd $fragmentRepositoryGroupsSelectionNLS.directnb to selectionlabel,
				IntCase(repository.bwa_repositoryanalytics_nbgroup) {
					when <50000 then [
						MultivaluedAdd "hierarchynb" to selectionkey,
						MultivaluedAdd $fragmentRepositoryGroupsSelectionNLS.hierarchynb to selectionlabel
					]
				}

	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incancompare = Variable { multivalued:False type:Boolean initial:False }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outgroupuid = Variable
	outgroupcode = Variable
	outgroupname = Variable

	selection = Variable { private:True initial:"directnb" }
	
	active_direct = Variable { initial:False multivalued:False type:Boolean }
	active_directnb = Variable { initial:False multivalued:False type:Boolean }
	active_hierarchy = Variable { initial:False multivalued:False type:Boolean }
	active_hierarchynb = Variable { initial:False multivalued:False type:Boolean }

	selectionkey = Variable { multivalued:True }
	selectionlabel = Variable { multivalued:True }
	
	selectionlist = Dataset {
		columns:selectionkey, selectionlabel
	}

	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
	}

	updateActiveFlags = NamedAction (
		StringCase(selection) {
			when "direct" then [
				Set True to active_direct
			]		
			when "directnb" then [
				Set True to active_directnb
			]		
			when "hierarchy" then [
				Set True to active_hierarchy
			]		
			when "hierarchynb" then [
				Set True to active_hierarchynb
			]		
		}
	)

	Combo {
		variable:selection
		layout: Layout { hint: width 300 }
		modify-event:ExecuteNamedAction updateActiveFlags
		options:Dynamic {
			data:selectionlist
			value:Current selectionkey
			text:Current selectionlabel
		
		}
	}

	ConditionalGroup {
		StringCondition(selection) {
//			when "direct" then [
//				IncludeFragment (fragmentRepositoryGroups with 	value-of inuid to inuid, 
//																	value-of incanshowdetails to incanshowdetails,
//																	outgroupuid binds-to outgroupuid, 
//																	outgroupcode binds-to outgroupcode,
//																	outgroupname binds-to outgroupname,
//																	value-of Eval "inenabled.get()&&active_direct.get()" to inenabled
//																	) 
//			]	
			when "directnb" then [
				IncludeFragment (fragmentRepositoryGroupsWithAccountsNumber with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of incancompare to incancompare,
																	outgroupuid binds-to outgroupuid, 
																	outgroupcode binds-to outgroupcode,
																	outgroupname binds-to outgroupname,
																	value-of Eval "inenabled.get()&&active_directnb.get()" to inenabled
																	) 
			]	
//			when "hierarchy" then [
//				IncludeFragment (fragmentRepositoryGroupsHierarchy with 	value-of inuid to inuid, 
//																	value-of incanshowdetails to incanshowdetails,
//																	outgroupuid binds-to outgroupuid, 
//																	outgroupcode binds-to outgroupcode,
//																	outgroupname binds-to outgroupname,
//																	value-of Eval "inenabled.get()&&active_hierarchy.get()" to inenabled
//																	) 
//			]	
			when "hierarchynb" then [
				IncludeFragment (fragmentRepositoryGroupsHierarchyWithAccountsNumber with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	outgroupuid binds-to outgroupuid, 
																	outgroupcode binds-to outgroupcode,
																	outgroupname binds-to outgroupname,
																	value-of Eval "inenabled.get()&&active_hierarchynb.get()" to inenabled
																	) 
			]	
		}
	}
}