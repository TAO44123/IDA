/**
 * <span style="white-space: pre-line">
 * Display the selected repository groups as a tree
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outgroupuid </b>the selected group uid</li>
 * <li><b>outgroupcode </b>the selected group code</li>
 * <li><b>outgroupname </b>the selected group display name</li>
 * </ul>
 * </span>
 */
fragmentRepositoryGroupsHierarchy = PageFragment {
	// Lazy loading when the number of groups is higher than 10000
	enter-event:IntCase(repository.bwa_repositoryanalytics_nbgroup) { when < 10000 then [ Set False to lazyloading ] }
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outgroupuid = Variable
	outgroupcode = Variable
	outgroupname = Variable

	lazyloading = Variable { type:Boolean initial:True }

	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
	}

	groups = HierarchicalData {
		view: bwf_repositorygroupswparents with inuid to uid
		initial:parentuid IsNull
		connect:parent uid to child parentuid
		max-level: 5
		disabled:
		 	OrPredicate {
				Not BooleanPredicate(inenabled)
				BooleanPredicate(lazyloading)
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}		 	
		 	}
	}

	groups_lazy = HierarchicalData {
		roots-view: bwf_repositoryrootgroups with inuid to uid
		attribute:uid
		children-view: bwf_repositorychildgroups with inuid to uid
		parameter:parentuid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate(inenabled)
				Not BooleanPredicate(lazyloading)
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}		 	
		 	}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowshares,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition(repository.bwa_repositoryanalytics_nbgroup) {
			when =0 then [
				Header {
					value:$fragmentRepositoryGroupsNLS.empty
					styling:bigTitleStyle
				}
			]
			otherwise [
				ConditionalGroup {
					BooleanCondition(lazyloading) {
						when True then [
							Tree {	
								data:groups_lazy
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								persist-configuration:True
								double-click:ExecuteNamedAction goDetails
								disabled:Not BooleanPredicate(lazyloading)
							
								Column {
									column:uid
									hidden:True
									selection:outgroupuid
								}
								
								Column {
									column:displayname
									width:240px
									header:$pgroup.displayname
									filterable:True
									sortable:True
									selection:outgroupname
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:code
									width:160px
									initially-masked:True
									header:$pgroup.code
									filterable:True
									sortable:True
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:comment
									width:100%
									header:$pgroup.comment
									filterable:True
									sortable:True
								}
							}
						]					
						when False then [
							Tree {	
								data:groups
								layout:Layout {grab:horizontal True vertical True}
								configurable:True
								show-filter:True
								persist-configuration:True
								double-click:ExecuteNamedAction goDetails
								disabled:BooleanPredicate(lazyloading)
							
								Column {
									column:uid
									hidden:True
									selection:outgroupuid
								}
								
								Column {
									column:displayname
									width:240px
									header:$pgroup.displayname
									filterable:True
									sortable:True
									selection:outgroupname
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:code
									width:160px
									initially-masked:True
									header:$pgroup.code
									filterable:True
									sortable:True
									actions: ExecuteNamedAction goDetails
									actions-disabled: Not BooleanPredicate(incanshowdetails)
									tooltip: $search_page.showdetails
								}
								Column {
									column:comment
									width:100%
									header:$pgroup.comment
									filterable:True
									sortable:True
								}
							}
						]					
					}
				}
			]
		}
	}
}
/**
 * <span style="white-space: pre-line">
