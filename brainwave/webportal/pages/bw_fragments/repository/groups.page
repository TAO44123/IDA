fragmentRepositoryGroupsNLS = NLS {
	nbdirectaccounts [en "Nb direct \naccounts" fr "Nb de comptes \ndirects"]
	nballaccounts [en "Nb accounts" fr "Nb de comptes"] 
	detaillabel [en "Shows selected group details" fr "Afficher les détails du groupe"]
	lastmodifiedby [en "Last modified by" fr "Dernière modification par"]
	empty [en "No groups found for this repository" fr "Ce référentiel ne contient pas de groupes"]
	comparewith [en "Compare {0} with ..." fr "Comparer {0} avec ..."]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected repository groups as a list
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outgroupuid </b>the selected group uid</li>
 * <li><b>outgroupcode </b>the selected group code</li>
 * <li><b>outgroupname </b>the selected group display name</li>
 * </ul>
 * </span>
 */
fragmentRepositoryGroups = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	outgroupuid = Variable
	outgroupcode = Variable
	outgroupname = Variable

	groups = Dataset {
		view: bwf_repositorygroups with inuid to uid
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:nbaccounts
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowshares,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition(Count groups) {
			when =0 then [
				Header {
					value:$fragmentRepositoryGroupsNLS.empty
					styling:bigTitleStyle
				}
			]
			otherwise [
				Table {	
					data:groups
					layout:Layout {grab:horizontal True vertical True}
					double-click:ExecuteNamedAction goDetails
					configurable:True
					show-filter:True
					show-count:True
				
					Column {
						column:uid
						hidden:True
						selection:outgroupuid
					}
					
					Column {
						column:displayname
						width:240px
						header:$group.displayname
						filterable:True
						sortable:True
						selection:outgroupname
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:code
						width:160px
						initially-masked:True
						header:$group.code
						filterable:True
						sortable:True
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
			
					Column {
						column:creationdate
						width:160px
						initially-masked:True
						header:$group.creationdate
						filterable:True
						sortable:True
					}
					Column {
						column:modificationdate
						width:160px
						initially-masked:True
						header:$group.modificationdate
						filterable:True
						sortable:True
					}
					Column {
						column:lastmodifiedby
						width:160px
						initially-masked:True
						header:$fragmentRepositoryGroupsNLS.lastmodifiedby
						filterable:True
						sortable:True
					}
					Column {
						column:dynamic
						width:160px
						initially-masked:True
						header:$group.dynamic
						filterable:True
						sortable:True
					}
					Column {
						column:filter
						width:160px
						initially-masked:True
						header:$group.filter
						filterable:True
						sortable:True
					}
					Column {
						column:grouptype
						width:160px
						initially-masked:True
						header:$group.grouptype
						filterable:True
						sortable:True
					}
					Column {
						column:guid
						width:160px
						initially-masked:True
						header:'guid'
						filterable:True
						sortable:True
					}
			
					Column {
						column:comment
						width:100%
						header:$group.comment
						filterable:True
						sortable:True
					}
					Column {
						column: trends
						header: $bw_fragment.trends
						text:Transform Current trends using bwf_trendStatusColumn 
						styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
						image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
						tooltip:$bwf_trendStatusColumnNLS.tooltip

						sortable: True
						filterable: True
						width: 10%
					}												
				}
			]
		}
	}
}
