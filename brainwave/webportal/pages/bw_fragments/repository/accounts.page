fragmentRepositoryAccountsNLS = NLS {
	noownercode [en "technical account" fr "compte technique"]
	nbgroups [en "Nb groups" fr "Nb groupes"]
	nbdirectgroups [en "Nb direct \ngroups" fr "Nb groupes \ndirects"]
	hidedisabled [en "Hide disabled accounts" fr "Masquer les comptes désactivés"]
	comparewith [en "compare {0} with ..." fr "comparer {0} avec ..."]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected repository accounts
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the repository uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * <li><b>incancompare </b>optional, boolean value, true to enable comparison button (false by default), forced to False if more than bwf_accountCanCompareThreshold accounts </li>
 * <li><b>incanreconcile</b>, optional boolean, can perform manual reconciliation, false by default</li>
 * <li><b>incanshowdisabled</b>, optional boolean, can show/hide disabled accounts, false by default</li>
 * <li><b>inhidedisabled</b>, optional boolean, hide disabled accounts, true by default</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentRepositoryAccounts = PageFragment {
	enter-event:IntCase(repository.bwa_repositoryanalytics_nbaccount) { when >Constant bwf_accountCanCompareThreshold then [ Set False to incancompare ] }
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	incanreconcile = Variable { type:Boolean initial:False }
	incanshowdisabled = Variable { type:Boolean initial:False }
	incancompare = Variable { type:Boolean initial:False }
	inhidedisabled = Variable { type:Boolean initial:True }
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	wgselectedUids = Variable { type: String multivalued: True}
	wogselectedUids = Variable { type: String multivalued: True}
	compareFrom = Variable { type: String multivalued: False}
	compareTo = Variable { type: String multivalued: True}

	repository = Record {
		view: bwf_repositoryDetail with inuid to uid
//		 disabled:Not BooleanPredicate(inenabled)
	}

	accounts_wgroups_comparison = Dataset {
		view: bwf_repositoryaccounts with
			inuid to uid,
			inhidedisabled to hideDisabled
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:bwa_accountanalytics_nbgroup
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate(inenabled)
				Not BooleanPredicate(incancompare)
				IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when =0 then True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	accounts_wgroups_nocomparison = Dataset {
		view: bwf_repositoryaccounts with
			inuid to uid,
			inhidedisabled to hideDisabled
		trend: Trend {
		 	join-column:uid
		 	status-column-name:trends
			value-column:bwa_accountanalytics_nbgroup
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate(inenabled)
				BooleanPredicate(incancompare)
				IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when =0 then True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	accounts_wogroups_comparison = Dataset {
		view: bwf_repositoryaccounts with
			inuid to uid,
			inhidedisabled to hideDisabled
		disabled:
		 	OrPredicate {
				Not BooleanPredicate(inenabled)
				Not BooleanPredicate(incancompare)
				IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			 }
	}
	accounts_wogroups_nocomparison = Dataset {
		view: bwf_repositoryaccounts with
			inuid to uid,
			inhidedisabled to hideDisabled
		disabled:
			OrPredicate {
				Not BooleanPredicate(inenabled)
				BooleanPredicate(incancompare)
				IntPredicate(repository.bwa_repositoryanalytics_nbgroup) { when >0 then True }
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

