bw_fragments_baderBoolImageMapping = BooleanImageTemplate {
	when True then ""
	when False then %status_16_orange.warning
}

bw_fragments_reverseBaderBoolImageMapping = BooleanImageTemplate {
	when False then ""
	when True then %status_16_orange.warning
}

bwf_controllevel = IntImageTemplate {
	when =-1 then %controllevel_16.levelNA
	when =0 then %controllevel_16.level0
	when =1 then %controllevel_16.level1
	when =2 then %controllevel_16.level2
	when =3 then %controllevel_16.level3
	when =4 then %controllevel_16.level4
	when >4 then %controllevel_16.level5
	otherwise ""
}

bwf_ControlLevelMapping = StringMapping {
	when "0" then $bwf_ControlLevel_NLS._0
	when "1" then $bwf_ControlLevel_NLS._1
	when "2" then $bwf_ControlLevel_NLS._2
	when "3" then $bwf_ControlLevel_NLS._3
	when "4" then $bwf_ControlLevel_NLS._4
	otherwise $bwf_ControlLevel_NLS.notclassified
}

bwf_ControlLevelMappingwempty = StringMapping {
	when "0" then $bwf_ControlLevel_NLS._0
	when "1" then $bwf_ControlLevel_NLS._1
	when "2" then $bwf_ControlLevel_NLS._2
	when "3" then $bwf_ControlLevel_NLS._3
	when "4" then $bwf_ControlLevel_NLS._4
}

bwf_trend = IntImageTemplate {
	when =956487965 then "" // magic number used to display nothing...
	when >100 then %trend_16_blue.hhigh
	when >0 then %trend_16_blue.high
	when =0 then %trend_16_blue.equals
	when <0 then %trend_16_blue.low
	when <100 then %trend_16_blue.llow
	otherwise %trend_16_blue.equals
}

