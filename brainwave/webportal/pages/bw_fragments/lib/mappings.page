/*
 * Resources used in the new web portal
 * 
 * As a best practice, do not create color/images/styles/mixins but use the ones provided in this page instead
 * whenever possible colors are linked to "technical configuration theme" colors

 * This file should be included in all pages
 * Pages should use "ngMixin" mixin
 */

import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/bw_fragments/lib/styles.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/constants.page"
import "/webportal/pages/resources/concepts_nls.page"

///////////////////////////////////////////////////////////////////////////////////////////////////////
// Dataset mappings used in tables
//

bwfManagerTypeMapping = StringMapping {
	when "businessowner" then $bw_fragment_updateownerNLS.pbusinessowner
	when "technicalowner" then $bw_fragment_updateownerNLS.ptechnicalowner
	when "areviewer" then $bw_fragment_updateownerNLS.previewer
	when "identitymanager" then $bw_fragment_updateownerNLS.pidentitymanager
	when "CyberArkManager" then $bw_fragment_updateownerNLS.cyberarkmanager
	otherwise current
}

bwf_reviewedEntityType = StringMapping {
	when Constant bw_reviewedEntityType_Account then $account.concept
	when Constant bw_reviewedEntityType_Right then $right.concept
	otherwise current
}

bwf_trendStatusColumn = StringMapping {
	when Constant bw_trend_New then $bwf_trendStatusColumnNLS.new prefix " "
	when Constant bw_trend_Modified then $bwf_trendStatusColumnNLS.updated prefix " "
	when Constant bw_trend_Removed then $bwf_trendStatusColumnNLS.removed prefix " "
	when Constant bw_trend_Deleted then $bwf_trendStatusColumnNLS.removed prefix " "
	when Constant bw_trend_Identical then $bwf_trendStatusColumnNLS.identical prefix " "
	when Constant bw_trend_null then ""
	otherwise current
}

bwf_trendStatusColumn = StringStylingTemplate {
	when Constant bw_trend_New then bwf_greencellNG
	when Constant bw_trend_Modified then bwf_orangecellNG
	when Constant bw_trend_Removed then bwf_redcellNG
	when Constant bw_trend_Deleted then bwf_redcellNG
}

bwf_defaultsTo0 = IntMapping {
	when InvalidInteger then 0
	otherwise current
}

bwf_defaultreviewstatus = StringMapping {
	when Constant bw_reviewStatusCode_ok then $fragmentDefaultReviewStatusNLS.ok
	when LowerCase Constant bw_reviewStatusCode_ok then $fragmentDefaultReviewStatusNLS.ok
	when Constant bw_reviewStatusCode_revoke then $fragmentDefaultReviewStatusNLS.revoke
	when LowerCase Constant bw_reviewStatusCode_revoke then $fragmentDefaultReviewStatusNLS.revoke
	when Constant bw_reviewStatusCode_remove then $fragmentDefaultReviewStatusNLS.remove
	when LowerCase Constant bw_reviewStatusCode_remove then $fragmentDefaultReviewStatusNLS.remove
	when Constant bw_reviewStatusCode_update then $fragmentDefaultReviewStatusNLS.update
	when LowerCase Constant bw_reviewStatusCode_update then $fragmentDefaultReviewStatusNLS.update
	when Constant bw_reviewStatusCode_reassign then $fragmentDefaultReviewStatusNLS.reassign
	when LowerCase Constant bw_reviewStatusCode_reassign then $fragmentDefaultReviewStatusNLS.reassign
	when Constant bw_reviewStatusCode_add then $fragmentDefaultReviewStatusNLS.add
	when LowerCase Constant bw_reviewStatusCode_add then $fragmentDefaultReviewStatusNLS.add
	when Constant bw_reviewStatusCode_notReviewed then $fragmentDefaultReviewStatusNLS.notreviewed
	when LowerCase Constant bw_reviewStatusCode_notReviewed then $fragmentDefaultReviewStatusNLS.notreviewed
	when Constant bw_reviewStatusCode_toBeReviewed then $fragmentDefaultReviewStatusNLS.toboreviewed
	when LowerCase Constant bw_reviewStatusCode_toBeReviewed then $fragmentDefaultReviewStatusNLS.toboreviewed
	when Constant bw_reviewStatusCode_null then ""
	when LowerCase Constant bw_reviewStatusCode_null then ""
	when IsEmpty then ""
	otherwise current
}

bwf_defaultreviewstatus = StringImageTemplate {
	when Constant bw_reviewStatusCode_ok then %status_16.ok
	when Constant bw_reviewStatusCode_revoke then %status_16.revoke
	when Constant bw_reviewStatusCode_remove then %status_16.remove
	when Constant bw_reviewStatusCode_update then %status_16.update
	// TODO: we need icons for reAssign, not Reviewed and To Be Reviewed statuses
	when Constant bw_reviewStatusCode_reassign then %browsing_16.help
	when Constant bw_reviewStatusCode_add then %status.add
	when Constant bw_reviewStatusCode_notReviewed then %browsing_16.help
	when Constant bw_reviewStatusCode_toBeReviewed then %browsing_16.help
	when Constant bw_reviewStatusCode_null then %browsing_16.help
	when IsEmpty then %browsing_16.help
	otherwise %browsing_16.help
}