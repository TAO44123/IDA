/* Import other pages here */
import "/webportal/pages/resources/pages_nls.page"

/* Nationalized labels here */
bwf_globalpreferencesNLS = NLS {
	title [en "Global Preferences" fr "Paramètres globaux"]
	tabletrends.includeremoved [en "Include removed items in table trends" fr "Inclure les éléments supprimés dans les tableaux"]
}

/*
 * global preferences variables
 */
global_tabletrends_includeremoved = UserVariable {
	type: Boolean
	multivalued: False
	initial: False
	persistent: True
}

/*
 * Page used to edit the user global preferences
 * 
 * 
 */
bwf_globalpreferences = Page {
	title: $bwf_globalpreferencesNLS.title
	tags: "USER_PREFERENCE"
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	
	/* Page content */
	Group {
		title: $bwf_globalpreferencesNLS.title
		
		Combo {
			options: Static {
				Option { value: False text: $global.no }
				Option { value: True text: $global.yes }
			}
			label: $bwf_globalpreferencesNLS.tabletrends.includeremoved
			variable: UserVariable global_tabletrends_includeremoved
		}
		
	}
}
