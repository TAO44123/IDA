bwfGroupSensitivityLevel_NLS = NLS {
	notclassified [en "Not classified" fr "Non classifié"]
	low [en "Low" fr "Faible"]
	medium [en "Medium" fr "Moyen"]
	high [en "High" fr "Elevé"]
	extreme [en "Highest" fr "Extrême"]
}

bwfGroupSensitivityLevelMapping = StringMapping {
	when "0" then $bwfGroupSensitivityLevel_NLS.notclassified
	when "1" then $bwfGroupSensitivityLevel_NLS.low
	when "2" then $bwfGroupSensitivityLevel_NLS.medium
	when "3" then $bwfGroupSensitivityLevel_NLS.high
	when "4" then $bwfGroupSensitivityLevel_NLS.extreme
	otherwise $bwfGroupSensitivityLevel_NLS.notclassified

}

