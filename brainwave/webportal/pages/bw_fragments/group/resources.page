/**
 * Update group description
 * 
 * @param paramGroupUid group uid
 */
bwfGroupDetailsMetadata_Dialog = Dialog {
	title: $bwfGroupDetailsMetadata_Dialog_NLS.title
	buttons:[
	
		OkButton {
			disabled:
				OrPredicate {
					StringPredicate(changed) {when '1' then False otherwise True}
					AndPredicate {
						IntPredicate(sensitivitylevel) { when >0 then True otherwise False }
						Not BooleanPredicate(reasonisvalid) 
					}
					StringPredicate(description) { when IsEmpty then True otherwise False }
				}
			actions:Set description to task.description,
					Set sensitivityreason to task.sensitivityreason,
					Set sensitivitylevel to task.sensitivitylevel,
					Set ismanaged to task.ismanaged,
					Set paramGroupUid to task.uid,
					TaskComplete task wait-end,
					Flash $bwfGroupDetailsMetadata_Dialog_NLS.done
		} 
	
		CancelButton
	]
	
	width:800
	height:280
	
	/* Parameters here */
	paramGroupUid = Variable {type:String multivalued:False}

	description = Variable
	sensitivitylevel = Variable
	sensitivityreason = Variable
	ismanaged = Variable { type:Boolean }
	
	selecteddescription = Variable { private:True }
	changed = Variable{type:String initial:'0' private:True }
	reasonisvalid = Variable

	task = TaskRecord (create "bwf_updategroupmetadata")
	

	Header {
		value:$bwfGroupDetailsMetadata_Dialog_NLS.description
		styling:subtitleStyle
	}
	Separator
	Combo {
		variable:sensitivitylevel
		label:$bwfGroupDetailsMetadata_Dialog_NLS.sensitivitylevel
		modify-event:Set '1' to changed, IntCase(sensitivitylevel) { when =0 then [ Set '-' to sensitivityreason] }
		options:Static {
			Option {
				text:Transform "0" using bwfGroupSensitivityLevelMapping
				value:0
			}
			Option {
				text:Transform "1" using bwfGroupSensitivityLevelMapping
				value:1
			}
			Option {
				text:Transform "2" using bwfGroupSensitivityLevelMapping
				value:2
			}
			Option {
				text:Transform "3" using bwfGroupSensitivityLevelMapping
				value:3
			}
			Option {
				text:Transform "4" using bwfGroupSensitivityLevelMapping
				value:4
			}
		}
	}
	Edit {
		variable:sensitivityreason
		label:$bwfGroupDetailsMetadata_Dialog_NLS.sensitivityreason
		modify-event:Set '1' to changed
		not-empty:True
		match:'[0-9a-zA-z].+'
		validity:reasonisvalid
		limit:2000
		error-tooltip:$bwfGroupDetailsMetadata_Dialog_NLS.sensitivityreasonvalid
		hidden:IntPredicate(sensitivitylevel) { when =0 then True otherwise False }
	}
	Checkbox {
		label:$bwfGroupDetailsMetadata_Dialog_NLS.managed
		variable:ismanaged
		modify-event:Set '1' to changed
	}
	Edit {
		variable:description
		label:$bwfGroupDetailsMetadata_Dialog_NLS.descriptionlabel
		multi-lines:True
		limit:2000
		layout:Layout{grab: horizontal True vertical False hint:height 64}
		modify-event:Set '1' to changed
		not-empty:True
	}	
}


