	height:150
 	buttons:[CancelButton OkButton {
			actions:
				Set uids to task.uids,
				TaskComplete task
			}
		]

	uids = Variable { multivalued:True }
	
	task = TaskRecord(create "bwa_bulkremoveallgrouptag")

	Header {
		value:$fragmentGroupTagsEditorNLS.removeallconfirmation(SizeOf uids)
	}
}

/**
 * Remove a tag from selected groups
 * 
 * @param uids group uids
 */
fragmentGroupBulkRemoveTag = Dialog {
	title:$fragmentGroupTagsEditorNLS.removetitle
	width:500
	height:150
 	buttons:[CancelButton OkButton {
			disabled:StringPredicate(tag) { when IsEmpty then True }
			actions:
				Set uids to task.uids,
				Set tag to task.tag,
				TaskComplete task
			}
		]

	groupSearch = SearchDefinition {
		entity: Group
		simple-mode-rule: br_group_simple_search
	}

	uids = Variable { multivalued:True }
	tag = Variable { multivalued:False }

	task = TaskRecord(create "bwa_bulkremoveallgrouptag")
	taglist = Dataset {
		search: Search {
			definition: groupSearch
			view:bwa_grouptagsfromsearch
		}
	}
	
	Combo {
		variable:tag
		allow-none:True
		label:Label { break:True value:$fragmentGroupTagsEditorNLS.removepicker }
		options:Dynamic {
			data:taglist
			text:Current tag		
			value:Current tag		
		}
	}
}

/*
 * Bulk add a new tag for groups
 * 
 * @param uids selected groups
 */
fragmentGroupBulkAddTag = Dialog {
	title:$fragmentGroupTagsEditorNLS.addtitle
	width:400
	height:200
 	buttons:[CancelButton OkButton {
			disabled:
					OrPredicate {
						AndPredicate {
							Not BooleanPredicate(createtag)
							StringPredicate(existingtag) { when IsEmpty then True }
						}
						AndPredicate {
							BooleanPredicate(createtag)
							Not BooleanPredicate(valid)
						}
					}
			actions:
					Confirm $fragmentGroupTagsEditorNLS.addconfirmation(SizeOf uids),
					BooleanCase(createtag) {
						when True then [
							Set Eval "newtag.get().toUpperCase()" to task.tag
						]
						when False then [
							Set existingtag to task.tag
						]
					},
					Set uids to task.uids,
					TaskComplete task
			}
		]

	uids = Variable

	newtag = Variable {private:True}
	existingtag = Variable {private:True}
	valid = Variable {private:True}
	createtag = Variable { type:Boolean }
		
	task = TaskRecord(create "bwa_bulkaddgrouptag")
	alltags = Dataset {
		view:bwf_groupalltags
	}

	Checkbox {
		variable:createtag
		text:$fragmentGroupTagsEditorNLS.createnewtag
	}

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentGroupTagsEditorNLS.addsyntaxerror
		validity:valid
		hidden:Not BooleanPredicate(createtag)
	}
	Combo {
		variable:existingtag
		allow-none:False
		options:Dynamic {
			data:alltags
			text:Current tag
			value:Current tag
		}
		hidden:BooleanPredicate(createtag)
	}
}

/*
 * INTERNAL dialog box used by fragmentGroupTagsEditor
 * 
 * @param 
 */
fragmentGroupNewTag = Dialog {
	title:$fragmentGroupTagsEditorNLS.addtitle
	width:400
	height:150
	enter-event:Set Join alltags using "|" to alltagsoneline
 	buttons:[CancelButton OkButton {
			disabled:
				OrPredicate {
					Not BooleanPredicate(valid)
					BooleanPredicate(Eval "alltags.indexOf(newtag.get().toUpperCase())!=-1")
				}
			actions:
				TransferData tags(tag) to (tags),
				MultivaluedAdd Eval "newtag.get().toUpperCase()" to tags,
				 Set tags to task.tags,
					Set uid to task.uid,
					TaskComplete task wait-end,
					Flash $fragmentGroupTagsEditorNLS.flash
			}
		]

	uid = Variable
	alltags = Variable { multivalued:True }
	newtag = Variable

	alltagsoneline = Variable { multivalued:False private:True }
	valid = Variable { private:True }
	tags = Variable { multivalued:True private:True }

	tags = Dataset {
		view:bwf_grouptags with uid to uid
	}
	
	task = TaskRecord(create "bwa_updategrouptags")

	Edit {
		variable:newtag
		limit:24
		not-empty:True
		match:"^[0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.][0-9,a-z,A-Z,\\-,_,.]+"
		error-tooltip:$fragmentGroupTagsEditorNLS.addsyntaxerror
		validity:valid
	}	
}

/**
 * Edit group tags
 *
 * @param uid group uid
 * @param canupdatetags True to enable tags update (false by default)
 */
fragmentGroupTagsEditor = Dialog {
	title:$fragmentGroupTagsEditorNLS.title
	buttons:[	CancelButton 
				OkButton {
					disabled:Not BooleanPredicate(canupdatetags)
					actions:
							BooleanCase(added) {
								when True then [
								]
								when False then [
									Set currenttags to task.tags,
									Set uid to task.uid,
									TaskComplete task wait-end,
									Flash $fragmentGroupTagsEditorNLS.flash
								]
							}
				} 
			]
	width:450
	height:200
	enter-event:TransferData tags(tag) to (currenttags), TransferData alltags(tag) to (alltags) 
	
	uid = Variable
	canupdatetags = Variable { type:Boolean initial:False }

	currenttags = Variable { multivalued:True private:True }
	alltags = Variable { multivalued:True private:True }
	newtag = Variable {private:True }
	modified = Variable {private:True }
	added = Variable {private:True }
	
	tags = Dataset {
		view:bwf_grouptags with uid to uid
	}
	alltags = Dataset {
		view:bwf_groupalltags
	}
	
	atags = Dataset {
		columns:alltags as tag
	}

	task = TaskRecord(create "bwa_updategrouptags")

	Combo {
		variable:currenttags
		multi-selection:True
		disabled:Not BooleanPredicate(canupdatetags)
		options:Dynamic {
			data:atags
			text:Current tag
			value:Current tag
		}
		commands:Commands {
			position:After
			orientation:Vertical
			Command {
				actions:Set True to added,
						Dialog fragmentGroupNewTag(uid to uid, alltags to alltags, newtag from newtag), 
						CloseDialog Ok
				icon:%status_16.add
				disabled:Not BooleanPredicate(canupdatetags)
				tooltip:$fragmentGroupTagsEditorNLS.newtag
			}
			Command {
				actions:Message "NOP"
				disabled:True
				icon:''
			}
		}
	}	
}


