import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"

fragmentGroupRightsNLS = NLS {
	description [en "Description" fr "Description"]
	alias [en "Alias" fr "Alias"]
	slevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sreason [en "Sensitivity Reason" fr "Raison de sensibilité"]
	lastmodifiedby [en "Last modified by" fr "Dernière modification par"]
	lastmodificationdate [en "Last modification date" fr "Date de dernière modification"]
	trends [en "Changes" fr "Changements"]
	empty [en "Does not grant permissions" fr "N'octroie pas de permissions"]
	filter [en "Results filtered for {0}" fr "Résultats filtrés sur {0}"]
}

/**
 * <span style="white-space: pre-line">
 * List group rights in a form of a Tree with lazy loading
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>group uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inpermissiontypes </b>optional, multivalued filtering of the permission types (set to Profile by default)</li>
 * <li><b>inapplicationtypes </b>optional, multivalued filtering of the permission types (set to Role by default)</li>
 * <li><b>inapplicationuids </b>optional, multivalued filtering on some applications only</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outSelectedpermissionuid </b>selected permission uid</li>
 * <li><b>outSelectedpermissioncode </b>selected permission code</li>
 * <li><b>outSelectedpermissionname </b>selected permission name</li>
 * <li><b>outSelectedapplicationname </b>selected application name</li>
 * </ul>
 * </span>
 */
fragmentGroupRightsHierarchy = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inpermissiontypes = Variable { multivalued:True type:String initial:NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") }
	inapplicationtypes = Variable { multivalued:True type:String initial:['Profile'] }
	inapplicationuids= Variable { multivalued:True type:String }
	
	outSelectedpermissionuid = Variable
	outSelectedpermissioncode = Variable
	outSelectedpermissionname = Variable
	outSelectedapplicationname = Variable
	
	/* Datasets here */
	accountRights = HierarchicalData {
		 roots-view: bwf_groupdirectrights with
		 	inuid to uid,
			inpermissiontypes to permissiontypes unless-empty, 
			inapplicationtypes to applicationtypes unless-empty, 
			inapplicationuids to applicationuids unless-empty
		 attribute: permissionuid
		 children-view: bwf_groupsubrights with 
			inpermissiontypes to permissiontypes unless-empty, 
			inapplicationtypes to applicationtypes unless-empty, 
			inapplicationuids to applicationuids unless-empty
		 parameter: parentuid
		 max-level: 5
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	application = Record {
		view:bwf_applicationDetail with inapplicationuids to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inapplicationuids ) {
					when IsEmpty then True
				}
			}
	}

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outSelectedpermissionuid to inuid, 
												True to inshowperjob,
												True to inshowperorg,
												False to inshowaccounts,
												False to inshowcontrols,
												False to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	Header {
		value:$fragmentGroupRightsNLS.filter(application.displayname)
		hidden:StringPredicate(inapplicationuids) { when IsEmpty then True otherwise False }
	}

	Tree {
		data:accountRights
		layout:Layout {grab:horizontal True vertical True}
		configurable:True
		persist-configuration:True
		double-click:ExecuteNamedAction goDetails
		
		
		Column {
			column:permissionuid
			selection:outSelectedpermissionuid
			hidden:True
		}	
		Column {
			column:permissiondisplayname
			sortable:True
			filterable:True
			header:$permission.displayname
			width:160px
			selection:outSelectedpermissionname
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}	
		Column {
			column:permissioncode
			sortable:True
			filterable:True
			header:$permission.code
			width:96px
			initially-masked:True
			selection:outSelectedpermissioncode
			actions: ExecuteNamedAction goDetails
			actions-disabled: Not BooleanPredicate(incanshowdetails)
			tooltip: $search_page.showdetails
		}	
		Column {
			column:permissiondescription
			sortable:True
			filterable:True
			header:$fragmentGroupRightsNLS.description
			width:100%
		}	
		Column {
			column:permissionalias
			sortable:True
			initially-masked:True
			filterable:True
			header:$fragmentGroupRightsNLS.alias
			width:128px
		}	
		Column {
			column:permissionsensitivitylevel
			sortable:True
			initially-masked:True
			header:$fragmentGroupRightsNLS.slevel
			width:96px
		}	
		Column {
			column:permissionsensitivityreason
			sortable:True
			initially-masked:True
			header:$fragmentGroupRightsNLS.sreason
			width:128px
		}	
		Column {
			column:permissiontype
			sortable:True
			filterable:True
			header:$permission.permissiontype
			width:96px
		}	
		Column {
			column:permissionlastmodifiedby
			sortable:True
			initially-masked:True
			header:$fragmentGroupRightsNLS.lastmodifiedby
			width:128px
		}	
		Column {
			column:permissionlastmodifydate
			text:DateLDAP(Current permissionlastmodifydate).value
			sortable:True
			header:$fragmentGroupRightsNLS.lastmodificationdate
			width:160px
			initially-masked:True
		}	
		Column {
			column:rightperimetercode
			sortable:True
			initially-masked:True
			filterable:True
			header:$right.perimetercode
			width:128px
		}	
		Column {
			column:rightperimeterdisplayname
			sortable:True
			filterable:True
			header:$right.perimeterdisplayname
			width:128px
		}
		Column {
			column:applicationcode
			sortable:True
			initially-masked:True
			filterable:True
			header:$papplication.code
			width:128px
		}	
		Column {
			column:applicationdisplayname
			sortable:True
			filterable:True
			header:$papplication.displayname
			width:128px
			selection:outSelectedapplicationname
		}	
		Column {
			column:applicationtype
			sortable:True
			initially-masked:True
			filterable:True
			header:$papplication.applicationtype
			width:128px
		}	
		Column {
			column:rightaction
			sortable:True
			initially-masked:True
			filterable:True
			header:$right.action
			width:96px
		}	
		Column {
			column:rightdisplayname
			sortable:True
			filterable:True
			header:$right.displayname
			width:128px
			initially-masked:True
		}	
		Column {
			column:rightlimit
			sortable:True
			header:$right.limit
			width:96px
			initially-masked:True
		}	
		Column {
			column:rightfromgroup
			sortable:True
			initially-masked:True
			header:$right.fromgroup
			width:64px
		}	
		Column {
			column:rightindirect
			sortable:True
			initially-masked:True
			header:$right.indirect
			width:64px
		}	
	}
}

