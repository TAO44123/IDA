	selection = Variable { private:True initial:'all' }

	active_direct = Variable { initial:False multivalued:False type:Boolean }
	active_all = Variable { initial:True multivalued:False type:Boolean }
	active_hierarchy = Variable { initial:False multivalued:False type:Boolean }

	updateActiveFlags = NamedAction (
		StringCase(selection) {
			when "direct" then [
				Set True to active_direct
			]		
			when "all" then [
				Set True to active_all
			]
			when "hierarchy" then [
				Set True to active_hierarchy
			]		
		}
	)

	Grid {
		columns:GridColumn, GridColumn, GridColumn { width:grow }
		layout:Layout { grab:horizontal True vertical False hint:height 32 }
		GridRow {
			GridCell {
			Combo {
				variable:selection
				layout: Layout { hint: width 300 }
				modify-event:ExecuteNamedAction updateActiveFlags
				options:Static {
					Option { value:"all" text:$fragmentGroupAccountsExplorerNLS._all }
					Option { value:"direct" text:$fragmentGroupAccountsExplorerNLS.direct }
					Option { value:"hierarchy" text:$fragmentGroupAccountsExplorerNLS.hierarchy }
				}
			}
			}
			GridCell {
				Checkbox {
					variable:inincludedisabled
					text:$fragmentGroupAccountsNLS.includedisabled
				}
			}
			GridCell {
			
			}
		}
	}

	ConditionalGroup {
		StringCondition(selection) {
			when "direct" then [
				IncludeFragment (fragmentGroupDirectAccounts with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of inincludedisabled to inincludedisabled,
																	outaccountlogin binds-to outaccountlogin, 
																	outaccountuid binds-to outaccountuid, 
																	outrepositoryname binds-to outrepositoryname,
																	outrepositoryuid binds-to outrepositoryuid,
																	value-of Eval "inenabled.get()&&active_direct.get()" to inenabled
																	) 
			]	
			when "all" then [
				IncludeFragment (fragmentGroupAccounts with 	value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of inincludedisabled to inincludedisabled,
																	outaccountlogin binds-to outaccountlogin, 
																	outaccountuid binds-to outaccountuid, 
																	outrepositoryname binds-to outrepositoryname,
																	outrepositoryuid binds-to outrepositoryuid,
																	value-of Eval "inenabled.get()&&active_all.get()" to inenabled
																	) 
			]	
			when "hierarchy" then [
				IncludeFragment (fragmentGroupAccountsHierarchy with value-of inuid to inuid, 
																	value-of incanshowdetails to incanshowdetails,
																	value-of inincludedisabled to inincludedisabled,
																	outaccountlogin binds-to outaccountlogin, 
																	outaccountuid binds-to outaccountuid, 
																	outrepositoryname binds-to outrepositoryname,
																	outrepositoryuid binds-to outrepositoryuid,
																	value-of Eval "inenabled.get()&&active_hierarchy.get()" to inenabled
																	) 
			]	
		}
	}	
}