fragmentGroupAccountsHierarchyNLS = NLS {
	empty [en "Select a group in the Tree to show its accounts" fr "Sélectionnez un groupe dans l'arbre pour afficher ses comptes"]
}
/**
 * <span style="white-space: pre-line">
 * Display the selected group accounts with subgroup hierarchy (explorer style)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the group uid</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inincludedisabled </b>optional, boolean value, true to include disabled accounts (false by default)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentGroupAccountsHierarchy = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inincludedisabled = Variable { multivalued:False type:Boolean initial:False }
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable
	
	selectedGroup = Variable { private:True }


	childgroups = HierarchicalData {
		 roots-view: bwf_groupminigroup with inuid to uid
		 attribute: uid
		 children-view: bwf_groupdirectsubgroups
		 parameter: parentuid
		 max-level: 5
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	Splitter {
		disposition:Horizontal
		Group {
			Tree {
				data:childgroups
				configurable:True
				expand-level:2
				layout:Layout {grab:horizontal True vertical True}
				
				Column {
					column:uid
					hidden:True
					selection:selectedGroup
				}
				Column {
					column:displayname
					header:$group.displayname
					width:33%
				}
				Column {
					column:comment
					header:$group.comment
					width:66%
				}
				Column {
					column:code
					header:$group.code
					initially-masked:True
				}
				Column {
					column:repositorydisplayname
					header:$repository.concept
					initially-masked:True
					width:160px
				}
			}
		}
		ConditionalGroup {
			StringCondition(selectedGroup) {
				when IsEmpty then [
					Header {
						value:$fragmentGroupAccountsHierarchyNLS.empty
					}
				]
				otherwise [
					IncludeFragment (fragmentGroupDirectAccounts with 	selectedGroup binds-to inuid, 
																		incanshowdetails binds-to incanshowdetails,
																		inincludedisabled binds-to inincludedisabled,
																		outaccountlogin binds-to outaccountlogin, 
																		outaccountuid binds-to outaccountuid, 
																		outrepositoryname binds-to outrepositoryname,
																		outrepositoryuid binds-to outrepositoryuid,
																		inenabled binds-to inenabled
																		) 
				]
			}
		}
	}
}

