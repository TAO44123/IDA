/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"

import "/webportal/pages/bw_fragments/lib/styles.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

import "/webportal/pages/bw_fragments/lib/icons.page"

fragmentGroupParentGroupsNLS = NLS {
	circularrefs [en "Circular References Detected" fr "Références circulaires détectées"]
	nbaccount [en "Number of Accounts" fr "Nombre de comptes"]
	nbdirectaccount [en "Number of Direct \nAccounts" fr "Nombre de comptes \nen directs"]
	nbidentity [en "Number of Identities" fr "Nombre de personnes"]
	nbdirectidentity [en "Number of Direct \nIdentities" fr "Nombre de personnes \ndirectes"]
	noparent [en "No Parent Groups" fr "Pas de groupes parents"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected group parent groups
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the group uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, can show sub groups details (false by default)</li>
 * <li><b>outnbparent </b>returns the number of parent groups</li>
 * </ul>
 * </span>
 */
fragmentGroupParentGroups = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	outnbparent = Variable { type:Integer }
	
	nbcircularrefs = Variable { private:True type:Integer }
	selectedgroup = Variable
	
	nbparentgroups = Dataset {
		view: bwf_groupparentgroups with inuid to uid
		count-variable:	outnbparent	
	}
	
	parentgroups = HierarchicalData {
		view: bwf_groupparentgroups with inuid to uid
		initial:parentuid IsNull
		max-level: 9
		connect:parent uid to child parentuid
		disabled:
			OrPredicate {
				IntPredicate(nbcircularrefs) { when >0 then True }
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	circularrefs = Dataset {
		view:bwf_grouphascircularrefs with inuid to uid
		 count-variable:nbcircularrefs
	}
	

	showdetails = NamedAction (
		BooleanCase(incanshowdetails) { 
			when False then [
			]
			when True then [
				Dialog bwf_groupDetailsDialog(selectedgroup to inuid,
					True to inshowaccounts,
					True to inshowapplications,
					True to inshowshares,
					True to inshowperorg,
					True to inshowperjob
				)
			]		
		}
	)

	Image {
		image:%status_32_orange.warning
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}
	Text {
		value:$fragmentGroupParentGroupsNLS.circularrefs
		compact:True
		styling:bwf_warningNG
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}
	ConditionalGroup {
		IntCondition(Count parentgroups) {
			when =0 then [
				Header {
					value:$fragmentGroupParentGroupsNLS.noparent
					hidden:IntPredicate(nbcircularrefs) { when >0 then True }
				}			
			]
			otherwise [
				Tree {
					data:parentgroups
					configurable:True
					persist-configuration:True
					expand-level:10
					layout:Layout {grab:horizontal True vertical True}
					hidden:IntPredicate(nbcircularrefs) { when >0 then True }
					Column {
						column:displayname
						header:$group.displayname
						width:50%
						actions:ExecuteNamedAction showdetails
						actions-disabled:Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column:comment
						header:$group.comment
						width:50%
					}
					Column {
						column:code
						header:$group.code
						initially-masked:True
						actions:ExecuteNamedAction showdetails
						actions-disabled:Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column:repositorydisplayname
						initially-masked:True
						header:$repository.concept
						width:160px
					}
					
					Column {
						column:nbdirectaccount
						initially-masked:True
						header:$fragmentGroupParentGroupsNLS.nbdirectaccount
					}
					Column {
						column:nbaccount
						initially-masked:True
						header:$fragmentGroupParentGroupsNLS.nbaccount
					}
					Column {
						column:nbdirectidentity
						initially-masked:True
						header:$fragmentGroupParentGroupsNLS.nbdirectidentity
					}
					Column {
						column:nbidentity
						initially-masked:True
						header:$fragmentGroupParentGroupsNLS.nbidentity
					}
					Column {
						column:uid
						hidden:True
						selection:selectedgroup
					}
				}
			]
		}
	}
}