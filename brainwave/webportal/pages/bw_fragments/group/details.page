fragmentGroupDetailsNLS = NLS {
	accounts [ en "Accounts" fr "Comptes"]
	identities [en "Identities" fr "Identités"]
	resources [en "Resources" fr "Ressources"]
	nbtotalidentities [en "Total Identities" fr "Total des identités"]
	nbidentities [en "Direct Identities" fr "Identités en direct"]
	nbtotalaccounts [en "Total Accounts" fr "Total des comptes"]
	nbaccounts [en "Direct Accounts" fr "Comptes en direct"]
	nbapplications [en "Number of Applications" fr "Nombre d'applications"]
	nbshares [en "Number of Shares" fr "Nombre de shares"]
	parentgroups [en "Parent Groups" fr "Groupes parents"]
	childgroups [en "Sub Groups" fr "Sous groupes"]
	expertise [en "Expertise" fr "responsabilité"]
	managers [en "Managers" fr "Responsables"]
	addowner [en "Add a New Group Owner" fr "Ajout d'un nouveau responsable de groupe"]
	deleteowner [en "Delete Selected Group Owner" fr "Suppression du responsable du groupe"]
	auditowner [en "Group Owner Update Audit Trail" fr "Piste d'audit des changements de responsable de groupe"]
	nomanagers [en "No Manager Set" fr "Pas de responsable configuré"]
	circularrefs [en "Circular References Detected" fr "Références circulaires détectées"]
	updatemetadata [en "Update Group Description" fr "Mise à jour de la description du groupe"]
	repoDisplayname [en "Repository / Displayname" fr "Référentiel / Nom"]

	classification [en "Classification" fr "Classification"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	managed [en "Managed Group" fr "Groupe sous gestion"]

	showdetails [en "Show details" fr "Afficher les détails"]

	managetags [en "Manage Tags" fr "Gérer les labels"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected group details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the group uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, can show sub groups details (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentGroupDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }
	nbsubgroups = Variable { private:True type:Integer }
	nbcircularrefs = Variable { private:True type:Integer }

	selectedgroup = Variable
	
	group = Record {
		view: bwf_group with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevgroup = Record {
		view: bwf_group with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}

	managers = Dataset {
		view: bwf_groupmanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	parentgroups = HierarchicalData {
		view: bwf_groupparentgroups with inuid to uid
		initial:parentuid IsNull
		max-level: 5
		connect:parent uid to child parentuid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	childgroups = HierarchicalData {
		 roots-view: bwf_groupdirectchildgroups with inuid to uid
		 attribute: uid
		 children-view: bwf_groupdirectsubgroups
		 parameter: parentuid
		 max-level: 5
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	cgroups = Dataset {
	 	 view: bwf_groupdirectchildgroups with inuid to uid
		 count-variable:nbsubgroups
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	circularrefs = Dataset {
		view: bwf_grouphascircularrefs with inuid to uid
		count-variable:nbcircularrefs
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	showdetails = NamedAction (
		BooleanCase(incanshowdetails) { 
			when False then [
			]
			when True then [
				Dialog bwf_groupDetailsDialog(selectedgroup to inuid,
					True to inshowaccounts,
					True to inshowapplications,
					True to inshowshares,
					True to inshowperorg,
					True to inshowperjob
				)
			]		
		}
	)
	
	// compact
	Text {
		label:$group.code
		value:group.code
		lines:3
		compact:True
		hidden:SameValuePredicate(group.code, group.displayname)
	}
	Text {
		label:Transform group.displayname using mayBeNullMapping
		value:group.displayname
		compact:True
	}
	Text {
		value:group.comment
		compact:True
		lines:3
		hidden:StringPredicate(group.comment) { when IsEmpty then True otherwise False }
	}
	Text {
		label:$repository.concept
		value:group.repositorydisplayname
		compact:True
	}

	Header {
		value:$fragmentGroupDetailsNLS.circularrefs
		icon:%status_16_orange.warning
		styling:bwf_warningNG
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}

	Tree {
		data:childgroups
		label:Label { layout: Layout { align:horizontal Beginning vertical Beginning } value:$fragmentGroupDetailsNLS.childgroups }
		configurable:True
		hide-header:True
// CANNOT HIDE IT DYNAMICALLY BECAUSE OF A LAYOUT BUG....
//		hidden:IntPredicate(nbsubgroups) { when >0 then False otherwise True }
		//expand-level:10
		layout:Layout {grab:horizontal True vertical True}
		Column {
			column:uid
			hidden:True
			selection:selectedgroup
		}
		Column {
			column:displayname
			header:$group.displayname
			width:50%
			actions:ExecuteNamedAction showdetails
			actions-disabled:Not BooleanPredicate(incanshowdetails)
		}
		Column {
			column:comment
			header:$group.comment
			width:50%
		}
		Column {
			column:code
			header:$group.code
			initially-masked:True
			actions:ExecuteNamedAction showdetails
			actions-disabled:Not BooleanPredicate(incanshowdetails)
		}
	}
				

	Header {
		value:$fragmentGroupDetailsNLS.accounts
	}
	Separator {
		width:1
	}
	Text {
		value:group.nbdirectaccount
		label:$fragmentGroupDetailsNLS.nbaccounts
		tooltip:Concat(Transform group.nbdirectaccount using mayBeNullMapping, ' / ', Transform prevgroup.nbdirectaccount using mayBeNullMapping)
		align:Right
		compact:True
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(group.nbdirectaccount, prevgroup.nbdirectaccount)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:group.nbaccount
		label:$fragmentGroupDetailsNLS.nbtotalaccounts
		tooltip:Concat(Transform group.nbaccount using mayBeNullMapping, ' / ', Transform prevgroup.nbaccount using mayBeNullMapping)
		align:Right
		compact:True
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(group.nbaccount, prevgroup.nbaccount)) using bwf_trend
				width:16
			}
		}
	}
	Header {
		value:$fragmentGroupDetailsNLS.resources
	}
	Separator {
		width:1
	}
	Text {
		value:group.nbapplication
		label:$fragmentGroupDetailsNLS.nbapplications
		tooltip:Concat(Transform group.nbapplication using mayBeNullMapping, ' / ', Transform prevgroup.nbapplication using mayBeNullMapping)
		align:Right
		compact:True
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(group.nbapplication, prevgroup.nbapplication)) using bwf_trend
				width:16
			}
		}
	}
	Text {
		value:group.nbshare
		label:$fragmentGroupDetailsNLS.nbshares
		feature:unstructureddata_license
		tooltip:Concat(Transform group.nbshare using mayBeNullMapping, ' / ', Transform prevgroup.nbshare using mayBeNullMapping)
		align:Right
		compact:True
		decorator:Decorator {
			width:50
			after:Image {
				image:TemplateImageSelection (Difference(group.nbshare, prevgroup.nbshare)) using bwf_trend
				width:16
			}
		}
	}
	Header {
		value:$fragmentGroupDetailsNLS.managers
	}
	Separator {
		width:1
	}

	ConditionalGroup {
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$fragmentGroupDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfGroupDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramGroupUid),
										ReloadData (group),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdateowners)
	                        	feature:groupdetails_updatemanager
	                        	tooltip:$fragmentGroupDetailsNLS.addowner
	                       }
					}
				}
			]
			otherwise [
				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical False hint:height 116 }
					configurable:True
					commands:Commands { position: After orientation: Vertical
									Command{	
											actions:Dialog bwfGroupDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerType, 
																										inuid to paramGroupUid),
													ReloadData (group),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:Not BooleanPredicate(incanupdateowners)
				                        	feature:groupdetails_updatemanager
				                        	tooltip:$fragmentGroupDetailsNLS.addowner
				                       }
									Command{	
											actions:Dialog bwfRepositoryDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode, 
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramGroupUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdateowners)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:groupdetails_updatemanager 
				                        	tooltip:$fragmentGroupDetailsNLS.deleteowner
				                       }
									Command{	
											actions:Dialog bwf_entityDetailsManagerAuditDialog("Group" to type, inuid to entity)
				                        	icon:%browsing_16.information 
				                        	disabled:
					                        		Not BooleanPredicate(incanupdateowners)
				                        	feature:groupdetails_updatemanager 
				                        	tooltip:$fragmentGroupDetailsNLS.auditowner
				                       }
				                  }
					
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column:managerLinkRecorduid
						hidden: True
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
			
			
					Column {
						column:comment
						header:$bwfManagement.comment
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
				}
			]			
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the selected group details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the group uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, can show sub groups details (false by default)</li>
 * <li><b>incanupdatedescription </b>optional, boolean value, can update group description (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * <li><b>incanupdatetags </b>optional, boolean value, true to enable tags update (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentGroupFullDetails = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdatedescription = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	incanupdatetags = Variable { multivalued: False type: Boolean initial: False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	selectedgroup = Variable
	
	group = Record {
		view: bwf_group with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevgroup = Record {
		view: bwf_group with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:FromPage(-1)
	}

	managers = Dataset {
		view: bwf_groupmanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tags = Dataset {
		view: bwf_grouptags with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	tagsasString = Record {
  		 view: bwa_grouptagsasastring with inuid to uid
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	showdetails = NamedAction (
		BooleanCase(incanshowdetails) { 
			when False then [
			]
			when True then [
				Dialog bwf_groupDetailsDialog(selectedgroup to inuid,
					True to inshowaccounts,
					True to inshowapplications,
					True to inshowshares,
					True to inshowperorg,
					True to inshowperjob
				)
			]		
		}
	)
	
	// standard	
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		Group {
			Text {
				value: Transform group.displayname using mayBeNullMapping
				styling: bigTitleStyle
				compact: True
				label: Label { break: False value: $group.displayname }
			}
			Text {
				value: group.code
				compact: True
				label: Label { break: False value: $group.code }
				hidden:
					SameValuePredicate ( group.code, group.displayname )
			}
			Text {
				value: group.repositorydisplayname
				label: Label { break: False value: $repository.concept }
				compact: True
				commands: 
					Commands {
					position:Before
					presentation:Icon
					orientation:Vertical
					Command {   
						actions:Dialog bwf_repositoryDetailsDialog (group.repositoryuid to inuid)
						icon:%browsing_16.zoom
						tooltip:$fragmentGroupDetailsNLS.showdetails
					}
				}
			}
			Text {
				value: @srv_truncatestring (tagsasString.tag to string, 150 to maxlength)
				tooltip: tagsasString.tag
				label: Label { break: False value: $group.tags }
				compact: True
				layout: Layout { grab: horizontal True vertical False }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog fragmentGroupTagsEditor (
									inuid to uid,
									incanupdatetags to canupdatetags
								), 
								ReloadData (group),
								ReloadData (tags),
								ReloadData (tagsasString)
							icon: %collection_16.tag
							disabled:
								Not BooleanPredicate ( incanupdatetags )
							feature: groupdetails_updatetags
							tooltip: $fragmentGroupDetailsNLS.managetags
						}
					}
			}
			Text {
				value: @srv_truncatestring ( NonEmpty ( group.description, group.comment ) to string, 150 to maxlength )
				tooltip: NonEmpty(group.description, group.comment)
				compact: True
				label: Label { break: False value: $group.description }
				commands:
					Commands {
						position: Before
						orientation: Horizontal 
						Command {
							actions:
								Dialog bwfGroupDetailsMetadata_Dialog (
									inuid to paramGroupUid,
									group.sensitivitylevel to sensitivitylevel,
									group.sensitivityreason to sensitivityreason,
									NonEmpty(group.description, group.comment) to description,
									group.ismanaged to ismanaged
								), 
								ReloadData (group)
							icon: %collection_16.pencil
							disabled:
								Not BooleanPredicate ( incanupdatedescription )
							feature: groupdetails_updatemetadata
							tooltip: $fragmentGroupDetailsNLS.updatemetadata
						}
					}
			}
		}
	}
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint: height 180 }
		GridRow {
			GridCell {
				Group {
					title:$fragmentGroupDetailsNLS.accounts
					Text {
						value:group.nbdirectaccount
						label:$fragmentGroupDetailsNLS.nbaccounts
						tooltip:Concat(Transform group.nbdirectaccount using mayBeNullMapping, ' / ', Transform prevgroup.nbdirectaccount using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbdirectaccount, prevgroup.nbdirectaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:group.nbaccount
						label:$fragmentGroupDetailsNLS.nbtotalaccounts
						tooltip:Concat(Transform group.nbaccount using mayBeNullMapping, ' / ', Transform prevgroup.nbaccount using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbaccount, prevgroup.nbaccount)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:group.nbdirectidentity
						label:$fragmentGroupDetailsNLS.nbidentities
						tooltip:Concat(Transform group.nbdirectidentity using mayBeNullMapping, ' / ', Transform prevgroup.nbdirectidentity using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbdirectidentity, prevgroup.nbdirectidentity)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:group.nbidentity
						label:$fragmentGroupDetailsNLS.nbtotalidentities
						tooltip:Concat(Transform group.nbidentity using mayBeNullMapping, ' / ', Transform prevgroup.nbidentity using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbidentity, prevgroup.nbidentity)) using bwf_trend
								width:16
							}
						}
					}
				}
			}		
			GridCell {
				Group {
					title:$fragmentGroupDetailsNLS.resources
					Text {
						value:group.nbapplication
						label:$fragmentGroupDetailsNLS.nbapplications
						tooltip:Concat(Transform group.nbapplication using mayBeNullMapping, ' / ', Transform prevgroup.nbapplication using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbapplication, prevgroup.nbapplication)) using bwf_trend
								width:16
							}
						}
					}
					Text {
						value:group.nbshare
						label:$fragmentGroupDetailsNLS.nbshares
						feature:unstructureddata_license
						tooltip:Concat(Transform group.nbshare using mayBeNullMapping, ' / ', Transform prevgroup.nbshare using mayBeNullMapping)
						align:Right
						compact:True
						decorator:Decorator {
							width:50
							after:Image {
								image:TemplateImageSelection (Difference(group.nbshare, prevgroup.nbshare)) using bwf_trend
								width:16
							}
						}
					}
				}
			}		
			GridCell {
				Group {
					title:$fragmentGroupDetailsNLS.classification

					Text {
						value:Transform group.sensitivitylevel using bwfGroupSensitivityLevelMapping
						label:$fragmentGroupDetailsNLS.sensitivitylevel
						compact:True
					}
					Text {
						value:group.sensitivityreason
						label:$fragmentGroupDetailsNLS.sensitivityreason
						compact:True
					}
					Text {
						value:Transform group.ismanaged using booleanDisplayMapping  
						label:$fragmentGroupDetailsNLS.managed
						compact:True
					}
				}
			}
		}
	}

	Group {
		title:$fragmentGroupDetailsNLS.managers
		layout:Layout { grab:horizontal True vertical False }

		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$fragmentGroupDetailsNLS.nomanagers			
						commands: Commands {
							position: After orientation: Vertical
							Command{	
									actions:Dialog bwfGroupDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																								selectedExpertiseDomain to paramManagerType, 
																								inuid to paramGroupUid),
											ReloadData (group),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdateowners)
		                        	feature:groupdetails_updatemanager
		                        	tooltip:$fragmentGroupDetailsNLS.addowner
		                       }
						}
					}
				]
				otherwise [
					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical False hint:height 116 }
						configurable:True
						commands:Commands { position: After orientation: Vertical
										Command{	
												actions:Dialog bwfGroupDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerType, 
																											inuid to paramGroupUid),
														ReloadData (group),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:Not BooleanPredicate(incanupdateowners)
					                        	feature:groupdetails_updatemanager
					                        	tooltip:$fragmentGroupDetailsNLS.addowner
					                       }
										Command{	
												actions:Dialog bwfRepositoryDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerTypeCode, 
																											selectedManagerLink to paramManagerLinkRecorduid,
																											inuid to paramGroupUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdateowners)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:groupdetails_updatemanager 
					                        	tooltip:$fragmentGroupDetailsNLS.deleteowner
					                       }
										Command{	
												actions:Dialog bwf_entityDetailsManagerAuditDialog("Group" to type, inuid to entity)
					                        	icon:%browsing_16.information 
					                        	disabled:
						                        		Not BooleanPredicate(incanupdateowners)
					                        	feature:groupdetails_updatemanager 
					                        	tooltip:$fragmentGroupDetailsNLS.auditowner
					                       }
					                  }
						
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column:managerLinkRecorduid
							hidden: True
							selection: selectedManagerLink
						}
						Column {
							column:expertisedomaincode
							hidden:True
							selection:selectedExpertiseDomain
						}
						Column {
							column:expertisedomaindisplayname
							text:Transform Current expertisedomaincode using bwfManagerTypeMapping
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$bwfManagement.type
							sortable:True
							width:140px
						}
						Column {
							column:hrcode
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							header:$identity.hrcode
							initially-masked:True
							sortable:True
						}
						Column {
							column:fullname
							header:$identity.fullname
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							sortable:True
							width:100%
						}
						Column {
							column:internal
							header:$pidentity.internal
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:active
							header:$pidentity.active
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
				
				
						Column {
							column:comment
							header:$bwfManagement.comment
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegation
							header:$bwfManagement.delegated
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:delegationreason
							header:$bwfManagement.^reason
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:_priority
							header:$bwfManagement.^priority
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:startdate
							header:$bwfManagement.startdate
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
						Column {
							column:enddate
							header:$bwfManagement.enddate
							styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
							initially-masked:True
							sortable:True
						}
					}
				]			
			}
		}
	}
}
