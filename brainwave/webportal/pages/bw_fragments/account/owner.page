/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/reconciliation_dialogs.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_fragments/resources/audittrail.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/styles.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"

import "/webportal/pages/bw_fragments/account/resources.page"
import "/webportal/pages/bw_fragments/identity/resources.page"
import "/webportal/pages/bw_fragments/identity/details.page"

fragmentAccountOwnerNLS = NLS {
	employeetype [en "Employee Type" fr "Type de contrat"]
	jobandorgs [en "{0} in {1}" fr "{0} au sein de {1}"]

	noownercode [en "Type" fr "type"]
	comment [en "Comment" fr "commentaire"]
	description [en "Description" fr "description"]
	reconciliationdate [en "Reconciliation Date" fr "date de réconciliation"]
	reliability [en "Reconciliation Reliability" fr "confiance dans la réconciliation"]
	rulename [en "Applied Reconciliation Rule" fr "règle de réconciliation appliquée"]
	
	reconpending [ en "A reconciliation request is in progress" fr "Une demande de réconciliation est en cours"]
	
	formeremployee [en "Former Employee" fr "ancien propriétaire"]
	leavedate [en "Leave Date" fr "date de départ"]
	
	ownerleft [en "Account Owner Left the Company" fr "Le propriétaire du compte a quitté l'entreprise"]
	
	jobandorganisation [en "Job and Organization" fr "métier et organisation"]
	orphanaccount [en "Orphaned Account" fr "Compte orphelin"]
	technicalaccount [en "Technical Account" fr "Compte technique"]

	expertise [en "Expertise" fr "responsabilité"]
	managers [en "Managers" fr "responsables"]
	addowner [en "Add a new account owner" fr "Ajout d'un nouveau responsable de compte"]
	deleteowner [en "Delete selected account owner" fr "Suppression du responsable du compte"]
	auditowner [en "Account owner updates audit trail" fr "Piste d'audit des changements de reponsable de compte"]
}

fragmentAccountOwnerError = Style {
	background:Color red
	foreground:white
	bold:True
}

fragmentAccountOwnerTitleError = Style {
	background:Color red
	foreground:white
	bold:True
	size: 16px
}

fragmentAccountOwnerTitleWarning = Style {
	background:Color RGB(255, 128, 0)
	foreground:white
	bold:True
	size: 16px
}

/**
 * <span style="white-space: pre-line">
 * Display the account owner or the "no owner information if needed" in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inenablemanualreconciliation </b>optional, boolean value, true to enable fragment (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentAccountOwner = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	inenablemanualreconciliation = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	
	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	reconciliationInProgress = Variable {
		type: Boolean
		initial: False
	}
	nbAllocations = Variable { type: Integer }

	/* Datasets here */
	account = Record {
		view: br_accountDetail with inuid to uid unless-empty
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	owner = Record {
		view: bwf_accountowner with account.uid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevowner = Record {
		view: bwf_accountowner with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:
			FromPage ( -1 )
	}
	
	ownerorgsandjobs = Dataset {
		view: bwf_accountownerorganisations with account.uid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		count-variable: nbAllocations
	}
	ownerorgandjob = Record {
		view: bwf_accountownerorganisations with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	accountnoownerinformation = Record {
		view: bwf_accountnoownerinformation with account.uid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	managers = Dataset {
		view: bwf_accountmanagers with account.uid to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	reloadRecon = NamedAction (
		Unset reconciliationInProgress,
		Call refreshPendingRecon( account.uid to accountUid,  reconciliationInProgress from isPending ),
		ReloadData(account), 
		ReloadData (managers),
		ReloadData (owner),
		ReloadData (ownerorgsandjobs)
	)

	Group {
		layout: Layout { grab: horizontal False vertical False }
		hidden: Not BooleanPredicate ( reconciliationInProgress )
		Button {
			actions: ExecuteNamedAction reloadRecon
			hidden: Not BooleanPredicate ( reconciliationInProgress )
			text: $fragmentAccountOwnerNLS.reconpending
			presentation: Link
		}
	}
	ConditionalGroup {
		StringCondition(owner.uid) {
			when Not IsEmpty then [
				// OWNER INFORMATION
				// ////////////////////////////////
				// Compact mode
				Text {
					value: owner.hrcode
					label: $identity.hrcode
					compact: True
				}
				Text {
					value: owner.fullname
					label: $identity.fullname
					compact: True
				}
				Text {
					value: owner.mail
					label: $identity.mail
					compact: True
				}
				Text {
					value: Transform owner.internal using booleanDisplayMapping
					label: $identity.internal // Internal
					compact: True
				}
				Text {
					value: Transform owner.active using booleanDisplayMapping
					label: $identity.active // Active
					compact: True
					decorator:
						Decorator {
							width: 32
							after:
								Image {
									image: TemplateImageSelection ( owner.active ) using bw_fragments_baderBoolImageMapping
									width: 16
								}
							gap: 16
						}
				}
				Text {
					value: SubString(0,10) owner.arrivaldate
					label: $identity.arrivaldate
					compact: True
					tooltip: owner.arrivaldate
					styling:DateStyling(owner.arrivaldate) {
						when DateAfter Date(PageTimeslot.CommitDate) then bwf_warningNG
						otherwise default
					}
				}
				Text {
					value: SubString(0,10) owner.departuredate
					label: $identity.departuredate
					compact: True
					tooltip: owner.departuredate 
					styling:DateStyling(owner.departuredate) {
						when DateBefore Date(PageTimeslot.CommitDate) then bwf_warningNG
						otherwise default
					}
				}

				Header {
					value:$identity.directboss // Direct Line Manager
				}
				Separator {
					width:1
				}
				ConditionalGroup {
					layout:Layout { grab:horizontal True vertical False }
					StringCondition ( owner.manageruid ) {
						when IsEmpty then [
							// No manager information
							Text {
								value: $bw_fragment.non.manager
								compact: True
							}
						] otherwise [
							// Manager
							Text {
								value: owner.managerhrcode
								label: $identity.hrcode
								compact: True
							}
							Text {
								value: owner.managerfullname
								label: $identity.fullname
								compact: True
							}
							Text {
								value: owner.managermail
								label: $identity.mail
								compact: True
							}
						]
					}
				}


				Header {
					value:$bw_fragment.allocation
				}
				Separator {
					width:1
				}					
				ConditionalGroup {
					layout:Layout { grab:horizontal True vertical False }
					IntCondition ( nbAllocations ) {
						when > 1 then [
							Text {
								iterate-on:ownerorgsandjobs
								value: $bw_fragment_identityDetailsNLS.jobandorgs ( Current jobtitledisplayname, Current organisationdisplayname )
								label: $bw_fragment_identityDetailsNLS.jobandorganisation
								compact: True
							}
						] when = 1 then [
							// Only one allocation
							Text {
								value: $bw_fragment_identityDetailsNLS.jobandorgs ( ownerorgandjob.jobtitledisplayname, ownerorgandjob.organisationdisplayname )
								label: $bw_fragment_identityDetailsNLS.jobandorganisation
								compact: True
							}
						] otherwise [
							Text {
								value: $bw_fragment.non.allocation
								compact: True
							}
						]
					}
				}
			]
			otherwise [
				ConditionalGroup {
					StringCondition(accountnoownerinformation.reconciliationnoownercode) {
						when IsEmpty then [
							Header {
								value:$fragmentAccountOwnerNLS.orphanaccount
								styling:fragmentAccountOwnerTitleWarning

								commands: Commands {
									position: After
									Command { 
											icon: %collection_16.user_enable
											tooltip: $reconciliationactions.reconcilewithidentity
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions: 
												Dialog reconciliationIdentityDialog (account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.identity_uid to localIdentityUid, account.identity_fullname to localIdentityFullName, account.reconciliation_comment to localComment),
												ExecuteNamedAction reloadRecon
										}										
										Command { 
											icon: %collection_16.user_disable
											tooltip: $reconciliationactions.reconcilewithleave
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationLeaveDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.username to identityFullname),
												ExecuteNamedAction reloadRecon
										}
										Command { 
											icon: %concept_16.techaccount
											tooltip: $reconciliationactions.reconcilewithnoowner
											feature:recon_noowner
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationNoOwnerDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid),
												ExecuteNamedAction reloadRecon
										}
									}
							}
						]
						when "leave" then [
							// ACCOUNT OWNER LEFT THE COMPANY
							Header {
								value:$fragmentAccountOwnerNLS.ownerleft
								styling:fragmentAccountOwnerTitleError

								commands: Commands {
									position: After
									Command { 
											icon: %collection_16.user_enable
											tooltip: $reconciliationactions.reconcilewithidentity
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions: 
												Dialog reconciliationIdentityDialog (account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.identity_uid to localIdentityUid, account.identity_fullname to localIdentityFullName, account.reconciliation_comment to localComment),
												ExecuteNamedAction reloadRecon
										}										
										Command { 
											icon: %collection_16.user_disable
											tooltip: $reconciliationactions.reconcilewithleave
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationLeaveDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.username to identityFullname),
												ExecuteNamedAction reloadRecon
										}
										Command { 
											icon: %concept_16.techaccount
											tooltip: $reconciliationactions.reconcilewithnoowner
											feature:recon_noowner
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationNoOwnerDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid),
												ExecuteNamedAction reloadRecon
										}
									}
							}
							Text {
								value:accountnoownerinformation.reconciliationcomment
								label:$fragmentAccountOwnerNLS.formeremployee
								compact:True
							}
							Text {
								value:accountnoownerinformation.reconciliationleavedate
								label:$fragmentAccountOwnerNLS.leavedate
								compact:True
							}
						]
						otherwise [
							// NO OWNER INFORMATION
							Header {
								value:$fragmentAccountOwnerNLS.technicalaccount
								styling:bigTitleStyle
							}
							
							Text {
								value:accountnoownerinformation.reconciliationnoownercode
								label:$fragmentAccountOwnerNLS.noownercode
								compact:True
								layout:Layout { hint:width 360 }

								commands: Commands {
									position: After
									Command { 
										icon: %collection_16.delete
										tooltip: $reconciliationactions.delete
										disabled:Not BooleanPredicate(inenablemanualreconciliation)
										feature:recon_remove 
										actions: 
											Dialog reconciliationRemoveDialog ( account.uid to inAccountUID ),
											ExecuteNamedAction reloadRecon
									}		
									Command { 
											icon: %collection_16.user_enable
											tooltip: $reconciliationactions.reconcilewithidentity
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions: 
												Dialog reconciliationIdentityDialog (account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.identity_uid to localIdentityUid, account.identity_fullname to localIdentityFullName, account.reconciliation_comment to localComment),
												ExecuteNamedAction reloadRecon
										}										
										Command { 
											icon: %collection_16.user_disable
											tooltip: $reconciliationactions.reconcilewithleave
											feature:recon_identity
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationLeaveDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid, account.username to identityFullname),
												ExecuteNamedAction reloadRecon
										}
										Command { 
											icon: %concept_16.techaccount
											tooltip: $reconciliationactions.reconcilewithnoowner
											feature:recon_noowner
											disabled:Not BooleanPredicate(inenablemanualreconciliation)
											actions:
												Dialog reconciliationNoOwnerDialog (account.uid to inAccountUID, account.login to inAccountLogin, account.recorduid to inAccountRecordUid),
												ExecuteNamedAction reloadRecon
										}
									}
							}
							Text {
								value:accountnoownerinformation.reconciliationcomment
								label:$fragmentAccountOwnerNLS.comment
								compact:True
							}
							Text {
								value:accountnoownerinformation.reconciliationdescription
								label:$fragmentAccountOwnerNLS.description
								compact:True
							}
							Text {
								value:accountnoownerinformation.reconciliationreconciliationdate
								label:$fragmentAccountOwnerNLS.reconciliationdate
								compact:True
							}
							Text {
								value:accountnoownerinformation.reconciliationreliability
								label:$fragmentAccountOwnerNLS.reliability
								compact:True
							}
							Text {
								value:accountnoownerinformation.reconciliationrulename
								label:$fragmentAccountOwnerNLS.rulename
								compact:True
							}
							
							Table {
								data:managers
								layout:Layout { grab:horizontal True vertical False hint:height 96 }
								configurable:True
								label:$fragmentAccountOwnerNLS.managers
								commands:Commands { position: After orientation: Vertical
												Command{	
														actions:Dialog bwfAccountDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																													selectedExpertiseDomain to paramManagerType, 
																													inuid to paramAccountUid),
																ReloadData (managers)
							                        	icon:%concept_16.manager
							                        	disabled:Not BooleanPredicate(incanupdateowners)
							                        	feature:repositorydetails_updatemanager
							                        	tooltip:$fragmentAccountOwnerNLS.addowner
							                       }
												Command{	
														actions:Dialog bwfAccountDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																													selectedExpertiseDomain to paramManagerTypeCode,
																													selectedManagerLink to paramManagerLinkRecorduid, 
																													inuid to paramAccountUid),
																ReloadData (managers)
							                        	icon:%status_16.delete
							                        	disabled:
							                        		OrPredicate {
								                        		Not BooleanPredicate(incanupdateowners)
							                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
							                        		}
							                        	feature:repositorydetails_updatemanager 
							                        	tooltip:$fragmentAccountOwnerNLS.deleteowner
							                       }
												Command{	
														actions:Dialog bwf_entityDetailsManagerAuditDialog("Account" to type, inuid to entity)
							                        	icon:%browsing_16.information 
							                        	disabled:
								                        		Not BooleanPredicate(incanupdateowners)
							                        	feature:repositorydetails_updatemanager 
							                        	tooltip:$fragmentAccountOwnerNLS.auditowner
							                       }
							                  }
								
								Column {
									column:uid
									hidden:True
									selection:selectedManager
								}
								Column {
									column: managerLinkRecorduid
									hidden: True
									selection: selectedManagerLink
								}
								Column {
									column:expertisedomaincode
									hidden:True
									selection:selectedExpertiseDomain
								}
								Column {
									column:expertisedomaindisplayname
									text:Transform Current expertisedomaincode using bwfManagerTypeMapping
									styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
									header:$fragmentAccountOwnerNLS.expertise
									sortable:True
								}
								Column {
									column:hrcode
									styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
									initially-masked:True
									sortable:True
								}
								Column {
									column:fullname
									styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
									sortable:True
									width:100%
								}
								Column {
									column:internal
									styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
									initially-masked:True
									sortable:True
								}
								Column {
									column:active
									styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
									initially-masked:True
									sortable:True
								}
							}
						]
					}
				}
			]		
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Display the account owner or the "no owner information if needed" in 1366px mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inenablemanualreconciliation </b>optional, boolean value, true to enable fragment (false by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update application owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentAccountOwnerFull = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	inenablemanualreconciliation = Variable { multivalued:False type:Boolean initial:False }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }
	
	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	reconciliationInProgress = Variable {
		type: Boolean
		initial: False
	}
	nbAllocations = Variable { type: Integer }

	/* Datasets here */
	account = Record {
		view: br_accountDetail with inuid to uid unless-empty
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	owner = Record {
		view: bwf_accountowner with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	prevowner = Record {
		view: bwf_accountowner with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		timeslot:
			FromPage ( -1 )
	}
	
	ownerorgsandjobs = Dataset {
		view: bwf_accountownerorganisations with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
		count-variable: nbAllocations
	}
	ownerorgandjob = Record {
		view: bwf_accountownerorganisations with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	accountnoownerinformation = Record {
		view: bwf_accountnoownerinformation with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	managers = Dataset {
		view: bwf_accountmanagers with account.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	tagsasString = Record {
		view: bwa_identitytagsasastring with owner.uid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	reloadRecon = NamedAction (
		Unset reconciliationInProgress,
		Call refreshPendingRecon( account.uid to accountUid,  reconciliationInProgress from isPending ),
		ReloadData(account), 
		ReloadData (managers),
		ReloadData (owner),
		ReloadData (ownerorgsandjobs)
	)

	Group {
		layout: Layout { grab: horizontal False vertical False }
		hidden: Not BooleanPredicate ( reconciliationInProgress )
		Button {
			actions: ExecuteNamedAction reloadRecon
			hidden: Not BooleanPredicate ( reconciliationInProgress )
			text: $fragmentAccountOwnerNLS.reconpending
			presentation: Link
		}
	}
	ConditionalGroup {
		StringCondition(owner.uid) {
			when Not IsEmpty then [
				// OWNER INFORMATION
				// ////////////////////////////////
				// Standard mode
				
				Grid {
					columns: GridColumn { width: 128px }, GridColumn { width: 250px }, GridColumn { width: grow }, GridColumn { width: 150px }, GridColumn { width: 150px }, GridColumn { width: grow }							
					layout: Layout { grab: horizontal True vertical False }
					GridRow {
						GridCell {
							Image {
								image: "various/photo.jpg"
							}
						}
						GridCell {
							Text {
								value: owner.hrcode
								label: $identity.hrcode
								compact: True
								styling: bigTitleStyle
								layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 16}
							}
							Text {
								value: owner.givenname
								label: $identity.givenname
								compact: True
								styling: bigTitleStyle
								layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 16}
							}
							Text {
								value: owner.surname
								label: $identity.surname
								compact: True
								styling: bigTitleStyle
								layout:Layout { grab:horizontal True vertical False indent:horizontal 0 vertical 0 hint: height 16}
							}
							Text {
								value: owner.fullname
