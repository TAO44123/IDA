fragmentAccountGroupsNLS = NLS {
	empty [en "Account does not have groups" fr "Ce compte n'a pas de groupes"]
	trends [en "Changes" fr "Changements"]
	circularrefs [en "Circular references detected" fr "Références circulaires détectées"]
	filter [en "Results filtered for {0}" fr "Résultats filtrés sur {0}"]
}

/**
 * <span style="white-space: pre-line">
 * Display the groups of the selected account in a Tree
 * with lazy loading 
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * <li><b>inapplicationuids </b>optional, multivalued filtering on some applications only</li>
*  * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outgroupuid </b>the selected group uid</li>
 * <li><b>outgroupname </b>the selected group name</li>
 * </ul>
 * </span>
 */
fragmentAccountGroupsHierarchy = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inapplicationuids= Variable { multivalued:True type:String }
	outgroupuid = Variable
	outgroupname = Variable
	
	nbcircularrefs = Variable { private:True type:Integer }

	/* Datasets and records here */
	directGroups = Dataset {
		 view: bwf_directgroups with inuid to uid, inapplicationuids to applicationuids unless-empty
		 disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	accountGroups = HierarchicalData {
		view: bwf_allgroups with inuid to uid, inapplicationuids to applicationuids unless-empty
		initial: parent_uid IsNull
		connect: parent uid to child parent_uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	
	circularrefs = Dataset {
		view: bwf_accountgroupshavecircularrefs with inuid to uid, inapplicationuids to applicationuids unless-empty
		count-variable:nbcircularrefs
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	application = Record {
		view:bwf_applicationDetail with inapplicationuids to uid
		disabled:
		 	OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inapplicationuids ) {
					when IsEmpty then True
				}
			}
	}
	
	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowapplications,
												True to inshowshares,
												True to inshowperjob,
												True to inshowperorg,
												False to inshowaccounts,
												False to inshowcontrols,
												False to inshowdecisionhistory,
												inapplicationuids to inapplicationuids
												)
			]
			when False then [
			
			]
		}
	)

	Image {
		image:%status_32_orange.warning
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}
	Text {
		value:$fragmentAccountGroupsNLS.circularrefs
		compact:True
		styling:bwf_warningNG
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}

	Text {
		iterate-on:circularrefs
		value:Concat(Current displayname, ' / ', Current repositorydisplayname)
		compact:True
		styling:bwf_warningNG
		hidden:IntPredicate(nbcircularrefs) { when =0 then True }
	}
	
	ConditionalGroup {
		IntCondition(Count directGroups) {
			when =0 then [
				Header {
					value:$fragmentAccountGroupsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Header {
					value:$fragmentAccountGroupsNLS.filter(application.displayname)
					hidden:StringPredicate(inapplicationuids) { when IsEmpty then True otherwise False }
				}
				Tree {
					data:accountGroups
					layout:Layout {grab:horizontal True vertical True}
					configurable:True
					persist-configuration:True
					double-click:ExecuteNamedAction goDetails
					expand-level: 1
					show-filter:True
					hidden:IntPredicate(nbcircularrefs) { when >0 then True }
					
				
					Column {
						column:uid
						hidden:True
						selection:outgroupuid
					}
				
					Column {
						column:displayname
						width:240px
						header:$pgroup.displayname
						selection:outgroupname
						filterable:True
						sortable:True
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:code
						width:160px
						initially-masked:True
						header:$pgroup.code
						filterable:True
						sortable:True
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:comment
						width:100%
						header:$pgroup.comment
						filterable:True
						sortable:True
					}
					Column {
						column:repositorydisplayname
						width:160px
						header:$repository.concept
						filterable:True
						sortable:True
					}
				}
			]
		}
	}
}

