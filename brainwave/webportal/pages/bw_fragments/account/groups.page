fragmentAccountGroupsSelectionNLS = NLS {
	directgroups [en "Groups list" fr "Liste des groupes"]
	allgroups [en "Direct and indirect groups list" fr "Liste des groupes directs et indirects"]
	groupshierarchy [en "Groups hierarchy" fr "Hiérarchie des groupes"]

}
/**
 * <span style="white-space: pre-line">
 * Display the selected account groups through different forms: direct groups, all groups, group hierarchy
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the group uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>true to enable details</li>
 * <li><b>inapplicationuids </b>optional, multivalued filtering on some applications only</li>
 * <li><b>ininitialgrouptypeselection </b>String (directlist, alllist,hierarchy) set the default panel (directlist if not specified)</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outgroupuid </b>the selected group uid</li>
 * <li><b>outgroupname </b>the selected group name</li>
 * </ul>
 * </span>
 */
fragmentAccountGroupsSelection = PageFragment {
	post-render-event:ExecuteNamedAction updateActiveFlags
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inapplicationuids= Variable { multivalued:True type:String }
	ininitialgrouptypeselection = Variable { multivalued:False initial:"directlist" }
	outgroupuid = Variable
	outgroupname = Variable

	active_directlist = Variable { initial:False multivalued:False type:Boolean }
	active_alllist = Variable { initial:False multivalued:False type:Boolean }
	active_hierarchy = Variable { initial:False multivalued:False type:Boolean }

	updateActiveFlags = NamedAction (
		StringCase(ininitialgrouptypeselection) {
			when "directlist" then [
				Set True to active_directlist
			]
			when "alllist" then [
				Set True to active_alllist
			]
			when "hierarchy" then [
				Set True to active_hierarchy
			]
		}
	)
	
	Combo {
		variable:ininitialgrouptypeselection
		layout: Layout { hint: width 300 }
		modify-event: ExecuteNamedAction updateActiveFlags
		options: Static {
			Option {
				value:"directlist"
				text:$fragmentAccountGroupsSelectionNLS.directgroups
			}
			Option {
				value:"alllist"
				text:$fragmentAccountGroupsSelectionNLS.allgroups
			}
			Option {
				value:"hierarchy"
				text:$fragmentAccountGroupsSelectionNLS.groupshierarchy
			}
		}
	}								
	ConditionalGroup {
		StringCondition(ininitialgrouptypeselection) {
			when "directlist" then [
				IncludeFragment {
					fragment:fragmentAccountDirectGroupsList
					with inuid binds-to inuid, incanshowdetails binds-to incanshowdetails, inapplicationuids binds-to inapplicationuids, value-of Eval "inenabled.get()&&active_directlist.get()" to inenabled
				}
			]									
			when "alllist" then [
				IncludeFragment {
					fragment:fragmentAccountAllGroupsList
					with inuid binds-to inuid, incanshowdetails binds-to incanshowdetails, inapplicationuids binds-to inapplicationuids, value-of Eval "inenabled.get()&&active_alllist.get()" to inenabled
				}
			]									
			when "hierarchy" then [
				IncludeFragment {
					fragment:fragmentAccountGroupsHierarchy
					with inuid binds-to inuid, incanshowdetails binds-to incanshowdetails, inapplicationuids binds-to inapplicationuids, value-of Eval "inenabled.get()&&active_hierarchy.get()" to inenabled
				}
			]									
		}
	}
}
	