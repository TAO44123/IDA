/**
 * <span style="white-space: pre-line">
 * Shows account unstructured data ACLs for a given permission (windows, sharepoint online, exchange online, ondrive)
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>account uid</li>
 * <li><b>inpermissionuid </b>account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * </span>
 */
fragmentAccountPermissionACLs = PageFragment {
	feature:unstructureddata_license
	enter-event:
		ExecuteNamedAction reload

	inuid = Variable
	inpermissionuid = Variable 
	inenabled = Variable { type: Boolean initial: True }
	incanshowdetails = Variable { type: Boolean initial: False }

	/* Internal Vars */
	groups =  Variable {type:String multivalued:True private:True} // account groups

	/* Datasets to get the groups of the accounts */
	publicgroups = Dataset {
		view: bwf_getaccountpublicgroups with inuid to uid
	}
	
	directaccountgroups = Dataset {
		view: bwf_fileexplorergetaccountgroups with inuid to uid
	}
	
	accountgroups = Dataset {
		union: Union { datasets: publicgroups, directaccountgroups discriminator-column: source }
	}
	
	permission = Record {
		view:br_permissionDetail with inpermissionuid to uid
	}
	
	permissions = Dataset {
		view:br_permissionDetail with inpermissionuid to uid
		disabled: Not BooleanPredicate ( inenabled )
		changed-event:
			BooleanCase (inenabled) {
				when False then []
				when True then [
					TransferData accountgroups(uid) to (groups)
				]
			}
	}
	
	reload = NamedAction (
		TransferData accountgroups( uid ) to ( groups ),
		StringCase ( permission.application_applicationfamily ) {
			when "SharePointOnline" then [
				ExecuteFragmentNamedAction fragmentAccountPermissionACLs_spo.reload
			] when "ExchangeOnline" then [
				ExecuteFragmentNamedAction fragmentAccountPermissionACLs_eo.reload
			] when "OneDrive" then [
				ExecuteFragmentNamedAction fragmentAccountPermissionACLs_OneDrive.reload
			] when "SharedFolders" then [
				ExecuteFragmentNamedAction fragmentAccountPermissionACLs_win.reload
			] otherwise [ 
				ExecuteFragmentNamedAction fragmentAccountPermissionACLs_generic.reload
			]
		}
	)
	
	ConditionalGroup {
		StringCondition ( permission.application_applicationfamily ) {
			when "SharePointOnline" then [
				fragmentAccountPermissionACLs_spo = IncludeFragment {
					fragment: fragmentAccountPermissionACLs_spo with
						value-of inpermissionuid to inpermissionuid,
						value-of inuid to inuid,
						value-of Eval "inenabled.get()&&permission.application_applicationfamily.equals('SharePointOnline')" to inenabled,
						incanshowdetails binds-to incanshowdetails,
						value-of groups to groups,
						value-of False to inresolvegroups
				}
			] when "ExchangeOnline" then [
				fragmentAccountPermissionACLs_eo = IncludeFragment {
					fragment: fragmentAccountPermissionACLs_eo with
						value-of inpermissionuid to inpermissionuid,
						value-of inuid to inuid,
						value-of Eval "inenabled.get()&&permission.application_applicationfamily.equals('ExchangeOnline')" to inenabled,
						incanshowdetails binds-to incanshowdetails,
						value-of groups to groups,
						value-of False to inresolvegroups
				}
			] when "OneDrive" then [
				fragmentAccountPermissionACLs_OneDrive = IncludeFragment {
					fragment: fragmentAccountPermissionACLs_win with
						value-of inpermissionuid to inpermissionuid,
						value-of inuid to inuid,
						value-of Eval "inenabled.get()&&permission.application_applicationfamily.equals('OneDrive')" to inenabled,
						incanshowdetails binds-to incanshowdetails,
						value-of groups to groups,
						value-of False to inresolvegroups
				}
			] when "SharedFolders" then [
				fragmentAccountPermissionACLs_win = IncludeFragment {
					fragment: fragmentAccountPermissionACLs_win with
						value-of inpermissionuid to inpermissionuid,
						value-of inuid to inuid,
						value-of Eval "inenabled.get()&&permission.application_applicationfamily.equals('SharedFolders')" to inenabled,
						incanshowdetails binds-to incanshowdetails,
						value-of groups to groups,
						value-of False to inresolvegroups
				}
			] otherwise [ 
				fragmentAccountPermissionACLs_generic = IncludeFragment {
					fragment: fragmentAccountPermissionACLs_generic with
						value-of inpermissionuid to inpermissionuid,
						value-of inuid to inuid,
						value-of Eval "((inenabled.get()?1:0)+(permission.application_applicationfamily.equals('SharePointOnline')?10:0)+(permission.application_applicationfamily.equals('ExchangeOnline')?10:0)+(permission.application_applicationfamily.equals('OneDrive')?10:0)+(permission.application_applicationfamily.equals('SharedFolders')?10:0))==1" to inenabled,
						incanshowdetails binds-to incanshowdetails,
						value-of groups to groups,
						value-of False to inresolvegroups
				}
			]
		}
	}
}

/**
 * <span style="white-space: pre-line">
 * Shows account unstructured data ACLs for a given windows/sharedfolder permission
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>account uid</li>
 * <li><b>ininpermissionuid </b>account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inresolvegroups </b>optional, boolean value, true to enable groups resolution (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * </span>
 */
fragmentAccountPermissionACLs_win = PageFragment {
	feature:unstructureddata_license
	enter-event: 
		ExecuteNamedAction reload
	
	/* Variables here */
	inuid = Variable
	inpermissionuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	inresolvegroups = Variable { type: Boolean initial: True }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	
	groups =  Variable {type:String multivalued:True}
	currentIndex =  Variable {type:Integer multivalued:False initial:10 private:True}
	showAdvanced = Variable { type: Boolean multivalued: False initial: False private:True}  // == hideBasic

	// Data binding

	sharedfolder = Record {
		view:bwf_fileexplorergetsharedfolder with inpermissionuid to uid
		disabled:Not BooleanPredicate(inenabled)
	}
	
	identityWithSharedfolder = Record {
		view:bwf_fileexplorergetpeoplewithsharedfolder with inpermissionuid to uid, inuid to accountuid
		disabled:Not BooleanPredicate(inenabled)
	}
	
	groups = HierarchicalData {
		roots-view:bwf_fileexplorergetfilesharegroupaclsforaccount with inpermissionuid to uid, inuid to accountuid, groups to groups
		children-view:bwf_fileexplorergetfilesharegroupaclsforaccountchildof with inuid to accountuid, groups to groups
		attribute: recorduid
		parameter:parentrecorduid
		max-level: 5
	}

	accountacls = Dataset {
		view:bwf_fileexplorergetfileshareaccountacls with inpermissionuid to uid, inuid to accountuid
		disabled:Not BooleanPredicate(inenabled)
	}
	
	publicgroups = Dataset {
		view: bwf_getaccountpublicgroups with inuid to uid
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	directaccountgroups = Dataset {
		view:bwf_fileexplorergetaccountgroups with inuid to uid
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	accountgroups = Dataset {
		union: Union { datasets: publicgroups, directaccountgroups discriminator-column: source }
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	reload = NamedAction (
		BooleanCase ( inresolvegroups ) {
			when False then []
			when True then [
				StringCase ( groups ) {
					when IsEmpty then [
						TransferData accountgroups( uid ) to ( groups )
					]
				}
			]
		}
	)

	// Layout
	Grid {
		layout:Layout{grab:horizontal True vertical False hint:height 126}
		columns:GridColumn{width:grow},GridColumn{width:220}
		GridRow {
			GridCell {
				Text {value:sharedfolder.code label:$fragmentAccountACLsNLS.directory compact:True}
				Text {value:identityWithSharedfolder.accountidentifier label:$account.identifier compact:True}
				Text {value:identityWithSharedfolder.accountlogin label:$account.login compact:True}
				Text {value:identityWithSharedfolder.accountusername label:$account.username compact:True}
				Text {value:identityWithSharedfolder.repositorydisplayname label:$repository.concept compact:True}
			}
			// Basic and advanced Permissions
			GridCell {
			   			
				Text {value: @bwf_jsBasicPermissionsFromRights(identityWithSharedfolder.action to action, "label" to fmt) 
				      hidden: BooleanPredicate( showAdvanced)
				      label:$fragmentAccountACLsNLS.identity.link.permissions				       
				      lines: 6 compact: True				      
				}
				Text {value:identityWithSharedfolder.action
				  hidden: Not BooleanPredicate( showAdvanced) 
				  label:$fragmentAccountACLsNLS.identity.link.permissions compact:True
				}       				       
			}
		
		}
	}
	// Basic group Permissions	
	Group {
		title: $fragmentAccountACLsNLS.tabs.aclexplorer.labels.grouppermissions 
		hidden: BooleanPredicate( showAdvanced)	
		
		Tree {
			data:groups
			expand-level:10
			configurable:True
			persist-configuration:True
			layout:Layout{grab:horizontal True vertical True}
			commands:Commands{position:After orientation:Vertical presentation:Icon Command{actions:Dialog bwf_sharedfolderexplorerhelpdialog( showAdvanced to showAdvanced) icon:%browsing_16.zoom tooltip:$fragmentAccountACLsNLS.tooltips.links.rightsexplained } Command{actions:Message 'todo' icon:'' disabled:True}}
			disabled:Not BooleanPredicate(inenabled)
			
			Column { column:displayname width:100% header: $group.concept}
			Column { column:code width:100% header: $pgroup.code initially-masked:True}
			Column { column:repositorydisplayname width:100px header: $repository.concept  initially-masked:True}
			// DEBUG Column { column:recorduid width:100% header: "[ACL]"}
			Column {column:order width:64px initially-masked: True }
			Column { column:negative initially-masked:True }
			Column {column:action initially-masked:True	}

			Column { column:BASIC_FULLCONTROL header: $bwf_sharedfolder_rights.fullcontrolright width: 80px image:TemplateImageSelection(Current BASIC_FULLCONTROL) using rightTemplate text:''} 
			Column { column:BASIC_MODIFY header: $bwf_sharedfolder_rights.modifyright width:60px image:TemplateImageSelection(Current BASIC_MODIFY) using rightTemplate text:''} 
			Column { column:BASIC_READEXECUTE header: $bwf_sharedfolder_rights.readexecuteright width: 100px  image:TemplateImageSelection(Current BASIC_READEXECUTE) using rightTemplate text:''} 
			Column { column:BASIC_READ header: $bwf_sharedfolder_rights.readright width:50px image:TemplateImageSelection(Current BASIC_READ) using rightTemplate text:''} 
			Column { column:BASIC_WRITE header: $bwf_sharedfolder_rights.writeright width:50px image:TemplateImageSelection(Current BASIC_WRITE) using rightTemplate text:''} 
			Column { column: action header: $bwf_sharedfolder_rights.specialright 
			   width: 60px  image:TemplateImageSelection( @bwf_jsHasSpecialPermission(Current action to action, Current negative to negative)) using rightTemplate
			  text: ''}  						
		}

	}
	// Basic Account Permissions 
	Group {
		title: $fragmentAccountACLsNLS.tabs.aclexplorer.labels.directacls
		layout:Layout{grab:horizontal True vertical False hint:height 100}
		hidden:Not AndPredicate{ 
		         Not BooleanPredicate( showAdvanced ) 
