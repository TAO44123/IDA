			configurable:True
			disabled:Not BooleanPredicate(inenabled)

			Column { header:$account.login column:login sortable:True width:20% }
			Column {header:$account.username column:username sortable:True width:80% }
			Column {column:order width:64px initially-masked:True}
			Column {column:negative initially-masked:True}
			Column {column:action initially-masked:True}
			
			Column { column:BASIC_FULLCONTROL header:$bwf_sharedfolder_rights.fullcontrolright  width: 80px image:TemplateImageSelection(Current BASIC_FULLCONTROL) using rightTemplate text:''} 
			Column { column:BASIC_MODIFY header:$bwf_sharedfolder_rights.modifyright width:60px image:TemplateImageSelection(Current BASIC_MODIFY) using rightTemplate text:''} 
			Column { column:BASIC_READEXECUTE header:$bwf_sharedfolder_rights.readexecuteright width: 100px  image:TemplateImageSelection(Current BASIC_READEXECUTE) using rightTemplate text:''} 
			Column { column:BASIC_READ header:$bwf_sharedfolder_rights.readright width:50px image:TemplateImageSelection(Current BASIC_READ) using rightTemplate text:''} 
