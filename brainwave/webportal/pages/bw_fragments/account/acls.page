/**
 * <span style="white-space: pre-line">
 * Shows account unstructured data ACLs for a given sharepoint-online permission
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>account uid</li>
 * <li><b>inpermissionuid </b>account uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inresolvegroups </b>optional, boolean value, true to enable groups resolution (true by default)</li>
 * <li><b>incanshowdetails </b>activate/deactivate accounts details list through GUI</li>
 * </ul>
 * </span>
 */
fragmentAccountPermissionACLs_spo = PageFragment {
	feature:unstructureddata_license
	enter-event: 
		ExecuteNamedAction reload
	
	/* Parameters */
	inuid = Variable
	inpermissionuid = Variable 
	inenabled = Variable { type: Boolean initial: True }
	inresolvegroups = Variable { type: Boolean initial: True }
	incanshowdetails = Variable { type: Boolean initial: False }

	/* Internal Vars */
	groups =  Variable {type:String multivalued:True} // account groups
	showAdvanced = Variable { type: Boolean multivalued: False initial: False}  // == hideBasic
	selectedadvanceadctions = Variable
	selectedaccountadvanceadctions = Variable
	
	/* Datasets to get the groups of the accounts */
	permission = Record {
		view:br_permissionDetail with inpermissionuid to uid
		disabled: Not BooleanPredicate ( inenabled )
	}

	publicgroups = Dataset {
		view: bwf_getaccountpublicgroups with inuid to uid
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	directaccountgroups = Dataset {
		view: bwf_fileexplorergetaccountgroups with inuid to uid
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	accountgroups = Dataset {
		union: Union { datasets: publicgroups, directaccountgroups discriminator-column: source }
		disabled:Not BooleanPredicate(inresolvegroups)
	}
	
	/* Datasets to get the the group ACLs */
	groupsACL = HierarchicalData {
		roots-view:bwf_generic_groupaclsforaccount_bs with inpermissionuid to uid, inuid to accountuid, groups to groups, permission.application_applicationfamily to appfamily
		children-view:bwf_generic_groupaclsforaccount_childof_bs with inuid to accountuid, groups to groups
		attribute: recorduid
		parameter:parentrecorduid
		max-level: 5
		disabled: Not BooleanPredicate ( inenabled )
	}

	groupsACLrootcount = Dataset {
		view: bwf_fileexplorergetfilesharegroupaclsforaccount with inpermissionuid to uid, inuid to accountuid, groups to groups
		disabled: Not BooleanPredicate ( inenabled )
	}
	
	/* Datasets to get the account ACLs */
	accountACL = Dataset {
		view:bwf_generic_accountaclsforaccount_bs with inpermissionuid to uid, inuid to accountuid, permission.application_applicationfamily to appfamily
		disabled: Not BooleanPredicate ( inenabled )
	}
	
	reload = NamedAction (
		BooleanCase ( inresolvegroups ) {
			when False then []
			when True then [
				StringCase ( groups ) {
					when IsEmpty then [
						TransferData accountgroups( uid ) to ( groups )
					]
				}
			]
		}
	)
	
	/* The warning in case no ACL is found */
	Group {
		background: Color RGB ( 254,239,176)
		border: True 
		layout: Layout { grab: horizontal True vertical False hint: height 50}
		hidden: IntPredicate ( Sum ( Count groupsACLrootcount, Count accountACL ) ) { when != 0 then True otherwise False }
		Text {
			layout: Layout { grab: horizontal True vertical False hint: height 40 indent: horizontal 0 vertical 5}
			compact: True
			value: $fragmentAccountACLsNLS.warning.noaclfound
			styling: warning
			lines: 2
		}
	}
	
	Group {
		margins: All 20
		/* Group ACLs */
		Group {
			title: $fragmentAccountACLsNLS.groupacl.title	
			hidden: StringPredicate ( permission.application_applicationfamily ) { when "SharePointOnline" then False otherwise True }
			ConditionalGroup {
				BooleanCondition ( showAdvanced ) {
					when True then [
						// Advanced Tree for Sharepoint
						Tree {
							data:groupsACL
							expand-level:10
							configurable:True
							layout:Layout{grab:horizontal True vertical True}
							disabled: IntPredicate ( Sum ( Count groupsACLrootcount, Count accountACL ) ) { when = 0 then True otherwise False }
							double-click: Dialog bwf_sharepointexplorerhelpdialog ( 'True' to showAdvanced, selectedadvanceadctions to advancedActions, permission.application_applicationfamily to appfamily )
							
							commands: Commands {
												position: After
												orientation: Vertical
												presentation:Icon
												Command{ disabled: StringPredicate ( selectedadvanceadctions ) { when IsEmpty then True otherwise False } actions:Dialog bwf_sharepointexplorerhelpdialog ( 'True' to showAdvanced, selectedadvanceadctions to advancedActions, permission.application_applicationfamily to appfamily ) icon:%browsing_16.help tooltip: $fragmentAccountACLsNLS.tooltips.links.rightsexplained }
										}
							
							Column { column:displayname width:100% header: $group.concept}
							Column { column:order width:64px initially-masked: True }
							Column { column:negative initially-masked:True }
							Column { column:code initially-masked:True width:100% }
							Column { column:advanced_appactioncount header:$bwf_sharepointNLS.action width: 90px align: Center }
							Column { column:advanced_appactiondisplayname header: $fragmentAccountACLsNLS.tabs.aclexplorer.labels.advanced width: 100% }			
							Column { column:action width:100% initially-masked:True selection: selectedadvanceadctions }
						}
					]
					when False then [
						// Basic Tree for Sharepoint
						Tree {
							data:groupsACL
							expand-level:10
							configurable:True
							layout:Layout{grab:horizontal True vertical True}
							disabled: IntPredicate ( Sum ( Count groupsACLrootcount, Count accountACL ) ) { when = 0 then True otherwise False }
							
							commands: Commands {
												position: After
												orientation: Vertical
												presentation:Icon
												Command{actions:Dialog bwf_sharepointexplorerhelpdialog ( 'False' to showAdvanced) icon:%browsing_16.help tooltip: $fragmentAccountACLsNLS.tooltips.links.rightsexplained }
										}
							
							Column { column:displayname width:100% header: $group.concept}
							Column {column:order width:64px initially-masked: True }
							Column { column:negative initially-masked:True }
							Column { column:code initially-masked:True width:100% }
							Column { width:32px  header:$bwf_sharedfolderexplorerNLS.readaccess column:readaccess image:TemplateImageSelection(Current readaccess) using rightTemplate  text:'' sortable:False } 
							Column { width:32px  header:$bwf_sharedfolderexplorerNLS.writeaccess column:writeaccess image:TemplateImageSelection(Current writeaccess) using rightTemplate  text:'' sortable:False } 			
							Column {column:basic width:100% initially-masked:True	header: $bwf_sharedfolderexplorerNLS.basic }
							Column {column:spobasic width:100% initially-masked:False	header: $bwf_sharepointNLS.basic }			
							Column {column:action width:100% initially-masked:True	header: $bwf_sharepointNLS.action }
						}
					] 
				}
			}
		}
		
		// Table for Sharepoint
		Group {
			title: $fragmentAccountACLsNLS.accountacl.title
			layout:Layout{grab:horizontal True vertical True}
			hidden: StringPredicate ( permission.application_applicationfamily ) { when "SharePointOnline" then False otherwise True }
			
			ConditionalGroup {
				BooleanCondition ( showAdvanced ) {
					when True then [
						Table {
							data:accountACL
							layout:Layout{grab:horizontal True vertical True}
							disabled: IntPredicate ( Sum ( Count groupsACLrootcount, Count accountACL ) ) { when = 0 then True otherwise False }
							double-click: Dialog bwf_sharepointexplorerhelpdialog ( 'True' to showAdvanced, selectedaccountadvanceadctions to advancedActions, permission.application_applicationfamily to appfamily )
							
							commands: Commands {
									position: After
									orientation: Vertical
									presentation:Icon
									Command{ disabled: StringPredicate ( selectedaccountadvanceadctions ) { when IsEmpty then True otherwise False } actions:Dialog bwf_sharepointexplorerhelpdialog ( 'True' to showAdvanced, selectedaccountadvanceadctions to advancedActions, permission.application_applicationfamily to appfamily ) icon:%browsing_16.help tooltip: $fragmentAccountACLsNLS.tooltips.links.rightsexplained }
							}
							
							configurable:True
							Column { header:$account.login column:login sortable:True width:20% }
							Column {header:$account.username column:username sortable:True width:80% }
							Column {column:order width:64px initially-masked:True}
							Column {column:negative initially-masked:True}
							
							Column {
								column:identifier
								initially-masked:True
								width:66%
							}
							Column { column:advanced_appactioncount header:$bwf_sharepointNLS.action width: 90px align: Center }
							Column { column:advanced_appactiondisplayname header: $fragmentAccountACLsNLS.tabs.aclexplorer.labels.advanced width: 100% }			
							Column { column:action width:100% initially-masked:True selection: selectedaccountadvanceadctions }
						}
					]
					when False then [
						Table {
							data:accountACL
							layout:Layout{grab:horizontal True vertical True}
							disabled: IntPredicate ( Sum ( Count groupsACLrootcount, Count accountACL ) ) { when = 0 then True otherwise False }
							
							commands: Commands {
									position: After
									orientation: Vertical
									presentation:Icon
									Command{actions:Dialog bwf_sharepointexplorerhelpdialog ( 'False' to showAdvanced) icon:%browsing_16.help tooltip: $fragmentAccountACLsNLS.tooltips.links.rightsexplained }
							}
							
							configurable:True
							Column { header:$account.login column:login sortable:True width:20% }
							Column {header:$account.username column:username sortable:True width:80% }
							Column {column:order width:64px initially-masked:True}
							Column {column:negative initially-masked:True}
							
							Column {
								column:identifier
								initially-masked:True
								width:66%
							}
							Column { width:32px  header:$bwf_sharedfolderexplorerNLS.readaccess column:readaccess image:TemplateImageSelection(Current readaccess) using rightTemplate  text:'' sortable:False } 
							Column { width:32px  header:$bwf_sharedfolderexplorerNLS.writeaccess column:writeaccess image:TemplateImageSelection(Current writeaccess) using rightTemplate  text:'' sortable:False } 
							Column {column:basic width:100% initially-masked:True	header: $bwf_sharedfolderexplorerNLS.basic }
							Column {column:spobasic width:100% initially-masked:False	header: $bwf_sharepointNLS.basic }			
							Column {column:action width:100% initially-masked:True	header: $bwf_sharepointNLS.action }
						}
					]
				}
			}
		}
		// Toggle advanced mode
		Checkbox { variable: showAdvanced label: $fragmentAccountACLsNLS.tabs.aclexplorer.labels.showadvanced }	

	}
}


