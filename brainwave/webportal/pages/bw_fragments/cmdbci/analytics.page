/* Import other pages here */
import "/webportal/pages/styles/styles.page"

import "/webportal/pages/bw_fragments/lib/styles.page"

fragmentCmldbciAnalyticsNLS = NLS {
	empty [en "No analytics available" fr "Pas d'analyse disponible"]
}

/**
 * <span style="white-space: pre-line">
 * Display the analytics for a given cmdb ci
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the cmdb uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * </ul>
 * </span>
 */
fragmentCmdbciAnalytics = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }

	allRelatedLinksTiles = Dataset {
		pages: Pages{tags: "cmdbci" and "byuid" }
		disabled:Not BooleanPredicate(inenabled)
	}
	
	ConditionalGroup {
		IntCondition(Count allRelatedLinksTiles) {
			when =0 then [
				Header {
					value:$fragmentCmldbciAnalyticsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				TemplateTable {
					data:allRelatedLinksTiles
					layout:Layout { grab:horizontal True vertical True }
					show-filter:True
					pagination:10
					row-height:100
					double-click:GoTo Dynamic (Current type, Current name) with inuid to uid save-state
										
					ImageCell {
						image:Current largeIcon
						left:20
						top:30
						width:48
						height:48
						on-click:GoTo Dynamic (Current type, Current name) with inuid to uid save-state
					}
					TextCell {
						column:title							
						left:10
						top:10
						width:970
						height:20
						filterable:True
						styling:bwf_boldNG
						on-click:GoTo Dynamic (Current type, Current name) with inuid to uid save-state
					}
					TextCell {
						column:description
						vertical-align:Top
						horizontal-align:Left
						styling:bwf_notboldNG
						filterable:True
						wrap:True
						left:80
						top:30
						width:900
						height:60
					}
				}
			]
		}
	}
}