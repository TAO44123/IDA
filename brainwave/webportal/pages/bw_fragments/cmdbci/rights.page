/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/bw_fragments/account/resources.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/nls.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/resources/constants.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/styles/styles.page"

fragmentCmdbciRightsNLS = NLS {
	noownercode [en "Technical account" fr "Compte technique"]
	pdescription [en "Permission description" fr "Description de la permission"]
	empty [en "CMDB CI element does not contain applications access rights" fr "Cet élément CMDB CI ne contient pas de droits d''accès applicatifs"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected cmdb CI rights
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the CMDB uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>inPermissionType </b>the permission type ('Role' by defaut)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * <li><b>inPermissionType </b>the permission type ('Role' by defaut)</li>
 * <li><b>incanreconcile</b>, optional boolean, can perform manual reconciliation, false by default</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outpermissionuid </b>the permission uid</li>
 * </ul>
 * </span>
 */
fragmentCmdbciRights = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:False changed-event:BooleanCase(inenabled) { when True then [ ExecuteNamedAction cacheCIs ] when False then [ ] } }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	inPermissionType = Variable {multivalued:True}
	incanreconcile = Variable { type:Boolean initial:False }
	outaccountuid = Variable
	outaccountlogin = Variable
	outpermissionuid = Variable

	allcis = Variable { type:String multivalued:True } // All sub CI elements including this one

	rights = Dataset {
		view: bw_cmdbrights with
			allcis to uid,
			inPermissionType to permissiontype unless-empty
		trend: Trend {
		 	join-column:key
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate(inenabled)
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// dataset to retreive and cache all sub CI including this one
	allSubCIDataset = Dataset {
		view:bw_cmdbtopdown with inuid to uid
	} 

	cacheCIs = NamedAction (
		TransferData allSubCIDataset(CI_uid) to (allcis)
	)

	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid,
													True to inshowaccounts,
													True to inshowcontrols,
													True to inshowdecisionhistory,
													True to inshowtheoretical,
													True to inshowoverallocated,
													True to inshowsodmodeldefects,
													True to inshowusages,
													True to inshowperorg,
													True to inshowperjob
												)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												incanreconcile to incanreconcile,
												True to inshowowner,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowusages,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	ConditionalGroup {
		IntCondition(Count rights) {
			when =0 then [
				Header {
					value:$fragmentCmdbciRightsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Table {
					data:rights
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					persist-configuration:True
					
					
					Column {
						column:permissionuid
						hidden:True
						selection:outpermissionuid
					}
			
					Column {
						column:applicationdisplayname
						header:$application.concept
						sortable:True
						filterable:True
						width:160px
					}
			
					Column {
						column:permissioncode
						header:$ppermission.code
						sortable:True
						filterable:True
						actions: ExecuteNamedAction goPermissionDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
						initially-masked:True
					}
					Column {
						column:permissiondisplayname
						header:$permission.concept
						sortable:True
						filterable:True
						actions: ExecuteNamedAction goPermissionDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
						width:160px
					}
					Column {
						column:permissiondescription
						header:$fragmentCmdbciRightsNLS.pdescription
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:accountuid
						hidden:True
						selection:outaccountuid
					}
					
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						selection:outaccountlogin
						actions: ExecuteNamedAction goAccountDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						width:160px
					}
			
					Column {
						column:accountusername
						header:$account.username
						sortable:True
						filterable:True
						width:160px
						actions: ExecuteNamedAction goAccountDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						initially-masked:True
					}
			
					Column {
						column:accountcreationdate
						header:$account.creationdate
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						filterable:True
						initially-masked:True
					}
					Column {
						column:noownercode
						sortable:True
						filterable:True
						header:$fragmentCmdbciRightsNLS.noownercode
					}
					Column {
						column:identityhrcode
						sortable:True
						filterable:True
						header:$pidentity.hrcode
						initially-masked:True
					}
					Column {
						column:identityfullname
						sortable:True
						filterable:True
						header:$pidentity.fullname
						width:100%
					}
					Column {
						column:identitymail
						sortable:True
						filterable:True
						header:$pidentity.mail
						initially-masked:True
					}
					Column {
						column:identityinternal
						sortable:True
						filterable:True
						header:$pidentity.internal
						initially-masked:True
					}
					Column {
						column:identityactive
						sortable:True
						filterable:True
						header:$pidentity.active
						initially-masked:True
					}
					Column {
						column:identitybwa_identityanalyticsdata_joborg
						initially-masked:True
						filterable:True
						sortable:True
						header:$pidentity.joborg
						width:160px
					}
					Column {
						column:ci_displayname
						header:$pcmdb.displayname
						width:200px
						sortable:True
						filterable:True
					}
					Column {
						column:ci_type
						header:$pcmdb.type
						width:200px
						sortable:True
						filterable:True
					}
					Column {
						column: trends
						header: $bw_fragment.trends
						text:Transform Current trends using bwf_trendStatusColumn 
						styling:StylingTemplateSelection(Current trends) using bwf_trendStatusColumn  
						image:TemplateImageSelection(Current trends) using bwf_trendStatusColumnWhite
						tooltip:$bwf_trendStatusColumnNLS.tooltip
			
						sortable: True
						filterable: True
						width: 10%
					}												
				}
			]
		}
	}
}