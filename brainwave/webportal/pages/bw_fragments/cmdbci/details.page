/* Import other pages here */
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/services.page"
import "/webportal/pages/styles/styles.page"

import "/webportal/pages/bw_fragments/lib/templates.page"
import "/webportal/pages/bw_fragments/lib/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_fragments/cmdbci/resources.page"

fragmentCmdbciDetailsNLS = NLS {
	family [en "Family" fr "Famille"]
	description [en "Description" fr "Description"]
	category [en "Category" fr "Catégorie"]
	sensitivitylevel [en "Sensitivity Level" fr "Niveau de sensibilité"]
	sensitivityreason [en "Sensitivity Reason" fr "Raison de la sensibilité"]
	nbaccounts [en "Number of active accounts" fr "Nombre de comptes actifs"]
	nbidentities [en "Number of user accounts" fr "Nombre de comptes utilisateur"]
	nbgroups [en "Number of groups" fr "Nombre de groupes"]
	expertise [en "Expertise" fr "Responsabilité"]
	managers [en "Managers" fr "Responsables"]
	addowner [en "Add a new cmdb ci owner" fr "Ajout d'un nouveau responsable de l''élément CMDB"]
	deleteowner [en "Delete cmdb ci owners" fr "Suppression des responsables de l''élément CMDB"]
	auditowner [en "CMDB CI owner updates audit trail" fr "Piste d'audit des changements de responsable de l''élément CMDB"]
	nomanagers [en "No manager set" fr "Pas de responsable configuré"]
	accountsgroups [en "Accounts && groups" fr "Comptes et groupes"]
	accessrights [en "Access rights" fr "Droits d''accès"]
	classification [en "Classification" fr "Classification"]
	updatemetadata [en "Update CMDB CI description" fr "Mise à jour de la description de l''élément CMDB"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected CMDB CI details in compact mode
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the cmdb ci uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentCmdbciDetails = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	cmdbci = Record {
		view: bwf_cmdbciDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	managers = Dataset {
		view: bwf_cmdbcimanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}
	

	Text {
		value:cmdbci.code
		label:$cmdb.code
		compact:True
		hidden:SameValuePredicate(cmdbci.code, cmdbci.displayname)
	}
	Text {
		label:$cmdb.displayname
		value:cmdbci.displayname
		compact:True
	}
	Text {
		value: @srv_truncatestring (cmdbci.description to string, 200 to maxlength)
		tooltip: cmdbci.description
		label:$cmdb.description
		lines:3
		compact:True
		layout: Layout{hint:height 48}
		hidden:StringPredicate(cmdbci.description) { when IsEmpty then True otherwise False }
	}

	Header {
		value:$fragmentCmdbciDetailsNLS.classification
	}
	Separator {
		width:1
	}

	Text {
		value: cmdbci.family
		label:$cmdb.family
		compact:True
	}
	Text {
		value:cmdbci.type
		label:$cmdb.type
		compact:True
	}
	Text {
		value:cmdbci.creationdate
		label:$cmdb.creationdate
		compact:True
	}
	Text {
		value:cmdbci.modifydate
		label:$cmdb.modificationdate
		compact:True
	}

	Header {
		value:"Status"
	}		
	Separator {
		width:1
	}	

	Text {
		value:cmdbci.state
		label:$cmdb.state
		compact:True
	}
	Text {
		value:cmdbci.environment
		label:$cmdb.environment
		compact:True
	}

	Header {
		value:$fragmentCmdbciDetailsNLS.managers
	}
	Separator {
		width:1
	}

	ConditionalGroup {
		IntCondition(Count managers) {
			when =0 then [
				Header {
					value:$fragmentCmdbciDetailsNLS.nomanagers			
					commands: Commands {
						position: After orientation: Vertical
						Command{	
								actions:Dialog bwfCmdbciDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																							selectedExpertiseDomain to paramManagerType, 
																							inuid to paramCmdbciUid),
										ReloadData (managers)
	                        	icon:%concept_16.manager
	                        	disabled:Not BooleanPredicate(incanupdateowners)
	                        	feature:cmdbcidetails_updatemanager
	                        	tooltip:$fragmentCmdbciDetailsNLS.addowner
	                       }
					}
				}
			]
			otherwise [

				Table {
					data:managers
					layout:Layout { grab:horizontal True vertical False hint:height 116 }
					configurable:True
					label:Label { break:True }
					commands:Commands { position: After orientation: Vertical
									Command{	
											actions:Dialog bwfCmdbciDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerType, 
																										inuid to paramCmdbciUid),
													ReloadData (managers)
				                        	icon:%concept_16.manager
				                        	disabled:Not BooleanPredicate(incanupdateowners)
				                        	feature:cmdbcidetails_updatemanager
				                        	tooltip:$fragmentCmdbciDetailsNLS.addowner
				                       }
									Command{	
											actions:Dialog bwfCmdbciDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																										selectedExpertiseDomain to paramManagerTypeCode, 
																										selectedManagerLink to paramManagerLinkRecorduid,
																										inuid to paramCmdbciUid),
													ReloadData (managers)
				                        	icon:%status_16.delete
				                        	disabled:
				                        		OrPredicate {
					                        		Not BooleanPredicate(incanupdateowners)
				                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
				                        		}
				                        	feature:cmdbcidetails_updatemanager 
				                        	tooltip:$fragmentCmdbciDetailsNLS.deleteowner
				                       }
				                  }
					
					Column {
						column:uid
						hidden:True
						selection:selectedManager
					}
					Column {
						column: managerLinkRecorduid
						hidden: True
						selection: selectedManagerLink
					}
					Column {
						column:expertisedomaincode
						hidden:True
						selection:selectedExpertiseDomain
					}
					Column {
						column:expertisedomaindisplayname
						text:Transform Current expertisedomaincode using bwfManagerTypeMapping
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$bwfManagement.type
						sortable:True
						width:140px
					}
					Column {
						column:hrcode
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						header:$identity.hrcode
						initially-masked:True
						sortable:True
					}
					Column {
						column:fullname
						header:$identity.fullname
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						sortable:True
						width:100%
					}
					Column {
						column:internal
						header:$pidentity.internal
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:active
						header:$pidentity.active
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
			
			
					Column {
						column:comment
						header:$bwfManagement.comment
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegation
						header:$bwfManagement.delegated
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:delegationreason
						header:$bwfManagement.^reason
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:_priority
						header:$bwfManagement.^priority
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:startdate
						header:$bwfManagement.startdate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
					Column {
						column:enddate
						header:$bwfManagement.enddate
						styling:BooleanStyling(Current active) { when False then errorStyle when True then default}
						initially-masked:True
						sortable:True
					}
				}
			]
		}
	}
}


/**
 * <span style="white-space: pre-line">
 * Display the selected cmdb ci details in 1366px wide
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the cmdb ci uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanupdateowners </b>optional, boolean value, can update cmdb ci owners (false by default). Warning, this function is also restricted through a Feature</li>
 * </ul>
 * </span>
 */
fragmentCmdbciFullDetails = PageFragment {
	feature: All(pam_license, Any(governance_license, compliance_license))
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:True }
	incanupdateowners = Variable { multivalued:False type:Boolean initial:False }

	selectedManager = Variable { private:True }
	selectedManagerLink = Variable { private: True }
	selectedExpertiseDomain = Variable { private:True }

	cmdbci = Record {
		view: bwf_cmdbciDetail with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	managers = Dataset {
		view: bwf_cmdbcimanagers with inuid to uid
		disabled:
			OrPredicate {
				Not BooleanPredicate ( inenabled )
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// standard
	Flow {
		disposition: Horizontal
		layout: Layout { grab: horizontal True vertical False }
		// cmdb ci card
		Group {
			Text {
				value: cmdbci.displayname
				styling: bigTitleStyle
				label: Label { break: False value: $cmdb.displayname }
				compact: True
			}
			Text {
				value: cmdbci.code
				compact: True
				label: Label { break: False value: $cmdb.code }
				hidden:
					SameValuePredicate ( cmdbci.code, cmdbci.displayname )
			}
			Text {
				value: @srv_truncatestring (cmdbci.description to string, 200 to maxlength)
				tooltip: cmdbci.description
				label: Label { break: False value: $server.description }
				compact: True
			}
		}
	}
	Grid {
		columns:GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			GridCell {
				Group {
					title:"Information"
					Text {
						value: cmdbci.family
						label:$cmdb.family
						compact:True
					}
					Text {
						value:cmdbci.type
						label:$cmdb.type
						compact:True
					}
					Text {
						value:cmdbci.creationdate
						label:$cmdb.creationdate
						compact:True
					}
					Text {
						value:cmdbci.modifydate
						label:$cmdb.modificationdate
						compact:True
					}
				}
			}
			GridCell {
				Group {
					title:"Status"

					Text {
						value:cmdbci.state
						label:$cmdb.state
						compact:True
					}
					Text {
						value:cmdbci.environment
						label:$cmdb.environment
						compact:True
					}
				}
			}
		}
	}
	Group {
		title:$fragmentCmdbciDetailsNLS.managers
		layout:Layout { grab:horizontal True vertical False }
		ConditionalGroup {
			IntCondition(Count managers) {
				when =0 then [
					Header {
						value:$fragmentCmdbciDetailsNLS.nomanagers
						commands: Commands {
							position: After orientation: Vertical
							Command{	
									actions:Dialog bwfCmdbciDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																								selectedExpertiseDomain to paramManagerType, 
																								inuid to paramCmdbciUid),
											ReloadData (managers)
		                        	icon:%concept_16.manager
		                        	disabled:Not BooleanPredicate(incanupdateowners)
		                        	feature:cmdbcidetails_updatemanager
		                        	tooltip:$fragmentCmdbciDetailsNLS.addowner
		                       }
						}
					}
				]
				otherwise [

					Table {
						data:managers
						layout:Layout { grab:horizontal True vertical False hint:height 116 }
						configurable:True
						label:Label { break:True }
						commands:Commands { position: After orientation: Vertical
										Command{	
												actions:Dialog bwfCmdbciDetailsAddManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerType, 
																											inuid to paramCmdbciUid),
														ReloadData (managers)
					                        	icon:%concept_16.manager
					                        	disabled:Not BooleanPredicate(incanupdateowners)
					                        	feature:cmdbcidetails_updatemanager
					                        	tooltip:$fragmentCmdbciDetailsNLS.addowner
					                       }
										Command{	
												actions:Dialog bwfCmdbciDetailsRemoveManager_Dialog(	selectedManager to paramManagerUid, 
																											selectedExpertiseDomain to paramManagerTypeCode, 
																											selectedManagerLink to paramManagerLinkRecorduid,
																											inuid to paramCmdbciUid),
														ReloadData (managers)
					                        	icon:%status_16.delete
					                        	disabled:
					                        		OrPredicate {
						                        		Not BooleanPredicate(incanupdateowners)
					                        			StringPredicate(selectedManager) { when IsEmpty then True otherwise False }
					                        		}
					                        	feature:cmdbcidetails_updatemanager 
					                        	tooltip:$fragmentCmdbciDetailsNLS.deleteowner
					                       }
					                  }
						
						Column {
							column:uid
							hidden:True
							selection:selectedManager
						}
						Column {
							column: managerLinkRecorduid
							hidden: True
							selection: selectedManagerLink
						}
						Column {
