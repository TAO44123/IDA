fragmentCmdbciServerAccountsNLS = NLS {
	noownercode [en "technical account" fr "compte technique"]
	nbgroups [en "Nb groups" fr "Nb groupes"]
	nbdirectgroups [en "Nb direct \ngroups" fr "Nb groupes \ndirects"]
	hidedisabled [en "Hide disabled accounts" fr "Masquer les comptes désactivés"]
	comparewith [en "compare {0} with ..." fr "comparer {0} avec ..."]
	gotodetail [en "Go to detail page" fr "Aller à la page de détail"]
	empty [en "CMDB CI element does not contain server accounts" fr "Cet élément CMDB CI ne contient pas de comptes dans les serveurs"]
}

/**
 * <span style="white-space: pre-line">
 * Display the selected cmdb CI servers accounts
 * 
 * <u>Parameters:</u><ul>
 * <li><b>inuid </b>the CMDB uid</li>
 * <li><b>inenabled </b>optional, boolean value, true to enable fragment (true by default)</li>
 * <li><b>incanshowdetails </b>optional, boolean value, true to enable button to show details (false by default)</li>
 * <li><b>incanredirectto </b>optional, boolean value, true to enable button to redirect to the selected item detail page (false by default)</li>
 * <li><b>incanreconcile</b>, optional boolean, can perform manual reconciliation, false by default</li>
 * <li><b>incanshowdisabled</b>, optional boolean, can show/hide disabled accounts, false by default</li>
 * <li><b>inhidedisabled</b>, optional boolean, hide disabled accounts, true by default</li>
 * </ul>
 * <u>Returns:</u><ul>
 * <li><b>outaccountuid </b>the selected account uid</li>
 * <li><b>outaccountlogin </b>the selected account login</li>
 * <li><b>outrepositoryuid </b>the selected account repository uid</li>
 * <li><b>outrepositoryname </b>the selected account repository name</li>
 * </ul>
 * </span>
 */
fragmentCmdbciServerAccounts = PageFragment {
	/* Parameters here */
		
	/* Variables here */
	inuid = Variable
	inenabled = Variable { multivalued:False type:Boolean initial:False changed-event:BooleanCase(inenabled) { when True then [ ExecuteNamedAction cacheCIs ] when False then [ ] } }
	incanshowdetails = Variable { multivalued:False type:Boolean initial:False }
	incanredirectto = Variable { multivalued:False type:Boolean initial:False }
	incanreconcile = Variable { type:Boolean initial:False }
	incanshowdisabled = Variable { type:Boolean initial:False }
	incancompare = Variable { type:Boolean initial:False }
	inhidedisabled = Variable { type:Boolean initial:True }
	outaccountuid = Variable
	outaccountlogin = Variable
	outrepositoryuid = Variable
	outrepositoryname = Variable

	allcis = Variable { type:String multivalued:True } // All sub CI elements including this one

	accounts = Dataset {
		view: bw_cmdbserversaccounts with
			allcis to uid,
			inhidedisabled to hideDisabled
		trend: Trend {
		 	join-column:key
		 	status-column-name:trends
			value-column:val
			timeslot:FromPage(-1)		 	
		}
		disabled:
			OrPredicate {
				Not BooleanPredicate(inenabled)
				StringPredicate ( inuid ) {
					when IsEmpty then True
				}
			}
	}

	// dataset to retreive and cache all sub CI including this one
	
	allSubCIDataset = Dataset {
		view:bw_cmdbtopdown with inuid to uid
	} 

	cacheCIs = NamedAction (
		TransferData allSubCIDataset(CI_uid) to (allcis)
	)

	goDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												incanreconcile to incanreconcile,
												True to inshowowner,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowusages,
												True to inshowcontrols,
												True to inshowdecisionhistory
												)
			]
			when False then [
			
			]
		}
	)

	Grid {
		columns:GridColumn { width:200 },GridColumn { width:200 },GridColumn { width:grow }
		layout:Layout { grab: horizontal True vertical False }
		GridRow {
			GridCell {
				Checkbox {
					variable:inhidedisabled
					text:$fragmentCmdbciServerAccountsNLS.hidedisabled
					hidden:Not BooleanPredicate(incanshowdisabled)
				}
			}
			GridCell {
			}
			GridCell {
			
			}
		}
	
	}

	ConditionalGroup {
		IntCondition(Count accounts) {
			when =0 then [
				Header {
					value:$fragmentCmdbciServerAccountsNLS.empty
					styling:bigTitleStyle
				}
			]		
			otherwise [
				Table {
					data:accounts
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					commands:Commands {
						presentation:Icon
						orientation:Vertical
						position:After
						Command {
							actions:GoTo Activity Account Detail with outaccountuid to paramAccountUid save-state
							icon:%browsing_16.link
							tooltip:$fragmentCmdbciServerAccountsNLS.gotodetail
							disabled:
							OrPredicate {
								StringPredicate(outaccountuid) { when IsEmpty then True otherwise False }
								Not BooleanPredicate(incanredirectto)	
							}
						}
						Command {
							actions:Message 'nop'
							disabled:True
						}
					}
													
					Column {
						column:uid
						hidden:True
						selection:outaccountuid
					}
					
			
					Column {
						column: login
						header: $account.login
						width: 100%
						sortable: True
						filterable:True
						selection:outaccountlogin
												
						initially-masked: False
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column: username
						header: $account.username
						width: 100%
						sortable: True
						filterable:True
						
						initially-masked: False
						actions: ExecuteNamedAction goDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column: lastlogindate
						header: $account.lastlogindate
						width: 100%
						sortable: True
						
						initially-masked: False
					}
					Column {
						column: identity_hrcode
						header: $pidentity.hrcode
						width: 100%
						sortable: True
						filterable:True
						
						initially-masked: False
					}
					Column {
