/* Import other pages here */
import "/webportal/pages/bw_cloud_base/resources/styles.page"

/* Nationalized labels here */
PRO014NLS = NLS {
	title [
		en "Processing Orphan Accounts"
		fr "Traitement les comptes orphelins"
	]

	maintitle [
		en "Processing Orphan Accounts"
		fr "Traiter les comptes orphelins"
	]

	p1 [
		en "Orphaned accounts are accounts for which no owner has been found.\nThe Role Mining service tries the following 3 methods to reconcile an account with an identity:\n- the HR number,\n-the email address,\n- the full name."
		fr "Les comptes orphelins sont les comptes pour lesquels aucun propriétaire n'a été trouvé.\nLe service de Role Mining essaie les 3 méthodes suivantes pour rapprocher un compte d'une identité :\n- le matricule RH,\n- l'adresse mail,\n- le nom complet."
	]

	p2 [
		en "Problems Caused by Orphan Accounts"
		fr "Les problèmes engendrés par les comptes orphelins"
	]

	p3 [
		en "Business Role Mining relies on a pivot table to display the permissions owned by identities."
		fr "Le Role Mining métier s'appuie sur un tableau croisé dynamique pour afficher les permissions détenues par les identités."
	]

	p4 [
		en "An account that is not linked to any identity cannot therefore appear in the pivot table and will be ignored in the analysis regardless of the scope of the analysis."
		fr "Un compte qui n'est relié à aucune identité ne peut donc pas apparaître dans le tableau croisé dynamique et sera ignoré dans l'analyse quelque soit le périmètre retenu."
	]

	p5 [
		en "An account can be orphaned because the attributes (HR number, email and full name) do not correspond to any loaded identity."
		fr "Un compte peut se trouver orphelin car les attributs (matricule RH, mail et nom complet) ne corrrespondent à aucune identité chargée."
	]

	p6 [
		en "Orphan accounts can also be technical accounts that do not belong to any identity."
		fr "Les comptes orphelins peuvent aussi être des comptes techniques n'appartenant à aucune identité."
	]

	p7 [
		en "How to Process Orphan Accounts?"
		fr "Comment traiter les comptes orphelins ?"
	]

	p8 [
		en "The Role Mining service allows the categorization of accounts (technical or user) and also allows to specify the owner for user accounts. Finding the owner of an account is a process called reconciliation."
		fr "Le service de Role Mining autorise la catégorisation de comptes (technique ou utilisateur) et permet aussi de préciser le propriétaire pour les comptes utilisateurs. Le fait de trouver le propriétaire d'un compte est une opération appelée réconciliation."
	]

	p9 [
		en "When an account remains orphaned after the creation of the Role Mining cube, it is necessary to determine if it is a technical account by looking at the different attributes of this account."
		fr "Lorsqu'un compte reste orphelin après la création du cube de Role Mining, il faut déterminer s'il s'agit d'un compte technique en regardant les différents attributs de ce compte."
	]

	p10 [
		en "If it is a user account, and you know the identity of the owner, you can enter this information. This operation is done on an account's page after having searched for it."
		fr "S'il s'agit bien d'un compte utilisateur, et que vous connaissez l'identité du propriétaire, il vous est possible de saisir cette information. Cette opération se fait sur la fiche d'un compte après l'avoir recherché."
	]

	p11 [
		en "All information entered in the Role Mining cube (categorization and designation of an owner) is retained even when you reload a new version of the data cube following a refresh of the source files."
		fr "Toutes les informations saisies dans le cube de Role Mining (catégorisation et désignation d'un propriétaire) sont conservées même lorsque vous recharger une nouvelle version du cube de données suite à un raffraichisement des fichiers source."
	]

	button.backtostage [
		en "Go Back to Dashboard"
		fr "Retour au tableau de bord"
	]
}

