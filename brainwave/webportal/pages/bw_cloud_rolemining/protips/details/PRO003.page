/* Import other pages here */
import "/webportal/pages/bw_cloud_base/resources/styles.page"

/* Nationalized labels here */
PRO003NLS = NLS {
	title [
		en "Benefits of a Role Model"
		fr "Bénéfices d'une modèle de rôles"
	]

	maintitle [
		en "Benefits of a Role Model"
		fr "Bénéfices d'une modèle de rôles"
	]

	p1 [
		en "The benefits are visible at two moments: during the Role Mining mission and once the roles are put into production."
		fr "Les bénéfices sont perceptibles à deux moments : lors de la mission de Role Mining puis, une fois les rôles mis en production."
	]
	p2 [
		en "During the Role Mining Mission"
		fr "Pendant la mission de Role Mining"
	]
	p3 [
		en "Highlighting of current authorizations: The pivot table provides visibility into user authorizations that were previously unobtainable. Indeed, for each user, the pivot table displays all the application profiles or fine permissions that each user has."
		fr "Mise en évidence des habilitations actuelles : Le  tableau croisé dynamique donne une visibilité sur les habilitations des utilisateurs jusqu'alors impossible à obtenir. En effet, pour chaque utilisateur, le tableau croisé affiche l'ensemble des profils applicatifs ou permissions fines que possède chaque utilisateur."
	]
	p4 [
		en "Identification of discrepancies in entitlements : The 360° vision of the authorizations obtained thanks to the pivot table allows the business managers or the application managers to detect discrepancies."
		fr "Identification des écarts dans les habilitations : La vision des habilitations à 360° obtenue grâce au tableau croisé dynamique permet au métier ou aux responsables applicatifs de détecter des écarts"
	]
	p5 [
		en "Increasing the quality of repositories (orphan accounts, managers...): To obtain quality roles, Role Mining is an opportunity to find the owners of orphan accounts and to update HR information (reporting organization, organization managers)."
		fr "Augmentation de la qualité des référentiels (comptes orphelins, responsables...) : Pour obtenir des rôles de qualité, le Role Mining est l'occasion de trouver les propriétaires des comptes orphelins et de mettre à jour les informations RH (organisation de rattachement, responsables d'organisation)."
	]
	p6 [
		en "Documentation of application profiles or fine permissions: In the context of business Role Mining, it is important to have documentation of application profiles or fine permissions so that business managers can position themselves during workshops on the relevance of including them in a role."
		fr "Documentation des profils applicatifs ou des permissions fines : Dans le cadre du Role Mining métier, il est important d'avoir une documentation des profils applicatifs ou des permissions fines afin que les responsables métiers puissent se positionner lors des ateliers sur la pertinence de les inclure dans un rôle."
	]
	p7 [
		en "Once the Roles are Put into Production"
		fr "Une fois les rôles mis en production"
	]
	p8 [
		en "Simplification of access requests for the business lines: The access request forms are much clearer. Managers and users gain more autonomy to request the accesses they need."
		fr "Simplification des demandes d'accès pour le métier : Les formulaires de demandes d'accès sont beaucoup plus clairs. Les responsables et les utilisateurs gagnent ainsi en autonomie pour demander les accès dont ils ont besoin."
	]
	p9 [
		en "Easier rights review for the business lines: Clearance reviews are greatly simplified because there are fewer rights to review and the roles are understandable by the business lines. Managers save precious time during reviews."
		fr "Revue des droits facilités pour le métier : Les revues d'habilitations sont grandement simplifiées car il y a moins de droits à revoir et les rôles sont compréhensibles par les métiers. Les responsables gagnent ainsi un temps précieux lors des revues."
	]
	p10 [
		en "Better compliance with the company's security policy: Compliance with the company's security policy is improved through the implementation of a role model and control is also greatly facilitated."
		fr "Meilleur respect de la politique de sécurité de l'entreprise : Le respect de la politique de sécurité de l'entreprise est amélioré par la mise en place d'un modèle de rôles et le contrôle en est aussi grandement facilité."
	]
	p11 [
		en "Gain in license cost on some applications: The role model makes it possible to streamline the allocation of permissions and, in some cases, to retrieve licenses if they are linked to the number of beneficiaries."
		fr "Gain en coût de licence sur certains applicatifs : Le modèle de rôles permet de rationaliser l'attribution des permissions et, dans certains cas, de récupérer des licences si celles-ci sont liées au nombre de bénéficiaires."
	]

	button.backtostage [
		en "Go Back to Dashboard"
		fr "Retour au tableau de bord"
	]
}

