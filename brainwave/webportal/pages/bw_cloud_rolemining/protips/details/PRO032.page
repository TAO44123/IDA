/* Import other pages here */
import "/webportal/pages/bw_cloud_base/resources/styles.page"

/* Nationalized labels here */
PRO032NLS = NLS {
	title [
		en "Suggestions for Final Output"
		fr "Suggestions de restitution finale"
	]

	maintitle [
		en "Suggestions for Final Output"
		fr "Suggestions de restitution finale"
	]

	p1 [
		en "The final return to the customer can be divided into 3 parts:"
		fr "La restitution finale au client peut se décomposer en 3 parties :"
	]
	p2 [
		en "Work Carried Out"
		fr "Travail réalisé"
	]
	p3 [
		en "The first part of the restitution must go back over the course of the mission:"
		fr "La première partie de la restitution doit revenir sur le déroulé de la mission :"
	]
	p4 [
		en "- Context of the project: briefly recall the stakes, describe the perimeter and its possible evolution."
		fr "- Contexte du projet : rappeler brièvement les enjeux, décrire le périmètre et son éventuelle évolution."
	]
	p5 [
		en "- State of play: give some KPIs on the initial data quality, which may explain phases of work on repositories that were not initially planned."
		fr "- Etat des lieux : donner quelques KPIs sur la qualité de données initiale ce qui peut expliquer des phases non prévues initialement de travail sur les référentiels."
	]
	p6 [
		en "- Difficulties encountered: These can be delays in the project due to extractions not arriving on time or of poor quality or unavailable interlocutors."
		fr "- Difficultés rencontrées : Il peut s'agir de retard dans le projet du à des extractions non parvenues à temps ou de mauvaise qualité ou des interlocuteurs non disponibles."
	]
	p7 [
		en "Results Obtained"
		fr "Résultat obtenu"
	]
	p8 [
		en "The presentation of the result obtained must include at least the following information:"
		fr "La présentation du résultat obtenu doit présenter à minima les informations suivantes :"
	]
	p9 [
		en "- Role KPIs: the KPI most expected by the customer is the number of roles found. However, the most relevant information is the coverage of roles in terms of identities and permissions. A very important indicator is the number of accesses (rights) covered by the roles. It may be interesting to mention the number of obsolete accesses identified during the workshops."
		fr "- KPI sur les rôles : le KPI le plus attendu par le client est le nombre de rôles trouvés. Cependant, l'information la plus pertinence est la couverture des rôles en termes d'identités et de permissions. Un indicateur très important est le nombre d'accès (droits) couverts par les rôles. Il peut être intéressant de mentionner le nombre d'accès obsolètes recensés lors des ateliers"
	]
	p10 [
		en "Continuation of the Mission"
		fr "Suite de la mission"
	]
	p11 [
		en "The end of the final restitution should help to project on the application and maintenance of the roles. Moreover, if the perimeter of Role Mining is partial, it may be interesting to consider an extension of the perimeter in a new phase:"
		fr "La fin de la restitution finale doit aider à se projeter sur l'application et la maintenance des rôles. De plus, si le périmètre du Role Mining est partiel, il peut être intéressant d'envisager une extension du périmètre dans une nouvelle phase :"
	]
	p12 [
		en "- Post-Role Mining Steps: Application of roles avoiding the Big Bang effect, life cycle, maintenance, role management risks. A point not to be neglected is the change management for the use of roles."
		fr "- Etapes post Role Mining : Application des rôles en évitant l'effet Big Bang, cycle de vie, maintenance, risques liés à la gestion des rôles. Un point à ne pas négliger est la conduite du changement pour l'utilisation des rôles."
	]
	p13 [
		en "- Scope Extension: Identify organizations or applications in the next scope."
		fr "- Extension de périmètre : Identifier les organisations ou les applications du prochain périmètre."
	]

	button.backtostage [
		en "Go Back to Dashboard"
		fr "Retour au tableau de bord"
	]
}

