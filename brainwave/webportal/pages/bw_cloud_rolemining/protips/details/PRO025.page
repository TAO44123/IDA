/* Import other pages here */
import "/webportal/pages/bw_cloud_base/resources/styles.page"

/* Nationalized labels here */
PRO025NLS = NLS {
	title [
		en "How a Workshop is Conducted"
		fr "Déroulement d'un atelier"
	]

	maintitle [
		en "How a Workshop is Conducted"
		fr "Déroulement d'un atelier"
	]

	p1 [
		en "The Brainwave methodology suggests the following steps to be adapted to the client context:"
		fr "La méthodologie Brainwave propose les étapes suivantes à adapter au contexte client :"
	]
	p2 [
		en "Introduction"
		fr "Introduction"
	]
	p3 [
		en "A workshop must be very short because the business manager's time is very precious. The average acceptable time for managers is about an hour and a half. Even if the manager has little time for the workshop, it is essential to take the time to present, at the beginning of the session, the context of the project:"
		fr "Un atelier doit être très court car le temps du responsable métier est très précieux. Le temps moyen acceptable pour les managers est d'environ une heure et demi. Même si le responsable dispose de peu de temps pour l'atelier, il est indispensable de prendre le temps de présenter, en début de séance, le contexte du projet :"
	]
	p4 [
		en "- The objectives of the project: Reminder of the key points of the project including the objective and duration. Do not hesitate to remind that the project is supported by management (if this is the case)."
		fr "- Les objectifs du projet : Rappel des points clés du projet dont l'objectif et la durée. Ne pas hésiter à rappeler que le projet est soutenu par la direction (si c'est le cas)."
	]
	p5 [
		en "- The benefits for the company: Application of the security policy, gain in licensing costs..."
		fr "- Les bénéfices pour l’entreprise : Application de la politique de sécurité, gain en coût de licence..."
	]
	p6 [
		en "- Benefits for the manager: Simplification of access requests and entitlement reviews,"
		fr "- Les bénéfice pour le responsable : Simplification des demandes d'accès et des revues des habilitations,"
	]
	p7 [
		en "- The objectives of this workshop: Identification of people having the same activity and determination of the roles within its team,"
		fr "- Les objectifs de cet atelier : Identification des personnes ayant la même activité et détermination des rôles au sein de son équipe,"
	]
	p8 [
		en "- The perimeter treated: Reminder of the applications included in the perimeter of this phase,"
		fr "- Le périmètre traité : Rappel des applications incluses dans le périmètre de cette phase,"
	]
	p9 [
		en "- The method used: Visualization of current entitlements in a pivot table"
		fr "- La méthode employée : Visualisation des habilitation actuelles dans un tableau croisé dynamique"
	]
	p10 [
		en "Search for Roles"
		fr "Recherche des rôles"
	]
	p11 [
		en "The search for roles is done in several steps:"
		fr "La recherche des rôles se fait en plusieurs étapes :"
	]
	p12 [
		en "- identify people with the same activity,\n- filter on these people,\n- activate the sorting of permissions,\n- determine whether to split permissions into multiple roles"
		fr "- identifier les personnes ayant la même activité,\n- filtrer sur ces personnes,\n- activer le tri des permissions\n- déterminer s'il faut scinder les permissions en plusieurs rôles"
	]

	button.backtostage [
		en "Go Back to Dashboard"
		fr "Retour au tableau de bord"
	]
}

