/* Import other pages here */
import "/webportal/pages/bw_cloud_rolemining/protips/details/PRO003.page"
import "/webportal/pages/bw_cloud_rolemining/protips/details/PRO014.page"
import "/webportal/pages/bw_cloud_rolemining/protips/details/PRO025.page"
import "/webportal/pages/bw_cloud_rolemining/protips/details/PRO032.page"

/* Nationalized labels here */
PROTIPS_NLS = NLS {
	PRO001.title [
		en "A role mining project can save on application licenses."
		fr "Un projet de Role Mining peut permettre de faire des économies de licences applicatives."
	]
	PRO001.description [
		en "Do not hesitate to include applications with high licensing costs as a priority."
		fr "N'hésitez pas à inclure en priorité des applications dont les coûts de licence sont élevés."
	]

	PRO002.title [
		en "Business role modeling saves time with regards to requests and permission reviews."
		fr "Un modèle de rôles métier permet de gagner beaucoup de temps dans les demandes et les revues d'habilitations."
	]
	PRO002.description [
		en "Business role modeling enables managers to reduce the amount of time spent monitoring accesses for their teams, including fewer permission request actions as well as fewer rights to be re-certified during periodic review campaigns."
		fr "Un modèle de rôles métiers permet aux managers de réduire le temps consacré à la gestion des accès de leurs équipes : moins d'actions de demandes d'habilitations, et moins de droits à recertifier lors des campagnes de revues périodiques."
	]

	PRO003.title [
		en "The benefits of setting up role modeling are numerous."
		fr "Les bénéfices de la mise en place d'un modèle de rôles sont nombreux."
	]
	PRO003.description [
		en "By clicking on the detail button, a page detailing the reasons to actively participate will be accessed and can be used internally to encourage people (application managers, business managers, etc.) to take part in the project."
		fr "En cliquant sur le bouton détail, vous accéderez à une page détaillant l'argumentaire dont vous pouvez vous servir en interne pour convaincre les personnes (responsables applicatifs, responsables métier…) de participer activement au projet."
	]

	PRO004.title [
		en "An announcement from upper manager introducing the start of the project reinforces legitimacy in subsequent communications."
		fr "Une communication de la hiérarchie pour annoncer le début du projet renforce votre légitimité dans les communications ultérieures."
	]
	PRO004.description [
		en "Obtaining an official announcement from upper management to the participants explaining the project's objectives and the stakes involved makes it easier to communicate with the business teams or application managers in order to request their assistance during the workshops."
		fr "Obtenir de votre hiérarchie ou du top management une communication officielle vers les intervenants expliquant l'objectif du projet et les enjeux permet de communiquer plus facilement vers les métiers ou les responsables applicatifs pour les solliciter lors des ateliers."
	]

	PRO005.title [
		en "Pay attention to excessive rights given to individuals who are assigned a new role."
		fr "Attention à l'excès de droits accordés aux personnes qui se voient attribuer un nouveau rôle."
	]
	PRO005.description [
		en "The creation of a role may result in the inclusion of roles, within an entity, with rights that were not assigned to all members of said entity. If the principle of least privilege is the priority, it is recommended to include in a role only those access rights that all users can and should have. Conversely, if the priority is the simplification of access management processes, over-allocations can be accepted as long as they do not concern permissions considered critical (writing with an international reach, admin rights, etc.)."
		fr "La création d'un modèle de rôles peut amener à inclure dans des rôles, à l'échelle d'une entité, des droits qui n'étaient pas attribués à tous les membres de cette entité. Si le principe du moindre privilège est votre priorité, nous vous recommandons plutôt d'inclure dans un rôle uniquement les droits d'accès dont tous les utilisateurs peuvent et doivent bénéficier. A l'inverse, si vous priorisez la simplification des processus de gestion des accès, les surallocations peuvent être acceptées, du moment qu'elles ne portent pas sur des permissions jugées critiques (écriture sur un périmètre international, droits admins…)."
	]

	PRO006.title [
		en "The success of a role mining project is not proportional to the number of roles created."
		fr "Le succès d'une mission de role mining n'est pas proportionnel au nombre de rôles créés."
	]
	PRO006.description [
		en "A widespread idea is that a role mining project is only successful if a large number of roles have been found. In fact, the main objective is not quantitative because if too many roles are created, they will be difficult to maintain. The main objective is qualitative and concerns the business relevance as well as the coverage of the roles."
		fr "Une idée très répandue est qu'une mission de role mining est réussie si un grand nombre de rôles ont été trouvés. En réalité, le critère principal n'est pas quantitatif car s'il y a trop de rôles créés, ceux-ci seront difficiles à maintenir. Les critères principaux sont qualitatifs et concernent la pertinence métier des rôles et la couverture des rôles."
	]

	PRO007.title [
		en "Make sure the right operational or organizational attachment for the people is present in the extractions."
		fr "Assurez-vous de disposer du bon rattachement opérationnel ou organisationnel des personnes dans les extractions."
	]
	PRO007.description [
		en "The attachment of identities to organizations is very important in business role mining because it allows the segmenting of workshops by organization. This data is essential in obtaining a relevant grouping of identities in the pivot table. In addition, the name of the manager of an organization is an important piece of information for soliciting the right participants for the workshops."
		fr "Le rattachement des identités aux organisations est très important dans le Role mining métier, car il permet de segmenter les ateliers par organisations. Cette donnée est indispensable pour obtenir un regroupement pertinent des identités dans le tableau croisé. De plus, le nom du manager d'une organisation est une information importante pour solliciter les bons intervenants en vue des ateliers."
	]

	PRO008.title [
		en "Contractors are an important group to be considered for role creation in IT organizations."
		fr "Les prestataires sont une population indispensable à considérer pour des créations de rôles dans des organisations IT (DSI / SSI…)."
	]
	PRO008.description [
		en "Widespread outsourcing has resulted in the presence of numerous contractors in IT organizations who may have privileged rights. However, these contractors are not always present in identity repositories. It is essential to be able to import them through other tools that reference them (AD, directory, purchasing application, etc.)."
		fr "L'outsourcing très répandu donne lieu à la présence de nombreux prestataires dans les organisations IT, susceptibles de détenir des droits à privilège. Or, ces prestataires ne sont pas toujours présents dans les référentiels d'identités. Il est essentiel de pouvoir les importer à travers d'autres outils qui les référencent (AD, annuaire, application achats…)."
	]

	PRO009.title [
		en "It is important to upload the criticality information of the permissions for role mining."
		fr "Il est important de charger l'information de criticité des permissions pour le role mining."
	]
	PRO009.description [
		en "When creating a role to simplify access requests, it is common to create roles with too many permissions that cover many people and reduce the number of roles. But it is important to be attentive to the criticality of the permissions that make up the role so as not to create security risks. Criticality information is, therefore, an important element of decision making during the workshops and must be obtained in the extractions."
		fr "Lors de la création d'un modèle de rôles ayant pour but de simplifier le geste de demandes d'habilitations, il est classique de créer des rôles contenant trop de permissions car cela permet d'obtenir des rôles touchant plus de personnes et cela diminue le nombre de rôles. Mais il faut alors être attentif à la criticité des permissions qui le composent afin de ne pas créer de risques de sécurité. L'information de criticité est donc un élément important de décision lors des ateliers. Il est donc important de l'obtenir dans les extractions."
	]

	PRO010.title [
		en "Don't hesitate to plan a reliability phase for the permission data, an essential prerequisite for successful role modeling."
		fr "N'hésitez pas à prévoir une phase de fiabilisation des données d'habilitation, prérequis indispensable à un bon modèle de rôles."
	]
	PRO010.description [
		en "In case of problems relating to the reconciliation of accounts, associations between identities and organizations, or the filling in of mandatory attributes, exchanges with the people in charge of data sources should be expected. This will guarantee a high quality of imported data while, at the same time, limit the risk of project delays."
		fr "En cas de problèmes liés à la réconciliation des comptes, au rattachement entre identités et organisations, ou encore au remplissage des attributs obligatoires, des échanges seront à prévoir avec les responsables de vos sources de données. Ces échanges sont à anticiper pour garantir une bonne qualité des données importées, tout en limitant le risque de retard du projet."
	]

	PRO011.title [
		en "Remember to integrate any organizational or access right developments into the project."
		fr "Pensez à intégrer dans le projet toute évolution sur les organisations ou les droits."
	]
	PRO011.description [
		en "In parallel with the current Role Mining campaign, are there any internal reorganization projects, application migrations or redesign of the rights catalog? If so, these projects may impact role modeling.  It is, therefore, essential to create a new Role Mining campaign based on new extractions."
		fr "En parallèle de votre campagne de Role Mining en cours, avez-vous connaissance de projets de réorganisation interne, de migrations applicatives ou de refonte du catalogue de droits ? Si oui, ces projets peuvent impacter votre modèle de rôles ; il est donc essentiel de concevoir une nouvelle campagne de Role Mining, basée sur de nouvelles extractions."
	]

	PRO012.title [
		en "What are the 3 most important data quality points to monitor for business role mining?"
		fr "Connaissez-vous les 3 points de qualité de données les plus importants à surveiller pour du role mining métier ?"
	]
	PRO012.description [
		en "The most important is reconciliation (having the fewest orphaned accounts). The second point is the association of each person with an organization or operational manager. Finally, the last point is the names of application profiles to ensure that business managers understand their meaning and the rights they grant within the applications."
		fr "Le plus important est la réconciliation (avoir le moins de comptes orphelins). Le second point est le rattachement de chaque personne à une organisation ou à un manager opérationnel. Enfin, le dernier point est la nomenclature des profils applicatifs pour s'assurer que les managers métier comprennent leur signification et les droits qu'ils octroient au sein des applications."
	]

	PRO013.title [
		en "Applicative role mining requires the uploading of all accounts (user and technical)."
		fr "Le role mining applicatif nécessite de charger tous les comptes (utilisateurs et techniques)."
	]
	PRO013.description [
		en "The completeness of the accounts is an important point for role mining. It is necessary to have technical and user accounts, for both employees and contractors."
		fr "La complétude des comptes est un point important pour le role mining. Il faut disposer à la fois des comptes techniques et des comptes d'utilisateurs, pour les internes comme pour les prestataires."
	]

	PRO014.title [
		en "Did you know that it is possible to work in the Role Mining Cloud service to process orphaned accounts?"
		fr "Saviez-vous qu'il est possible de travailler dans le service de role mining Cloud pour traiter les comptes orphelins ?"
	]
	PRO014.description [
		en "Whether it is business or application role mining, it is very important to take stock of orphaned accounts and to specify whether they are technical or user accounts. The Cloud role mining service allows the locating of orphaned accounts and marks them as technical accounts or attaches them to an owner."
		fr "Qu'il s'agisse de role mining métier ou applicatif, il est très important de faire le point sur les comptes orphelins, et préciser s'il s'agit de comptes techniques ou de comptes utilisateurs. Le service de role mining Cloud permet de trouver les comptes orphelins et de les marquer comme compte technique, ou de les rattacher à un propriétaire."
	]

	PRO015.title [
		en "Did you know that it is possible to work on improving the documentation of permissions in the Role Mining Cloud service?"
		fr "Saviez-vous qu'il est possible de travailler à l'amélioration de la documentation des permissions dans le service de role mining Cloud ?"
	]
	PRO015.description [
		en "Good documentation of permissions is an important point. If permissions are not properly documented, business managers will not be able to build roles that everyone can understand. Permissions can be documented within the Cloud role mining service at two different times: after creating the data cube or during the workshops."
		fr "Une bonne documentation des permissions est un point important. Si les permissions ne sont pas correctement documentées, les managers métiers ne vont pas être en capacité de construire des rôles compréhensibles de tous. Les permissions peuvent être documentées au sein du service de role mining Cloud a deux moments : après avoir créé le cube de données, ou lors des ateliers"
	]

	PRO016.title [
		en "Plan to verify the accuracy of the association of identities to organizations before the Role Mining workshops begin."
		fr "Prévoyez de vérifier l'exactitude des rattachements des identités aux organisations avant le début des ateliers de Role Mining."
	]
	PRO016.description [
		en "The Role Mining workshops will go more smoothly and accurately if the identity data and its link to organizations is validated beforehand. Do not hesitate to identify contacts who can consult the imported data and confirm its relevance."
		fr "Le déroulement des ateliers de Role Mining sera d'autant plus fluide que l'exactitude des données d'identité et leurs rattachements aux organisations auront été validées en amont. N'hésitez pas à identifier des interlocuteurs pouvant consulter les données que vous aurez importées, et vous confirmer leur pertinence."
	]

	PRO017.title [
		en "Start your Role Mining campaign with the organizations whose permissions are best managed."
		fr "Démarrez votre campagne de Role Mining avec les organisations dont les habilitations sont les mieux maîtrisées."
	]
	PRO017.description [
		en "The ownership of the process during the workshops, as well as the development of skills related to the role mining tool, can take a little time to master. It will be easier with a highly developed scope within the management of its accesses: clear naming of permissions, previously formalized and applied request processes, catalog of rights defined by the departments, for example, the finance or purchasing departments. Conversely, other areas such as IT teams and departments can have numerous rights and sensitive permissions on many systems. Within such a scope, the pivot table will not necessarily show big clusters. It is advisable to plan role mining on IT populations after dealing with mature organizations."
		fr "L'appropriation de la démarche lors des ateliers, ainsi que la montée en compétence sur l'outil de role mining peuvent prendre un peu de temps. Cette prise en main sera plus aisée sur un périmètre mature dans la gestion de ses accès : nommage des permissions clair, processus de demande déjà formalisés et appliqués, catalogue de droits défini par département… Les départements finance ou achats représentent de bons exemples. A l'inverse, d'autres périmètres comme les populations IT possèdent beaucoup de droits, dont des permissions sensibles, sur beaucoup de systèmes. Sur un tel périmètre, le tableau croisé ne fera pas forcément apparaître des clusters nets. Il est conseillé de planifier le Role mining sur les populations IT après avoir traité des organisations déjà matures."
	]

	PRO018.title [
		en "Adopt a business logic to choose which organizations to include in the scope of the role mining."
		fr "Adoptez une logique métier pour choisir les organisations à inclure dans le périmètre du rôle mining."
	]
	PRO018.description [
		en "The selection of organizations to be included in the analysis has two distinct aspects: width and depth. Width corresponds to the scope and extent of the business lines included (e.g. finance department, HR department, EMEA department, etc.). The depth criterion is the adaptation to the company context. For example, if the manager of a department is a member of the executive committee which is rarely available, it is preferable not to select this group and to divide the workshops into sub-organizations. The same thing is true if an organization is too large in terms of the number of identities. Conversely, if some organizations have too few identities, the analysis will not determine relevant roles; it is, therefore, preferable in this case to treat the parent organization as a whole."
		fr "La sélection des organisations à inclure dans l'analyse revêt deux aspects distincts : la largeur et la profondeur. La largeur correspond au périmètre, et à l'étendue des métiers englobés (ex : la direction financière, le département RH, la direction EMEA… ). Le critère de profondeur est l'adaptation au contexte de l'entreprise. Par exemple, si le manager d'un département est un membre du comité de direction, rarement disponible, il est préférable de ne pas sélectionner ce niveau, et de découper les ateliers au niveau des sous-organisations. De même si une organisation est trop importante en termes de nombre d'identités. A l'inverse, si certaines organisations ont trop peu d'identités, l'analyse ne permettra pas de déterminer des rôles pertinents ; il est préférable de traiter l'organisation parente dans son ensemble."
	]

	PRO019.title [
		en "Pay special attention to reconciliation keys between accounts and identities in the extraction files."
		fr "Portez une attention particulière lors des extractions aux clés de rapprochement entre les comptes et les identités."
	]
	PRO019.description [
		en "Application extraction files contain accounts. It is important to be able to find the owner of an account in the identities. The Role Mining Cloud service is based first on the HR number, then the email address and finally the full name in order to find an identity. The account will be considered orphaned if attempts to match it to an identity fail. Orphaned accounts are not visible in the Role Mining analysis, therefore, it is important to find their owners before starting the workshops."
		fr "Les fichiers d'extraction des applications contiennent des comptes. Il est important de pouvoir retrouver dans les identités le propriétaire du compte. Le service de Role Mining Cloud se base sur le matricule, puis sur l'adresse mail et enfin sur le nom complet pour retrouver une identité. Le compte sera considéré comme orphelin si les tentatives de rapprochement avec une identité échouent. Les comptes orphelins ne sont pas visibles dans l'analyse Role Mining donc il est important de trouver leur propriétaire avant de démarrer les ateliers."
	]

	PRO020.title [
		en "Be sure to process a reasonable number of identities at each workshop."
		fr "Assurez-vous de traiter un nombre d'identités raisonnable lors de chaque atelier."
	]
	PRO020.description [
		en "If the scope of a Role Mining workshop includes more than 150 people, it becomes more difficult for managers to know enough about the people to identify relevant roles. Within this context, it is a real challenge to complete a Role Mining workshop in a reasonable amount of time (2 hours or less) without having to re-involve these managers."
		fr "Si le périmètre d'un atelier de Role Mining inclut plus de 150 personnes, il devient plus difficile pour des managers de connaître suffisamment ces identités pour identifier des rôles pertinents. Dans un tel contexte, faire aboutir un atelier de Role Mining en un temps raisonnable (2h ou moins), sans solliciter à nouveau ces managers, est un véritable défi."
	]

	PRO021.title [
		en "Start your role mining campaign with global roles based on the specificity rate."
		fr "Démarrez votre campagne de role mining avec les rôles globaux, en vous appuyant sur le taux de spécificité."
	]
	PRO021.description [
		en "It is recommended to plan the first workshops with IT teams in order to determine cross-functional roles which are common to a large number of organizations.  This will subsequently streamline the workshops with the business managers."
		fr "Il est recommandé de planifier les premiers ateliers avec des personnes de l'IT afin de déterminer des rôles transverses communs à un grand nombre d'organisations, afin d'alléger par la suite les ateliers avec les responsables métier."
	]

	PRO022.title [
		en "Distinguish between global office roles and cross-functional business roles."
		fr "Distinguez rôles globaux bureautiques et rôles métiers transverses."
	]
	PRO022.description [
		en "Global roles typically involve common access such as user network directories, messaging, or vacation management applications. But it is interesting to also make transversal roles for business applications if certain application profiles are used in several organizations (e.g. for managers to access a reporting application, for the office managers of each entity to make purchases, etc.)."
		fr "Les rôles globaux concernent généralement les accès communs tels que les répertoires réseaux des utilisateurs, la messagerie ou l'application de gestion des congés. Mais il est intéressant de faire des rôles transverses aussi pour des applications métiers si certains profils applicatifs sont utilisés dans plusieurs organisations (ex : pour que les managers accèdent à une application de reporting, pour que les office managers de chaque entité effectuent des achats…)."
	]

	PRO023.title [
		en "Remind business managers of the scope of the project so that they can identify their team's activities prior to the workshop."
		fr "Rappelez aux responsables métier le périmètre du projet afin qu'il puissent réfléchir aux activités de l'équipe en amont de l'atelier."
	]
	PRO023.description [
		en "When communicating with the business managers, it is advisable to remind them of the workshops' objective and scope, and, in particular, what is excluded from the analysis.  This will prevent the manager from preparing information that would not be useful at the time of the workshop. For example, if the scope is only about payroll permissions, the manager can focus on identifying those who have such permissions while excluding other team members who do not."
		fr "Dans la communication avec les responsables métier, il est conseillé de leur rappeler l'objectif de l'atelier mais aussi le périmètre, et notamment ce qui est exclu de l'analyse, ce qui évite au responsable de préparer des informations qui ne seraient pas utiles au moment de l'atelier. Par exemple, si le périmètre ne concerne que les droits liés à la paie, le responsable peut se concentrer sur l'identification des personnes qui possèdent de telles habilitations et écarter les autres personnes de l'équipe."
	]

	PRO024.title [
		en "Save time in the workshops by preparing the roles in advance.  This can be done if the business manager provides a description of his team members' functions beforehand."
		fr "Gagnez du temps dans les ateliers en préparant à l'avance les rôles, si le responsable métier fournit en amont la description des activités des personnes de son équipe."
	]
	PRO024.description [
		en "In order to save time for the business manager, he should be requested to provide the functions and activities of his team prior to the workshop. Once this is completed, preparation can consist of creating roles corresponding to the name of the activity and pre-assigned to the people in the team. At the workshop, all that will remains is to list the permissions to be included in these roles."
		fr "Dans l'idée d'économiser le temps précieux du responsable métier, la communication en amont de l'atelier doit lui demander d'identifier les activités de ses équipes. Si l'information est fournie avant l'atelier, alors la préparation peut consister à créer des rôles correspondant au nom de l'activité et pré-attribués aux personnes de l'équipe. Lors de l'atelier, il ne reste plus qu'à lister les permissions à intégrer à ces rôles."
	]

	PRO025.title [
		en "Start the workshops by presenting the benefits for the company and for the stakeholders."
		fr "Démarrez les ateliers en présentant les bénéfices pour l'entreprise et pour les intervenants."
	]
	PRO025.description [
		en "To reassure the business or application manager of the value of the Role Mining workshops, it is important to begin by highlighting the objectives of the project and the workshops, the benefits for the company and for himself, the scope of the project and the method to be used."
		fr "Pour conforter le responsable métier ou applicatif sur l'intérêt des ateliers de Role Mining, il est important de commencer par rappeler les objectifs du projet, les bénéfices pour l'entreprise et pour lui-même, les objectifs de ces ateliers, le périmètre traité et la méthode employée."
	]

	PRO026.title [
		en "Perform the pivot table filtering before sorting the credentials."
		fr "Effectuez les filtrages du tableau croisé avant de lancer le tri des habilitations."
	]
	PRO026.description [
		en "Sorting the pivot table to show clusters can be misleading because it can create the notion that people with the same permissions have the same job functions and can share the same role. However, to ensure role sustainability, it is more important to base them on the fact that people have the same job functions instead of the fact that they have permissions in common. Begin by filtering people with the same job, then sort them to create roles that are understandable and maintainable per the job functions."
		fr "Le tri du tableau croisé pour faire apparaître des clusters peut être trompeur car il peut faire penser que les personnes ayant les mêmes permissions ont les mêmes activités et peuvent partager le même rôle. Or, pour garantir la pérennité des rôles, il est plus important de baser les rôles sur le fait que les personnes font la même activité plutôt que le fait qu'elles possèdent des permissions en commun seulement. Commencer par filtrer les personnes ayant le même métier, puis activer le tri permet de créer des rôles compréhensibles et maintenables par les métiers."
	]

	PRO027.title [
		en "Adopt a clear naming convention for the roles."
		fr "Adoptez une convention de nommage claire pour vos rôles."
	]
	PRO027.description [
		en "Concatenating the name of the organization and the activity with an important filter criterion (employee/contractors, etc.) is a good practice in naming new roles.  This helps to ensure that they will be quickly selected for future rights requests. Ex: DFIN_Accountant_Internal"
		fr "Concaténer le nom de l'organisation, de l'activité, et d'un critère important dans les filtres (interne/externe...) peut représenter une bonne pratique pour nommer vos nouveaux rôles, et vous assurer qu'ils seront rapidement sélectionnés lors des futures demandes de droits. Ex: DFIN_Comptable_Interne"
	]

	PRO028.title [
		en "Be vigilant with over-allocating when it comes to privileged permissions."
		fr "Soyez vigilants avec les sur-allocations, lorsqu'elles concernent des permissions à privilège."
	]
	PRO028.description [
		en "If the objective of role mining is to simplify the act of granting permissions, it may be tempting to create fairly broad roles, possibly including more permissions than necessary for members of the organization being studied. In this case, it is strongly recommended to check that over-allocated permissions are not privileged accesses."
		fr "Si l'objectif du Role mining est de simplifier le geste d'attribution des habilitations, il peut être tentant de créer des rôles assez larges, incluant éventuellement plus de permissions que ce qui est nécessaire pour les membres de l'organisation étudiée. Dans ce cas, il est fortement recommandé de vérifier que les permissions en sur-allocation ne sont pas des accès à privilèges."
	]

	PRO029.title [
		en "Beware of overly perfect clusters that appear in the pivot table after sorting is activated."
		fr "Méfiez-vous des clusters trop parfaits qui apparaissent dans le tableau croisé après l'activation du tri."
	]
	PRO029.description [
		en "After activating the sorting feature, a perfect rectangle may appear, suggesting that all users concerned have exactly the same rights. Clusters that are too perfect can be the result of cloned rights management. If everyone in the team has rights that were copied and pasted from another user, the entire group appears to have identical job functions.  However, in reality, they do not all do the same job. In this case, it is important to check with the business manager in order to verify whether or not the cluster does indeed correspond to a role or if it is hiding several roles with permissions that need to be differentiated."
		fr "Après activation du tri, un rectangle parfait peut apparaître, laissant croire que tous les utilisateurs concernés possèdent exactement les mêmes droits. Des clusters trop parfaits peuvent être le fruit d'une gestion des droits par clonage. En effet, si toutes les personnes de l'équipe ont des droits copiés/collés d'un autre utilisateur, l'ensemble paraît très homogène alors qu'en réalité les personnes n'ont peut-être pas les mêmes activités. Dans ce cas, il est important de vérifier avec le responsable métier si le cluster correspond bien à un rôle, ou s'il en cache plusieurs avec des permissions à différencier."
	]

	PRO030.title [
		en "Putting role modeling into production is not necessarily a Big Bang."
		fr "La mise en production d'un modèle de rôles n'est pas forcément un Big Bang."
	]
	PRO030.description [
		en "Role implementation is possible without disrupting existing access rights. Maintaining the access rights of existing users while, at the same time, applying roles to new requests and internal mobility limits the risk of deactivating existing authorizations."
		fr "Le déploiement des rôles est possible sans bouleverser les droits d'accès existants. Maintenir les droits d'accès des utilisateurs existants, tout en appliquant les rôles aux nouvelles demandes et aux mobilités internes, permet de limiter le risque de déprovisioning des habilitations existantes."
	]

	PRO031.title [
		en "Plan to periodically solicit role owners to keep the model in line with the business activity."
		fr "Prévoyez de solliciter périodiquement les propriétaires de rôles pour maintenir le modèle en phase avec l'activité opérationnelle des métiers."
	]
	PRO031.description [
		en "A regular review of the roles is necessary to realign them with the business activity. For entities that restructure frequently or whose missions change, it may be necessary to assist role owners."
		fr "Une revue régulière des rôles est nécessaire pour les réaligner avec l'activité des métiers. Pour des entités qui se restructurent fréquemment ou dont les missions évoluent, il peut être nécessaire d'accompagner les propriétaires de rôles."
	]

	PRO032.title [
		en "What are the elements to be mentioned to the customer during the final meeting?"
		fr "Quels sont les éléments à mentionner au client lors de la restitution finale ?"
	]
	PRO032.description [
		en "The project debriefing is an important moment to look back at all the completed work, the difficulties encountered, the results achieved and to imagine the role implementation as well as the expansion to possible new scopes. By clicking on the detail button, a page recalling the topics to be discussed during this meeting will be accessed."
		fr "La restitution de fin de mission est un moment important pour revenir sur le travail effectué, les difficultés rencontrées, les résultats et pour se projeter sur la mise en place des rôles et l'extension à d'éventuels nouveaux périmètres. En cliquant sur le bouton de détail, vous accéderez à une page rappelant les thèmes à aborder lors de cette réunion."
	]
}

