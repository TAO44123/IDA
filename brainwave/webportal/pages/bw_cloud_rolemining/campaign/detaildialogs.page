bwcdrm_orgsNoMgrDetailDialog = Dialog {

		title: $bwcdrm_validatedatacubeNLS.details.org.title 
		width: 500
		height: 330 
		buttons: ActionButton { text: $bwcdrm_wizardsNLS.button.close actions:  CloseDialog Cancel}
     
     in_timeslotUID = Variable
     in_orgs = Variable { multivalued: True }
     
     selectedOrgUID= Variable { private: True}
     
		details_orgsnomgr = Dataset {
			view: bwcdrm_allorgs_nomanager with in_orgs to uids
			timeslot: in_timeslotUID
		}
     
		doOrgDetails = NamedAction (
			Dialog bwf_organisationDetailsDialog ( selectedOrgUID to inuid, True to inshowteam, True to incanupdatemanagers )
			, CloseDialog Cancel
		) 
     
		Table {
			data: details_orgsnomgr
			show-filter: True
			show-count: True
			layout: Layout { grab: horizontal True vertical True }
			Column { column: org_uid hidden: True selection: selectedOrgUID }
			Column { column: org_displayname 
				width: 100% 
				actions: ExecuteNamedAction doOrgDetails 
				sortable: True
				header:  $bwcdrm_validatedatacubeNLS.details.orgs.columns.displayname}
			Column { column: org_shortname
				width: 50% 
				actions: ExecuteNamedAction doOrgDetails 
				sortable: True
				header:  $bwcdrm_validatedatacubeNLS.details.orgs.columns.shortname}

			Column { column: org_bwa_organisationanalytics_nbdirectmembers 
				width: 120px align: Right 
				sortable: True
				header: $bwcdrm_validatedatacubeNLS.details.orgs.columns.nbidentity}
		}
}

bwcdrm_orphanAccountsDetailDialog = Dialog {

     title: $bwcdrm_validatedatacubeNLS.details.recon.title 
     width: 600
     height: 330 
     buttons: ActionButton { text: $bwcdrm_wizardsNLS.button.close actions:  CloseDialog Cancel}
     
     in_timeslotUID = Variable
     in_permRules = Variable { multivalued: True}
     
     selectedRepoUID= Variable { private: True}
     
     repos_with_orphan = Dataset {
       view: bwcdrm_repo_with_orphan with in_permRules to permRules unless-empty
       timeslot: in_timeslotUID 
     }
     
     doRepoDetails = NamedAction (
		Dialog bwf_repositoryDetailsDialog ( selectedRepoUID to inuid, True to inshowaccounts, True to inshowgroups , True to incanreconcile)
		, CloseDialog Cancel
	  )
	  
	  doRepoReconDetails = NamedAction (
		GoTo Page access360r_repository_reconciliation with selectedRepoUID to uid save-state
		, CloseDialog Cancel		
	   )
     
		Table {
			data: repos_with_orphan
			layout: Layout { grab: horizontal True vertical True }
			show-count: True
			
			Column { column: repo_code 
			   width: 100% 
			   actions: ExecuteNamedAction doRepoDetails 
			   sortable: True
			   header: $repository.concept}
			Column { column: repo_bwa_repositoryanalytics_nbaccount 
				width: 130px align: Right 
			   sortable: True
				header: $bwcdrm_validatedatacubeNLS.details.recon.columns.nbaccounts}
			Column { column: nb_orphan 
				width: 80px align: Right 
				sortable:True
			   header: $bwcdrm_validatedatacubeNLS.details.recon.columns.nborphan } 
			Column { column: repo_uid width: 220px align: Center 
			    header: "" text: $bwcdrm_validatedatacubeNLS.details.recon.link.recondetails 
			    actions: ExecuteNamedAction doRepoReconDetails selection: selectedRepoUID }
		}
}