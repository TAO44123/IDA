/* detail dialogs */

bwcdrm_identitiesExtDialog = Dialog {

     title: $bwcdrm_validatedatacubeNLS.details.identities_ext.title
     width: 650
     height: 350 
		buttons: ActionButton { text: $bwcdrm_wizardsNLS.button.close actions:  CloseDialog Cancel}
     
     in_timeslotUID = Variable
     in_orgs = Variable { multivalued: True }
     
     selectedOrg= Variable { private: True}
     
		details_identitiesextbyorg = Dataset {
			view: bwcdrm_cube_identities_ext_byorg with in_orgs to orgUids
			timeslot: in_timeslotUID
		}
     
		goDetails = NamedAction (
			GoTo Activity Organisation Detail with selectedOrg to paramOrganisationUid save-state
			, CloseDialog Cancel
		) 
     
		Table {
			data: details_identitiesextbyorg
			show-filter: True
			show-count: True
			initial-sort: displayname
			layout: Layout { grab: horizontal True vertical True }
			Column { column: uid hidden: True selection: selectedOrg }
			Column {
				column: displayname
				sortable:True
				filterable:True
				header:$organisation.concept
				width:100%
				actions: ExecuteNamedAction goDetails
			}
			Column {
				column: shortname
				sortable:True
				filterable:True
				header: $organisation.shortname
				width:100px
			}
			Column {
				column: nb_members
				sortable:True
				header: $bwcdrm_validatedatacubeNLS.details.identities_ext.column.members  
				width:100px align: Right
			}
			Column {
				column:nb_members_ext
				sortable:True
				header: $bwcdrm_validatedatacubeNLS.details.identities_ext.column.members_ext
				width:100px align: Right
			}
			Column {
				column:ext_rate
				//sortable:True  sort not working on computed columns 
				text: Concat ( Current ext_rate, "%")
				header:$bwcdrm_validatedatacubeNLS.details.identities_ext.column.ext_rate
				width:100px align: Right
			}
		}
}
 
bwcdrm_identitiesNoOrgDetailDialog = Dialog {

     title: $bwcdrm_validatedatacubeNLS.details.identities_noorg.title
     width: 700
     height: 400 
		buttons: ActionButton { text: $bwcdrm_wizardsNLS.button.close actions:  CloseDialog Cancel}
     
     in_timeslotUID = Variable
     
     selectedIdentity= Variable { private: True}
     
		details_identitiesNoOrg = Dataset {
			view: bwcdrm_allidentities_noorg
			timeslot: in_timeslotUID
		}
     
		doIdentityDetails = NamedAction (
			GoTo Activity Identity Detail with selectedIdentity to paramIdentityUid save-state
			, CloseDialog Cancel
		) 
     
		Table {
			data: details_identitiesNoOrg
			show-filter: True
			show-count: True
			initial-sort: fullname
			layout: Layout { grab: horizontal True vertical True }
			Column { column: uid hidden: True selection: selectedIdentity }
			Column {
				column:fullname
				sortable:True
				filterable:True
				header:$identity.fullname
				width:160px
				actions: ExecuteNamedAction doIdentityDetails
			}
			Column {
				column:internal
				text:Transform Current internal using booleanDisplayMapping
				sortable:True
				filterable:True
				header:$identity.internal
				width:96px
			}
			Column { 
			   column: employeetypecode 
			   sortable:True 
			   header:  $businessowner.employeetypedisplayname} 
			Column {
				column:arrivaldate
				sortable:True
				filterable:True
				header:$identity.arrivaldate
				width:132px
			}
			Column {
				column:departuredate
				sortable:True
				filterable:True
				header:$identity.departuredate
				width:132px
			}
		}
}

