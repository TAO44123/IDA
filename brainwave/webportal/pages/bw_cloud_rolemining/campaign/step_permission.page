/* Import other pages here */
import "/webportal/pages/bw_cloud_base/resources/styles.page"
import "/webportal/pages/bw_cloud_rolemining/resources/nls/campaign_nls.page"
import "/webportal/pages/bw_cloud_rolemining/resources/nls/stagechecks.page"
import "/webportal/pages/bw_cloud_base/resources/nls/general.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"

import "/webportal/pages/bw_rm/campaign/campaign_start.page"

bwcdrm_scope_permission = PageFragment {

   enter-event: ExecuteNamedAction doInit
    
   currentStep = Variable   
   scopePermRule = Variable
   scopePermRuleEditCounter = Variable 
	
	selectedRule = Variable 
	nbPermissions = Variable { type: Integer}
	
	selectedSinglePermUID = Variable
	selectedSingleAppUID = Variable
	
	ruleResults = Dataset {
      view: bwrm_permissions_inrules with selectedRule to permRules
      count-variable: nbPermissions
    }
    
   doPermissionDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog ( selectedSinglePermUID to inuid, True to inshowperjob, True to inshowperorg )
	)
	
	doApplicationDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog ( selectedSingleAppUID to inuid, True to inshowperjob, True to inshowperorg )
	)
	
	doInit = NamedAction (
	  Set scopePermRule to selectedRule 
	)
	
	doPrevious = NamedAction (
	    Set "organisations" to currentStep
	)
	
	doNext = NamedAction (
	  Set selectedRule to scopePermRule,
	  Set Sum( scopePermRuleEditCounter, 1) to scopePermRuleEditCounter,
	  Set "review" to currentStep
	)
		
	Group {
		margins: Right 20 Left 20
		
		Header {
			value: $bwcdrm_scopeNLS.permission.title
		}
		
		RuleSelector {
			entity: Permission
			selection: selectedRule
			edit-event: ReloadData ( ruleResults)									
			editable: True
			tag-family: "RoleMining"
			label: $bwcdrm_scopeNLS.permission.label.criteria
			layout: Layout { grab: horizontal False vertical True hint: width 500 }
	    }
	    
		Table {
			data: ruleResults
			label: Label { value: $bwcdrm_scopeNLS.permission.label.result break: True}
			show-count: True
			layout: Layout { grab: horizontal True vertical True }
			Column{
				column: displayname
				header: $bw_rm_startNLS.permHeader
				width: 100%
				actions: ExecuteNamedAction doPermissionDetails
			}
			Column{
				column: app_displayname
				header: $bw_rm_startNLS.appHeader
				width: 60%
				actions: ExecuteNamedAction doApplicationDetails
			}	
			Column { column: uid hidden: True selection: selectedSinglePermUID }
			Column { column: app_uid hidden: True selection: selectedSingleAppUID }		  
		} 
	}
	
	ButtonGroup {
		mixins: wizardButtonBarMixin
		Button {
			text: $bwcdrm_wizardsNLS.button.back
			mixins: secondaryButtonMixin
			actions: ExecuteNamedAction doPrevious
		}
		Button {
			text: $bwcdrm_wizardsNLS.button.next
			disabled: Eval " selectedRule.length == 0 "
			actions: ExecuteNamedAction doNext
		}
	}
			
}
