bwrm_campaign_config_wizard = Page {
	title: $bwrm_campaign_config_NLS.title
	enter-event: ExecuteNamedAction doInit 
	tags:"campaign"
	feature:All( bw_rm_startingpage, rolemining_license, Any(governance_license, compliance_license)) 

	/* Parameters here */
	campaignId = Parameter {
		type: String
		mandatory: False
		hidden: True
	}
	
	/* variables here */
	// campaign infos
	campaignCode = Variable
	campaignTitle = Variable
	campaignDescription = Variable
	campaignFrequency = Variable
	campaignDuration = Variable
	campaignStartingDate = Variable
	campaignOwneruid = Variable
	campaignOwnerfullname = Variable
	campaignPrioritylevel = Variable
	
	campaignType = Variable {initial:"rights"}
	campaignStatus = Variable
	
	scopeOrganisations = Variable { multivalued: True}	
	scopePermRule = Variable
	scopePermRuleEditCounter = Variable { type: Integer initial: 0}
	
	// state variables 
	currentStep = Variable { initial: "info" }

	/* Datasets and records here */
	task = TaskRecord (campaignId or create "bw_rm_master")
	campaign = Record(br_campaign with campaignId to recorduid)
	
		//stepper
	steps = Dataset {
		values: [
			( id -> "info", label -> $bwrm_campaign_config_NLS.step.campaign.short, desc -> "" ), 
			( id -> "organisations", label -> $bwrm_campaign_config_NLS.step.organisations.short, desc -> ""  ),
			( id -> "permissions", label -> $bwrm_campaign_config_NLS.step.permissions.short, desc -> ""),
			( id -> "review", label -> $bwrm_campaign_config_NLS.step.review , desc -> "" )
		]
	}
		
	identityInfo = Record {
		view: br_identityDetail with campaignOwneruid to uid
	}
	
	doInit = NamedAction (
		Set campaign.code to campaignCode, 
		Set campaign.title to campaignTitle, 
		Set campaign.description to campaignDescription,
		Set campaign.frequency to campaignFrequency, 
		Set campaign.duration to campaignDuration,
		Set campaign.owneruid to campaignOwneruid, 
		Set campaign.ownerfullname to campaignOwnerfullname,
		StringCase(campaignOwneruid) {
			when IsEmpty then [Set Principal.uid to campaignOwneruid,Set identityInfo.fullname to campaignOwnerfullname] 	    
		},
		StringCase(campaignId) {
			when IsEmpty then [
			] otherwise [
				Set task.uid to scopeOrganisations,
				Set task.perm_rulenames to scopePermRule
			]
		}
	)
	
	doFinish = NamedAction (
		Confirm $bwrm_campaign_config_NLS.saveconfirm,
		Set campaignPrioritylevel to task.prioritylevel,
		Set campaignCode to task.campaignid,
		Set campaignDuration to task.duration,
		Set scopePermRule to task.perm_rulenames,
		Set scopeOrganisations to task.uid,		
		
		CampaignSave task {
			code: campaignCode
			title:campaignTitle
			description: campaignDescription
			type: campaignType
			status-variable: campaignStatus
			owner:campaignOwneruid
			frequency: campaignFrequency
			duration:campaignDuration
			start-date:DateLDAP(campaignStartingDate)
			when-complete:
				Flash Information $bwrm_campaign_config_NLS.saveflash,
				GoTo Page br_campaignManager
			when-failed:
				Flash Error Concat( $bw_rm_startwNLS.error, campaignStatus )
		}
	)

	Splitter {
		disposition: Horizontal
		size: 60%
			Group {
				IncludeHTMLWidget {
					layout: Layout { grab: horizontal True vertical False }
					template: bw_stepper
					datasets: steps( id, label, desc ) to stepsdata (id, label, description)
					bindings:
						value-of "horizontal" to orientation,
						value-of False to showState,
						value-of currentStep to currentStep
					widget-events:
					{ 
						when onlabelclick then [
							Set Current id to currentStep
						]
					}
				}
				ConditionalGroup {
					layout: Layout { grab: horizontal True vertical True }
					StringCondition (currentStep){	
						when "info" then [
							IncludeFragment ( bw_rm_campaigninfo with
								currentStep binds-to io_currentStep,
								campaignCode binds-to campaignCode,
								campaignTitle binds-to campaignTitle,
								campaignDescription binds-to campaignDescription,
								campaignFrequency binds-to campaignFrequency,
								campaignDuration binds-to campaignDuration,
								campaignStartingDate binds-to campaignStartingDate,
								campaignOwneruid binds-to campaignOwneruid,
								campaignOwnerfullname binds-to campaignOwnerfullname,
								campaignPrioritylevel binds-to campaignPrioritylevel
							)
						]	 
						when "organisations" then [
							IncludeFragment ( bwcdrm_scope_organisation with 
								currentStep binds-to currentStep,
								scopeOrganisations binds-to scopeOrganisations
							)
						]
						when "permissions" then [
							IncludeFragment ( bwcdrm_scope_permission with 
								currentStep binds-to currentStep,
								scopePermRule binds-to scopePermRule,
								scopePermRuleEditCounter binds-to scopePermRuleEditCounter
							)
						]
						when "review" then [ 
							IncludeFragment {
								fragment: bwcdrm_scope_review with
									currentStep binds-to io_currentStep,
									scopeOrganisations binds-to in_scopeOrganisations,
									scopePermRule binds-to in_scopePermRule,
									scopePermRuleEditCounter binds-to in_scopePermRuleEditCounter
								fragment-events: {
									when "finish" then [
										ExecuteNamedAction doFinish
									]
								}
							}
						]
						otherwise [ ]
					}
				}
			}
		Group {
			IncludeFragment ( bw_rm_campaign_help with currentStep binds-to step )
		}
	}
}