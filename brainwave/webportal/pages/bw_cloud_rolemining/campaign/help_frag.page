import "/webportal/pages/bw_cloud_base/resources/styles.page"
import "/webportal/pages/bw_cloud_base/resources/nls/general.page"
import "/webportal/pages/bw_cloud_base/resources/nls/dashboard.page"

// Role mining campaign configuration help / GUIDE(s)
bw_rm_campaign_help = PageFragment {

	step = Variable { type: String }
	
	language = Variable { type: String initial: $bwcdrm_mylang.currentnls }

	Group {
		mixins: helpPageMixin
		Header { value: $bwcdrm_stagedashboardNLS.dashboard.guide }
		// conditional group pour mettre l'aide qui va bien en fonction du state 
		ConditionalGroup {
			layout: Layout { grab: horizontal True vertical True }
			StringCondition (step) {
				when "organisations" then [
					ConditionalGroup {
						StringCondition(language) {
							when "fr" then [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_org_fr.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							] otherwise [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_org_en.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							]
						}
					}
				]
				when "permissions" then [
					ConditionalGroup {
						StringCondition(language) {
							when "fr" then [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_perm_fr.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							] otherwise [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_perm_en.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							]
						}
					}
				]
				when "review" then [
					ConditionalGroup {
						StringCondition(language) {
							when "fr" then [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_review_fr.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							] otherwise [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_scope_review_en.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							]
						}
					}
				]
				when "info" then [
					ConditionalGroup {
						StringCondition(language) {
							when "fr" then [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_info_fr.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							] otherwise [
								Browser {
									static: "static/bw_cloud_rolemining/guides/guide_info_en.html"
									layout: Layout { grab: horizontal True vertical True }
								}
							]
						}
					}
				]
				otherwise [
				]
		 	}
		}
	}
}