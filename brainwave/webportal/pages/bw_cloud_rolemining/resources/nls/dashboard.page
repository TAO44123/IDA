bwcdrm_confirm_modify_cfg_NLS = NLS {

   button [
     en "Modify Configuration"
     fr "Modifier la configuration"
   ]
   title [
      en "Confirm Modify Configuration"
      fr "Confirmer la modification de la configuration"
   ]

  	message [
		en "This operation will delete the datacube and reset any progress counters in the role mining analysis.
However, you will not lose any file or association nor already built roles.
You will be able to modify file and application configuration then recreate the data cube.

 Click OK to modify the configuration ? "
		fr "Cette opération va détruire le cube de données et réinitialiser les compteurs de progression dans le role mining.
Cependant vous ne perdez ni vos fichiers et associations ni les rôles déjà construits.
Vous pourrez modifier la configuration des fichiers et des applications puis reconstruire le cube de données.

Cliquez OK pour modifier la configuration ?"
	]
}
