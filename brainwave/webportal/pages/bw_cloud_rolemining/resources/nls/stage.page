	adextract.step [
		en "Active Directory"
		fr "Active Directory"
	]
	adextract.step_desc [
		en "Access to Active Directory Retrieval Resources"
		fr "Accès aux ressources d'extraction d'Active Directory"
	]
	adextract.title [
		en "Active Directory Extraction Resources"
		fr "Ressources d'extraction d'Active Directory"
	]
	adextract.p1 [
		en "Connectors usually provide a script to run on the target system in order to extract security data (accounts-rights-permissions). In the absence of a script, a procedure is provided that explains how to extract the information from the application."
		fr "Les connecteurs fournissent généralement un script à exécuter sur le système cible pour extraire les données de sécurité (comptes-droits-permissions). En l'absence de script, une procédure est fournie expliquant comment extraire les informations de l'application."
	]
	adextract.p2 [
		en "The list below shows the files available for the Active Directory connector."
		fr "La liste ci-dessous vous indique les fichiers disponibles pour le connecteur Active Directory."
	]
	adextract.p3 [
		en "Please download them now."
		fr "Veuillez les télécharger maintenant"
	]
	adextract.p4 [
		en "To clarify, these scripts do not have to be run right now. Proceed to the next step without the Active Directory extraction files."
		fr "Ne vous inquiétez pas, vous n'avez pas à exécuter ces scripts pour l'instant. Vous pouvez passer à l'étape suivante sans les fichiers d'extraction Active Directory."
	]
	adextract.p5 [
		en "Later, when the extraction files are available, they will need to be uploaded to the OneDrive folder. Be sure to create one folder per application so that data files from different applications do not get mixed up. In the case of Active Directory, we suggest that a folder called AD be created."
		fr "Plus tard, lorsque vous aurez obtenu les fichiers d'extraction, vous devrez les télécharger dans le dossier OneDrive. Veillez à créer un dossier par application afin de ne pas mélanger les fichiers de données de différentes applications. Dans le cas d'Active Directory, nous vous suggérons de créer un dossier appelé AD."
	]

	adextract.ps1.filename [
		en "ExtractAD.ps1"
		fr "ExtractAD.ps1"
	]
	adextract.ps1.description [
		en "PowerShell extraction script for Active Directory to be executed, preferably on the domain controller."
		fr "Script d'extraction PowerShell pour Active Directory à exécuter de préférence sur le contrôleur de domaine."
	]

	adextract.docpdf.filename [
