	  fr "Démarrer l'analyse de Role Mining"
	]
	
	msg.start_confirm  [
		en "Do you really want to start role mining analysis ? "
		fr "Voulez-vous vraiment démarrer l'analyse de role mining ? "
	]
	
	msg.start_confirm_with_risk  [
		en "There are still {0} alerts identified that you have already confirmed or that are to be reviewed.\n For more details click on the button ALERTS on upper right of the page.\n\n Do you really want to start the role mining analysis without reviewing the alerts?"
		fr "Il existe encore {0} alertes identifiées que vous avez confirmées ou que vous n''avez pas encore évaluées.\n Pour les consulter, cliquez sur le bouton ALERTES en haut à droite de la page.\n\n Voulez-vous vraiment démarrer l''analyse de role mining sans consulter les alertes ? "
