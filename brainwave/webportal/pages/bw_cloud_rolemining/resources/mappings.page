import "/webportal/pages/bw_cloud_base/resources/nls/general.page"
import "/webportal/pages/bw_cloud_base/resources/icons.page"

bwcdrm_clouduploadsimplestatusmapper = StringMapping {
	when "P"  then $bwcdrm_simpleuploadfilestatusNLS.pending
	when "E"  then $bwcdrm_simpleuploadfilestatusNLS.pending
	when "T"  then $bwcdrm_simpleuploadfilestatusNLS.pending
	when "S"  then $bwcdrm_simpleuploadfilestatusNLS.pending
	when "C"  then $bwcdrm_simpleuploadfilestatusNLS.fetched
	when "U"  then $bwcdrm_simpleuploadfilestatusNLS.error
	when "V"  then $bwcdrm_simpleuploadfilestatusNLS.error
	when "W"  then $bwcdrm_simpleuploadfilestatusNLS.error
	when "Valid" then $bwcdrm_simpleuploadfilestatusNLS.valid
	when "Invalid" then $bwcdrm_simpleuploadfilestatusNLS.invalid
	otherwise current
	
}

bwcdrm_clouduploaddetailedtatusmapper = StringMapping {
	when "P"  then $bwcdrm_detaileduploadfilestatusNLS.declared
	when "E"  then $bwcdrm_detaileduploadfilestatusNLS.downloading
	when "T"  then $bwcdrm_detaileduploadfilestatusNLS.downloaded
	when "S"  then $bwcdrm_detaileduploadfilestatusNLS.uploading
	when "C"  then $bwcdrm_detaileduploadfilestatusNLS.uploaded
	when "U"  then $bwcdrm_detaileduploadfilestatusNLS.downloaderror
	when "V"  then $bwcdrm_detaileduploadfilestatusNLS.uploaderrorv
	when "W"  then $bwcdrm_detaileduploadfilestatusNLS.uploaderrorw
	
}

bwcdrm_cloudapplicationtypemapper = StringMapping {
	when "A" then "Add-on"
}


bwcdrm_cloudapplicationfilestatus_showmore = StringImageTemplate {
	when IsEmpty then ""
	otherwise %others_16_blue.clickformore
}