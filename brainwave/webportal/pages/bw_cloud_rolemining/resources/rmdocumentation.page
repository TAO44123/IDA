/* Import other pages here */
import "/webportal/pages/bw_portaluar_base/admin/documentation.page"

/* Nationalized labels here */

bwcrm_documentation_enduser_guideNLS = NLS {
	title [en "Role Mining Services End-User Guide" fr "Guide utilisateur de Role Mining Services (Anglais)" ]
	url [ 
		fr "static/static/bw_cloud_rolemining/generated_doc/enduser_guide_en.html" 
		en "static/static/bw_cloud_rolemining/generated_doc/enduser_guide_en.html"
	]
}
bwcrm_documentation_enduser_guide = Page {
	title: $bwcrm_documentation_enduser_guideNLS.title
	
	IncludeHTMLWidget {
		template: BrainwaveDocDisplayWidget
		layout: Layout { grab: horizontal True vertical True }
		bindings:
			value-of $bwcrm_documentation_enduser_guideNLS.title to title,
			value-of $bwcrm_documentation_enduser_guideNLS.url to url
	}
}

bwcrm_documentation_enduser_preparation_guideNLS = NLS {
	title [en "Role Mining Services End-User Guide" fr "Guide utilisateur de Role Mining Services (Anglais)" ]
	url [ 
		fr "static/static/bw_cloud_rolemining/generated_doc/enduser_guide_en.html#préparation-des-données-du-role-mining"
		en "static/static/bw_cloud_rolemining/generated_doc/enduser_guide_en.html#préparation-des-données-du-role-mining" 
	]
}
bwcrm_documentation_enduser_preparation_guide = Page {
	title: $bwcrm_documentation_enduser_preparation_guideNLS.title
	
	IncludeHTMLWidget {
		template: BrainwaveDocDisplayWidget
		layout: Layout { grab: horizontal True vertical True }
		bindings:
			value-of $bwcrm_documentation_enduser_preparation_guideNLS.title to title,
			value-of $bwcrm_documentation_enduser_preparation_guideNLS.url to url
	}
}