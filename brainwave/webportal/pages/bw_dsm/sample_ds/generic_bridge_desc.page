
ds_generic_bridge_file_NLS = NLS {
  title [ en "Generic bridge - file" fr "Passerelle générique - fichier"]
  description [ 
    en "Copies all files to a given location so that it can be processed by a custom collector."
    fr "Copie les fichiers fournis dans le dossier indiqué pour qu'ils soient pris en charge par une collecte personnalisée."]
}


ds_generic_bridge_file = Page {
	title: $ds_generic_bridge_file_NLS.title
	tags: "bwds_connector" , "file" , "custom"
	description: $ds_generic_bridge_file_NLS.description
	icon: "bw_dsm/L/bw_genericapp.png"
	large-icon: "bw_dsm/XL/bw_genericapp.png"	
	 metadata: ( 	  
	    category -> "infrastructure", 
	    family -> "Custom",
	    hasMapping -> False,
	    multiFile -> True,
	    hasDestDir -> True
	 )
}

