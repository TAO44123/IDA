/* adds a new datasource and returns recordid */
bwdsm_createDsCfg = IntService {
   javascript-file: "/webportal/pages/bw_dsm/services/services.javascript"
   javascript-method: createDsCfgRest 
   type = Input{ mandatory: True }
   category = Input{ mandatory: True }
   name=Input {mandatory: True}
   description = Input
   enabled = Input { type: Boolean default: True }
   config = Input {mandatory: True}
   scheduling = Input {mandatory: True default: ""
  }     
}

