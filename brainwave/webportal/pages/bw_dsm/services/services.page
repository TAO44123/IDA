bwdsm_listBatches = DatasetService {
 	javascript-file: "/webportal/pages/bw_dsm/services/services.javascript"
   javascript-method: listBatches
    id = Column { type: Integer}
    principal_name = Column 
    status = Column
    submit_date = Column { type: Date }
    start_date = Column { type: Date}
    completed_date = Column { type: Date}
    error_message = Column 
}

bwdsm_getCurrentBatch = DatasetService {
 	javascript-file: "/webportal/pages/bw_dsm/services/services.javascript"
   javascript-method: getCurrentBatch
    id = Column { type: Integer}
    principal_name = Column 
    status = Column
    submit_date = Column { type: Date }
    error_message = Column    
}

bwdsm_getLastCompletedBatch = DatasetService {
 	javascript-file: "/webportal/pages/bw_dsm/services/services.javascript"
   javascript-method: getLastCompletedBatch
    id = Column { type: Integer}
    principal_name = Column 
    status = Column
    submit_date = Column { type: Date } //ISO 8601 format eg. 2022-09-19T21:55:08.533494Z
    start_date = Column { type: Date } //ISO format 
    completed_date = Column { type: Date } //ISO format 
    error_message = Column    
}

bwdsm_startBatch = EventService {
   javascript-file: "/webportal/pages/bw_dsm/services/services.javascript"
