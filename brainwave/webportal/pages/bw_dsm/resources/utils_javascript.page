stringSplit = EventService {
   javascript-file: "/webportal/pages/bw_dsm/resources/dsm_utils.javascript"
   javascript-method: strSplit
   str = Input { mandatory: True}
   separator = Input 
   parts = Output { multivalued: True}
}

durationString = StringService {
   javascript-file: "/webportal/pages/bw_dsm/resources/dsm_utils.javascript"
   javascript-method: durationString
   ^from = Input { mandatory: True} //LDAP format
   ^to = Input //LDAP Format
    lang = Input { default: $dsm_generalNLS.lang} 
}

durationStringShort = StringService {
   javascript-file: "/webportal/pages/bw_dsm/resources/dsm_utils.javascript"
