/* Batch  */

dsm_batch_status_NLS = NLS {
  submitted [ en "Pending..." fr "En attente..." ]
  started [ en "Running" fr "En cours..." ]
  done [ en "Completed" fr "Terminé"]
  error [ en "Completed in error" fr "Terminé en erreur"]
  aborted [ en "Aborted" fr "Interrompu" ]
}

batch_status_label = StringMapping {
  when "S" then $dsm_batch_status_NLS.submitted
  when "R" then $dsm_batch_status_NLS.started
  when "C" then $dsm_batch_status_NLS.done
  when "E" then $dsm_batch_status_NLS.error
  when "A" then $dsm_batch_status_NLS.aborted
  otherwise current
}

