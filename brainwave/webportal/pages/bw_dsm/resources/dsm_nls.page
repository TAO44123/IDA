//to include:  import "/webportal/pages/bw_dsm/resources/dsm_nls.page"

dsm_generalNLS = NLS {
  lang [en "en" fr "fr"]
}

dsm_categoriesNLS = NLS {
   ^all [ en "All" fr "Tout"]
   identity [ en "Identities" fr "Identités"]
   application [ en "Applications" fr "Applications"]
   infrastructure [ en "Infrastructure" fr "Infrastructure"]
   cloud [ en "Digital Workplace" fr "Digital Workplace"]
}

dsm_categoryMapping = StringMapping {
  when "identity" then $dsm_categoriesNLS.identity
  when "application" then $dsm_categoriesNLS.application
  when "infrastructure" then $dsm_categoriesNLS.infrastructure
  when "cloud" then $dsm_categoriesNLS.cloud
  otherwise "?"
}

dsm_toggleEnabledMapping = BooleanMapping {
	when True then $dsm_cfg_NLS.main.button_disable
	when False then $dsm_cfg_NLS.main.button_enable
}

