/* CFG */
import "/webportal/pages/bw_fragments/lib/colors.page"

dsm_cats_icons_S = ImageMap {
  cat_cloud [ "bw_dsm/cats/noun-cloud-5065376.svg" width: 20px color: blueNG ]
  cat_infra [ "bw_dsm/cats/noun-server-5224459.svg" width: 20px color: blueNG ]
  cat_identity [ "bw_dsm/cats/noun-people-5125546.svg" width: 20px color: blueNG] 
  cat_appli [ "bw_dsm/cats/noun-applications-3009750.svg" width: 20px color: blueNG] 
}

dsm_batch_status_L = ImageMap {
  submitted [ "bw_dsm/batch/noun-time-5196244.svg" width: 64px color: grayNG  ]
  running [ "bw_dsm/batch/running.svg" width: 64px  ]
  done [ "bw_dsm/batch/noun-done-808419.svg" width: 64px color: greenNG]
  error [ "bw_dsm/batch/noun-error-1073623.svg" width: 64px color: redNG ] 
}

dsm_ds_cat_IconMapping = StringImageTemplate {
  when "application" then %dsm_cats_icons_S.cat_appli
  when "infrastructure" then %dsm_cats_icons_S.cat_infra
  when "cloud" then %dsm_cats_icons_S.cat_cloud
  when "identity" then %dsm_cats_icons_S.cat_identity
}

dsm_batch_status_IconMapping = StringImageTemplate {
  when "S" then %dsm_batch_status_L.submitted
  when "R" then %dsm_batch_status_L.running
  when "C" then %dsm_batch_status_L.done
  when "E" then %dsm_batch_status_L.error
}