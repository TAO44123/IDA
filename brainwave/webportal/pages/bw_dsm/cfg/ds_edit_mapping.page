import "/webportal/pages/bw_dsm/resources/styles.page"
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/bw_fragments/lib/icons.page"
import "/webportal/pages/bw_dsm/cfg/ds_test.page"
import "/webportal/pages/bw_dsm/resources/utils_javascript.page"
 
dsm_edit_mapping = Page {
   title: $bw_entitydatamanagementNLS.title
	dynamic-title: $bw_entitydatamanagementNLS.dynamictitle(pcode)
	description:$bw_entitydatamanagementNLS.description
	icon:%report_32.csv
	large-icon:%report_48.csv

    enter-event: ExecuteNamedAction doInit

   //events
   // changed :  mapping has changed 
    pcode = Parameter  { type: String hidden: True mandatory: True } // unique name of datasource ,     
    pconnector = Parameter { type: String hidden: True mandatory: True }
	 
   dateformat = Variable { initial:'yyyy/MM/dd' }
	booleanformat = Variable { initial:'True,Yes,1;False,No,0' }
	separator = Variable { initial:';' }
	encoding = Variable { initial:'UTF-8' }
	delimiter = Variable { initial:'"' }
	minimumNbLine = Variable { initial:1 }

	errornbdays = Variable { initial:30 }
	warningnbdays = Variable { initial:20 }
	checkfilevariation = Variable { initial:True type:Boolean }
	filevariation = Variable { initial:20 }

	hasConfig = Variable
	selectedColumnName = Variable
	selectedColumnType = Variable
	selectedColumnFormat = Variable
	selectedColumnFormatDescription = Variable
	selectedColumnMandatory = Variable
	selectedColumnMustBeUnique = Variable 
	selectedColumnOrder = Variable
	selectedColumnMinimumFillFactor = Variable

	selectedComputedColumnName = Variable
	selectedComputedColumnOrder = Variable
	selectedComputedColumnExpression = Variable

	columntomap = Variable
	brainwaveattributetomap = Variable
	brainwaveattributetypetomap = Variable

	filediscovery = Variable
		
	// //////////////////////////////////////////////////////////////////////////////////
	// columns for the mapping
	modelcolumns = Variable {
		multivalued:True
		type:String
	}
	modelcolumnsorder = Variable {
		multivalued:True
		type:Integer
	}
	modelcolumnsmandatory = Variable {
		multivalued:True
		type:Boolean
	}
	modelmappedcolumn = Variable {
		multivalued:True
		type:String
	}
	modelcolumnsdescription = Variable {
		multivalued:True
		type:String
	}
	modelcolumnsexample = Variable {
		multivalued:True
		type:String
	}
	modelcolumnstype = Variable {
		multivalued:True
		type:String
	}
	// //////////////////////////////////////////////////////////////////////////////////
	// default values
	imodelcolumns = Variable {multivalued:True type:String	}
	imodelcolumnsorder = Variable {	multivalued:True type:Integer	}
	imodelcolumnsmandatory = Variable {	multivalued:True	type:Boolean	}
	imodelmappedcolumn = Variable {multivalued:True type:String	}
	imodelcolumnsdescription = Variable { multivalued:True type:String}
	imodelcolumnsexample = Variable {multivalued:True type:String }
	imodelcolumnstype = Variable {multivalued:True type:String }
	// //////////////////////////////////////////////////////////////////////////////////

	taskformat = TaskRecord(create "bw_setdatasourceformat")
	taskremove = TaskRecord(create "bw_removedatasourcecolumn")
	taskremoveconfig = TaskRecord(create "bw_removedatasourceformat")
	taskmapping = TaskRecord(create "bw_savedatasourcemapping")
	// Delete existing columns & mappings (if any) and discover from uploaded file
	taskdiscover = TaskRecord(create "bw_dsmdiscovercolumns")
	
	connector_desc = Record {
		  page: pconnector
	 }
	 
	datasourceconfigDataset = Dataset {
		view: bw_getdatasourceconfig with	pcode to code
		count-variable: hasConfig
	}
	datasourceconfig = Record {
		view: bw_getdatasourceconfig with	pcode to code
	}

	datasourcecolumns = Dataset {
		view: bw_getdatasourcecolumns with	pcode to code
	}
	datasourcecomputedcolumns = Dataset {
		view: bw_getdatasourcecomputedcolumns with	pcode to code
	}

	datasourcemapping = Dataset {
		view: bw_getdatasourcemapping with	pcode to code
	}
	
	modeltable = Dataset {
		columns:
			modelcolumns as column, 
			modelcolumnsmandatory as ismandatory, 
			modelmappedcolumn as mappedcolumn, 
			modelcolumnsdescription as description,
			modelcolumnsexample as example,
			modelcolumnstype as type,
			modelcolumnsorder as order
	}

	doInit = NamedAction (
	  	IntCase(hasConfig) {
			when >0 then [
				Set datasourceconfig.bw_datasourceformat_warningifolderthan to warningnbdays,
				Set datasourceconfig.bw_datasourceformat_errorifolderthan to errornbdays,
				Set datasourceconfig.bw_datasourceformat_checkfilesizevariation to checkfilevariation,
				Set datasourceconfig.bw_datasourceformat_filesizevariation to filevariation,
				Set datasourceconfig.bw_datasourceformat_booleanformat to booleanformat,
				Set datasourceconfig.bw_datasourceformat_dateformat to dateformat,
				Set datasourceconfig.bw_datasourceformat_delimiter to delimiter,
				Set datasourceconfig.bw_datasourceformat_encoding to encoding,
				Set Sum(datasourceconfig.bw_datasourceformat_minimumnblines,0) to minimumNbLine,
				Set datasourceconfig.bw_datasourceformat_separator to separator
			]
		},
		IntCase(Count datasourcemapping) {
			when >0 then [
				TransferData datasourcemapping(name, type, order, column, ismandatory, description, example) to 
											  (modelcolumns, modelcolumnstype, modelcolumnsorder, modelmappedcolumn, modelcolumnsmandatory, modelcolumnsdescription, modelcolumnsexample)
			]
			otherwise [
				ExecuteNamedAction resetMapping
			]
	 },
	  // init model columns default values from page descriptor
	   Set Split connector_desc.imodelcolumns using ";" to imodelcolumns,
		Set Split connector_desc.imodelcolumnsorder using ";" to imodelcolumnsorder,
		Set Split connector_desc.imodelcolumnsmandatory using ";" to imodelcolumnsmandatory,
		Set Split connector_desc.imodelcolumnsdescription using ";" to imodelcolumnsdescription,
		Set Split connector_desc.imodelcolumnsexample using ";" to imodelcolumnsexample, 		
		Set Split connector_desc.imodelcolumnstype using  ";" to  imodelcolumnstype ,
		Call dsm_initColumns( imodelcolumns to columns, imodelcolumnsorder from columnsOrder, imodelmappedcolumn from mappedColumns)
	) 
	 

	saveMappings = NamedAction (
		// save mapping
		Set pcode to taskmapping.code,
		Set modelcolumns to taskmapping.name, 
		Set modelcolumnsorder to taskmapping.order, 
		Set modelcolumnstype to taskmapping.type, 
		Set modelcolumnsmandatory to taskmapping.ismandatory, 
		Set modelcolumnsdescription to taskmapping.description, 
		Set modelcolumnsexample to taskmapping.example, 
		Set modelmappedcolumn to taskmapping.column, 
		TaskComplete taskmapping wait-end  timeout-seconds 240
	)
	
	resetSelectColumn = NamedAction (
		MultivaluedSet "" to modelmappedcolumn where modelcolumns is brainwaveattributetomap
	)
	
	resetMapping = NamedAction (
		Set imodelcolumns to modelcolumns,
		Set imodelcolumnsdescription to modelcolumnsdescription,
		Set imodelcolumnsexample to modelcolumnsexample,
		Set imodelcolumnsmandatory to modelcolumnsmandatory,
		Set imodelcolumnsorder to modelcolumnsorder,
		Set imodelcolumnstype to modelcolumnstype,
		Set imodelmappedcolumn to modelmappedcolumn
	)
	
	saveConfiguration = NamedAction (
	   //Flash Concat("Save Format configuration:", pcode),
		// Save configuration
		Set pcode to taskformat.code,
		Set errornbdays to taskformat.errornbdays,
		Set warningnbdays to taskformat.warningnbdays,		
		Set booleanformat to taskformat.booleanformat,
		Set dateformat to taskformat.dateformat,
		Set delimiter to taskformat.delimiter,
		Set encoding to taskformat.encoding,
		Set minimumNbLine to taskformat.minimumnblines,
		Set separator to taskformat.separator,
		Set checkfilevariation to taskformat.checkfilesizevariation,
		Set filevariation to taskformat.filesizevariation,
		TaskComplete taskformat wait-end  timeout-seconds 240
	)
	
	saveAll = NamedAction (
		IntCase ( Count datasourcecolumns ) {
			when > 0 then [
				// Save
				ExecuteNamedAction saveMappings
			] otherwise [
				// Nothing to do
			]
		},
		ExecuteNamedAction saveConfiguration
	)

	
	// Add/update column
	entitydatamanagement_add = NamedAction (
		Dialog bw_entitydatamanagement_add(
            True to updatemode, 
            pcode to code, 
            selectedColumnOrder to corder, 
            selectedColumnName to cname, 
            selectedColumnType to ctype, 
            selectedColumnFormat to cformat, 
            selectedColumnFormatDescription to cformatps, 
            selectedColumnMandatory to cmandatory,
            selectedColumnMustBeUnique to cmustbeunique,
            selectedColumnMinimumFillFactor to cfillfactor
        ),
        ReloadData (datasourcecolumns),
        Flash $bw_entitydatamanagementNLS.updatecolumnflash
	)
	
	// Add/update computed column
	entitydatamanagement_addcomputed = NamedAction (
		Dialog bw_entitydatamanagement_addcomputed(
			False to updatemode, 
			pcode to code
		),
		ReloadData (datasourcecomputedcolumns),
		Flash $bw_entitydatamanagementNLS.updatecomputedcolumnflash
	)
	entitydatamanagement_updatecomputed = NamedAction (
		Dialog bw_entitydatamanagement_addcomputed(
			True to updatemode, 
			pcode to code, 
			selectedComputedColumnOrder to corder, 
			selectedComputedColumnName to cname, 
			selectedComputedColumnExpression to ccomputedexpression 
		),
		ReloadData (datasourcecomputedcolumns),
		Flash $bw_entitydatamanagementNLS.updatecomputedcolumnflash
	)
	
	// Select column
	entitydatamanagement_selectcolumn = NamedAction (
		Dialog bw_entitydatamanagement_selectcolumn(
		    pcode to code,
		    brainwaveattributetypetomap to brainwaveattributetypetomap,
		    columntomap from selectedcolumn
		), 
		MultivaluedSet columntomap to modelmappedcolumn where modelcolumns is brainwaveattributetomap,
		Flash $bw_entitydatamanagementNLS.setmappingflash(brainwaveattributetomap),
		ReloadData (modeltable)
	)
	
	//Text {
	//  value: code label: "[DEBUG] code"
	//}

	TabFolder {
		TabItem {
			text:$bw_entitydatamanagementNLS.tab1
			Header {
				value:$bw_entitydatamanagementNLS.uploadconfiguration
			}
			Separator {
				width:1
			}
			Flow {
				disposition:Horizontal
				layout:Layout { grab:horizontal True vertical False hint: height 40}		
				Group {
					Spinner {
						variable:warningnbdays
						label:$bw_entitydatamanagementNLS.warningolder
						tooltip:$bw_entitydatamanagementNLS.warningoldertooltip
						minimum:1
						maximum:1000
						layout:Layout { grab:horizontal False vertical False hint: width 100}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
				}
				Group {
					Spinner {
						variable:errornbdays
						label:$bw_entitydatamanagementNLS.errorolder
						tooltip:$bw_entitydatamanagementNLS.erroroldertooltip
						minimum:1
						maximum:1000
						layout:Layout { grab:horizontal False vertical False hint: width 100}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
				}
				Group {
					Checkbox {
						variable:checkfilevariation
						label:$bw_entitydatamanagementNLS.checkvariation
						tooltip:$bw_entitydatamanagementNLS.checkvariationtooltip
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
					Spinner {
						variable:filevariation
						label:$bw_entitydatamanagementNLS.checkvariationpercent
						minimum:0
						maximum:99999
						layout:Layout { grab:horizontal False vertical False hint: width 100}		
						disabled:
							OrPredicate {
								Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
								Not BooleanPredicate(checkfilevariation)
							}
					}
				}
			}
			Header {
				value:$bw_entitydatamanagementNLS.fileformat
			}
			Separator {
				width:1
			}
			Flow {
				disposition:Horizontal
				layout:Layout { grab:horizontal True vertical False hint: height 80}		
				Group {
					Edit {
						variable:separator
						label:$bw_entitydatamanagementNLS.separator
						layout:Layout { grab:horizontal False vertical False hint: width 160}		
						limit:1
						not-empty:True
						tooltip:$bw_entitydatamanagementNLS.separatortooltip
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
					Combo {
						variable:encoding
						label:$bw_entitydatamanagementNLS.fileencoding
						allow-none:False
						options:Static {
							Option { text:'ascii' value:'ascii' }
							Option { text:'windows-1252' value:'windows-1252' }
							Option { text:'UTF-8' value:'UTF-8' }
							/*Option { text:'ISO-2022-CN' value:'ISO-2022-CN' }
							Option { text:'UTF-16BE' value:'UTF-16BE' }
							Option { text:'UTF-16LE' value:'UTF-16LE' }*/
						}		
						layout:Layout { grab:horizontal False vertical False hint: width 160}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
				}
				Group {
					Edit {
						variable:booleanformat
						label:$bw_entitydatamanagementNLS.booleanformat
						tooltip:$bw_entitydatamanagementNLS.booleanformattooltip	
						limit:40
						not-empty:True
						layout:Layout { grab:horizontal False vertical False hint: width 160}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
					Edit {
						variable:dateformat
						label:$bw_entitydatamanagementNLS.dateformat
						tooltip:$bw_entitydatamanagementNLS.dateformattooltip
						limit:20
						not-empty:True
						layout:Layout { grab:horizontal False vertical False hint: width 160}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
				}
				Group {
					Edit {
						variable:delimiter
						label:$bw_entitydatamanagementNLS.fielddelimiter
						tooltip:$bw_entitydatamanagementNLS.fielddelimitertooltip
						limit:1
						not-empty:True
						layout:Layout { grab:horizontal False vertical False hint: width 160}
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
					Spinner {
						variable:minimumNbLine
						label:$bw_entitydatamanagementNLS.minimumnblines	
						tooltip:$bw_entitydatamanagementNLS.minimumnblinestoolip	
						minimum:0
						maximum:10000000
						layout:Layout { grab:horizontal False vertical False hint: width 160}		
						disabled:
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					}
				}
			}
			Header {
				value:$bw_entitydatamanagementNLS.filecolumns
			}
			Separator {
				width:1
			}
			ButtonGroup {
				Button {
					actions:
						Dialog bw_entitydatamanagement_add(
							pcode to code,
							Sum(Count datasourcecolumns, 1) to corder
						),
						ReloadData (datasourcecolumns),
						Flash $bw_entitydatamanagementNLS.addnewcolumnflash
					text:$bw_entitydatamanagementNLS.addnewcolumn
					image:%status_16.add
					disabled:
						Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
				}
				Button {
					actions:
						ExecuteNamedAction entitydatamanagement_add
					text:$bw_entitydatamanagementNLS.updatecolumn
					image:%collection_16.refresh
					disabled:
						OrPredicate {
							StringPredicate(selectedColumnName) { when IsEmpty then True }
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
				Button {
					actions:
						Set pcode to taskremove.code,
						Set selectedColumnName to taskremove.name,
						TaskComplete taskremove wait-end  timeout-seconds 240,
						ReloadData (datasourcecolumns),
						Flash $bw_entitydatamanagementNLS.removecolumnflash
					text:$bw_entitydatamanagementNLS.removecolumn
					image:%status_16.remove
					disabled:
						OrPredicate {
							StringPredicate(selectedColumnName) { when IsEmpty then True }
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
				Button {
					actions:
						Confirm $bw_entitydatamanagementNLS.autodiscoverconfirm, 
						Dialog bw_entitydatamanagement_autodiscover(filediscovery from file),
						Set pcode to taskdiscover.code,
						Set filediscovery to taskdiscover.file,
						Set encoding to taskdiscover.encoding,
						Set separator to taskdiscover.separator,
						Set delimiter to taskdiscover.delimiter,
						Set dateformat to taskdiscover.dateformat,
						Set booleanformat to taskdiscover.booleanformat,
						Set imodelcolumnsdescription to taskdiscover.mappingdescription,
						Set imodelcolumnsexample to taskdiscover.mappingexample,
						Set imodelcolumnsmandatory to taskdiscover.mappingmandatory,
						Set imodelmappedcolumn to taskdiscover.mappingmapped,
						Set imodelcolumns to taskdiscover.mappingname,
						Set imodelcolumnsorder to taskdiscover.mappingorder,
						Set imodelcolumnstype to taskdiscover.mappingtype,
						TaskComplete taskdiscover wait-end  timeout-seconds 240,
						Call fileDelete(filediscovery to filename),
						ReloadData(datasourcecolumns),
						TransferData datasourcemapping(name, type, order, column, ismandatory, description, example) to // reload data from the database 
													  (modelcolumns, modelcolumnstype, modelcolumnsorder, modelmappedcolumn, modelcolumnsmandatory, modelcolumnsdescription, modelcolumnsexample),
						ReloadData(modeltable)
					text:$bw_entitydatamanagementNLS.autodiscover
					tooltip:$bw_entitydatamanagementNLS.autodiscovertooltip
					image:%collection_16.bulb
				}
			}
			Table {
				data:datasourcecolumns
				layout: Layout { grab:horizontal True vertical True }
				show-filter:True
				configurable:True
				persist-configuration:True
				persist-configuration-key:pcode
				Column {
					header:$bw_entitydatamanagementNLS.corder
					column:bw_datasourcecolumn_order
					selection:selectedColumnOrder
					width:60px
					align:Right
				}
				Column {
					header:$bw_entitydatamanagementNLS.cname
					column:bw_datasourcecolumn_name
					tooltip:Current bw_datasourcecolumn_name
					image:TemplateImageSelection(Current bw_datasourcecolumn_type) using bw_entitymanagementColumnImageTemplate
					selection:selectedColumnName
					filterable:True
					width:160px
					actions-disabled:
						Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					actions:
						ExecuteNamedAction entitydatamanagement_add
				}
				Column {
					header:$bw_entitydatamanagementNLS.ctype
					column:bw_datasourcecolumn_type
					text:Transform Current bw_datasourcecolumn_type using bw_entitymanagementColumnTypeMapping
					selection:selectedColumnType
					width:160px
					align:Right
				}
				Column {
					header:$bw_entitydatamanagementNLS.cformat
					column:bw_datasourcecolumn_format
					tooltip:Current bw_datasourcecolumn_format
					selection:selectedColumnFormat
					width:160px
				}
				Column {
					header:$bw_entitydatamanagementNLS.cformatdescription
					column:bw_datasourcecolumn_formatprettystring
					tooltip: Current bw_datasourcecolumn_formatprettystring
					selection:selectedColumnFormatDescription
					width:160px
				}
				Column {
					header:$bw_entitydatamanagementNLS.cmustbeunique
					column:bw_datasourcecolumn_mustbeunique
					text:Transform Current bw_datasourcecolumn_mustbeunique using bw_entitymanagementYesNoMapping 
					selection:selectedColumnMustBeUnique
					align:Right
					width:110px
				}
				Column {
					header:$bw_entitydatamanagementNLS.cmandatory
					column:bw_datasourcecolumn_mandatory
					text:Transform Current bw_datasourcecolumn_mandatory using bw_entitymanagementYesNoMapping
					selection:selectedColumnMandatory
					align:Right
					width:110px
				}
				Column {
					header:$bw_entitydatamanagementNLS.cminimumfillfactor
					tooltip:$bw_entitydatamanagementNLS.cminimumfillfactortooltip
					column:bw_datasourcecolumn_minimumfillfactor
					text:Concat(Transform Current bw_datasourcecolumn_minimumfillfactor using bw_entitydatamanagement_addEmptybyDashMapping, ' %') 
					selection:selectedColumnMinimumFillFactor
					align:Right
					width:90px
				}
			}
		}
		TabItem {
			text:$bw_entitydatamanagementNLS.tab2
			Header {
				value:$bw_entitydatamanagementNLS.tab2subtitle
			}
			Separator {
				width:1
			}
			ButtonGroup {
				Button {
					actions:
						ExecuteNamedAction entitydatamanagement_addcomputed
					text:$bw_entitydatamanagementNLS.addnewcomputedcolumn
					image:%status_16.add
					disabled:
						Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
				}
				Button {
					actions:
						ExecuteNamedAction entitydatamanagement_updatecomputed
					text:$bw_entitydatamanagementNLS.updatecomputedcolumn
					image:%collection_16.refresh
					disabled:
						OrPredicate {
							StringPredicate(selectedComputedColumnName) { when IsEmpty then True }
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
				Button {
					actions:
						Set pcode to taskremove.code,
						Set selectedComputedColumnName to taskremove.name,
						TaskComplete taskremove wait-end  timeout-seconds 240,
						ReloadData (datasourcecomputedcolumns),
						Flash $bw_entitydatamanagementNLS.removecomputedcolumnflash
					text:$bw_entitydatamanagementNLS.removecomputedcolumn
					image:%status_16.remove
					disabled:
						OrPredicate {
							StringPredicate(selectedComputedColumnName) { when IsEmpty then True }
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
			}
			Table {
				data:datasourcecomputedcolumns
				layout: Layout { grab:horizontal True vertical True }
				Column {
					header:$bw_entitydatamanagementNLS.corder
					column:bw_datasourcecolumn_order
					selection:selectedComputedColumnOrder
					width:60px
					align:Right
				}
				Column {
					header:$bw_entitydatamanagementNLS.cname
					column:bw_datasourcecolumn_name
					tooltip:Current bw_datasourcecolumn_name
					image:%collection_16.gear
					selection:selectedComputedColumnName
					width:160px
					actions-disabled:
						Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
					actions:
						ExecuteNamedAction entitydatamanagement_updatecomputed
				}
				Column {
					header:$bw_entitydatamanagementNLS.ccomputedexpression
					column:bw_datasourcecolumn_computedexpression
					tooltip:Current bw_datasourcecolumn_computedexpression
					selection:selectedComputedColumnExpression
					width:100%
				}
			}
		}
		TabItem {
			text:$bw_entitydatamanagementNLS.tab3
			Header {
				value:$bw_entitydatamanagementNLS.tab3subtitle
			}
			Separator {
				width:1
			}
			ButtonGroup {
				nb-inline:3
				Button {
					actions:
						ExecuteNamedAction entitydatamanagement_selectcolumn
					text:$bw_entitydatamanagementNLS.setmapping
					image:%status_16.update
					tooltip:$bw_entitydatamanagementNLS.setmappingtooltip
					disabled:
						OrPredicate {
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
							StringPredicate(brainwaveattributetomap) { when IsEmpty then True }
						}
				}
				Button {
					actions:
						ExecuteNamedAction saveAll,
						Dialog bwdsm_testDsDialog(pcode to code)
					text:$bw_entitydatamanagementNLS.test
					tooltip:$bw_entitydatamanagementNLS.testtooltip
					image:%collection_16.bulb
					disabled:
						OrPredicate {
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
				
				Button {
					actions:
						ExecuteNamedAction resetSelectColumn
					text:$bw_entitydatamanagementNLS.resetselectedmapping
					image:%status_16.remove
					tooltip: $bw_entitydatamanagementNLS.resetselectedmappingtooltip
					disabled:
						OrPredicate {
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
							StringPredicate(brainwaveattributetomap) { when IsEmpty then True }
						}
				}
				
				Button {
					actions:
						Confirm $bw_entitydatamanagementNLS.resetmappingconfirm,
						ExecuteNamedAction resetMapping
					text:$bw_entitydatamanagementNLS.resetmapping
					image:%status_16.remove
					tooltip:$bw_entitydatamanagementNLS.resetmappingtooltip
					disabled:
						OrPredicate {
							Not FeaturePredicate bw_datasourcemanagement_canupdateconfig
						}
				}
			}
			Table {
				data:modeltable
				layout:Layout { grab:horizontal True vertical True }
				configurable:True
				show-filter:True
				persist-configuration:True
				persist-configuration-key:pcode
				
				Column {
					column:column
					selection:brainwaveattributetomap
					header:$bw_entitydatamanagementNLS.mappingcolumn
					image:TemplateImageSelection(Current type) using bw_entitymanagementColumnImageTemplate
					styling:BooleanStyling(Current ismandatory) { when True then bold when False then default}
					filterable:True
					width:180px
					tooltip:$bw_entitydatamanagementNLS.mappingcolumntooltip
					actions:
						ExecuteNamedAction entitydatamanagement_selectcolumn
				}
				Column {
