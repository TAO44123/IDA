bw_entitydatamanagement_add = Dialog {
	title: $bw_entitydatamanagement_addNLS.title
	enter-event:
		StringCase ( cmustbeunique ) {
			when "Yes" then [
				Set True to innermustbeunique
			] when "No" then [
				Set False to innermustbeunique
			]
		},
		TransferData tmpallcolumns(bw_datasourcecolumn_name) to (tmpallcolumns)
	width:400
	height:350
	buttons: [
		OkButton {
			disabled: 
				OrPredicate {
					StringPredicate(cname) { when IsEmpty then True }
					AndPredicate { // le nom de la colonne doit etre unique dans le cas de l'ajout d'une nouvelle colonne
						Not BooleanPredicate(updatemode)
						IntPredicate(Count namealreadyexists) { when >0 then True }
					}
				}
			actions:
				Set code to task.code,
				Set cname to task.name,
				Set ctype to task.type,
				Set cformat to task.cformat,
				Set cformatps to task.cformatprettystring,
				Set cmandatory to task.cmandatory,
				Set cfillfactor to task.cfillfactor,
				Set cmustbeunique to task.cmustbeunique,
				Set corder to task.corder,
				Set 0 to task.iscomputed,
				TaskComplete task wait-end  timeout-seconds 240
		}
		CancelButton
	]
	
	code = Variable 
	
	updatemode = Variable { type:Boolean initial:False }
	
	cname= Variable
	ctype= Variable
	cformat= Variable
	cformatps= Variable
	cmandatory= Variable { initial:False}
	cfillfactor= Variable { initial:0 }
	corder= Variable { initial:1 }
	cmustbeunique = Variable { initial:'No' }
	innermustbeunique = Variable

	tmpallcolumns = Variable { multivalued:True }
	tmpallcolumns = Dataset {
		view: bw_getdatasourceallcolumns with
			code to code
	}
	namealreadyexists = Dataset {
		columns: tmpallcolumns
		includes:
			SameValuePredicate ( cname, Current tmpallcolumns )		
	}

	task = TaskRecord(create "bw_adddatasourcecolumn")

	Edit {
		variable:cname
		label:$bw_entitydatamanagement_addNLS.name
		tooltip:$bw_entitydatamanagement_addNLS.nametooltip
		disabled:
			BooleanPredicate(updatemode)
	}
	Combo {
		variable:ctype
		label:$bw_entitydatamanagement_addNLS.type
		options:Static {
			Option { value:'String' text:$bw_entitydatamanagement_addNLS.cstring }
			Option { value:'Date' text:$bw_entitydatamanagement_addNLS.cdate }
			Option { value:'Customdate' text:$bw_entitydatamanagement_addNLS.ccustomdate }
			Option { value:'Boolean' text:$bw_entitydatamanagement_addNLS.cboolean }
			Option { value:'Number' text:$bw_entitydatamanagement_addNLS.cnumber }
			Option { value:'EMail' text:$bw_entitydatamanagement_addNLS.cemail }
		}
		tooltip:$bw_entitydatamanagement_addNLS.typetooltip
	}
	Edit {
		variable:cformat
		label:$bw_entitydatamanagement_addNLS.lformat
		tooltip:$bw_entitydatamanagement_addNLS.lformattooltip
		disabled:
			StringPredicate(ctype) {
				when 'String' then False
				when 'Customdate' then False
				otherwise True
			}
	}
	Edit {
		variable:cformatps
		label:$bw_entitydatamanagement_addNLS.lformatps
		tooltip:$bw_entitydatamanagement_addNLS.lformatpstooltip
		disabled:
			OrPredicate {
				StringPredicate ( cformat ) {
					when IsEmpty then True
				}
				StringPredicate ( ctype ) {
					when 'String' then False
					otherwise True
				}
			}
	}
	Checkbox {
		variable:innermustbeunique
		label:$bw_entitydatamanagement_addNLS.lmustbeunique
		tooltip:$bw_entitydatamanagement_addNLS.lmustbeuniquetooltip
		modify-event:
			BooleanCase ( innermustbeunique ) {
				when True then [ Set "Yes" to cmustbeunique ]
				when False then [ Set "No" to cmustbeunique ]
			}
	}
	Checkbox {
		variable:cmandatory
		label:$bw_entitydatamanagement_addNLS.lcontent
		tooltip:$bw_entitydatamanagement_addNLS.lcontenttooltip
		modify-event:
			BooleanCase ( cmandatory ) {
				when True then [ Set 0 to cfillfactor ]
				when False then []
			}
	}
	Spinner {
		variable:cfillfactor
		label:$bw_entitydatamanagement_addNLS.lfillfactor
		tooltip:$bw_entitydatamanagement_addNLS.lfillfactortooltip
		minimum:0
		maximum:100
		disabled:
			BooleanPredicate(cmandatory)
	}
	Spinner {
		variable:corder
		label:$bw_entitydatamanagement_addNLS.lorder
		tooltip:$bw_entitydatamanagement_addNLS.lordertooltip
		minimum:1
		maximum:1000
	}
}

