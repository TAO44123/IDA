bw_entitydatamanagement_addcomputed = Dialog {
	title:$bw_entitydatamanagement_addNLS.titlecomputed
	width:800
	height:250
	enter-event:
		TransferData tmpallcolumns(bw_datasourcecolumn_name) to (tmpallcolumns)
	
	buttons: [
		OkButton {
			disabled:
				OrPredicate { 
					StringPredicate ( cname ) {
						when IsEmpty then True
					}
					AndPredicate { // le nom de la colonne doit etre unique dans le cas de l'ajout d'une nouvelle colonne
						Not BooleanPredicate(updatemode)
						IntPredicate(Count namealreadyexists) {
							when >0 then True
						}
					}
					Not BooleanPredicate(cname_valid)
				}
			actions:
				Set code to task.code,
				Set cname to task.name,
				Set 'String' to task.type,
				Set '' to task.cformat,
				Set '' to task.cformatprettystring,
				Set False to task.cmandatory,
				Set 0 to task.cfillfactor,
				Set False to task.cmustbeunique,
				Set corder to task.corder,
				Set 1 to task.iscomputed,
				Set ccomputedexpression to task.computedexpression,
				TaskComplete task wait-end  timeout-seconds 240
		}
		CancelButton
	]
	
	code = Variable 
	
	updatemode = Variable { type:Boolean initial:False }
	
	cname= Variable{type:String}
	cname_valid = Variable{type:Boolean}
	corder= Variable { initial:1 }
	ccomputedexpression = Variable { initial:'' }
	
	tempexpression = Variable
	
	checkexpression = Variable

	tmpallcolumns = Variable { multivalued:True}
	tmpallcolumns = Dataset {
		view: bw_getdatasourceallcolumns with
			code to code
	}
	namealreadyexists = Dataset {
		columns: tmpallcolumns
		includes:
			SameValuePredicate ( cname, Current tmpallcolumns )		
	}
	check = Record {
		view: bw_dsmcheckexpression with
			code to code,
			checkexpression to expression
	}
	task = TaskRecord(create "bw_adddatasourcecolumn")

	Edit {
		variable:cname
		label:$bw_entitydatamanagement_addNLS.name
		tooltip:$bw_entitydatamanagement_addNLS.nametooltip
		disabled:
			BooleanPredicate(updatemode)
		layout:Layout {hint:width 300}
		match: "^[a-zA-Z0-9_]*$"
		validity: cname_valid
	}
	Edit {
		variable:ccomputedexpression
		label:$bw_entitydatamanagement_addNLS.computedexpression
		tooltip:$bw_entitydatamanagement_addNLS.computedexpressiontooltip
		commands:Commands {
			position:After 
			orientation:Horizontal
			presentation:Icon
			Command {
				actions:
					Dialog bw_entitydatamanagement_pickcolumn (
						code to code,
						tempexpression from expression
					),
					Set Concat(ccomputedexpression, tempexpression) to ccomputedexpression
				icon:%status_16.add		
			}
			Command {
				actions:
					Set ccomputedexpression to checkexpression,
					StringCase ( check.error ) {
						when Not IsEmpty then [
							Message Error check.error
						] otherwise [
							Message $bw_entitydatamanagement_addNLS.noSyntaxErrorFound
						]
					}
				icon:%status_16.check		
			}
		
		}
	}
	Spinner {
		variable:corder
		label:$bw_entitydatamanagement_addNLS.lorder
		tooltip:$bw_entitydatamanagement_addNLS.lordertooltip
		minimum:1
		maximum:1000
		layout:Layout {hint:width 200}
	}
}

