	title [en "Pick a column" fr "Sélectionnez une colonne"]
	subtitle [en "Pick a column in the list" fr "Choisissez une colonne dans la liste"]
	pickexpression [en 'Pick a column in the list to include it in your expression' fr "Choisissez une colonne dans la liste pour l''inclure dans votre expression"]
