bw_entitydatamanagement_selectcolumn = Dialog {
	title:$bw_entitydatamanagement_selectcolumnNLS.title
	enter-event:
		MultivaluedAdd brainwaveattributetypetomap to dynfilter,
		StringCase(brainwaveattributetypetomap) { 
			when "String" then [  // we also accept Email when the column type is a String
				MultivaluedAdd "Email" to dynfilter 
			] 
			when "Date" then [ // two kind of date format are allowed here
				MultivaluedAdd "Customdate" to dynfilter
			] 
		}
	buttons:
		[
			OkButton {
				actions:
					Set column to selectedcolumn,
					StringCase ( selectedcolumn ) {
						when IsNull then [
							Set '' to selectedcolumn
						]
					}
			}
			CancelButton 
		]
	
	brainwaveattributetypetomap = Variable
	code = Variable 
	column = Variable
	selectedcolumn = Variable
	dynfilter = Variable { multivalued:True }
	
	standardcolumns = Dataset {
		view: bw_getdatasourceallcolumns with
			code to code,
			dynfilter to type,
			0 to iscomputed
	}
	computedcolumns = Dataset {
		view: bw_getdatasourceallcolumns with
			code to code,
			1 to iscomputed
	}
	columns = Dataset {
		union:Union {
			datasets:standardcolumns, computedcolumns
			discriminator-column:discr
		}
	}
	
	Header {
		value:$bw_entitydatamanagement_selectcolumnNLS.subtitle
	}
	Combo {
		label:Label {break:True}
		allow-none:True
		variable:column
		options:Dynamic {
			data:columns
			value:Current bw_datasourcecolumn_name
			text:Current bw_datasourcecolumn_name
		}
	}
}

