	title [
		en "DSM Configuration"
		fr "Configuration DSM"
	]
	export.button [
		en "Export" 
		fr "Exporter"
	]
	importfile.button [
		en "Import" 
		fr "Importer"
	]
	label.selectFile [ 
		en "Select file to import" 
		fr "Selectionner le fichier d'import"
	]
	ds.header.ds.name [ 
		en "Name" 
		fr "Nom"
	]
	ds.header.ds.status [ 
		en "Status" 
		fr "Etat"
	]
	ds.status.new [
		en "New" 
		fr "Nouveau"
	]
	ds.status.overwrite [ 
		en "Will overwrite existing" 
		fr "Remplacera les données existantes"
	]
	importdialog.title  [ 
		en "Import" 
		fr "Importer"
	]
	importdialog.importfiles.title [ 
		en "Data sources found in the import file" 
		fr "Sources de données trouvées dans le fichier d'import"
	]
	groups.importexport.title [ 
		en "Import and Export Data sources" 
		fr "Importer et exporter des sources de données"
	]
	groups.secrets.title [
		en "Secrets" 
		fr "Secrets"
	]
	concept.datasource [
		en "Data source" 
		fr "Source de données"
	]
	concept.secret.name [
		en "Secret Name" 
		fr "Nom du secret"
	]
	concept.secret.status [
		en "Status" 
		fr "Etat"
	]
	concept.secret.status.missing [
		en "Empty" 
		fr "Vide"
	]
	concept.secret.status.found [
		en "Found" 
		fr "Trouvé" 
	]
	label.secret.message [
		en "Credentials and other secrets are never exported. \n Imported data sources may require some credentials or secrets to be present. \n Here a list of required secrets and the status. Select the data source and click on Edit to review the data source configuration."
		fr "Les informations d'identification et autres secrets ne sont jamais exportés. \n Les sources de données importées peuvent nécessiter la présence de certains secrets. \n Sélectionnez la source de données et cliquez sur Modifier pour revoir sa configuration."
	]
	label.secret.edit [
		en "Edit" 
