/* Import other pages here */
import "/webportal/pages/bw_dsm/history/timeslot_frag.page"
import "/webportal/pages/bw_dsm/history/batch_history_frag.page"
import "/webportal/pages/bw_dsm/resources/dsm_nls.page"

bw_dsm_history = Page { 
	title: $dsm_history_NLS.page_title

	TabFolder {
      
	  TabItem {
	    text: $dsm_history_NLS.tab_batches
	    IncludeFragment { fragment: bwdsm_batch_history }
	  }
	  TabItem {
	    text: $dsm_history_NLS.tab_timeslots
	    IncludeFragment { fragment: bwdsm_timeslots }
	  }
	}
	
	
}
