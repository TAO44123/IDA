/**
 * Review status constant
 * Please use those values in the 'action' field of the ticketreviews
 * 
 */

import "/webportal/pages/resources/pages_nls.page"

// generic status 
notreviewed_reviewstatus = Constant { value: "not reviewed" type: String } // entry has not been reviewed
ok_reviewstatus = Constant { value: "ok" type: String } // the entry has been reviewed, status is ok
update_reviewstatus = Constant { value: "update" type: String } // the entry has been reviewed, the entry needs to be updated (the comment should contain the description of the required actions) 

// Access right/Account related review
revoke_reviewstatus = Constant { value: "revoke" type: String } // this access right needs to be removed, the account needs to be disabled/removed 

// Identity Allocation related review
leaver_reviewstatus = Constant { value: "leaver" type: String } // the identity has left the company
mover_reviewstatus = Constant { value: "mover" type: String } // the identity has moved to another dpt, the comment field contains the new allocation
joiner_reviewstatus = Constant { value: "joiner" type: String } // the identity has not been declared yet in the identity ledger ()
unknown_reviewstatus = Constant { value: "unknown" type: String } // the identity is unknown

// Review types
identities_review = Constant { type: String value: "identities" }
applications_review = Constant { type: String value: "applications" }
permissions_review = Constant { type: String value: "permissions" }
accounts_review = Constant { type: String value: "accounts" }
groups_review = Constant { type: String value: "groups" }
repositories_review = Constant { type: String value: "repositories" }
allocations_review = Constant { type: String value: "allocations" }
rights_review = Constant { type: String value: "rights" }
fs_rights_review = Constant { type: String value: "fsrights" }
folder_rights_review = Constant { type: String value: "folder_rights" }
reconciliations_review = Constant { type: String value: "reconciliations" }
managers_review = Constant { type: String value: "managers" }
organization_managers_review = Constant { type: String value: "organization_managers" }

// Campaign frequencies
adhoc_frequency = Constant { type: String value: "" }
daily_frequency = Constant { type: String value: "d" }
weekly_frequency = Constant { type: String value: "w" }
monthly_frequency = Constant { type: String value: "m" }
quarterly_frequency = Constant { type: String value: "q" }
semesterly_frequency = Constant { type: String value: "s" }
yearly_frequency = Constant { type: String value: "y" }

// Campaign statuses
campaign_status_complete = Constant { type: String value: "Completed" }
campaign_status_inProgress = Constant { type: String value: "In Progress" }

