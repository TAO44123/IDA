// Style section

brcm_bigWhiteTitleStyle = Style {
	size: 16px
}

brcm_deactivatedCampaignStyle = Style {
	italic: True
	background: Color RGB(192, 192, 192)
}

// Dialog section

br_campaignLaunchConfirmation = Dialog {
	title: $br_campaignLaunchConfirmation.title
	width: 500
	height: 260
	buttons:
		[
			OkButton {
				disabled:
					OrPredicate {
					Not BooleanPredicate ( canLaunch )
						SameValuePredicate (campaignInstanceTitleEmptyFlag, campaignInstanceTitleExistenceFlag)
					}
				actions:
					ExecuteFragmentNamedAction setCampaignInstanceTitle.saveCampaign
			}
			CancelButton
		]
	
	canLaunch = Variable { type: Boolean initial: False }
	campaignTitle = Variable { type: String initial: False } 
	campaignInstanceTitleEmptyFlag = Variable { type: Boolean initial: False }
	campaignInstanceTitleExistenceFlag = Variable { type: Boolean initial: False }
	selectedCampaign = Variable { type: Integer }
	selectedCampaignProcessDefId = Variable { type: String }

	Spacer {
		height: 5
	}
	Text{
		value: $br_campaignLaunchConfirmation.description(campaignTitle)
		compact: True
	}
	Text {
		value: $br_campaignLaunchConfirmation.description2
		compact: True
	}
	
	Group {
		hidden: Not BooleanPredicate (campaignInstanceTitleExistenceFlag)
		
		setCampaignInstanceTitle = IncludeFragment {
				fragment: setCampaignInstanceTitleFragment with 
								value-of selectedCampaign to selectedCampaignParam,
								value-of selectedCampaignProcessDefId to selectedCampaignProcessDefIdParam,
								campaignInstanceTitleExistenceFlag binds-to campaignInstanceTitleExistenceFlag,
								campaignInstanceTitleEmptyFlag binds-to campaignInstanceTitleEmptyFlag
		}
	}
	
	Spacer {
		height: 10
	}	
	Checkbox {
		variable: canLaunch
		text: $br_campaignLaunchConfirmation.confirmation
	}
}

setCampaignInstanceTitleFragment = PageFragment {
	enter-event:
		Set campaignInfos.status to campaignStatus,
		Set Concat(campaignInfos.title, " ", Date.valueLDAP) to task.instanceTitle,
		StringCase (task.instanceTitle) {
			when IsEmpty then [
				Set False to campaignInstanceTitleExistenceFlag,
				Set True to campaignInstanceTitleEmptyFlag
			]
			otherwise [
				Set True to campaignInstanceTitleExistenceFlag,
				Set False to campaignInstanceTitleEmptyFlag
			]
		}
	
	selectedCampaignParam = Parameter {
		type: Integer
		mandatory: False
	}
	
	selectedCampaignProcessDefIdParam = Parameter {
		type: String
		mandatory: False
	}
	
	campaignInstanceTitleEmptyFlag = Variable { type: Boolean initial: False }
	campaignInstanceTitleExistenceFlag = Variable { type: Boolean initial: False }
	
	campaignStatus = Variable { type: String initial: "None" }
	
	campaignInfos = Record {
		view: br_campaign with selectedCampaignParam to recorduid
	}
	
	task = TaskRecord ( selectedCampaignParam or create selectedCampaignProcessDefIdParam )
	
	saveCampaign = NamedAction (
		CampaignSave task {
			code: campaignInfos.code
			title: campaignInfos.title
			description: campaignInfos.description
			type: campaignInfos.type
			status-variable: campaignStatus
			owner: campaignInfos.owneruid
			frequency: campaignInfos.frequency
			duration: campaignInfos.duration
			start-date: DateLDAP ( campaignInfos.startexecutiondate )
			when-complete:
			    Flash Information $br_campaignLaunchConfirmation.instanceTitleModifiedConfirmation
			when-failed:
				Flash Error Concat( $br_campaignLaunchConfirmation.instanceTitleModifiedProblem, campaignStatus )
		}
	)
	
	Text {
		value: $br_campaignLaunchConfirmation.instanceTitle
		tooltip: $br_campaignLaunchConfirmation.instanceTitleTt
		compact: True
	}
	
	Edit {
		variable: task.instanceTitle
		tooltip: $br_campaignLaunchConfirmation.instanceTitleTt
		modify-event:
			StringCase(task.instanceTitle) {
				when IsEmpty then [
					Set True to campaignInstanceTitleEmptyFlag
				]
				otherwise [
					Set False to campaignInstanceTitleEmptyFlag				]
			}
	}
}

generateConfirmationCode = StringService {
	javascript-file: "/webportal/pages/bw_campaignmanager/campaignmanager_utils.javascript"
    javascript-method: generateConfirmationCode
}
warning = Style {
	foreground: RGB ( 159 , 96, 0 )
}

br_campaignDeleteError = Dialog {
	title: $br_campaignDeleteConfirmation.title
	width: 500
	height: 210
	buttons:
		[
			OkButton {
				disabled: True
			}
			CancelButton
		]
	
	canLaunch = Variable { type: Boolean initial: False }
	campaignTitle = Variable { type: String initial: False } 
	description = Variable { type: String initial: False } 
	Group {
		background: Color RGB ( 254,239,176)
		border: True 
		layout: Layout { grab: horizontal True vertical False hint: height 80}
		Text{
			layout: Layout { grab: horizontal True vertical False hint: height 20 indent: horizontal 0 vertical 5}
			value: $br_campaignDeleteError.description(campaignTitle)
			compact: True
			styling: warning
		}
		Text {
			layout: Layout { grab: horizontal True vertical False hint: height 40 indent: horizontal 0 vertical 5}
			value: description
			compact: True
			styling: warning
			lines: 2
		}
	}
	Spacer {
		height: 10
	}
}

br_campaignDeleteConfirmation = Dialog {
	title: $br_campaignDeleteConfirmation.title
	height: 450
	width: 600
	enter-event: Set @generateConfirmationCode to confirmationCode
	buttons:
		[
			OkButton {
				disabled:
					OrPredicate{
						Not SameValuePredicate ( codeInput, confirmationCode )
						StringPredicate(codeInput){when IsEmpty then True}
						Not BooleanPredicate ( canDelete )
					 }
			}
			CancelButton
		]
	
	canDelete = Variable { type: Boolean initial: False }
	campaignTitle = Variable { type: String initial: False }
	codeInput = Variable { type:  String }
	confirmationCode = Variable { type: String }

	Spacer {
		height: 5
	}
	Group {
		background: Color RGB ( 254,239,176)
		border: True 
		layout: Layout { grab: horizontal True vertical False hint: height 100}
		Text{
			layout: Layout { grab: horizontal True vertical False hint: height 20 indent: horizontal 0 vertical 5}
			value: $br_campaignDeleteConfirmation.description(campaignTitle)
			compact: True
			styling: warning
		}
		Text {
			layout: Layout { grab: horizontal True vertical False hint: height 60 indent: horizontal 0 vertical 5}
			value: $br_campaignDeleteConfirmation.description2
			compact: True
			styling: warning
			lines: 3
		}
	}
	Spacer {
		height: 10
	}	
	Checkbox {
		variable: canDelete
		text: $br_campaignDeleteConfirmation.confirmation
	}
	
	Spacer {
		height: 10
	}
	
	Group {
		hidden: Not BooleanPredicate ( canDelete )
		layout: Layout { grab: horizontal True vertical True }
		
		Spacer {
			height: 5
		}
		
		Edit {
			variable: codeInput
			layout: Layout { hint: width 100}
			label: $projectUpdateManagerNLS.installdialog.askconfirmationcode ( Concat(" ",confirmationCode) )
		}
		
		Spacer {
			height: 5
		}
	}	
}