					Text { label: $logFields_NLS.custom19 value: logDetail.custom19  hidden: StringPredicate(logDetail.custom19) { when IsEmpty then True otherwise False} }			        
			     }	     
			   }
	      }
	    } 
	   }	 
	}	  
	}
}
