					Text { label: $logFields_NLS.custom13 value: logDetail.custom13  hidden: StringPredicate(logDetail.custom13) { when IsEmpty then True otherwise False} }
					Text { label: $logFields_NLS.custom14 value: logDetail.custom14  hidden: StringPredicate(logDetail.custom14) { when IsEmpty then True otherwise False} }
