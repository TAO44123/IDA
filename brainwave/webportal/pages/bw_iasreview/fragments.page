								Unset inselectedentries
							image:"16/famfamfam_silk_icons_v013/comment.png"
							text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkcomment.text
							tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkcomment.tooltip
							disabled:
								OrPredicate {
									StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
									IntPredicate(SizeOf inselectedentries) { when =0 then True }
									IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
									Not FeaturePredicate iasr_canmanagecampaignentries
									BooleanPredicate (actioninprogress)
								}
						}				
					}		
				}
				GridCell {
					// Layouting: grow
				}
				GridCell {
					// Missing reviewers
					reviewStatusMissingReviewers = IncludeFragment {
						layout: Layout { grab: horizontal True vertical False }
						fragment: bw_ias_review_missingReviewers with
							value-of incampaignid to campaignTicketLogRecordUid,
							value-of inenabled to enabled,
							value-of Constant bw_ias_review_missingReviewers_sourceToReview to source,
							filterMissingReviewers binds-to filterMissingReviewers
					}
				}
			}
		}
	}
}

bw_iasreview_ExplicitApprovalTable_bulkActionButtons = PageFragment {
	periodic-actions:
		PeriodicAction {
			actions:
				ReloadData (actionInProgress),
				Set actionInProgress.ticketopen to processing,
				BooleanCase (processing) {
					when False then [
						FireFragmentEvent "ReloadTable",
						Set False to actioninprogress
					]
					when True then []
				}
			period: 5
			disabled:
				Not BooleanPredicate (actioninprogress)
		}
	
	inenabled = Variable { initial:False type:Boolean }
	inexplicitfilter = Variable { initial:["1"] type:String  }
	incampaignid = Variable
	inselectedentries = Variable { multivalued:True }
	infilteredentries = Variable { multivalued:True }
	inreviewtype = Variable
	// Current batch of entries for workflow
	entries_batch = Variable { type: String multivalued: True }
	
	entries = Variable { multivalued:True }
	
	reviewcount = Variable
	
	updatestatus = Variable { type:Boolean }
	statustowrite = Variable
	updatecomment = Variable { type:Boolean }
	commenttowrite = Variable
	
	actioninprogress = Variable { type:Boolean initial: False }
	processing = Variable { type:Boolean initial: False }
	
	finalizedreview = Record {
		view: bwaccess360_accessreviewcampaignsfinalized with
			incampaignid to campaignid
		disabled:
			Not BooleanPredicate ( inenabled )
	}
	
	reviewtickets = Dataset {
		view: bwaccess360_ticketreviewcampaignsentries_bv with
			incampaignid to campaignid,
			[ Constant review_status_revoke, Constant review_status_update ] to status,
			entries_batch to ticketreviewrecorduids,
			True to filterprocessed,
			inreviewtype to reviewtype
	}

	actionInProgress = Record {
		view: br_workflowticketstatus_parellelmode with
			incampaignid to custom1,
			"REVIEW" to tickettype,
			Principal.uid to actoruid
	}
	
	resetExplicitApproval = TaskRecord( create "bwaccess360_performBulkResetExplicitApprovalOperation")
	markEntryExplicitelyProcessed = TaskRecord ( create "bwaccess360_performBulkMarkExplicitelyProcessedOperation" )
	

	checkActionInProgress = NamedAction (
		ReloadData (actionInProgress),
		Set actionInProgress.ticketopen to actioninprogress
	)
	
	resetExplicitApproval_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_ExplicitApprovalTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf entries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction resetExplicitApproval,
				// Recursive call on remainder
				ExecuteNamedAction resetExplicitApproval_batch
			] otherwise [
				// Done
			]
		}
	)
	
	resetExplicitApproval = NamedAction (
		Set True to actioninprogress,
		Set entries to resetExplicitApproval.ticketreviewrecorduid,
		Set [statustowrite repeat SizeOf entries] to resetExplicitApproval.status,
		Set [commenttowrite repeat SizeOf entries] to resetExplicitApproval.comment,
		Set [Date.valueLDAP repeat SizeOf entries] to resetExplicitApproval.actiondate,
		Set updatestatus to resetExplicitApproval.updatestatus,
		Set updatecomment to resetExplicitApproval.updatecomment,
		Set incampaignid to resetExplicitApproval.campaignId,
		TaskComplete resetExplicitApproval
	)
	
	markEntryExplicitelyProcessed_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_ExplicitApprovalTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf entries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction markEntryExplicitelyProcessed,
				// Recursive call on remainder
				ExecuteNamedAction markEntryExplicitelyProcessed_batch
			] otherwise [
				// Done
			]
		}
	)
	
	markEntryExplicitelyProcessed = NamedAction (
		Set True to actioninprogress,
		Set entries_batch to markEntryExplicitelyProcessed.reviewrecorduids,
		Set incampaignid to markEntryExplicitelyProcessed.campaignid,
		TransferData reviewtickets (recorduid, remediationstatus, remediationclosed, remediationcomment, label, remediationtype)
			to  (markEntryExplicitelyProcessed.ticketreviewrecorduid, markEntryExplicitelyProcessed.status, markEntryExplicitelyProcessed.ticketclosed,
					 markEntryExplicitelyProcessed.comment, markEntryExplicitelyProcessed.ticketlabel, markEntryExplicitelyProcessed.tickettype),
		Set [Date.valueLDAP repeat SizeOf markEntryExplicitelyProcessed.ticketreviewrecorduid] to markEntryExplicitelyProcessed.actiondate,
		Set ['' repeat SizeOf markEntryExplicitelyProcessed.ticketreviewrecorduid] to markEntryExplicitelyProcessed.accountableuid,
		TaskComplete markEntryExplicitelyProcessed
	)
	
	getNextBatch_ExplicitApprovalTable_bulkActionButtons = IncludeFragment {
		layout: Layout { grab: horizontal False vertical False }
		fragment: bw_getNextBatch with
			value-of entries to inselectedentries,
			entries_batch binds-to selectedentries_batch
	}
	
	Group {
		styling: cssPageDashboard
		layout: Layout {  grab: horizontal True vertical True}
		Header {
			value: $bwaccess360_accessreviewmanagementPerimeterTable.thresholdwarning( Constant bwReview_display_thresold_warning )
			styling: warningFieldStyle
			hidden:
				IntPredicate( reviewcount ) {
					when > Constant bwReview_display_thresold_warning then False
					otherwise True
				}
		}
		Group {
			styling:cssRound
			layout: Layout { grab:horizontal True vertical False hint:height 40}
			Grid {
				columns: GridColumn, GridColumn, GridColumn { width:grow }
				GridRow {
					GridCell {
						Image {
							image: "various/running.svg"
							hidden:
								Not BooleanPredicate (actioninprogress)
						}
					}
					GridCell {
						ButtonGroup {
							nb-inline:2
							layout:Layout { align:horizontal Beginning vertical Center }
							hidden:
								StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
							Button {
								actions:
									Confirm $bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.confirm,
									Flash $bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.flash,
									Set inselectedentries to entries,
									ExecuteNamedAction markEntryExplicitelyProcessed_batch,
									Unset inselectedentries
								image:"16/famfamfam_silk_icons_v013/cog.png"
								text:$bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.text
								tooltip:$bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.confirm
								hidden: Not BooleanPredicate(ConfigurationVariable "ias_reviewcanproceedsignedentries")
								disabled:
									OrPredicate {
										StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
										IntPredicate(SizeOf inselectedentries) { when =0 then True }
										IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
										Not FeaturePredicate iasr_canmanagecampaignentries
										StringPredicate(inexplicitfilter) { when '2' then True when '3' then True }
										BooleanPredicate (actioninprogress)
									}
							}
							Button {
								actions:
									Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.confirm,
									// reset explicit approval
									Set inselectedentries to entries,
									Set "to be reviewed" to statustowrite,
									Set "" to commenttowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									ExecuteNamedAction resetExplicitApproval_batch, 
											Unset inselectedentries
								image:"16/famfamfam_silk_icons_v013/resultset_previous.png"
								text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.text
								tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.tooltip
								disabled:
									OrPredicate {
										StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
										IntPredicate(SizeOf inselectedentries) { when =0 then True }
										IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
										Not FeaturePredicate iasr_canmanagecampaignentries
										StringPredicate(inexplicitfilter) { when '2' then True when '3' then True }
										BooleanPredicate (actioninprogress)
									}
							}
							Button {
								actions:
									Confirm $bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.confirm,
									Flash $bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.flash,
									FireFragmentEvent "TransferEditableReviewRecordUidToEntries",
									Set infilteredentries to entries,
									ExecuteNamedAction markEntryExplicitelyProcessed_batch
								image:"16/famfamfam_silk_icons_v013/cog.png"
								text:$bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignofall.button.text
								tooltip:$bwaccess360_accessreviewmanagementExplicitApprovalTable.reviewsignof.button.confirm
								hidden: Not BooleanPredicate(ConfigurationVariable "ias_reviewcanproceedsignedentries")
								disabled:
									OrPredicate {
										StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
										IntPredicate(SizeOf inselectedentries) { when =0 then True }
										IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
										Not FeaturePredicate iasr_canmanagecampaignentries
										StringPredicate(inexplicitfilter) { when '2' then True when '3' then True }
										BooleanPredicate (actioninprogress)
									}
							}
							Button {
								actions:
									Confirm $bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.confirm,
									// reset explicit approval
									FireFragmentEvent "TransferEditableReviewRecordUidToEntries",
									Set infilteredentries to entries,
									Set "to be reviewed" to statustowrite,
									Set "" to commenttowrite,
									Set True to updatestatus,
									Set True to updatecomment,
									ExecuteNamedAction resetExplicitApproval_batch
								image:"16/famfamfam_silk_icons_v013/resultset_previous.png"
								text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkresetall.text
								tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkreset.tooltip
								disabled:
									OrPredicate {
										StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
										IntPredicate(SizeOf inselectedentries) { when =0 then True }
										IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
										Not FeaturePredicate iasr_canmanagecampaignentries
										StringPredicate(inexplicitfilter) { when '2' then True when '3' then True }
									}
							}
						}
					}
				}
			}
		}
	}
}