// Buttons to send initial & reminder notifications to selected reviewers
bw_iasreview_followUpNotifications = PageFragment {
	
	// Parameters
	campaignid = Parameter { type: String hidden: True }
	campaignname = Parameter { type: String hidden: True }
	campaigndescription = Parameter { type: String hidden: True }
	campaigndeadline = Parameter { type: Date hidden: True }
	campaignpriority = Parameter { type: Integer hidden: True }
	selectedRevieweruids = Variable { type: String multivalued: True }
	hide = Variable { type: Boolean initial: False }
	
	// EN
	mailcontent_en = Variable { type: String }
	mailtitle_en = Variable { type: String }
	// FR
	mailcontent_fr = Variable { type: String }
	mailtitle_fr = Variable { type: String }
	// ES
	mailcontent_es = Variable { type: String }
	mailtitle_es = Variable { type: String }
	// Default/previous
	mailcontent = Variable { type: String }
	mailtitle = Variable { type: String }
	sendtocc = Variable { type: String }
	sendtobcc = Variable { type: String }
	
	campaign = Record {
		view: bwaccess360_accessreviewcampaigns with
			campaignid to campaignid
	}
	
	openMailDialog = NamedAction (
		Dialog bwaccess360_accessreviewmanagementSendReportsFollowUp(
			campaignid to campaignid,
			selectedRevieweruids to reviewers,
			// EN
			mailcontent_en to emailcontent_en,
			mailtitle_en to emailtitle_en,
			// FR
			mailcontent_fr to emailcontent_fr,
			mailtitle_fr to emailtitle_fr,
			// ES
			mailcontent_es to emailcontent_es,
			mailtitle_es to emailtitle_es,
			// Default / previous
			mailcontent to emailcontent,
			mailtitle to emailtitle,
			sendtocc to emailcc,
			sendtobcc to emailbcc,
			campaignname to campaignname,
			campaigndescription to campaigndescription,
			campaigndeadline to campaigndeadline,
			campaignpriority to campaignpriority,
			campaign.reviewtype to campaigntype,
			campaign.offlinemode to offlinemode,
			campaign.duedate to campaigndeadline
		),
		Flash $bwaccess360_accessreviewmanagementNLS.SendReports.mailsentselected.flash,
		Unset selectedRevieweruids
	)
	
	ButtonGroup {
		align: Center
		uniform: True
		hidden: BooleanPredicate ( hide )
		Button {
			text: $bwaccess360_accessreviewmanagementNLS.SendReports.ini.text
			tooltip: $bwaccess360_accessreviewmanagementNLS.SendReports.ini.tooltip
			image: %collection_16.mail
			actions:
				Call mailcontents(
					campaign.defuid to reviewdefmduid,
					// EN
					mailcontent_en from cfg_en,
					mailtitle_en from cfgtitle_en,
					// FR
					mailcontent_fr from cfg_fr,
					mailtitle_fr from cfgtitle_fr,
					// ES
					mailcontent_es from cfg_es,
					mailtitle_es from cfgtitle_es,
					// Default / previous
					mailcontent from cfg,
					mailtitle from cfgtitle,
					// To & Cc
					sendtocc from cfgtocc,
					sendtobcc from cfgtobcc
				),
				ExecuteNamedAction openMailDialog
			disabled:
				OrPredicate {
					StringPredicate ( campaignid ) {
						when IsEmpty then True
					}
					StringPredicate ( selectedRevieweruids ) {
						when IsEmpty then True
					}
					Not FeaturePredicate iasr_cansendmessage
				}
		}
		Button {
			text: $bwaccess360_accessreviewmanagementNLS.SendReports.reminder.text
			tooltip: $bwaccess360_accessreviewmanagementNLS.SendReports.reminder.tooltip
			image: %collection_16.mail
			actions:
				Call reminderMailContents(
					campaign.defuid to reviewdefmduid,
					// EN
					mailcontent_en from cfg_en,
					mailtitle_en from cfgtitle_en,
					// FR
					mailcontent_fr from cfg_fr,
					mailtitle_fr from cfgtitle_fr,
					// ES
					mailcontent_es from cfg_es,
					mailtitle_es from cfgtitle_es,
					// Default / previous
					mailcontent from cfg,
					mailtitle from cfgtitle,
					// To & Cc
					sendtocc from cfgtocc,
					sendtobcc from cfgtobcc
				),
				ExecuteNamedAction openMailDialog
			disabled:
				OrPredicate {
					StringPredicate ( campaignid ) {
						when IsEmpty then True
					}
					StringPredicate ( selectedRevieweruids ) {
						when IsEmpty then True
					}
					Not FeaturePredicate iasr_cansendmessage
				}
		}
	}
}

// Multivalued combo used to filter on the review status
bw_iasreview_reviewStatusFilter = PageFragment {
	
	campaignid = Variable { type: String }
	filterByReviewStatus = Variable { type: String multivalued: True }
	filterByExplicitStatus = Variable { type: String multivalued: True }
	selectedEntries = Variable { type: String multivalued: True }
	canFilterByStatus = Variable { type: Boolean initial: False }
	
	statuses = Dataset {
		view: bwaccess360r_statuslist with
			campaignid to campaignid,
			filterByExplicitStatus to filterbyexplicitstatus
	}
	
	refreshStatuses = NamedAction (
		ReloadData ( statuses )
	)
	
	Combo {
		variable: filterByReviewStatus
		allow-none: True
		modify-event:
			Unset selectedEntries
		multi-selection: True
		label:
			Label {
				value: $bwaccess360_review.reviewstatus
				align: Left
				layout: Layout { align: vertical Beginning horizontal Beginning }
			} 
		layout: Layout { hint: width 260 }
		hidden:
			Not BooleanPredicate(canFilterByStatus)
		commands:
			Commands {
				orientation: Vertical
				Command {
					icon: %collection_16.refresh
					text: $global.refresh
					tooltip: $global.refreshTt
					actions:
						Unset filterByReviewStatus,
						ExecuteNamedAction refreshStatuses,
						Flash $global.refresh.complete
				}
				Command {
					icon: %status_16.remove
					text: $global.clear
					tooltip: $global.clearTt
					actions:
						Unset filterByReviewStatus
					disabled:
						StringPredicate ( filterByReviewStatus ) {
							when IsEmpty then True
						}
				}
			}
		options:
			Dynamic {
				data: statuses
				value: Current status
				text: Transform Current status using bwReviewStatus
		}
	}
}

/*
 * Split entries to process by batches
 */
bw_getNextBatch = PageFragment {
	
	// Max for MSSQL Server is 2 000
	batchSize = Variable { type: Integer initial: Constant bwReview_batch_thresold }
	// List of all entries (input)
	inselectedentries = Variable { type: String multivalued: True }
	// Current batch for workflow
	selectedentries_batch = Variable { type: String multivalued: True }
	// All remaining entries to process
	selectedentries_todo = Variable { type: String multivalued: True }
	// Processed entries
	selectedentries_done = Variable { type: String multivalued: True }
	
	getNextBatch = NamedAction (
		// Initialization: if no entries have been processes yet, add entries to process to variable
		IntCase ( SizeOf selectedentries_done ) {
			when = 0 then [
				Set inselectedentries to selectedentries_todo
			]
		},
		// Get next batch of entries to process
		Call srv_getFirtNEnties(
			selectedentries_todo to entries,
			batchSize to size,
			selectedentries_batch from result
		),
		// Update done & todo lists
		MultivaluedRemove all selectedentries_batch from selectedentries_todo,
		MultivaluedAdd selectedentries_batch to selectedentries_done,
		IntCase ( SizeOf selectedentries_batch ) {
			when > 0 then [
				// Still entries to process
				MultivaluedAdd selectedentries_batch to selectedentries_done
			] otherwise [
				// No more entries
				Unset selectedentries_done
			]
		}
	)
}

bw_iasreview_PerimeterTable_bulkActionButtons = PageFragment {
	periodic-actions:
		PeriodicAction {
			actions:
				ReloadData (actionInProgress),
				Set actionInProgress.ticketopen to processing,
				BooleanCase (processing) {
					when False then [
						FireFragmentEvent "ReloadTable",
						Set False to actioninprogress
					]
					when True then []
				}
			period: 5
			disabled:
				Not BooleanPredicate (actioninprogress)
		}

	inenabled = Variable { initial:False type:Boolean }	
	incampaignid = Variable
	inselectedentries = Variable { multivalued:True }
	// Current batch of entries for workflow
	inselectedentries_batch = Variable { type: String multivalued: True }
	
	delegatedentries = Variable { multivalued:True }
	
	actioninprogress = Variable { type:Boolean initial: False }
	processing = Variable { type:Boolean initial: False }
	
	changeaccountable = Variable //in?
	updatestatus = Variable { type:Boolean }
	statustowrite = Variable
	updatecomment = Variable { type:Boolean }
	commenttowrite = Variable
	
	newrevieweruid = Variable
	newreviewername = Variable
	
	// Reviewers (accountables + responsibles)
	filterMissingReviewers = Variable { type: Boolean initial: False }

	finalizedreview = Record {
		view: bwaccess360_accessreviewcampaignsfinalized with
			incampaignid to campaignid
		disabled:
			Not BooleanPredicate( inenabled )
	}
	
	delegatedEntries = Dataset {
		view: bwaccess360_delegatedentries with
			inselectedentries_batch to recorduid
		disabled:
			Not BooleanPredicate( inenabled )
	}
	
	actionInProgress = Record {
		view: br_workflowticketstatus_parellelmode with
			incampaignid to custom1,
			"REVIEW" to tickettype,
			Principal.uid to actoruid
	}

	task = TaskRecord( create "bwaccess360_writeAccessRightsReviewTickets")
	reassigntask = TaskRecord( create "bwaccess360_reassignAccessRightsReviewTickets")
	escalatetask = TaskRecord ( create "bwaccess360_performBulkEscalateOperation" )
	resetdelegation = TaskRecord( create "bwaccess360_performBulkResetOperation")
	markEntryExplicitelyReviewed = TaskRecord( create "bwaccess360_performBulkMarkExplicitelyReviewedOperation")
	performBulkActionTask = TaskRecord( create "bwaccess360_performBulkOperation")

	checkActionInProgress = NamedAction (
		ReloadData (actionInProgress),
		Set actionInProgress.ticketopen to actioninprogress
	)

	writeBulkComment = NamedAction (
		Set True to actioninprogress,
		Set inselectedentries_batch to task.ticketreviewrecorduid,
		Set [ statustowrite repeat SizeOf inselectedentries_batch ] to task.status,
		Set [ commenttowrite repeat SizeOf inselectedentries_batch ] to task.comment,
		Set [ Date.valueLDAP repeat SizeOf inselectedentries_batch ] to task.actiondate,
		Set updatestatus to task.updatestatus,
		Set updatecomment to task.updatecomment,
		Set incampaignid to task.campaignId,
		TaskComplete task
	)
	
	writeBulkComment_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction writeBulkComment,
				// Recursive call on remainder
				ExecuteNamedAction writeBulkComment_batch
			] otherwise [
				// Done
			]
		}
	)
	
	bulkSignOff_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction bulkSignOff,
				// Recursive call on remainder
				ExecuteNamedAction bulkSignOff_batch
			] otherwise [
				// Done
			]
		}
	)
	
	bulkSignOff = NamedAction (
		Set True to actioninprogress,
		Set True to markEntryExplicitelyReviewed.forcemarkentry,
		Set incampaignid to markEntryExplicitelyReviewed.campaignid,
		Set inselectedentries_batch to markEntryExplicitelyReviewed.reviewtickets,
		Set Principal.uid to markEntryExplicitelyReviewed.currentreviewer,
		TaskComplete markEntryExplicitelyReviewed
	)
	
	resetDelegation_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction resetDelegation,
				// Recursive call on remainder
				ExecuteNamedAction resetDelegation_batch
			] otherwise [
				// Done
			]
		}
	)
	
	resetDelegation = NamedAction (
		Set True to actioninprogress,
		Set inselectedentries_batch to resetdelegation.ticketreviewrecorduid,
		Set [ statustowrite repeat SizeOf inselectedentries_batch ] to resetdelegation.status,
		Set [ commenttowrite repeat SizeOf inselectedentries_batch ] to resetdelegation.comment,
		Set [ Date.valueLDAP repeat SizeOf inselectedentries_batch ] to resetdelegation.actiondate,
		Set updatestatus to resetdelegation.updatestatus,
		Set updatecomment to resetdelegation.updatecomment,
		TransferData delegatedEntries(recorduid) to (delegatedentries),
		Set delegatedentries to resetdelegation.delegatedticketreviewrecorduid,
		Set incampaignid to resetdelegation.campaignId,
		TaskComplete resetdelegation
	)
	
	performBulkReviewAction_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction performBulkReviewAction,
				// Recursive call on remainder
				ExecuteNamedAction performBulkReviewAction_batch
			] otherwise [
				// Done
			]
		}
	)
	
	performBulkReviewAction = NamedAction (
		Set True to actioninprogress,
		Set inselectedentries_batch to performBulkActionTask.ticketreviewrecorduid,
		Set [ statustowrite repeat SizeOf inselectedentries_batch ] to performBulkActionTask.status,
		Set [ commenttowrite repeat SizeOf inselectedentries_batch ] to performBulkActionTask.comment,
		Set [ Date.valueLDAP repeat SizeOf inselectedentries_batch ] to performBulkActionTask.actiondate,
		Set updatestatus to performBulkActionTask.updatestatus,
		Set updatecomment to performBulkActionTask.updatecomment,
		// reassign entries to the campaign manager
		Set Principal.uid to performBulkActionTask.reviewer,
		Set incampaignid to performBulkActionTask.campaignId,
		TaskComplete performBulkActionTask
	)
	
	performBulkReassignAction_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction performBulkReassignAction,
				// Recursive call on remainder
				ExecuteNamedAction performBulkReassignAction_batch
			] otherwise [
				// Done
			]
		}
	)
	
	performBulkReassignAction = NamedAction (
		Set True to actioninprogress,
		Set inselectedentries_batch to performBulkActionTask.ticketreviewrecorduid,
		Set [ statustowrite repeat SizeOf inselectedentries_batch ] to performBulkActionTask.status,
		Set [ commenttowrite repeat SizeOf inselectedentries_batch ] to performBulkActionTask.comment,
		Set [ Date.valueLDAP repeat SizeOf inselectedentries_batch ] to performBulkActionTask.actiondate,
		Set updatestatus to performBulkActionTask.updatestatus,
		Set updatecomment to performBulkActionTask.updatecomment,
		// reassign entries to selected identity
		Set newrevieweruid to performBulkActionTask.reviewer,
		Set changeaccountable to performBulkActionTask.updateAccountable,
		Set incampaignid to performBulkActionTask.campaignId,
		TaskComplete performBulkActionTask
	)
	
	performBulkEscalation_batch = NamedAction (
		ExecuteFragmentNamedAction getNextBatch_PerimeterTable_bulkActionButtons.getNextBatch,
		IntCase ( SizeOf inselectedentries_batch ) {
			when >0 then [
				// Process current batch
				ExecuteNamedAction performBulkEscalation,
				// Recursive call on remainder
				ExecuteNamedAction performBulkEscalation_batch
			] otherwise [
				// Done
			]
		}
	)
	
	performBulkEscalation = NamedAction (
		Set True to actioninprogress,
		Set inselectedentries_batch to escalatetask.ticketreviewrecorduids,
		Set incampaignid to escalatetask.campaignId,
		TaskComplete escalatetask,
		Unset inselectedentries
	)
	
	checkMissingReviewers = NamedAction (
		ExecuteFragmentNamedAction reviewStatusMissingReviewers.checkMissingReviewers
	)

	getNextBatch_PerimeterTable_bulkActionButtons = IncludeFragment {
		layout: Layout { grab: horizontal False vertical False }
		fragment: bw_getNextBatch with
			value-of inselectedentries to inselectedentries,
			inselectedentries_batch binds-to selectedentries_batch
	}
	Group {
		styling:cssRound
		layout: Layout { grab:horizontal True vertical False hint:height 40}
		Grid {
			columns: GridColumn, GridColumn, GridColumn { width:grow }, GridColumn {}
			GridRow {
				GridCell {
					Image {
						image: "various/running.svg"
						hidden:
							Not BooleanPredicate (actioninprogress)
					}
				}
				GridCell {
					ButtonGroup {
						layout:Layout { align:horizontal Beginning vertical Center }
						nb-inline:2
						hidden:
							StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
						// reassign button
						Button {
							actions:
								Dialog identityPicker(newrevieweruid from outUid, newreviewername from outDisplayname),
								Dialog bwaccess360_accessmanagementreassignconfirm(SizeOf inselectedentries to innbentries,newreviewername to innewreviewername, changeaccountable from outwithaccountable),
								Set "to be reviewed" to statustowrite,
								Set "" to commenttowrite,
