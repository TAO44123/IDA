							disabled:
								OrPredicate {
									StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
									IntPredicate(SizeOf inselectedentries) { when =0 then True }
									IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
