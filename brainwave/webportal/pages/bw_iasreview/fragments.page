								ExecuteNamedAction performBulkEscalation_batch
							image:"16/audit/manager_16.png"
							text:$bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.text
							tooltip:$bwaccess360_accessreviewmanagementPerimeterTable.bulkescalate.tooltip
							disabled:
								OrPredicate {
									StringPredicate(finalizedreview.recorduid) { when IsEmpty then False otherwise True }
									IntPredicate(SizeOf inselectedentries) { when =0 then True }
									IntPredicate(SizeOf inselectedentries) { when > Constant bwReview_selectionMax then True } // SQL limitation
