bwaccess360_groupmembersreviewmanagementExplicitApprovalTable = PageFragment {
	campaignid = Variable
	accountableuid = Variable
	accountablename = Variable
	repositoryname = Variable { initial:"" type:String }
	
	incanshowdetails = Variable { initial:True type:Boolean }
	incanfilterbystatus = Variable { initial:False type:Boolean}
	incanfilterbyrepository = Variable { initial:True type:Boolean}
	incanfilterbyaccount = Variable { initial:True type:Boolean}
	inenabled = Variable { initial:False type:Boolean }
	inrevieweruid = Variable
	inreviewername = Variable
	infilterbyreviewstatus = Variable { multivalued:True }
	infilterbyrepositories = Variable { multivalued:True }
	intimestamp = Variable
	inreviewtype = Variable
	
	outidentityuid = Variable
	outaccountuid = Variable
	outgroupuid = Variable

	selectedentries = Variable { multivalued:True }
	filteredentries = Variable { multivalued:True }

	reviewcount = Variable
	
	selectedrevieweruid = Variable { type: String }
	selectedrepositoryuid = Variable

	reportname = Variable { type: String }
	
	explicitfilter = Variable { initial: "1" type: String }
	explicitfilter_mv = Variable { initial: ["1"] type: String multivalued: True }
	
	editablereview = Dataset {
		view: bwaccess360_repositorygroupmembersforcampaign_bv with
			campaignid to campaignid unless-empty,
			infilterbyreviewstatus to filterbyreviewstatus unless-empty,
			inrevieweruid to revieweruid unless-empty,
			accountableuid to accountableuid unless-empty,
			infilterbyrepositories to filterbyrepositories unless-empty,
			$bwaccess360_accessreviewmanagementNLS.onbehalfof to delegationtext,
			$bwaccess360_review.reviewerAbsent to reviewergonetext,
			explicitfilter_mv to includeexplicitstatus,
			intimestamp to dummy
		// Limit should match bwReview_display_thresold_warning
		limit: 10000
		disabled:
			Not BooleanPredicate(inenabled)
	}

	countreview = Dataset {
		view: bwaccess360_applicationaccessrightsforcampaign_count with
			campaignid to campaignid unless-empty,
			explicitfilter to includeexplicitstatus,
			intimestamp to dummy
		disabled:
			Not BooleanPredicate ( inenabled )
		count-variable: reviewcount
	}

	repositories = Dataset {
		view: bwaccess360r_repositorylist_groupmembers with
			campaignid to campaignid
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid)
			]
			when False then [
			]
		}
	)

	goReviewerDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				StringCase ( selectedrevieweruid ) {
					when IsEmpty then []
					otherwise [
						Dialog bwf_identityDetailsDialog(selectedrevieweruid to inuid)
					]
				}
			]
			when False then [
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowowner,
												True to inshowdecisionhistory,
												True to inshowcontrols
				)
			]
			when False then [
			]
		}
	)

	goRepositoryDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_repositoryDetailsDialog(selectedrepositoryuid to inuid)
			]
			when False then [
			]
		}
	)

	goGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowaccounts,
												True to inshowperjob,
												True to inshowperorg,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			]
		}	
	)
	
	setExplicitFilterToBoth = NamedAction (
		Set '3' to explicitfilter,
		ExecuteNamedAction applyExplicitiFilter
	)
	
	applyExplicitiFilter = NamedAction (
		Unset selectedentries,
		Unset explicitfilter_mv,
		StringCase ( explicitfilter ) {
			when '1' then [
				Set '1' to explicitfilter_mv
			] when '2' then [
				Set '2' to explicitfilter_mv
			] when '3' then [
				Set [ '1', '2' ] to explicitfilter_mv
			]
		}
	)

