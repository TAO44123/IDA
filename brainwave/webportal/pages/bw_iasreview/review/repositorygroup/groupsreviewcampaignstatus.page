bwaccess360_groupmembersreviewmanagementdetailright_dialog = NLS {
	title [ en "Review Details" fr "Détails de la revue" ]
	label.date [ en "Date" fr "Date" ]
	label.reviewer [ en "Reviewed by" fr "Revu par"]
	label.comment [ en "Comment" fr "Commentaire"]
