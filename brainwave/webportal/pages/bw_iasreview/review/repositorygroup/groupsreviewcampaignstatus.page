bwaccess360_groupmembersreviewmanagementActionsTable = PageFragment {
	campaignid = Variable
	filterbyreviewstatus = Variable { multivalued:True }
	filterbyrepositories = Variable { multivalued:True }
	revieweruid = Variable
	reviewername = Variable
	
	incanshowdetails = Variable { initial:True type:Boolean }	
	incanfilterbystatus = Variable { initial:False type:Boolean}	
	incanfilterbyrepository = Variable { initial:True type:Boolean}	
	inenabled = Variable { initial:False type:Boolean }	
	intimestamp = Variable // just to force a dataset refresh...

	outaccountuid = Variable
	outidentityuid = Variable
	outgroupuid = Variable

	review = Dataset {
		view: bwaccess360_repositorygroupmembersandremediationforcampaign with
			campaignid to campaignid unless-empty,
			filterbyreviewstatus to filterbyreviewstatus unless-empty,
			revieweruid to revieweruid unless-empty,
			filterbyrepositories to filterbyrepositories unless-empty,
			intimestamp to dummy unless-empty
		disabled:
			Not BooleanPredicate(inenabled)
	}

	reviewers = Dataset {
		view: bwaccess360r_applicationreviewers with
			campaignid to campaignid
		disabled:
			Not BooleanPredicate(inenabled)
	}
	repositories = Dataset {
		view: bwaccess360r_repositorylist_groupmembers with
			campaignid to campaignid
		disabled:
			Not BooleanPredicate(inenabled)
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowowner,
												True to inshowcontrols
				)
			]
			when False then [
			
			]
		}
	)

	goGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid, 
												True to inshowaccounts,
												True to inshowperjob,
												True to inshowperorg,
												True to inshowcontrols,
												True to inshowdecisionhistory
				)
			]
			when False then [
			
			]
		}	
	) 

	Group {
		styling:cssPageDashboard
		Group {
			layout: Layout { grab:horizontal True vertical True }
			styling:cssRound
			Grid {
				columns:GridColumn,GridColumn,GridColumn,GridColumn { width:grow }
				layout:Layout { grab:horizontal True vertical False hint:height 64 }
				GridRow {
					GridCell {
						Text {
							label:$bwaccess360_accessreviewmanagementPerimeterTable.reviewer
							layout:Layout { hint: width 220 }
							value:reviewername
							tooltip:reviewername
							commands:Commands {
								position:After
								orientation:Horizontal
								Command {
									actions:Dialog bwaccess360_accessreviewmanagementPickReviewer(campaignid to incampaignid, revieweruid from outidentityuid, reviewername from outidentityname)
									icon:%concept_16.identity
								}
								Command {
									actions:Unset reviewername, Unset revieweruid
									icon:%collection_16.delete
								}
							}
						}
					}		
					GridCell {
						Combo {
							variable:filterbyrepositories
							allow-none:True
							multi-selection:True
							label:Label {value:$bwaccess360_accessreviewmanagementActionsTable.repository align:Left layout:Layout { align:vertical Beginning horizontal Beginning } } 
							layout:Layout { hint:width 260 }
							hidden:Not BooleanPredicate(incanfilterbyrepository)
							options:Dynamic {
								data:repositories
								value:Current uid
								text:Current displayname
							}
						}
					}
					GridCell {
						Combo {
							variable:filterbyreviewstatus
							allow-none:True
							multi-selection:True
							label:Label {value:$bwaccess360_accessreviewmanagementActionsTable.reviewstatus align:Left layout:Layout { align:vertical Beginning horizontal Beginning } } 
							layout:Layout { hint:width 260 }
							hidden:Not BooleanPredicate(incanfilterbystatus)
							options:Static {
								Option { value:"ok" text:$fragmentDefaultReviewStatusNLS.ok }
								Option { value:"revoke" text:$fragmentDefaultReviewStatusNLS.revoke }
								Option { value:"update" text:$fragmentDefaultReviewStatusNLS.update }
								Option { value:"to be reviewed" text:$fragmentDefaultReviewStatusNLS.toboreviewed }
								Option { value:"not reviewed" text:$fragmentDefaultReviewStatusNLS.notreviewed }
							}
						}
					}
					GridCell {
					}
				}
			}
			Spacer {
				height:8
			}
			Table {
				data:review
