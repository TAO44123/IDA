	campaignid = Variable { type: String }
	campaignname = Variable { type: String }
	campaigndescription = Variable { type: String }
	campaigndeadline = Variable { type: Date }
	campaignpriority = Variable { type: String }
	campaigntype = Variable { type: String }
	filterbyreviewstatus = Variable { type: String }
	offlinemode = Variable { type: String }
	targetmail = Variable { type: String multivalued: True}
	
	// EN
	emailcontent_en = Variable { type: String initial: "" }
	emailtitle_en = Variable { type: String initial: "" }
	emailcontentout_en = Variable { type: String initial: "" }
	// FR
	emailcontent_fr = Variable { type: String initial: "" }
	emailtitle_fr = Variable { type: String initial: "" }
	emailcontentout_fr = Variable { type: String initial: "" }
	// ES
	emailcontent_es = Variable { type: String initial: "" }
	emailtitle_es = Variable { type: String initial: "" }
	emailcontentout_es = Variable { type: String initial: "" }
	// Default / previous
	emailcontent = Variable { type: String initial: "" }
