bwaccess360_accessreviewmanagement_old = Page {
	title: $bwaccess360_accessreviewmanagementNLS.customTitle
	feature:iasreview_license
	mixins: simpleReport	
	
	/* Parameters here */
	
	/* Variables here */
	campaignid = Variable
	statuspage = Variable
	currentcampaignstatus = Variable
	finalizepage = Variable
	offlinemode = Variable
	campaignname = Variable
	campaigndescription = Variable
	campaignsubmissiondate = Variable
	campaigndeadline = Variable { type:Date }
	campaignpriority = Variable
	finalizedcampaignrecorduid = Variable
	nbreviewed = Variable
	campaigntype = Variable
	
	newcampaign_name = Variable	
	newcampaign_type = Variable	
		
	
	/* Datasets and records here */
	campaigns = Dataset { // all campaigns
		view:bwaccess360_accessreviewcampaignsbv with ["ok","update","revoke"] to filterbystatus, True to v22only
		excludes:
			AndPredicate {
				Not SameValuePredicate(Current launchedbyuid, Principal.uid)
				FeaturePredicate iasr_canonlylistitsowncampaigns
			}
	}

	updatecampaigninfos = TaskRecord(create "bwr_updatecampaigninfos")
	deletetask = TaskRecord(create "bwaccess360_deleteCampaign")
	markLatestReviewStatus = TaskRecord(create "bwa_markLatestReviewStatus")
	markEntryExplicitelyReviewed = TaskRecord( create "bwaccess360_markEntryExplicitelyReviewed")
	
	goToDetails = NamedAction (
		GoTo Dynamic("page", statuspage) with
						campaignid to campaignid,
						campaignname to campaignname,
						campaigndescription to campaigndescription,
						campaigndeadline to campaigndeadline,
						campaignpriority to campaignpriority
	)
	
	pauseCampaign = NamedAction (
		StringCase(campaignid) {
			when Not IsEmpty then [
				Set "pause" to updatecampaigninfos.currentstatus,
				Set campaignid to updatecampaigninfos.campaignid,
				TaskComplete updatecampaigninfos wait-end timeout-seconds 30,
				Flash Information $bwaccess360_accessreviewmanagementNLS.pause.flash,
				ReloadData(campaigns)
			]
		}
	)
	resumeCampaign = NamedAction (
		StringCase(campaignid) {
			when Not IsEmpty then [
				Set "active" to updatecampaigninfos.currentstatus,
				Set campaignid to updatecampaigninfos.campaignid,
				TaskComplete updatecampaigninfos wait-end timeout-seconds 30,
				Flash Information $bwaccess360_accessreviewmanagementNLS.resume.flash,
				ReloadData(campaigns)
			]
		}
	)
	
	/* Page content */
	Group {
       layout: Layout { grab:horizontal True vertical True}
       styling: cssPageDashboard

		Spacer {
			height:8
		}
		Group {
	        styling: cssRound
	        layout: Layout { grab:horizontal True vertical False hint:height 40}
	        
			ButtonGroup {
				align:Left
				nb-inline:7
				Button {
					actions:	Dialog bwaccess360_accessreviewmanagementNew(newcampaign_name from outname, newcampaign_type from outtype),
								GoTo Dynamic (newcampaign_type, newcampaign_name)
								
					text:$bwaccess360_accessreviewmanagementNLS.new // "Create new review"
					tooltip:$bwaccess360_accessreviewmanagementNLS.new.tooltip // "Create and launch a new review campaign"
					image:%status_16.add		
					disabled:
						OrPredicate {
							Not FeaturePredicate iasr_cancreate
							StringPredicate(PageTimeslot.Status) { when "C" then False otherwise True }
						}
				}
				Button {
					actions:ExecuteNamedAction goToDetails
					text:$bwaccess360_accessreviewmanagementNLS.details
					tooltip:$bwaccess360_accessreviewmanagementNLS.details.tooltip
					image:%browsing_16.expand
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							StringPredicate(currentcampaignstatus) { when "init" then True }
							StringPredicate(currentcampaignstatus) { when "finalizing" then True }
							Not FeaturePredicate iasr_canshowdetails
						}
				}
				Button {
					actions:ExecuteNamedAction pauseCampaign
					layout:Layout { hint: width 140 grab:horizontal True vertical False }
					text:$bwaccess360_accessreviewmanagementNLS.pause.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.pause.tooltip
					image:%browsing_16.pause
					disabled:
					OrPredicate {
						StringPredicate(currentcampaignstatus) { when "active" then False otherwise True }
						Not FeaturePredicate iasr_canpause
					}				
					hidden:StringPredicate(currentcampaignstatus) { when "pause" then True otherwise False }
				}
				Button {
					actions:ExecuteNamedAction resumeCampaign
					layout:Layout { hint: width 140 grab:horizontal True vertical False }
					text:$bwaccess360_accessreviewmanagementNLS.resume.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.resume.tooltip
					image:%browsing_16.forward
					disabled:Not FeaturePredicate iasr_canpause
					hidden:StringPredicate(currentcampaignstatus) { when "pause" then False otherwise True }
				}
				Button {
					actions:
						Dialog bwaccess360_accessreviewmanagementSendReports(campaignid to campaignid,
															campaignname to campaignname,
															campaigndescription to campaigndescription,
															campaigndeadline to campaigndeadline,
															campaignpriority to campaignpriority,
															campaigntype to campaigntype,
															offlinemode to offlinemode
															),
						Flash $bwaccess360_accessreviewmanagementNLS.SendReports.mailsent.flash
					text:$bwaccess360_accessreviewmanagementNLS.SendReports.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.SendReports.tooltip
					image:%collection_16.mail
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							StringPredicate(currentcampaignstatus) { when "active" then False otherwise True }
							Not FeaturePredicate iasr_cansendmessage
						}
				}
				Button {
					actions:
						//Dialog bwaccess360_accessreviewmanagementupload(campaignid to incampaignid),
						ReloadData(campaigns)
					text:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.tooltip
					image:%report_16.upload
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							StringPredicate(offlinemode) { when "1" then False otherwise True }
							StringPredicate(currentcampaignstatus) { when "active" then False otherwise True }
							Not FeaturePredicate iasr_canupload
						}
				}
				Button {
					actions:
						GoTo Dynamic("page", finalizepage) with campaignid to campaignid, nbreviewed to currentprogress
						//,Dialog bwaccess360_accessreviewmanagementFinalize(campaignid to incampaignid)
						//,ReloadData (campaigns)
					text:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementFinalize.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementFinalize.tooltip
					image:%status_16.check
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							StringPredicate(currentcampaignstatus) { when "active" then False when "pause" then False otherwise True }
							Not FeaturePredicate iasr_canfinalize
						}
				}
				Button {
					actions:
						DownloadComplianceReport finalizedcampaignrecorduid
					text:$bwaccess360_accessreviewmanagementNLS.compliancereport
					tooltip:$bwaccess360_accessreviewmanagementNLS.compliancereport.tooltip
					image:%report_16.report
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							Not HasComplianceReportPredicate(finalizedcampaignrecorduid)
							Not FeaturePredicate iasr_candownloadcompliancereport
						}
				}
				Button {
					actions:
						Dialog bwaccess360_accessreviewmanagementGantt
					text:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementGantt.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.accessreviewmanagementGantt.tooltip
					image:%collection_16.calendar
					disabled:Not FeaturePredicate iasr_canshowplanning
				}
				Button {
					actions:
								Confirm $bwaccess360_accessreviewmanagementNLS.refreshcompliance.confirm,
								Set True to markLatestReviewStatus.filterpartialcampaigns, 
								TaskComplete markLatestReviewStatus, // re-init the latest review status
								Flash Information $bwaccess360_accessreviewmanagementNLS.refreshcompliance.flash
						
					image:%collection_16.refresh_round
					text:$bwaccess360_accessreviewmanagementNLS.refreshcompliance.button
					disabled:Not FeaturePredicate iasr_canrefreshstatus
				}
				Button {
					actions:
						Confirm $bwaccess360_accessreviewmanagementNLS.delete.confirm,
						Set campaignid to deletetask.campaignid,
						TaskComplete deletetask wait-end timeout-seconds 180, // delete the campaign
						StringCase(currentcampaignstatus) {
							when "closed" then [
								Set True to markLatestReviewStatus.filterpartialcampaigns, 
								TaskComplete markLatestReviewStatus // re-init the latest review status
							]				
						},
						Flash $bwaccess360_accessreviewmanagementNLS.delete.confirm,
						ReloadData(campaigns)
						
					text:$bwaccess360_accessreviewmanagementNLS.delete.text
					tooltip:$bwaccess360_accessreviewmanagementNLS.delete.tooltip
					image:%status_16.delete
					disabled:
						OrPredicate {
							StringPredicate(campaignid) { when IsEmpty then True }
							StringPredicate(currentcampaignstatus) { when "pause" then False when "closed" then False when "cancelled" then False otherwise True }
							Not FeaturePredicate iasr_candeletecampaign
						}
				}
			}
		}
				
		Spacer {
			height:8
		}

		Group {
	        styling: cssRound
	        layout: Layout { grab:horizontal True vertical True}
	        
			ConditionalGroup {
	
			IntCondition(Count campaigns) {
				when >0 then [
					Table {
						data:campaigns
						layout: Layout { grab: horizontal True vertical True }
						show-filter:True
						show-count:True
						configurable:True
						persist-configuration:True
						initial-sort: ticketnumber descending
						
						Column {
							column:currentcampaignstatus
							selection:currentcampaignstatus
							hidden:True
						}
						Column {
							column:statuspage
							selection:statuspage
							hidden:True
						}
						Column {
							column:finalizepage
							selection:finalizepage
							hidden:True
						}
						Column {
							column:offlinemode
							selection:offlinemode
							hidden:True
						}
						Column {
							column:recorduid
							selection:campaignid
							hidden:True
						}
						Column {
							column:ticketnumber
							header:$bwaccess360_accessreviewmanagementNLS.cticketnumber
							width:90px
							filterable:True
							sortable:True
							align:Right
							image:TemplateImageSelection (Current currentcampaignstatus) using bwaccess360_accessreviewmanagementStatus
							actions:
								StringCase(currentcampaignstatus) { when "init" then [ ] when "finalizing" then [ ] otherwise [ ExecuteNamedAction goToDetails ] }
							actions-disabled:Not FeaturePredicate iasr_canshowdetails
						}
						Column {
							column:title
							tooltip:Current description
							header:$bwaccess360_accessreviewmanagementNLS.cname
							width:100%
							filterable:True
							sortable:True
							align:Right
							selection:campaignname
							actions:
								StringCase(currentcampaignstatus) { when "init" then [ ] when "finalizing" then [ ] otherwise [ ExecuteNamedAction goToDetails ] }
							actions-disabled:Not FeaturePredicate iasr_canshowdetails
						}
						Column {
							column:description
							tooltip:Current description
							header:$bwaccess360_accessreviewmanagementNLS.cdescription
							initially-masked:True
							width:300px
							filterable:True
							sortable:True
							align:Right
							selection:campaigndescription
							actions:
								StringCase(currentcampaignstatus) { when "init" then [ ] when "finalizing" then [ ] otherwise [ ExecuteNamedAction goToDetails ] }
							actions-disabled:Not FeaturePredicate iasr_canshowdetails
						}
						Column {
							column:prioritylevel
							header:$bwaccess360_accessreviewmanagementNLS.cprioritylevel
							width:100px
							sortable:True
							selection:campaignpriority
							align:Right
						}
						Column {
							column:submissiondate
							text:SubString(10) Current submissiondate
							width:160px
							header:$bwaccess360_accessreviewmanagementNLS.csubmissiondate
							sortable:True
							selection:campaignsubmissiondate
							align:Right
						}
						Column {
							column:duedate
							text:SubString(10) Current duedate
							width:160px
							header:$bwaccess360_accessreviewmanagementNLS.cduedate
							sortable:True
							selection:campaigndeadline
							align:Right
						}
						Column {
							column:finalized_closedate
							text:SubString(10) Current finalized_closedate
							width:160px
							header:$bwaccess360_accessreviewmanagementNLS.cfinalizedon
							sortable:True
							align:Right
						}
						Column {
							column:nbdayssince
							width:120px
							header:$bwaccess360_accessreviewmanagementNLS.cnbdaysince.header
							sortable:True
							align:Right
						}
						Column {
							column:nbdaysleft
							width:100px
							header:$bwaccess360_accessreviewmanagementNLS.cnbdaysleft.header
							sortable:True
							align:Right
						}
						Column {
							column:reviewed_nb
							hidden:True
							selection:nbreviewed
						}
						Column{
							column:nbtotal 
							width:100px
							text:Concat(NonEmpty(Current reviewed_nb,0) , '/', Current nbtotal) 
							header:$bwaccess360_accessreviewmanagementNLS.cprogress
							sortable:True 
							image:TemplateImageSelection(Ratio(Product(Current reviewed_nb,100), Current nbtotal,'{0,number,#}')) using br_campaignManagerPieProgress
						}
						Column {
							column:reviewtype
							width:100px
							header:$bwaccess360_accessreviewmanagementNLS.creviewtype
							text: Transform Current reviewtype using reviewtypemapping
							sortable:True
							filterable:True
							align:Right
							initially-masked:True
							selection:campaigntype
						}
						Column {
							column:finalized_recorduid
							hidden:True
							selection:finalizedcampaignrecorduid
						}
				
						Column {
							column:launchedbyhrcode
							width:100px
							header:$bwaccess360_accessreviewmanagementNLS.claunchedbyhrcode
							initially-masked:True
							sortable:True
							filterable:True
							align:Right
						}
						Column {
							column:launchedbyfullname
							width:160px
							header:$bwaccess360_accessreviewmanagementNLS.claunchedbyfullname
							initially-masked:True
							sortable:True
							filterable:True
							align:Right
						}
						Column {
							column:launchedbymail
							width:160px
							header:$bwaccess360_accessreviewmanagementNLS.claunchedbymail
							initially-masked:True
							sortable:True
							filterable:True
							align:Right
						}
					}
				]
				otherwise [
					Spacer {
						height:Fill
					}
					Header {
						value:$bwaccess360_accessreviewmanagementNLS.empty
						layout:Layout { grab: horizontal True vertical False align:horizontal Center vertical Beginning }
					}		
					Image {
						image:%collection.checked
						image-size:300 300
						layout:Layout { grab: horizontal True vertical True align:horizontal Center vertical Beginning }
					}	
					Spacer {
						height:Fill
					}
				]		
			}
		}
		}
	}
}

