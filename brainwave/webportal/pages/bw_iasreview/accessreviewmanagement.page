	emailbcc = Variable { type: String initial: "" }
	mailstrategyonline =  Variable { initial: $bwaccess360_accessreviewmanagementSendReportsNLS.mailstrategyselected._2 }
	mailstrategy = Variable { type: Integer initial: 0 }

	mailstrategyoffline = Variable { type: Integer initial: 0 }
		
	notificationwithreport = Variable { type: String }
	notificationwithoutreport = Variable { type: String }
	
	reviewdefmduid = Variable { type: String }
	
	supportedLanguages = Variable { type: String initial: ConfigurationVariable "ias_supportedlanguages" }
	
	// Workflow notification
	notify = TaskRecord ( create "bwir_followUpNotification" )
	
	reviewer = Dataset {
		view: bwaccess360_accessreviewselectedreviewersforcampaign with
			reviewers to reviewuids
	}
	
	// Notify via a workflow (ExecuteNotifyRule does not work)
	notify = NamedAction (
		Set mailstrategy to notify.mailstrategy,
		Set offlinemode to notify.offlinemode,
		Set mailstrategy to notify.mailstrategy,
		Set reviewers to notify.reviewerUids,
		Set campaignid to notify.campaignid,
		Set campaignname to notify.campaignname,
		Set campaigndescription to notify.campaigndescription,
		Set Date(campaigndeadline).valueLDAP to notify.campaigndeadline,
		Set False to notify.isoffline,
		Set campaignpriority to notify.campaignpriority,
		Set campaigntype to notify.campaigntype,
		// EN
		Set emailtitle_en to notify.reviewtitle_en,
		Set emailcontentout_en to notify.reviewmessage_en,
		// FR
		Set emailtitle_fr to notify.reviewtitle_fr,
		Set emailcontentout_fr to notify.reviewmessage_fr,
		// EN
		Set emailtitle_es to notify.reviewtitle_es,
		Set emailcontentout_es to notify.reviewmessage_es,
		// Default / previous
		Set emailtitle to notify.reviewtitle,
		Set emailcontentout to notify.reviewmessage,
		// BB & CC
		Set emailcc to notify.emailcc,
		Set emailbcc to notify.emailbcc,
		Set reportname to notify.reportname,
		Set filterbyreviewstatus to notify.filterbyreviewstatus,
		Set True to notify.filternotsignedofonly,
		TaskSave notify,
		TaskComplete notify
	)
	
	sendNotifications = NamedAction (
		// This is to ensure the dynamic body is correctly parsed if it contains variables:
		Set Eval "prefixmail.get() + emailcontent.get()" to emailcontentout,
		Set Eval "prefixmail.get() + emailcontent_en.get()" to emailcontentout_en,
		Set Eval "prefixmail.get() + emailcontent_fr.get()" to emailcontentout_fr,
		Set Eval "prefixmail.get() + emailcontent_es.get()" to emailcontentout_es,
		// With or without report
		StringCase ( offlinemode ) {
			when "1" then [
				Set mailstrategyoffline to mailstrategy					
			] otherwise [
				// No report
				Set "2" to mailstrategy					
			]
		},
		// Filter on status if needed
		IntCase ( mailstrategy ) {
			when =1 then [
				// pending only
				Set Constant review_status_toBeReviewed to filterbyreviewstatus
			] otherwise [
				Set '' to filterbyreviewstatus
			]
		},
		ExecuteNamedAction notify
	)

