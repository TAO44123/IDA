	emailcontentout = Variable { type: String initial: "" }
	reviewers = Variable { type: String multivalued: True }
	prefixmail = Variable { type: String initial: "{$''}" }
	
	reportname = Variable { type: String initial: $bwaccess360_accessreviewmanagementSendReportsNLS._reportname }
	emailto = Variable { type: String initial: "" }
