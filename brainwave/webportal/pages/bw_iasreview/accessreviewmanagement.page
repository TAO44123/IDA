bwaccess360_accessreviewmanagementStatus = StringImageTemplate {
	// currentstatus = init, active, pause, finalizing, closed, cancelled
	when 'init' then %collection_16.clock
	when 'active' then %browsing_16.forward
	when 'pause' then %browsing_16.pause
	when 'finalizing' then %collection_16.clock
	when 'closed' then %status_16_green.check
	when 'cancelled' then %status_16_green.cancel
}


