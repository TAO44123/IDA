bwaccess360_accessreviewmanagementfileparser = EventService {
	javascript-file:"/webportal/pages/bw_iasreview/accessreviewmanagement.javascript"
	javascript-method:parseFile
	
	filename = Input { mandatory: True}
	campaignId = Input { type: String mandatory: True }
	reviewstatus = Output{ type:String multivalued:True }
	reviewcomment = Output{ type:String multivalued:True }
	reviewrecorduid = Output{ type:String multivalued:True }
	invalidReview = Output { type: Boolean }
}

bwaccess360_accessreviewmanagementabovethreshold = Dialog {
	title: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.title
	width: 600
	buttons:[
		OkButton {
			disabled:  Eval "reviewrecorduid.length == 0 || invalidReview.get() == true " 
			actions:
				Set reviewstatus to task.status,
				Set reviewcomment to task.comment,
				Set reviewactiondate to task.actiondate,
				Set reviewrecorduid to task.ticketreviewitem,
				Set incampaignid to task.currentcampaignid,
				Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.flash,
				TaskComplete task wait-end timeout-seconds 300
		}
		CancelButton
		]
		
	incampaignid = Variable { type: String }
	inreviweruid = Variable { type: String }
	inreviewtype = Variable { type: String }
	inreviewtitle = Variable { type: String }
	inreviewtickets = Variable { type: String multivalued: True }
	remainingreviewtickets = Variable { type: String multivalued: True }
	
	filename = Variable { type: String }

	reviewstatus = Variable { type: String multivalued: True }
	reviewcomment = Variable { type: String multivalued: True }
	reviewrecorduid = Variable { type: String multivalued: True }
	reviewactiondate = Variable { type: Date multivalued: True }
	invalidReview = Variable { type: Boolean initial: False }

	uploaddisabled = Variable { type: Boolean initial: False }
	allowsignoff = Variable { type: Boolean initial: False }
	signoff = Variable { type: Boolean initial: False }
	isAbove = Variable { type: Boolean initial: False }

	task = TaskRecord(create "bwaccess360_uploadAccessRightsReviewTickets")

	Header {
		value: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.description
		hidden:
			Not BooleanPredicate ( isAbove )
	}
	Header {
		value: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.description
		hidden:
			BooleanPredicate ( isAbove )
	}
	Group {
		hidden:
			Not BooleanPredicate ( isAbove )
		// Access rights review
		ButtonGroup {
			align: Right
			hidden:
				Not SameValuePredicate( inreviewtype, Constant campaign_type_rights )
			Button {							
				actions:  
					Set Concat( $bwaccess360_accessreviewmanagementNLS.reportName.rights, inreviewtitle) to filename,
					ExportReport "reports/bw_access360/accessrightsreviewperapplication.rptdesign" 
						with
							inreviweruid to revieweruid,
							incampaignid to campaignid no-cache
						export-name filename									
						format "xlsx",		
					Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.generating_flash
				text: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport
				tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport_tooltip
				layout: Layout align: Right
			}
		}
		// Account review
		ButtonGroup {
			align: Right	
			hidden:
				Not SameValuePredicate( inreviewtype, Constant campaign_type_account )
			Button {
				actions:  
					Set Concat( $bwaccess360_accessreviewmanagementNLS.reportName.accounts, inreviewtitle) to filename,
					ExportReport "reports/bw_access360/accountsreviewperrepository.rptdesign" 
						with
							inreviweruid to revieweruid,
							incampaignid to campaignid no-cache
						export-name filename									
						format "xlsx",
					Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.generating_flash
				text: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport
				tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport_tooltip
				layout: Layout align: Right
			}
		}
		// Safe review
		ButtonGroup {
			align: Right	
			hidden:
				Not SameValuePredicate( inreviewtype, Constant campaign_type_safe )
			Button {
				actions:  
					Set Concat( $bwaccess360_accessreviewmanagementNLS.reportName.safe, inreviewtitle) to filename,
					ExportReport "reports/bw_cloud_pam/review/accessrightsreviewpersafe.rptdesign" 
						with
							inreviweruid to revieweruid,
							incampaignid to campaignid no-cache
						export-name filename									
						format "xlsx",
					Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.generating_flash
				text: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport
				tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport_tooltip
				layout: Layout align: Right
			}
		}
		// Group member review
		ButtonGroup {
			align: Right	
			hidden:
				Not SameValuePredicate( inreviewtype, Constant campaign_type_members )
			Button {
				actions:  
					Set Concat( $bwaccess360_accessreviewmanagementNLS.reportName.members, inreviewtitle) to filename,
					ExportReport "reports/bw_access360/groupmembersreviewperrepository.rptdesign" 
						with
							inreviweruid to revieweruid,
							incampaignid to campaignid no-cache
						export-name filename									
						format "xlsx",
					Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.generating_flash
				text: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport
				tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport_tooltip
				layout: Layout align: Right
			}
		}
		// Servers review
		ButtonGroup {
			align: Right
			hidden:
				Not SameValuePredicate( inreviewtype, Constant campaign_type_servers )
			Button {							
				actions:  
					Set Concat( $bwaccess360_accessreviewmanagementNLS.reportName.servers, inreviewtitle) to filename,
					ExportReport "reports/bw_access360/accessrightsreviewperapplication.rptdesign" 
						with
							inreviweruid to revieweruid,
							incampaignid to campaignid no-cache
						export-name filename									
						format "xlsx",		
					Flash $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.generating_flash
				text: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport
				tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementabovethreshold.getreport_tooltip
				layout: Layout align: Right
			}
		}
	}
	FileUpload {
		uploaded-filename: filename
		disabled:
			BooleanPredicate ( uploaddisabled )
		upload-complete-event:
			Set True to uploaddisabled,
			MultivaluedAdd inreviewtickets to remainingreviewtickets,
			Call bwaccess360_accessreviewmanagementfileparser(
				filename to filename,
				incampaignid to campaignId,
				reviewstatus from reviewstatus,
				reviewcomment from reviewcomment,
				reviewrecorduid from reviewrecorduid,
				invalidReview from invalidReview
			),
			MultivaluedRemove all [ "", Constant bwReviewStatus_ToBeReviewed ]  from reviewstatus and (reviewcomment, reviewrecorduid),
			MultivaluedRemove all "" from reviewrecorduid and (reviewcomment, reviewstatus),
			Set [Date.valueLDAP repeat SizeOf reviewrecorduid] to reviewactiondate,
			// Check if all entries have been reviewed
			MultivaluedRemove all reviewrecorduid from remainingreviewtickets,
			IntCase ( SizeOf remainingreviewtickets ) {
				when = 0 then [
					Set True to allowsignoff
				]
			}
	}
	
	Header {
		value: Concat(SizeOf reviewrecorduid, $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.header)
		hidden: Eval " reviewrecorduid.length == 0 || invalidReview.get() == true"			
	}
	Header {
	  value: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.wrongFile
	  hidden: Eval "invalidReview.get() == false"
	}
	// Signoff if all entries have been reviewed
	Group {
		hidden:
			Not BooleanPredicate ( allowsignoff )
		Checkbox {
			label: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.signoff
			tooltip: $bwaccess360_accessreviewmanagementNLS.accessreviewmanagementupload.signoffTt
			variable: signoff
		}
	}
}


