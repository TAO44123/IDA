	Edit {
		variable:reportname
		label:Label { value:$bwaccess360_accessreviewmanagementSendReportsNLS.reportname }
		hidden:
			OrPredicate {
				StringPredicate(offlinemode) { when "1" then False otherwise True }
				IntPredicate(mailstrategyoffline) {
