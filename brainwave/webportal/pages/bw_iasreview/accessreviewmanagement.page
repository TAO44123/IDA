						when =0 then True
						when =1 then True
					}
				}
		template:textEditorArea
		layout:Layout {grab:horizontal True vertical True}
		bindings:
		emailcontentonline binds-to content,
		value-of False to readonly
	}
	
	//Mode online
	IncludeHTMLWidget {
		hidden: StringPredicate(offlinemode) { when "0" then False otherwise True }
		template:textEditorArea
		layout:Layout {grab:horizontal True vertical True}
		bindings:
		emailcontentonline binds-to content,
		value-of False to readonly
	}
						
