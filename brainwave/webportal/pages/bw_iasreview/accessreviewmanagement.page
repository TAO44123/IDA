		template:textEditorArea
		layout:Layout {grab:horizontal True vertical True}
		bindings:
		emailcontent binds-to content,
		value-of False to readonly
	}

	//Mode offline notif without report
	IncludeHTMLWidget {
		hidden: OrPredicate {
					StringPredicate(offlinemode) { when "1" then False otherwise True }
