	pages = Dataset {
		pages:			
			Pages {
				tags: "newiasreview"				
			}
			excludes: 
				AndPredicate { 
					StringPredicate(Current name) { when 'bwir_cloud_pam_accessrightsreviewcampaignconfiguration' then True }
