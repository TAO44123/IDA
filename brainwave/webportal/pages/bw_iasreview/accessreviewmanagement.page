				actions:
					MultivaluedIterate permissionnames as app_name[
						Set Concat(outpermissionsstring, " ", Current app_name, " ") to outpermissionsstring
					]
				}
			CancelButton
		]

	incampaignid = Variable { type: String }
	inappfilter = Variable { type: String multivalued: True }
	inoutpermissionuid = Variable { type: String multivalued: True }
	outpermissionsstring = Variable { type: String initial:"" }
