								ReloadData(itsminitinprogress),
								IntCase(itsminitinprogress.nb) {
									when >0 then [
										Message $access360_remediationmanagementNLS.action.new.error
									]
									otherwise [
										Confirm $access360_remediationmanagementNLS.action.new.confirm, 
										// We launch ALL pending remediation because for ITSM they have to be grouped by target
										//Set selectedentries to launchpendingremediation.filterbytickets,
										TaskComplete launchpendingremediation wait,
										Flash $access360_remediationmanagementNLS.action.new.flash
									]
								}
							disabled:
								OrPredicate { 
