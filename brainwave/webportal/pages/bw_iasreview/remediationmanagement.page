bwaccess360_remediationmanagementSendNotification = Dialog {
	title:$access360_remediationmanagementNLS.notificationdialog.title
	width:1200
	height:700
	buttons:[
			OkButton {
				actions:
				Confirm $access360_remediationmanagementNLS.notificationdialog.confirm,
				Set '' to filterbyreviewstatus,
				ExecuteNotifyRule bwaccess360r_accessreviewperapplicationremediation with
													campaignid to campaignid,
													campaignname to campaignname,
													campaigndescription to campaigndescription,
													Date(campaigndeadline).valueLDAP to campaigndeadline,
													campaignpriority to campaignpriority,
													emailtitle to reviewtitle,
													emailcontent to reviewmessage,
													emailcc to emailcc,
													emailbcc to emailbcc,
				Message $access360_remediationmanagementNLS.notificationdialog.sent
			}
			CancelButton
			]
			

	campaignid = Variable
	campaignname = Variable
	campaigndescription = Variable
	campaigndeadline = Variable { type:Date }
	campaignpriority = Variable
	filterbyreviewstatus = Variable
	
	emailtitle = Variable {initial:$access360_remediationmanagementNLS.notificationdialog._title }
	emailcontent = Variable {initial:$access360_remediationmanagementNLS.notificationdialog._content }
	emailcc = Variable {initial:"" }
	emailbcc = Variable {initial:"" }

	Header {
		value:$access360_remediationmanagementNLS.notificationdialog.subtitle
		styling:bigTitleStyle
	}
	Separator {
		color:blue
		width:1
	}
	Edit {
		variable:emailcc
		label:Label { value:$access360_remediationmanagementNLS.notificationdialog.sendto_cc }
	}
	Edit {
		variable:emailbcc
		label:Label { value:$access360_remediationmanagementNLS.notificationdialog.sendto_bcc }
	}
	Separator {
		color:blue
		width:1
	}
	Edit {
		variable:emailtitle
		label:Label { value:$access360_remediationmanagementNLS.notificationdialog.mailtitle }
	}

	Text {
		value:''
		compact:True
		label:$access360_remediationmanagementNLS.notificationdialog.mailcontent
		styling:blueStyle
	}
	IncludeHTMLWidget {
		template:textEditorArea
		layout:Layout {grab:horizontal True vertical True}
		bindings:
		emailcontent binds-to content,
		value-of False to readonly
	}
}

bwaccess360_remediationerrors = Dialog {
	title:$access360_remediationmanagementNLS.remediationerrordialog.subtitle
	width:1200
	height:400
	buttons: OkButton
	
	remediationerrors = Dataset {
		view: bwaccess360r_remediationerrors with
			'3' to filterbyrunstatus
	}
	
	Table {
		data:remediationerrors
		layout:Layout { grab:horizontal True vertical True }
		show-count:True
		show-filter:True
		configurable:True
		label:Label { break:True }
		Column {
			column: remediationstatus
			header: $access360_remediationmanagementNLS.remediationerrordialog.status
			initially-masked:False
			width:150px
			sortable:True
			filterable:True
		}
		Column {
			column: remediationinstancecode
			header: $access360_remediationmanagementNLS.remediationerrordialog.instancecode
			initially-masked:False
			width:200px
			sortable:True
			filterable:True
		}
		Column {
			column: remediationerrorreason
			header: $access360_remediationmanagementNLS.remediationerrordialog.error
			initially-masked:False
			width:850px
			sortable:True
			filterable:True
		}
	}
}

bwaccess360_remediationmanagement = Page {
	title: $access360_remediationmanagementNLS.title
	enter-event:
		IntCase ( nbpendingremediation ) {
			when >0 then [
				Set "init" to filterbyclosedstatus
			]
		}
	post-render-event:
		IntCase ( activeTabParam ) {
			when Not InvalidInteger then [
				Set activeTabParam to activeTab
			]
		}
	feature: iasreview_license						
	header:
		PageHeader {
			Button {
				layout: Layout { grab: horizontal True vertical True indent: vertical 4 horizontal 0 }
				text: $access360_remediationmanagementNLS.warningpending ( nbpendingremediation )
				hidden:
					IntPredicate ( nbpendingremediation ) {
						when >0 then False
						otherwise True
					}
				presentation: Link
				styling: warningFieldStyle
				actions:
					Unset filterbyremediationstatus,
					Set 'init' to filterbyclosedstatus,
					Set 1 to activeTab 
			}
			Button {
				layout: Layout { grab: horizontal True vertical True indent: vertical 4 horizontal 0 }
				text: $access360_remediationmanagementNLS.warningerror ( nberroringremediation )
				hidden:
					IntPredicate ( nberroringremediation ) {
						when >0 then False
						otherwise True
					}
				presentation: Link
				styling: warningFieldStyle
				actions:
					Unset filterbyremediationstatus,
					Set 'error' to filterbyclosedstatus,
					Set 1 to activeTab 
			}
	}
	
	activeTabParam = Parameter { hidden:True type:Integer mandatory:False  }
	
	filterbyremediationstatus = Variable { multivalued:True }
	filterbyclosedstatus = Variable { initial:'active' }

	revieweruid = Variable
	
	incanshowdetails = Variable { initial:True type:Boolean }	

	outapplicationuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable

	selectedentries = Variable { multivalued:True }
	selectedremediationitsmlink = Variable { type: String }

	nbremediation = Variable { type:Integer }
	nbpendingremediation = Variable { type:Integer }
	nberroringremediation = Variable { type:Integer }
	nbactiveremediation = Variable { type:Integer }
	nbactive7daysremediation = Variable { type:Integer }
	nbclosedremediation = Variable { type:Integer }
	nbcancelledremediation = Variable { type:Integer }
	nbinactiveremediation = Variable { type:Integer }

	nbdiscrepancies = Variable { type:Integer }

	statustowrite = Variable
	commenttowrite = Variable
	statusisclosed = Variable { type:String }
	
	filterolder90days = Variable { type:Boolean initial:True }
	filterbycampaign = Variable
	
	activeTab = Variable
	detailTabActive = Variable { type: Boolean initial: False }
	
	// Overview tab
	
	nbremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbremediation
	}

	nbpendingremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'-1' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbpendingremediation
	}
	
	nberroringremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'3' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nberroringremediation
	}

	nbactiveremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'0' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbactiveremediation
	}

	nbactive7daysremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'0' to filterbyrunstatus, True to filterlessthan7days,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbactive7daysremediation
	}

	nbclosedremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'1' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbclosedremediation
	}

	nbcancelledremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			'2' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbcancelledremediation
	}
	
	nbinactiveremediation = Dataset {
		view: bwaccess360r_applicationnbremediation with
			['1','2'] to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
		count-variable: nbinactiveremediation
	}
	
	nbremediationperstatus = Dataset {
		view: bwaccess360r_applicationnbremediationperstatus with
			'0' to filterbyrunstatus,
			filterolder90days to filterolderthan90days unless-empty,
			filterbycampaign to campaignid unless-empty
	}
	
	nbperday = Dataset {
		view: bwaccess360_applicationnbremediationperday with
			True to sumresult,
			filterbycampaign to campaignid unless-empty
	}

	selectedcampaign = Record {
		view: bwaccess360_accessreviewcampaigns with
			filterbycampaign to campaignid
		disabled:
			StringPredicate ( filterbycampaign ) {
				when IsEmpty then True
			}
	}
	
	// Details tab
	
