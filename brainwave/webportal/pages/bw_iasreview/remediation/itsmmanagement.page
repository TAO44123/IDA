				),
				TaskComplete createitsm wait-end,
				ReloadData (itsm)
			disabled:
				StringPredicate ( recorduid ) {
					when IsEmpty then True
				}
		}
		Button {
			text: $bwiasr_itsmmanagementNLS.action.delete
			tooltip: $bwiasr_itsmmanagementNLS.action.deleteTt
			image: "16/famfamfam_silk_icons_v013/delete_black.png"
			actions:	
				BooleanCase ( Eval "(getnbrepoperitsm.nb>0 || getnbappperitsm.nb>0)?true:false" ) {
					when True then [
						Message $bwiasr_itsmmanagementNLS.action.delete.error						
					] when False then [
						Confirm $bwiasr_itsmmanagementNLS.action.delete.confirm, 
						Set uid to deleteitsm.metadatauid, 
						TaskComplete deleteitsm wait-end, 
						ReloadData ( itsm )
					]
				}
			disabled:
				StringPredicate ( recorduid ) {
					when IsEmpty then True
				}
		}
		Button {
			actions:
				Message "nop"
			disabled: True
			presentation: Link
			text: ""
		}
		Button {
			text: $bwiasr_itsmmanagementNLS.refresh.short
			tooltip: $bwiasr_itsmmanagementNLS.refresh.tooltip
			image: "16/famfamfam_silk_icons_v013/arrow_refresh.png"
			actions:
				Confirm $bwiasr_itsmmanagementNLS.action.refresh.confirm, 
				Set code to refreshpendingremediation.filterbyremediationsintance,
				TaskComplete refreshpendingremediation wait,
				Flash $bwiasr_itsmmanagementNLS.action.refresh.flash 
			disabled:
				StringPredicate ( code ) {
					when IsEmpty then True
				}
		}
	}
