bwiasr_itsmmanagement_testServiceNow_dialog = Dialog {
	title: $bwiasr_itsmmanagementNLS.sn.testticketcreation.result
	height: 250
	enter-event: Set lastServiceNowTest.serverReachable to itsmalive,
		StringCase(ticketType) {
			when Regexp ".*incident" then [
				Set Concat("https://", serviceNowDomain, "/incident.do?sysparm_query=number=", lastServiceNowTest.ticketIdentifier) to testTicketUrl
			]
			when Regexp ".*changerequest" then [
				Set Concat("https://", serviceNowDomain, "/change_request.do?sysparm_query=number=", lastServiceNowTest.ticketIdentifier) to testTicketUrl
			]
		}
	
	buttons: 
		ActionButton {
			text: $bwiasr_itsmmanagementNLS.sn.testticketcreation.close
			actions: CloseDialog Ok
			close: True
		} 
	
	serviceNowDomain = Variable { type: String }
	ticketType = Variable { type: String }
	testTicketUrl = Variable { type: String }
	itsmalive = Variable { type: Boolean }
	
	lastServiceNowTest = Record {
		view: bwiasr_validateservicenowconnection with ticketType to ticketType
	}
	
	ConditionalGroup {
		StringCondition(ticketType) {
			when Regexp ".*ping" then [
				// Ping ServiceNow
				Image {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.testping
					image: BooleanImageSelection(lastServiceNowTest.serverReachable) { 
						when True then "16/famfamfam_silk_icons_v013/accept.png" 
						when False then "16/famfamfam_silk_icons_v013/delete.png" 
					}
				}
				Text {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.errorping
					value: lastServiceNowTest.errorMessagePing
					hidden: BooleanPredicate(lastServiceNowTest.serverReachable)
					compact: True
				}
				// Read ticket type table
				Image {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.testtickettable
					image: BooleanImageSelection(lastServiceNowTest.ticketTableReadable) { 
						when True then "16/famfamfam_silk_icons_v013/accept.png" 
						when False then "16/famfamfam_silk_icons_v013/delete.png" 
					}
				}
				Text {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.errortickettable
					value: lastServiceNowTest.errorMessageTicketType
					hidden: BooleanPredicate(lastServiceNowTest.ticketTableReadable)
					compact: True
				}
				// Read attachment table
				Image {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.testattachmenttable
					image: BooleanImageSelection(lastServiceNowTest.attachmentTableReadable) { 
						when True then "16/famfamfam_silk_icons_v013/accept.png" 
						when False then "16/famfamfam_silk_icons_v013/delete.png" 
					}
				}
				Text {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.errorattachmenttable
					value: lastServiceNowTest.errorMessageAttachment
					hidden: BooleanPredicate(lastServiceNowTest.attachmentTableReadable)
					compact: True
				}
			]
			otherwise [
				// Create a ticket
				Image {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.ticketcreated
					image: BooleanImageSelection(lastServiceNowTest.ticketCreated) { 
						when True then "16/famfamfam_silk_icons_v013/accept.png" 
						when False then "16/famfamfam_silk_icons_v013/delete.png" 
					}
				}
				Text {
					value: lastServiceNowTest.errorMessageTicketType
					hidden: BooleanPredicate(lastServiceNowTest.ticketCreated)
				}
				// Attach a file
				Image {
					label: $bwiasr_itsmmanagementNLS.sn.testticketcreation.fileattached
					image: BooleanImageSelection(lastServiceNowTest.attachmentCreated) { 
						when True then "16/famfamfam_silk_icons_v013/accept.png" 
						when False then "16/famfamfam_silk_icons_v013/delete.png" 
					}
				}
				Button {
					text: $bwiasr_itsmmanagementNLS.sn.testticketcreation.openticket
					actions: BrowseURL testTicketUrl
					hidden: Not BooleanPredicate(lastServiceNowTest.attachmentCreated)
				}
			]
		}
	}
}


bwiasr_itsmmanagement_add = Dialog {
	title:$bwiasr_itsmmanagementNLS.addupdate
	enter-event:StringCase(code) { when IsEmpty then [ Set False to updatemode ] otherwise [ Set True to updatemode ] },
				TransferData itsms(bwr_remediation_itsmdef_code) to (existingcodes),
				ExecuteNamedAction initString_action
	width:800
	height:600
	buttons:
			[
				CancelButton
				OkButton {
					actions: 
						ExecuteNamedAction unsetUnusedFields,
						ExecuteNamedAction updateString_action,
						ExecuteNamedAction encrypt_password_fields,
						ExecuteNamedAction encrypt_fields
					disabled:
						OrPredicate {
							StringPredicate(code) { when IsEmpty then True otherwise False }
							StringPredicate(name) { when IsEmpty then True otherwise False }
							AndPredicate {
								Not BooleanPredicate(updatemode)
								IntPredicate(Count codealreadyexists) { when >0 then True otherwise False }
							}
							AndPredicate {
								StringPredicate(type) { when "Mail" then True otherwise False }
								OrPredicate {
									StringPredicate(string4) { when IsEmpty then True otherwise False }
									StringPredicate(string5) { when IsEmpty then True otherwise False }
								}
							}
							AndPredicate {
								StringPredicate(type) { when "iddm" then True otherwise False }
								OrPredicate {
									StringPredicate(string4) { when IsEmpty then True otherwise False }
									StringPredicate(string5) { when IsEmpty then True otherwise False }
								}
							}
							AndPredicate {
								StringPredicate(type) { when "ServiceNow" then True otherwise False }
								OrPredicate {
									StringPredicate(string4) { when IsEmpty then True otherwise False } // domain
									StringPredicate(string5) { when IsEmpty then True otherwise False } // ticket type
									AndPredicate {
										// Basic auth need login/password
										StringPredicate(string11) { when Constant auth_type_basic then True otherwise False}
										OrPredicate {
											StringPredicate(string6) { when IsEmpty then True otherwise False } // login
											StringPredicate(string7) { when IsEmpty then True otherwise False } // password
										}
									}
									AndPredicate {
										// OAuth need the rest
										StringPredicate(string11) { when Regexp Constant auth_type_oauth_regex then True otherwise False}
										OrPredicate {
											StringPredicate(string12) { when IsEmpty then True otherwise False } // token grant type
											StringPredicate(string13) { when IsEmpty then True otherwise False } // client id
											StringPredicate(string14) { when IsEmpty then True otherwise False } // client secret
											AndPredicate {
												StringPredicate(string12) { when "password" then True otherwise False }
												OrPredicate {
													StringPredicate(string6) { when IsEmpty then True otherwise False } // login
													StringPredicate(string7) { when IsEmpty then True otherwise False } // password
												}
											}
											AndPredicate {
												StringPredicate(string12) { when "refresh_token" then True otherwise False }
												OrPredicate {
													StringPredicate(string15) { when IsEmpty then True otherwise False } // refresh token
													StringPredicate(string17) { when IsEmpty then True otherwise False } // token expiration date	
												}
											}
										}
									}
								}
							}
						}
				}
			]
	
	code = Variable
	name = Variable
	type = Variable
	existingcodes = Variable { multivalued:True }

	string4 = Variable
	string5 = Variable
	string6 = Variable
	string7 = Variable
	string8 = Variable
	string9 = Variable
	string10 = Variable
	string11 = Variable
	string12 = Variable
	string13 = Variable
	string14 = Variable
	string15 = Variable
	string16 = Variable
	string17 = Variable
	string18 = Variable
	string19 = Variable
	string20 = Variable
	
	tmpsnstring5 = Variable
	tmpsnstring11 = Variable
	tmpsnstring12 = Variable
	tmpjirastring5 = Variable
	tmpcyberarkstring5 = Variable
	updatemode = Variable { type:Boolean initial:False }

	itsmalive = Variable { type:Boolean initial:False }
	itsmerrormessage = Variable
	
	sn_table_tickettype_readable = Variable
	sn_table_attachment_readable = Variable
	sn_table_tickettype_errormessage = Variable
	sn_table_attachment_errormessage = Variable
	sn_table_tickettype_message = Variable
	sn_table_attachment_message = Variable
	sn_test_description = Variable { type: String initial: "Test - Radiant Logic" }
	sn_test_type = Variable
	
	itsms = Dataset {
		view:bwiasr_itsms
	}
	codealreadyexists = Dataset {
		columns:existingcodes
		includes: SameValuePredicate(code, Current existingcodes)
	}
	
	validateconnexionservicenow = TaskRecord (create "bwr_validateservicenowconnection")
	
	initString_action = NamedAction(
		StringCase(type) {
			when "ServiceNow" then [
				StringCase(string12) {
					when Not IsEmpty then [ Set string12 to tmpsnstring12 ]
				},
				StringCase(string5) {
					when Not IsEmpty then [ Set string5 to tmpsnstring5 ]
				},
				StringCase(string11) {
					when Not IsEmpty then [ Set string11 to tmpsnstring11 ]
				}
			]
		}
	)
	
	updateString_action = NamedAction(
		StringCase(type) { 
			when "ServiceNow" then [ 
				Set tmpsnstring5 to string5, 
				Set tmpsnstring11 to string11, 
				Set tmpsnstring12 to string12 
			]
			when "Jira" then [ Set tmpjirastring5 to string5 ] 
			when "CyberArk" then [ Set tmpcyberarkstring5 to string5 ] 
		}
	)
	
	encrypt_fields = NamedAction(
		Call bwiasr_itsmmanagement_encryptDecryptFields(
			False to decrypt,
			string4 to string4,
			string5 to string5,
			string6 to string6,
//			string7 to string7,
			string8 to string8,
			string9 to string9,
			string10 to string10,
			string11 to string11,
			string12 to string12,
			string13 to string13,
//			string14 to string14,
			string15 to string15,
			string16 to string16,
			string17 to string17,
			string18 to string18,
			string19 to string19,
			string20 to string20,
			string4 from string4,
			string5 from string5,
			string6 from string6,
//			string7 from string7,
			string8 from string8,
			string9 from string9,
			string10 from string10,
			string11 from string11,
			string12 from string12,
			string13 from string13,
//			string14 from string14,
			string15 from string15,
			string16 from string16,
			string17 from string17,
			string18 from string18,
			string19 from string19,
			string20 from string20
		)
	)
	
	encrypt_password_fields = NamedAction(
		StringCase(string7) { when Not Regexp "nomacro\\:\\{secret\\}.*" then [
				Call bwiasr_itsmmanagement_encryptDecryptFields(
					False to decrypt,
					string7 to string7,
					string7 from string7
				)
			]
		},
		StringCase(string14) { when Not Regexp "nomacro\\:\\{secret\\}.*" then [
				Call bwiasr_itsmmanagement_encryptDecryptFields(
					False to decrypt,
					string14 to string14,
					string14 from string14
				)
			]
		}
	)
	
	unsetUnusedFields = NamedAction(
		StringCase(type) {
			when "ServiceNow " then [
				StringCase(string11) {
					when Constant auth_type_basic then [
						Set "" to string12,
						Set "" to string13,
						Set "" to string14,
						Set "" to string15,
						Set "" to string17,
						Set "" to string18
					]
					when Constant auth_type_oauth then [
						StringCase(string12) {
							when "password" then [
								Set "" to string15,
								Set "" to string17
							]
							when "refresh_token" then [
