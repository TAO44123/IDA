	alldata1 = Dataset {
		join:Join {
			primary-dataset: itsm
			secondary-dataset: repoperitsm
			primary-column: bwr_remediation_itsmdef_code
			secondary-column: bwr_remediation_repository_instancecode
			secondary-prefix: repository
			primary-optional: False
			secondary-cardinality: optional		
		}
	}

	alldata11 = Dataset {
		join:Join {
			primary-dataset: alldata1
			secondary-dataset: appperitsm
			primary-column: bwr_remediation_itsmdef_code
			secondary-column: bwr_remediation_application_instancecode
			secondary-prefix: application
			primary-optional: False
			secondary-cardinality: optional		
		}
	}

	alldata111 = Dataset {
		join:Join {
			primary-dataset:alldata11
			secondary-dataset:safeperitsm
			primary-column:bwr_remediation_itsmdef_code
			secondary-column:bw_remediation_safe_instancecode
			secondary-prefix:safe
			primary-optional:False
			secondary-cardinality:optional		
		}
	}

	alldata1111 = Dataset {
		join:Join {
			primary-dataset: alldata111
			secondary-dataset: adwinserverperitsm
			primary-column: bwr_remediation_itsmdef_code
			secondary-column: bwr_remediation_repository_instancecode
			secondary-prefix: adserver
			primary-optional: False
			secondary-cardinality: optional		
		}
	}
	
	alldata11111 = Dataset {
		join:Join {
			primary-dataset: alldata1111
			secondary-dataset: otherserverperitsm
			primary-column: bwr_remediation_itsmdef_code
			secondary-column: bwr_remediation_repository_instancecode
			secondary-prefix: otherserver
			primary-optional: False
			secondary-cardinality: optional		
		}
	}
		
