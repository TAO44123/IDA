						hidden:StringPredicate(reviewerstrategy) { when 'z' then False otherwise True }
						text:$access360analytics_grouprepository_accountreviewcampaignNLS.tab1.scriptbutton
					}
					Button {
						actions:Confirm $access360analytics_grouprepository_accountreviewcampaignNLS.tab1.previewbutton.tooltip,
								StringCase(reviewerstrategy) {
									// User accounts by the line manager, other accounts by the repository owner
									when "a" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// User accounts by the line manager, all other accounts by the repository owner
									when "d" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "1" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// User accounts by themself, all other accounts by the repository owner
									when "e" then [
										Set "1" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "1" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// User account members by the line manager, tech./service account members by the group owner
									when "f" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "1" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// User account members by the line manager, all other members by the group owner
									when "g" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "1" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// User account members by themself, all other members by the group owner
									when "h" then [
										Set "1" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "1" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// All members by the group owners
									when "i" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "1" to forcegroupownerasreviewer,										
										Unset reviewerstrategyscript
									]																																				
									// "All accounts by the repository owner"
									when "b" then [
										Set "0" to forcehimselfasreviewer,
										Set "1" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
									// "All accounts by the default reviewer"
									when "c" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "1" to forcedefaultreviewerasreviewer,
										Set "0" to forcegroupownerfortechaccounts,
										Set "0" to forcegroupownerforallotheraccounts,
										Set "0" to forcegroupownerasreviewer,
										Unset reviewerstrategyscript
									]
								},
								GoTo Page bwir_grouprepository_membersreviewcampaignpreview with
											totalnbgroupmembers to param_totalnbgroupmembers,
											repositorylist to repositorylist,
											includelatestreviewstatus to includelatestreviewstatus,
											includeleaveraccounts to includeleaveraccounts,
											includeorphanaccounts to includeorphanaccounts,
											includeuseraccounts to includeuseraccounts,
											includetechaccounts to includetechaccounts,
											includedynamicgroups to includedynamicgroups,
											includegroupswithoutowner to includegroupswithoutowner,
											defaultrevieweruid to defaultrevieweruid,
											filterbygrouptag to filterbygrouptag,											
											filterbyaccounttag to filterbyaccounttag,
											filterifalreadyreviewed to filterifalreadyreviewed,
											defaultrevieweruid to defaultrevieweruid,
											forcehimselfasreviewer to forcehimselfasreviewer,
											forcebusinessownerasreviewer to forcebusinessownerasreviewer,
											forcebusinessownerforallotheraccounts to forcebusinessownerforallotheraccounts,
											forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
											forcegroupownerfortechaccounts to forcegroupownerfortechaccounts,
											forcegroupownerforallotheraccounts to forcegroupownerforallotheraccounts,
											forcegroupownerasreviewer to forcegroupownerasreviewer,
											reviewerstrategy to reviewerstrategy,
											reviewerstrategyscript to reviewerstrategyscript,
											advancedmode to advancedmode,
											nbdays to nbdays,
											dynamicmode to dynamicmode,
											staticmode to staticmode,
											taglist to taglist
											save-state
											
											
						disabled:
							OrPredicate {
								IntPredicate(repositorylist) { when <1 then True when >999 then True otherwise False }							
								IntPredicate(totalnbgroupmembers) { when =0 then True when InvalidInteger then True otherwise False }
								AndPredicate {
									Not BooleanPredicate(advancedmode) // si advanced mode, on verifiera apres le calcul de preview...
									IntPredicate(totalnbgroupmembers) { when >Constant access360analytics_grouprepository_membersmaxentries then True when =0 then True when InvalidInteger then True otherwise False } // limite arbitraire pour l'instant pour eviter de planter la plate forme
								}
							}
						text:$access360analytics_grouprepository_accountreviewcampaignNLS.tab1.previewbutton
						image:%collection_16.gear		
					}
				}
			}		
		}
	}
}

bwir_grouprepository_membersreviewcampaignpreview = Page {
	title: $access360analytics_grouprepository_accountreviewcampaignNLS.title
	description: $access360analytics_grouprepository_accountreviewcampaignNLS.description
	icon: "16/details/review_16.png" large-icon: "48/details/review_48.png"
	feature:iasreview_license
	enter-event:	
					Set @access360analytics_reviewcampaignDate(nbdays to nbdays) to filterminimumreviewdate,
					TransferData datatoreview	(revieweruid, reviewermail, reviewerorigin, accountuid, groupuid, reviewstatus, reviewcomment, identitypositionkey, grouplabel) to 
												(allreviewers, allreviewersmail, allreviewerorigin, allaccounts, allgroups, allstatus, allcomment, allidentitypositionkeys, allgrouplabels), 
					Set allreviewers to reviewerlist, 
					MultivaluedDistinct reviewerlist,
					Set allgroups to grouplist,
					MultivaluedDistinct grouplist,
					Set param_totalnbgroupmembers to totalnbgroupmembers,
					Set SizeOf filterbyaccounttag to nbfiltertags, // to avoid a bug as Eval "filterbyaccounttag.length" does not work if filterbyaccounttag is empty
					Set SizeOf filterbygrouptag to nbfiltergptags, // to avoid a bug as Eval "filterbygrouptag.length" does not work if filterbyaccounttag is empty
					BooleanCase(Eval "includeuseraccounts.get().equals('1') && includeorphanaccounts.get().equals('1') &&  includetechaccounts.get().equals('1') && includeleaveraccounts.get().equals('1') && nbfiltertags.get()==0 && includedynamicgroups.get().equals('1') &&  includegroupswithoutowner.get().equals('1') && nbfiltergptags.get()==0 ") { when True then [  Set True to isafullreview ] when False then [ Set False to isafullreview ] }

	mixins: simpleReport	

	/* Parameters here */
	dynamicmode = Parameter { type:Boolean mandatory:False hidden:True label:"Tags selection mode" }
	staticmode = Parameter { type:Boolean mandatory:False hidden:True label:"Static selection mode" }
	taglist = Parameter { type:String multivalued:True mandatory:False hidden:True label:"List of tags" }	
	
	param_totalnbgroupmembers = Parameter { type:Integer mandatory:True hidden:True multivalued:True label:"Total nb Group Members" }
	repositorylist = Parameter { type:String mandatory:True hidden:True multivalued:True label:"Repositories to review" }
	includeuseraccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include User Accounts" }
	includeorphanaccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Orphaned Accounts" }
	includetechaccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Technical Accounts" }
	includeleaveraccounts = Parameter { type:String mandatory:True hidden:True default:True label:"Include Leaver Accounts" }
	includegroupswithoutowner = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Groups Without Owner" }
	includedynamicgroups = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Dynamic Groups" }
	filterbygrouptag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Groups with Tag" }	
	filterbyaccounttag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Accounts with Tag" }
	includelatestreviewstatus = Parameter { type:String mandatory:False hidden:True label:"Include Last Reviewed Status" }
	filterifalreadyreviewed = Parameter { type:String mandatory:True hidden:True label:"Filter Entries Already Reviewed" }
	nbdays = Parameter { type:Integer mandatory:False hidden:True label:"Consider Only Entries Reviewed in the Last N Days" }
	forcehimselfasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force user himself as the Reviewer" }
	forcebusinessownerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force repository owner as the Reviewer" }
	forcebusinessownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True label:"Force repository owner as the Reviewer for all other accounts" }
	forcedefaultreviewerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force Default Reviewer as the Reviewer" }
	forcegroupownerfortechaccounts = Parameter { type:String mandatory:False hidden:True label:"Force Group Owner as the Reviewer for Tech Accounts" }
	forcegroupownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True label:"Force Group Owner as the Reviewer for all other accounts" }
	forcegroupownerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force Group Owner as Reviewer" }	
	defaultrevieweruid = Parameter { type:String mandatory:False hidden:True label:"Default reviewer" }
	reviewerstrategy = Parameter { type:String mandatory:False hidden:True label:"Reviewer Strategy" }
	reviewerstrategyscript = Parameter { type:String mandatory:False hidden:True label:"Reviewer Strategy script" }
	advancedmode = Parameter { type:String mandatory:False hidden:True default:False label:"Advanced Mode"}

	/* Variables here */
	inpermissiontypes = Variable { multivalued:True initial:NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") }

	outrepositoryuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable
	outgroupuid = Variable
	outrevieweruid = Variable
	
	isafullreview = Variable { type:Boolean }
	nbfiltertags = Variable { type:Integer }
	nbfiltergptags = Variable { type:Integer }
	totalnbgroupmembers = Variable { type:Integer }
	
	reviewerlist = Variable { multivalued:True }
	grouplist = Variable { multivalued:True }
	filterminimumreviewdate = Variable
	selectedreviewer = Variable
	allaccounts = Variable { multivalued:True } 
	allgroups = Variable { multivalued:True } 
	allidentitypositionkeys = Variable { multivalued:True } 
	allgrouplabels = Variable { multivalued:True } 
	allreviewers = Variable { multivalued:True } 
	allreviewersmail = Variable { multivalued:True } 
	allreviewerorigin = Variable { multivalued:True }
	allstatus = Variable { multivalued:True } 
	allcomment = Variable { multivalued:True } 

	incanshowdetails = Variable { initial:True type:String }	
	
	nbemptyreviewers = Variable { type:Integer }	

	reviewname = Variable { type:String }
	reviewdescription = Variable { type:String }
	reviewpriority = Variable { type:Integer initial:3 }
	reviewdeadline = Variable { type:Date initial:Date.offset( 30 days).value }
	boolofflinemode = Variable { type:Boolean initial:False }
	offlinemode = Variable
	boolselfdelegation = Variable { type:Boolean initial:False }
	selfdelegation = Variable
	
	wizardstep = Variable { initial:0 type:Integer }
	
	/* Datasets and records here */
	containsemptyreviewers = Dataset {
		columns:allreviewersmail
		includes: StringPredicate(Current allreviewersmail) { when IsEmpty then True otherwise False}
		count-variable:nbemptyreviewers
	}

	datatoreview = Dataset {
		view:access360r_repositorygroupmembersreviewbv with
			repositorylist to repositorylist,
			includeuseraccounts to includeuseraccounts,
			includeorphanaccounts to includeorphanaccounts,
			includetechaccounts to includetechaccounts,
			includeleaveraccounts to includeleaveraccounts,
			includegroupswithoutowner to includegroupswithoutowner,
			includedynamicgroups to includedynamicgroups,
			filterbygrouptag to filterbygrouptag,				
			filterbyaccounttag to filterbyaccounttag,
			includelatestreviewstatus to includelatestreviewstatus,
			filterifalreadyreviewed to filterifalreadyreviewed,
			filterminimumreviewdate to filterminimumreviewdate,
			forcehimselfasreviewer to forcehimselfasreviewer,
			forcebusinessownerasreviewer to forcebusinessownerasreviewer,
			forcebusinessownerforallotheraccounts to forcebusinessownerforallotheraccounts,
			forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
			forcegroupownerfortechaccounts to forcegroupownerfortechaccounts,
			forcegroupownerforallotheraccounts to forcegroupownerforallotheraccounts,
			forcegroupownerasreviewer to forcegroupownerasreviewer,			
			defaultrevieweruid to defaultrevieweruid,
			reviewerstrategyscript to reviewerscript unless-empty,
			selectedreviewer to filterbyreviewer unless-empty // used to filter per reviewer in the GUI
	}
	
	reviewers = Dataset {
		view:access360r_identity with reviewerlist to uids
		disabled:IntPredicate(SizeOf reviewerlist) { when >999 then True otherwise False }
	}

	task = TaskRecord (create "bwaccess360_assignGroupMembershipReviewTickets")
	
