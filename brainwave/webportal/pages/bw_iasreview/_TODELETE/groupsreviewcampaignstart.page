scripttester = EventService {
	javascript-file:"/webportal/pages/bw_iasreview/review/repository/script.javascript"
	javascript-method:test
	script = Input
	errMsg = Output
	lineNumber = Output
}

access360analytics_grouprepository_accountreviewcampaignreviewerscript = NLS {
	title [en "Reviewer script" fr "Script acteur de revue"]
	errMsg [en "Error found line {0}, {1}" fr "Erreur ligne {0}, {1}"]
	validate [en "Validate script" fr "Valider le script"]
}
access360analytics_grouprepository_accountreviewcampaignreviewerscript = Dialog {
	title:$access360analytics_grouprepository_accountreviewcampaignreviewerscript.title
	width:1366
	height:600
	buttons:[ActionButton { text:$access360analytics_grouprepository_accountreviewcampaignreviewerscript.validate actions:Call scripttester(script to script, errMsg from errMsg, lineNumber from lineNumber), Set True to checkdone }
	 OkButton { disabled:OrPredicate { Not BooleanPredicate(checkdone) StringPredicate(errMsg) { when Not IsEmpty then True } } } CancelButton]
	
	script = Variable { initial:"// This script identifies the reviewer for each individual review line.\n\n// You have to send back a value amongst the following:\n// - linemanager\n// - repositoryowner\n// - accountowner\n// - default\n// - myself\n// - HRCODE value\n// You can also send back a list of values such as linemanager,accountowner,repositoryowner,default\n// In this case, the first valid reviewer will be taken (valid = reviewer found + reviewer having an email)\n// \n// \n// The following variables are fulfilled for your convenience:\n// accountowneruid\n// accountownerhrcode\n// accountownerfullname\n// accountownermail\n// linemanageruid\n// linemanagerhrcode\n// linemanagerfullname\n// linemanagermail\n// identityuid\n// identityhrcode\n// identityfullname\n// identitymail\n// defaultrevieweruid\n// defaultreviewerhrcode\n// defaultreviewerfullname\n// defaultreviewermail\n// accountuid\n// accountlogin\n// repositoryname\n// repositoryowneruid\n// repositoryownerhrcode\n// repositoryownerfullname\n// repositoryownermail\n// accountmaxrisklevel\n// accountsensitivitylevel\n// accountnoownercode\n// accounttype (user,leave,technical,orphan)\n// lastloginindays\n// Those custom variable are also provided in case you want to attach reviewers HR code to the objects at loading time\n// this is not a best practice and should be used as a last resort\n// accountcustom1\n// accountcustom2\n// accountcustom3\n// repositorycustom1\n// repositorycustom2\n// repositorycustom3\n// identitycustom1\n// identitycustom2\n// identitycustom3\n\nif(accounttype.equals('user')) {\n	'linemanager,repositoryowner,default';\n}\nelse {\n	if(accountsensitivitylevel>2)\n		'accountowner,repositoryowner,default';\n	else\n		'repositoryowner,default';\n}\n" }
	errMsg = Variable
	lineNumber = Variable
	checkdone = Variable { type:Boolean initial:False } 
	Header {
		value:$access360analytics_grouprepository_accountreviewcampaignreviewerscript.errMsg(lineNumber, errMsg)
		hidden:StringPredicate(errMsg) { when IsEmpty then True }
		styling:warningFieldStyle
	}
	Edit {
		variable:script
		multi-lines:True
		layout:Layout { grab:horizontal True vertical True }
		modify-event:Set False to checkdone
	} 
}

// Max number of entries to be able to review per campaign...
access360analytics_grouprepository_membersmaxentries = Constant { value: 100000 type: Integer }

access360analytics_grouprepository_membersreviewcampaignconfigurationFirst = UserVariable { type:Boolean initial:True }

bwir_grouprepository_membersreviewcampaignconfiguration = Page {
	title: $access360analytics_grouprepository_accountreviewcampaignNLS.title
	description: $access360analytics_grouprepository_accountreviewcampaignNLS.description
	icon: "32/details/review_32.png" large-icon: "48/details/review_48.png"
	tags: "application", "iasreview25"
	feature: All(iasreview_license, Any(governance_license, compliance_license))
	enter-event:
		Set param_dynamicmode to dynamicmode,
		Set param_staticmode to staticmode,
		Set param_taglist to taglist,	
		Set param_repositorylist to selectedrepositories, 
		Set param_includeuseraccounts to includeuseraccounts, 
		Set param_includeorphanaccounts to includeorphanaccounts, 
		Set param_includetechaccounts to includetechaccounts,
		Set param_includeleaveraccounts to includeleaveraccounts,
		Set param_includegroupswithoutowner to 	includegroupswithoutowner,
		Set param_includedynamicgroups to 	includedynamicgroups,	
		Set param_filterbygrouptag to filterbygrouptag, 
		Set param_filterbyaccounttag to filterbyaccounttag, 
		Set param_includelatestreviewstatus to includelatestreviewstatus, 
		Set param_filterifalreadyreviewed to filterifalreadyreviewed, 
		Set param_nbdays to nbdays, 
		Set param_forcebusinessownerasreviewer to forcebusinessownerasreviewer,
		Set param_forcehimselfasreviewer to forcehimselfasreviewer,
		Set param_forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
		Set param_forcebusinessownerforallotheraccounts to forcebusinessownerforallotheraccounts,
		Set param_forcegroupownerfortechaccounts to forcegroupownerfortechaccounts,
		Set param_forcegroupownerforallotheraccounts to forcegroupownerforallotheraccounts,
		Set param_forcegroupownerasreviewer to forcegroupownerasreviewer,			
		Set param_reviewerstrategy to reviewerstrategy,
		Set param_reviewerstrategyscript to reviewerstrategyscript,
		Set param_defaultrevieweruid to defaultrevieweruid,
		Set param_advancedmode to advancedmode,
		StringCase ( defaultrevieweruid ) {
			when Not IsEmpty then [
				Set defaultreviewerinfos.fullname to defaultreviewer
			]
		},
		StringCase ( staticmode ) {
			when IsEmpty then [
				Set True to staticmode
			]
		}
	post-render-event:
		BooleanCase ( UserVariable access360analytics_grouprepository_membersreviewcampaignconfigurationFirst ) {
			when True then [ 
				Set False to UserVariable access360analytics_grouprepository_membersreviewcampaignconfigurationFirst,
				Message $access360analytics_grouprepository_accountreviewcampaignNLS.info 
			] when False then []
		}

	mixins: simpleReport	

	param_dynamicmode = Parameter { type:Boolean mandatory:False hidden:True label:"Tags selection mode" }
	param_staticmode = Parameter { type:Boolean mandatory:False hidden:True label:"Static selection mode" }
	param_taglist = Parameter { type:String multivalued:True mandatory:False hidden:True label:"List of tags" }

	param_repositorylist = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Repositories to review" }
	param_includeuseraccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include User Accounts" }
	param_includeorphanaccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Orphaned Accounts" }
	param_includetechaccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Technical Accounts" }
	param_includeleaveraccounts = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Leaver Accounts" }
	param_includegroupswithoutowner = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Groups Without Owner" }
	param_includedynamicgroups = Parameter { type:String mandatory:False hidden:True default:'1' label:"Include Dynamic Groups" }
	param_filterbygrouptag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Groups with Tag" }
	param_filterbyaccounttag = Parameter { type:String multivalued:True mandatory:False hidden:True label:"Filter Accounts with Tag" }
	param_includelatestreviewstatus = Parameter { type:String mandatory:False hidden:True default:'0' label:"Include Last Reviewed Status" }
	param_filterifalreadyreviewed = Parameter { type:String mandatory:False hidden:True default:'0' label:"Filter Entries Already Reviewed" }
	param_nbdays = Parameter { type:Integer mandatory:False hidden:True default:90 label:"Consider Only Entries Reviewed in the Last N Days" }
	param_forcehimselfasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force user himself as the Reviewer" }
	param_forcebusinessownerasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force repository owner as the Reviewer" }
	param_forcedefaultreviewerasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force Default Reviewer as the Reviewer" } 
	param_forcebusinessownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force repository owner as the Reviewer for all Other Accounts" }
	param_forcegroupownerfortechaccounts = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force Group Owner as the Reviewer for Tech Accounts" }
	param_forcegroupownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force Group Owner as the Reviewer for all Other Accounts" }
	param_forcegroupownerasreviewer = Parameter { type:String mandatory:False hidden:True default:'0' label:"Force Group Owner as the Reviewer" }

	param_defaultrevieweruid = Parameter { type:String mandatory:False hidden:True label:"Default Reviewer if no Reviewer Found"}
	param_reviewerstrategy = Parameter { type:String mandatory:False hidden:True default:"a" label:"Reviewer Strategy"}
	param_reviewerstrategyscript = Parameter { type:String mandatory:False hidden:True label:"Reviewer Strategy script"}
	param_advancedmode = Parameter { type:String mandatory:False hidden:True default:False label:"Advanced Mode"}

	includeuseraccounts = Variable { type: String }
	includeorphanaccounts = Variable { type: String }
	includetechaccounts = Variable { type: String }
	includeleaveraccounts = Variable { type: String }
	includegroupswithoutowner = Variable { type: String }
	includedynamicgroups = Variable { type: String }
	filterbyaccounttag = Variable { type: String multivalued: True }
	filterbygrouptag = Variable { type: String multivalued: True }
	includelatestreviewstatus = Variable { type: String }

	nbdays = Variable { type: Integer }
	filterifalreadyreviewed = Variable { type: String }
	forcehimselfasreviewer = Variable { type: String }
	forcebusinessownerforallotheraccounts = Variable { type: String }
	forcebusinessownerasreviewer = Variable { type: String }
