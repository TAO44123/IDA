bwir_grouprepository_accountreviewcampaignconfigurationNLS = NLS {
	nbaccount [en "Nb Accounts" fr "Nb Comptes"]
	nbidentity [en "Nb Identities" fr "Nb Identités"]
	nbgroup [en "Nb Groups" fr "Nb Groupes"]
	nbapplication [en "Nb Applications" fr "Nb Applications"]
	nbshare [en "Nb Shares" fr "Nb Partages"]
	accsensitivitylevel [ en "Account\nSensitivity" fr "Sensibilité\nComptes" ]
	gpsensitivitylevel [ en "Group\nSensitivity" fr "Sensibilité\nGroupes" ]
