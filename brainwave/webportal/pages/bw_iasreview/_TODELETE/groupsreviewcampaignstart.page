													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	goReviewerDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outrevieweruid to inuid)
												
			]
			when False then [
			
			]
		}
