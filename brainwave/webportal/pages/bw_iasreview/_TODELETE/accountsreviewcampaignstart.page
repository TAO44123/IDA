	Separator {
		width:1
		color:blue
	}
	Grid {
		columns:GridColumn{ group:a },GridColumn{ group:a }
		layout: Layout { grab: horizontal True vertical False }
		GridRow {
			GridCell {
				reviewerstrategy = Combo {
					variable:reviewerstrategy
					layout:Layout { grab:horizontal True vertical False }
					options:Static {
						Option { value:'a' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.a }
						Option { value:'d' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.d }
						Option { value:'e' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.e }
						Option { value:'b' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.b }
						Option { value:'c' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.c }
						Option { value:'z' text:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.z feature:iasr_accountreviewadvancedreviewermode }
					}
					label:Label {break:True }
					tooltip:$access360analytics_repository_accountreviewcampaignNLS.tab1.reviewerstrategy.tooltip
				}	
			}
			GridCell {
				Text {
					label: Label {
						value:$access360analytics_repository_accountreviewcampaignNLS.tab1.defaultreviewer
					}
					tooltip:$access360analytics_repository_accountreviewcampaignNLS.tab1.defaultreviewer.tooltip
					value:defaultreviewer
					styling:detailsText
					compact:False
					align:Left
					layout:Layout { grab:horizontal False vertical False hint: width 300 align:horizontal Beginning vertical Center }
					commands:Commands { position:After presentation: Icon 
							Command {
										icon:%concept_16.identity
										actions:Dialog identityPicker(defaultreviewer from outDisplayname, defaultrevieweruid from outUid, defaultreviewermail from outMail),
										StringCase(defaultreviewermail) {
											when IsEmpty then [
												Flash Error $access360analytics_repository_accountreviewcampaignNLS.tab1.defaultreviewer.error,
												Unset defaultreviewer,
												Unset defaultrevieweruid,
												Unset defaultreviewermail
											]
										}
							} 
							Command{	
									actions:Unset defaultreviewer, Unset defaultrevieweruid
		                        	icon:%status_16.delete
		                    }
					}
				}
			}
