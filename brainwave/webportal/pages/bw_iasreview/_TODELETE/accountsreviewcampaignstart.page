	}
	Spacer { height: Fill }	
	Grid {
		columns:GridColumn,GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 48 }
		GridRow {
			GridCell {
				Text {
					value:$access360analytics_repository_accountreviewcampaignNLS.tab1.warning(gettotalnbaccounts.totalnbaccounts)
					styling:warningFieldStyle
					layout: Layout { grab: horizontal True vertical True align:vertical Center horizontal Beginning hint:width 400 }
					hidden:
						OrPredicate {
							BooleanPredicate(advancedmode) // hidden if advanced mode is selected as we consider that it is filtered...
							IntPredicate(gettotalnbaccounts.totalnbaccounts) { when <Constant access360analytics_repository_accountmaxentries then True when InvalidInteger then True otherwise False }
						}
				}
			}		
			GridCell {
				ButtonGroup {
					align:Right
					Button {
						actions:GoTo //BackInHistory 
						Page replace-history bwir_repository_accountreviewcampaignconfiguration with
									repositorylist to param_repositorylist,
									includeuseraccounts to param_includeuseraccounts,
									includeorphanaccounts to param_includeorphanaccounts,
									includetechaccounts to param_includetechaccounts,
									includeleaveraccounts to param_includeleaveraccounts,
									filterbyaccounttag to param_filterbyaccounttag,
									includelatestreviewstatus to param_includelatestreviewstatus,
									filterifalreadyreviewed to param_filterifalreadyreviewed,
									nbdays to param_nbdays,
									forcehimselfasreviewer to param_forcehimselfasreviewer,
									forcebusinessownerasreviewer to param_forcebusinessownerasreviewer,
									forcedefaultreviewerasreviewer to param_forcedefaultreviewerasreviewer,
									defaultrevieweruid to param_defaultrevieweruid, 
									reviewerstrategy to param_reviewerstrategy,
									advancedmode to param_advancedmode,
									dynamicmode to param_dynamicmode,
									staticmode to param_staticmode,
									taglist to param_taglist									
								
						text:$access360analytics_repository_accountreviewcampaignNLS.tab2.back
						image:%browsing_16.rewind
					}					
					Button {
						actions:Dialog access360analytics_repository_accountreviewcampaignreviewerscript(reviewerstrategyscript from script, reviewerstrategyscript to script)
						hidden:StringPredicate(reviewerstrategy) { when 'z' then False otherwise True }
						text:$access360analytics_repository_accountreviewcampaignNLS.tab1.scriptbutton
					}
					Button {
						actions:Confirm $access360analytics_repository_accountreviewcampaignNLS.tab1.previewbutton.tooltip,
								StringCase(reviewerstrategy) {
									// User accounts by the line manager, other accounts by the repository owner
									when "a" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Unset reviewerstrategyscript
									]
									// User accounts by the line manager, all other accounts by the repository owner
									when "d" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "1" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Unset reviewerstrategyscript
									]
									// User accounts by themself, all other accounts by the repository owner
									when "e" then [
										Set "1" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "1" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Unset reviewerstrategyscript
									]
									// "All accounts by the repository owner"
									when "b" then [
										Set "0" to forcehimselfasreviewer,
										Set "1" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "0" to forcedefaultreviewerasreviewer,
										Unset reviewerstrategyscript
									]
									// "All accounts by the default reviewer"
									when "c" then [
										Set "0" to forcehimselfasreviewer,
										Set "0" to forcebusinessownerasreviewer,
										Set "0" to forcebusinessownerforallotheraccounts,
										Set "1" to forcedefaultreviewerasreviewer,
										Unset reviewerstrategyscript
									]
								},
								GoTo Page bwir_repository_accountreviewcampaignpreview with
											repositorylist to repositorylist,
											includelatestreviewstatus to includelatestreviewstatus,
											includeleaveraccounts to includeleaveraccounts,
											includeorphanaccounts to includeorphanaccounts,
											includeuseraccounts to includeuseraccounts,
											includetechaccounts to includetechaccounts,
											defaultrevieweruid to defaultrevieweruid,
											filterbyaccounttag to filterbyaccounttag,
											filterifalreadyreviewed to filterifalreadyreviewed,
											defaultrevieweruid to defaultrevieweruid,
											forcehimselfasreviewer to forcehimselfasreviewer,
											forcebusinessownerasreviewer to forcebusinessownerasreviewer,
											forcebusinessownerforallotheraccounts to forcebusinessownerforallotheraccounts,
											forcedefaultreviewerasreviewer to forcedefaultreviewerasreviewer,
											reviewerstrategy to reviewerstrategy,
											reviewerstrategyscript to reviewerstrategyscript,
											advancedmode to advancedmode,
											nbdays to nbdays,
											dynamicmode to dynamicmode,
											staticmode to staticmode,
											taglist to taglist
											save-state
											
											
						disabled:
							OrPredicate {
								IntPredicate(repositorylist) { when <1 then True when >999 then True otherwise False }							
								IntPredicate(gettotalnbaccounts.totalnbaccounts) { when =0 then True when InvalidInteger then True otherwise False }
								AndPredicate {
									Not BooleanPredicate(advancedmode) // si advanced mode, on verifiera apres le calcul de preview...
									IntPredicate(gettotalnbaccounts.totalnbaccounts) { when >Constant access360analytics_repository_accountmaxentries then True when =0 then True when InvalidInteger then True otherwise False } // limite arbitraire pour l'instant pour eviter de planter la plate forme
								}
							}
						text:$access360analytics_repository_accountreviewcampaignNLS.tab1.previewbutton
						image:%collection_16.gear		
					}
				}
			}		
		}
	}
}

bwir_repository_accountreviewcampaignpreview = Page {
