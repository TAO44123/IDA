	outrepositoryuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable
	outrevieweruid = Variable
	
	isafullreview = Variable { type:Boolean }
	nbfiltertags = Variable { type:Integer }
	
