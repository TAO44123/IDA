	feature:iasreview_license
	enter-event:	
					Set @access360analytics_reviewcampaignDate(nbdays to nbdays) to filterminimumreviewdate,
					TransferData datatoreview	(revieweruid, reviewermail, reviewerorigin, accountuid, reviewstatus, reviewcomment, identitypositionkey, accountlabel) to 
												(allreviewers, allreviewersmail, allreviewerorigin, allaccounts, allstatus, allcomment, allidentitypositionkeys, allaccountlabels), 
					Set allreviewers to reviewerlist, 
					MultivaluedDistinct reviewerlist,
					Set SizeOf filterbyaccounttag to nbfiltertags, // to avoid a bug as Eval "filterbyaccounttag.length" does not work if filterbyaccounttag is empty
					BooleanCase(Eval "includeuseraccounts.get().equals('1') && includeorphanaccounts.get().equals('1') &&  includetechaccounts.get().equals('1') && includeleaveraccounts.get().equals('1') && nbfiltertags.get()==0") { when True then [  Set True to isafullreview ] when False then [ Set False to isafullreview ] }

