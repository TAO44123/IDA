						}
					layout: Layout { grab: horizontal False vertical False hint:width 100}
				}
				DateTime {
					variable:reviewdeadline
					label:$access360analytics_repository_accountreviewcampaignNLS.tab3.reviewdeadline
					type:Date
					date-after:Date
				}
				Checkbox {
					variable:boolselfdelegation
					label:$access360analytics_repository_accountreviewcampaignNLS.tab3.selfdelegation
					tooltip:$access360analytics_repository_accountreviewcampaignNLS.tab3.selfdelegation.tooltip
				}
				Checkbox {
					variable:boolofflinemode
					label:$access360analytics_repository_accountreviewcampaignNLS.tab3.offlinemode
					tooltip:$access360analytics_repository_accountreviewcampaignNLS.tab3.offlinemode.tooltip
				}
				Separator {
					color:blue
					width:1
				}
				
				
				Grid {
					columns: GridColumn{},GridColumn{},GridColumn{}
					GridRow {
						GridCell {
							IncludeHTMLWidget {
								layout: Layout { hint: height 200 width 200 align: horizontal Center vertical Center }
								template: mashupGaugeIndicator
								bindings:
									value-of $access360analytics_repository_accountreviewcampaignNLS.tab3.repostoreview to title,
									value-of "numeric" to mode, // radial, numeric, row
									value-of False to hasLink,
									value-of False to hasThresholds,
									value-of SizeOf repositorylist to count,
									value-of "#9400D3" to gaugeColor
							}
						}
						GridCell {
							IncludeHTMLWidget {
								layout: Layout { hint: height 200 width 200 align: horizontal Center vertical Center }
								template: mashupGaugeIndicator
								bindings:
									value-of $access360analytics_repository_accountreviewcampaignNLS.tab3.entriestoreview to title,
									value-of "numeric" to mode, // radial, numeric, row
									value-of False to hasLink,
									value-of False to hasThresholds,
									value-of SizeOf allaccounts to count,
									value-of "#9400D3" to gaugeColor
							}
						}       		
						GridCell {
							IncludeHTMLWidget {
								layout: Layout { hint: height 200 width 200 align: horizontal Center vertical Center }
								template: mashupGaugeIndicator
								bindings:
									value-of $access360analytics_repository_accountreviewcampaignNLS.tab3.reviewers to title,
									value-of "numeric" to mode, // radial, numeric, row
									value-of False to hasLink,
									value-of False to hasThresholds,
									value-of SizeOf reviewerlist to count,
									value-of "#9400D3" to gaugeColor
							}				
						}       		
					}	
				}
			
				Spacer {
					height:Fill
				}
				
				ButtonGroup {
					align:Right
					Button {
						actions: Set 0 to wizardstep				
						text:$access360analytics_repository_accountreviewcampaignNLS.tab3.back
						image:%browsing_16.rewind
					}
					Button {
						actions: 	Confirm $access360analytics_repository_accountreviewcampaignNLS.tab3.confim,
									BooleanCase(boolofflinemode) {
										when True then [ Set "1"  to offlinemode ]
										when False then [ Set "0"  to offlinemode ]
									},
									BooleanCase(boolselfdelegation) {
										when True then [ Set "1"  to selfdelegation ]
										when False then [ Set "0"  to selfdelegation ]
									},
									Set "account" to task.reviewtype,
									Set "bwaccess360_accessreviewmanagementdetailaccount" to task.statuspage,
									Set "bwaccess360_accountsreviewcampaignfinalize" to task.finalizepage,
									Set "bwaccess360_accountsreviewpage" to task.reviewpage,
									Set PageTimeslot.UID to task.timeslotuid,
									Set reviewname to task.reviewname,
									Set reviewdescription to task.reviewdescription,
									Set reviewpriority to task.prioritylevel,
									Set Date(reviewdeadline).valueLDAP to task.deadline,
									Set allaccounts to task.accounts,
									Set allidentitypositionkeys to task.identitypositionkeys,
									Set allaccountlabels to task.labels,
									Set allreviewers to task.reviewers,
									Set allreviewerorigin to task.reviewersorigin,
									Set allstatus to task.status,
									Set allcomment to task.comment,
									Set offlinemode to task.offlinemode,
									Set selfdelegation to task.selfdelegation,
									Set isafullreview to task.isafullreview,
									TaskComplete task,
									Flash $bwaccess360_review.launched,
									GoTo HomePage
						image:%browsing_16.play
						text:$access360analytics_repository_accountreviewcampaignNLS.tab3.launch
						tooltip:$access360analytics_repository_accountreviewcampaignNLS.tab3.launch.tooltip
						disabled:
							 OrPredicate {
							 	StringPredicate(reviewname) { when IsEmpty then True otherwise False }
							 	StringPredicate(reviewdescription) { when IsEmpty then True otherwise False }
							 }
					}
				}
			]
		}
	
	}
}