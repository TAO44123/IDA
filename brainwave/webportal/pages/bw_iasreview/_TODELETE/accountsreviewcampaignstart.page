	includelatestreviewstatus = Parameter { type:String mandatory:False hidden:True label:"Include Last Reviewed Status" }
	filterifalreadyreviewed = Parameter { type:String mandatory:True hidden:True label:"Filter Entries Already Reviewed" }
	nbdays = Parameter { type:Integer mandatory:False hidden:True label:"Consider Only Entries Reviewed in the Last N Days" }
	forcehimselfasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force user himself as the Reviewer" }
	forcebusinessownerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force repository owner as the Reviewer" }
	forcebusinessownerforallotheraccounts = Parameter { type:String mandatory:False hidden:True label:"Force repository owner as the Reviewer for all other accounts" }
	forcedefaultreviewerasreviewer = Parameter { type:String mandatory:False hidden:True label:"Force Default Reviewer as the Reviewer" }
