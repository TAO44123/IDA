	tab3.back [en "Preview Data" fr "Prévisualiser les données"]
	tab3.arinfo [en "Access Review Information" fr "Informations sur la campagne de revue"]
	tab3.reviewid [en "Review Unique Identifier" fr "Identifiant unique de revue"]
	tab3.reviewname [en "Review Name" fr "Nom de la revue"]
	tab3.reviewdescr [en "Review Description" fr "Description de la revue"]
	tab3.reviewpriority[en "Review Priority"fr "Priorité de la revue"]
	tab3.reviewpriority.low[en "Low"fr "Basse"]
	tab3.reviewpriority.medium[en "Medium"fr "Moyenne"]
	tab3.reviewpriority.high[en "High"fr "Haute"]
	tab3.reviewdeadline [en "Expected Deadline"fr "Date d'échéance de la revue"]

