								fr "Comptes utilisateur par eux-mêmes, tous les autres comptes par le responsable de référentiel"	
							]
	tab1.reviewerstrategy.b [	en "All accounts by the repository owner" 
								fr "Tous les comptes par le responsable de référentiel"	
							]
	tab1.reviewerstrategy.c [	en "All accounts by the default reviewer" 
								fr "Tous les comptes par l'acteur par défaut"	
							]
	tab1.reviewerstrategy.z [	en "Advanced mode" 
								fr "Mode avancé"	
							]

	tab1.warning [
		en "Overall, your repositories are totalizing {0} accounts\nyou should consider refining your review perimeter in this page"
		fr "Au total, les référentiels contiennent {0} comptes\nvous devriez affiner le périmètre de revue dans cette page"
	]	
