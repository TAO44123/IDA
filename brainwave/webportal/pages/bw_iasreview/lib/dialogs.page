import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_iasreview/accessreviewmanagement.page"

// Roles Content Review: child applications
bwaccess360_rolesContentFilterApplications = Dialog {
	title: $bwaccess360_accessreviewmanagementNLS.pickapplications
	enter-event:
		Unset outapplicationsstring
	buttons:
		[
			OkButton {
				disabled:
					IntPredicate ( SizeOf inoutapplicationuid ) {
						when =0 then True
					}
				actions:
					MultivaluedIterate applicationnames as app_name[
						Set Concat(outapplicationsstring, " ", Current app_name, " ") to outapplicationsstring
					]
				}
			CancelButton
		]

	incampaignid = Variable { type: String }
	inoutapplicationuid = Variable { type: String multivalued: True }
	outapplicationsstring = Variable { type: String initial: "" }
	applicationnames = Variable { type: String multivalued: True }
	explicitstatus = Variable { type: String multivalued: True }

	applications = Dataset {
		view: bwaccess360r_roleContentApplicationlist with
			incampaignid to campaignid,
			explicitstatus to explicitstatus unless-empty
	}

	Table {
		data: applications
		layout: Layout { grab: horizontal True vertical True }
		show-filter: True
		show-count: True
		checkboxes:
			uid to inoutapplicationuid and (
				displayname to applicationnames
			)
		Column {
			column: uid
			hidden: True
		}
		Column {
			column: code
			header: $application.code
			sortable: True
			filterable: True
			width: 100%
		}
		Column {
			column: displayname
			header: $application.displayname
			sortable: True
			filterable: True
			width: 100%
		}
	}
}

