importExportFragment = PageFragment {
	
	bwrm_adminoverview_v1 = Dataset {
		view: bwrm_adminoverview_v1
	}

	ConditionalGroup {
		IntCondition( Count bwrm_adminoverview_v1 ) {
			when = 0 then [
				IncludeFragment ( importExportFragmentV2 )
			] otherwise [
				Flow {
					layout: Layout { grab: horizontal True vertical True }
					disposition: Horizontal
					IncludeFragment ( importExportFragmentV1 )
					IncludeFragment ( importExportFragmentV2 )
				}	
			]
		}
	}
}

