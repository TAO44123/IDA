bw_role_styling = StringStylingTemplate {
	when 'x' then bwpm_grayStyle
	when 'v' then bwpm_directStyle
	when 'i' then bwpm_indirectStyle
	when '0' then bwpm_roleStyle0
	when '1' then bwpm_roleStyle1
	when '2' then bwpm_roleStyle2
	when '3' then bwpm_roleStyle3
	when '4' then bwpm_roleStyle4
	when '5' then bwpm_roleStyle5
	when '6' then bwpm_roleStyle6
	when '7' then bwpm_roleStyle7
	when '8' then bwpm_roleStyle8
	when '9' then bwpm_roleStyle9
	when '10'  then bwpm_roleStyle10
	when '11' then bwpm_roleStyle11
	when '12' then bwpm_roleStyle12
	when '13' then bwpm_roleStyle13
	when '14' then bwpm_roleStyle14
	when '15' then bwpm_roleStyle15
	when '16' then bwpm_roleStyle16
	when '17' then bwpm_roleStyle17
	when '18' then bwpm_roleStyle18
	when '19' then bwpm_roleStyle19

	when '0+' then bwpm_roleStyle0p
	when '1+' then bwpm_roleStyle1p
	when '2+' then bwpm_roleStyle2p
	when '3+' then bwpm_roleStyle3p
	when '4+' then bwpm_roleStyle4p
	when '5+' then bwpm_roleStyle5p
	when '6+' then bwpm_roleStyle6p
	when '7+' then bwpm_roleStyle7p
	when '8+' then bwpm_roleStyle8p
	when '9+' then bwpm_roleStyle9p
	when '10+' then bwpm_roleStyle10p
	when '11+' then bwpm_roleStyle11p
	when '12+' then bwpm_roleStyle12p
	when '13+' then bwpm_roleStyle13p
	when '14+' then bwpm_roleStyle14p
	when '15+' then bwpm_roleStyle15p
	when '16+' then bwpm_roleStyle16p
	when '17+' then bwpm_roleStyle17p
	when '18+' then bwpm_roleStyle18p
	when '19+' then bwpm_roleStyle19p

	when '0g' then bwpm_roleStyle0g
	when '1g' then bwpm_roleStyle1g
	when '2g' then bwpm_roleStyle2g
	when '3g' then bwpm_roleStyle3g
	when '4g' then bwpm_roleStyle4g
	when 'C' then bwpm_commentStyle
	otherwise bwpm_roleStyleOther
}

/* dialog utils */

bwpm_orgprofilesmining_help = Dialog {
	title:$permminingNLS.titlehelp
	width:1000
	height:500
	buttons:OkButton
	
	Header {
		value: $permminingNLS.roleminingcheatsheet
		styling: bigTitleStyle
		layout: Layout { grab: horizontal True vertical False align: horizontal Center vertical Center }
	}
	
	Group {
		compact: True 
		layout: Layout { hint: height 160 }
		Text {
			layout:Layout {grab: horizontal True vertical False  hint: height 160 }
			compact:True	
			value: $bwrm_helpNLS.intro
			lines: 12
		}
	}
	Group {
		compact: True
		Grid {
			layout: Layout{ grab: horizontal True vertical True }
			columns:GridColumn { width: 40px }, GridColumn { width: grow }
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "v"
						styling: bwpm_directStyle
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.v_black
						compact: True
					}
				}
			}
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "x"
						styling: bwpm_grayStyle
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.x_gray
						compact: True
					}
				}
			}
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "v"
						styling: bwpm_roleStyle1 
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.v_color
						compact: True
					}
				}
			}
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "+"
						styling: bwpm_roleStyle1p
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.plus_color
						compact: True
					}
				}
			}
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "v"
						styling: bwpm_roleStyle1g
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.v_gray
						compact: True
					}
				}
			}
			GridRow {
				height: 25px
				GridCell {
					Text {
						value: "v"
						styling: bwpm_commentStyle
					}
				}
				GridCell {
					Text {
						value: $bwrm_helpNLS.comment
						compact: True
					}
				}
			}
		}
	}
}