import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_rm/rolemining_nls.page"

GLOBAL_ROLE = Constant  {value: "$GLOBAL$"} 

ROLE_MIN_COLOR = Constant { type: Integer value: 0}
ROLE_MAX_COLOR = Constant { type: Integer value: 19}

bwpm_xifnull = StringMapping {
	when IsEmpty then "X"
	otherwise current
}

bwrm_rolestatus = StringMapping {
	when 1 then $permminingNLS.status.design
	when 2	then $permminingNLS.status.production
	when 0 then $permminingNLS.status.disabled
}

bwrm_permType = StringMapping {
	when "perm" then $permminingNLS.perm
	when "orga" then $permminingNLS.orga
	when "hist" then $permminingNLS.hist
	otherwise ""
}

imageButton = Style {
	background: Color white
}

bwpm_grayStyle = Style {
	foreground: gray
}

bwpm_redStyle = Style {
	background:Color red
	foreground:white
}

bwpm_directStyle = Style {
	background:Color RGB(60, 60, 60)
	foreground:white
}

bwpm_indirectStyle = Style {
	background:Color RGB(90, 90, 90)
	foreground:white
}

bwpm_commentStyle = Style {
	background: Color  RGB(255, 255, 140)
}

