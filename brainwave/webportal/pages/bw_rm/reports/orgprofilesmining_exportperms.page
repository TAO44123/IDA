/* Import other pages here */
import "/webportal/pages/bw_rm/utils.page"
import "/webportal/pages/bw_rm/rolemining_nls.page"

/* Nationalized labels here */
bwpm_orgprofilesmining_exportpermsNLS = NLS {
	title [en "permission export" fr "permission export"]
	dyntitle [en "Role/permission export for organisation {0}" fr "Export des rôles/permissions pour l''organisation {0}"]
}

bwpm_orgprofilesmining_exportperms = Page {
	title: $bwpm_orgprofilesmining_exportpermsNLS.title
	dynamic-title: $bwpm_orgprofilesmining_exportpermsNLS.dyntitle(organisation.shortname)
	
	/* Parameters here */
	uid = Parameter
	/* Variables here */
	
	/* Datasets and records here */
	export = Dataset {
		view:bwpm_getrolespermissions_1 with uid to organisation
	}
	organisation = Record {
		view:br_organisation_picker with uid to paramUid
	}
	
	/* Page content */
	
	Table {
		data:export
		layout:Layout {grab:horizontal True vertical True}
		show-count:True
		show-filter:True
		
		Column {
			column:rolecode
			width:200px
			sortable:True
			filterable:True
		}
		Column {
			column:rolename
			width:200px
			sortable:True
			filterable:True
		}

		Column {
			column:code
			width:200px
			header: $permminingNLS.permcode
			sortable:True
			filterable:True
		}
		Column {
			column:displayname
			width:200px
			header: $permminingNLS.permname
			sortable:True
			filterable:True
		}
		Column {
			column:description
			width:200px
			header: $permminingNLS.permdesc
			sortable:True
			filterable:True
		}
		Column {
			column:applicationdisplayname
			width:200px
			header: $permminingNLS.app
			sortable:True
			filterable:True
		}
	}
}
