/* Import other pages here */
import "/webportal/pages/bw_rm/utils.page"
import "/webportal/pages/bw_rm/rolemining_nls.page"

/* Nationalized labels here */
bwpm_orgprofilesmining_exportidentitiesNLS = NLS {
	title [en "Permission export" fr "Export permissions"]
	dyntitle [en "Role/identity export for organisation {0}" fr "Export des rôles/identités pour l''organisation {0}"]
}

bwpm_orgprofilesmining_exportidentities = Page {
	title: $bwpm_orgprofilesmining_exportidentitiesNLS.title
	dynamic-title: $bwpm_orgprofilesmining_exportidentitiesNLS.dyntitle(organisation.shortname)
	
	/* Parameters here */
	uid = Parameter
	/* Variables here */
	
	/* Datasets and records here */
	export = Dataset {
		view:bwpm_getrolesidentities_md with uid to organisation
	}
	organisation = Record {
		view:br_organisation_picker with uid to paramUid
	}
	
	/* Page content */
	
	Table {
		data:export
		layout:Layout {grab:horizontal True vertical True}
		show-count:True
		show-filter:True
		
		Column {
			column:rolecode
			width:200px
			sortable:True
			filterable:True
		}
		Column {
			column:rolename
			width:200px
			sortable:True
			filterable:True
		}
		Column {
			column:comment
			width:300px
			header: $permminingNLS.rolecomment
			sortable:True
			filterable:True
		}
		Column {
			column:hrcode
			width:200px
			header:$permminingNLS.hrcode
			sortable:True
			filterable:True
		}
		Column {
			column:fullname
			width:200px
			header:$permminingNLS.fullname
			sortable:True
			filterable:True
		}
		Column {
			column:mail
			width:200px
			header:$permminingNLS.mail
			sortable:True
			filterable:True
		}
	}
}
