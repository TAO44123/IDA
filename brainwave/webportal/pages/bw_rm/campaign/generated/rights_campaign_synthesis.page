/* Nationalized labels here */
bw_rm_rights_campaign_synthesisNLS = NLS {
	title [en "rights based campaign synthesis" fr "rights based campaign synthesis"]
	status [en "status" fr "statut"]
	comment [en "comment" fr "commentaires"]
	by [en "by" fr "par"]
	^on [en "on" fr "le"]
	campaign [en "campaign" fr "campagne"]

	remediationsubmissiondate [en "remediation starting date" fr "Démarrage de la remédiation"]
	remediationclosedate [en "remediation close date" fr "Cloture de la remédiation"]
	remediationstatus [en "remediation status" fr "statut de remédiation"]
	remediationextref [en "remediation external ticket" fr "ticket externe de remédiation"]
}

bw_rm_synthesis_icons = StringImageTemplate {
	//when "ok" then "16/famfamfam_silk_icons_v013/accept.png"
	//when "revoke" then "16/famfamfam_silk_icons_v013/delete.png"
	//when "update" then "16/famfamfam_silk_icons_v013/pencil.png"
	when "ok" then "16/famfamfam_silk_icons_v013/accept.png"
	when "revoke" then "16/famfamfam_silk_icons_v013/delete.png"
	when "update" then "16/famfamfam_silk_icons_v013/pencil.png"
	
}


