bw_rm_start = Page {
	title: $bw_rm_startNLS.title
	enter-event:Set campaign.code to campaignCode, Set campaign.title to campaignTitle, Set campaign.description to campaignDescription,
				Set campaign.frequency to campaignFrequency, Set campaign.duration to campaignDuration,
				Set campaign.owneruid to campaignOwneruid, Set campaign.ownerfullname to campaignOwnerfullname,
				StringCase(campaignOwneruid) { when IsEmpty then [Set Principal.uid to campaignOwneruid,Set identityPicker.fullname to campaignOwnerfullname] }  
	//tags:"campaign"
	feature:bw_rm_startingpage

	/* Parameters here */
	campaignId = Parameter {
		type: String
		mandatory: False
		hidden: True
	}
	
	/* variables here */
	// campaign infos
	campaignCode = Variable
	campaignTitle = Variable
	campaignDescription = Variable
	campaignType = Variable {initial:"rights"}
	campaignStatus = Variable
	campaignFrequency = Variable
	campaignDuration = Variable
	campaignStartingDate = Variable
	campaignOwneruid = Variable
	campaignOwnerfullname = Variable

	/* Datasets and records here */
	task = TaskRecord (campaignId or create "bw_rm_master")
	campaign = Record(br_campaign with campaignId to recorduid)
	identityPicker = Record {
		view: br_identityDetail with campaignOwneruid to uid
	}

	master = Dataset {
		view:bw_rm_organisation_masterview
	}
	
	permRules = Dataset {
	   view: bwrm_rules_permissions
	}
	
	permInRules = Dataset {
	  view: bwrm_permissions_inrules with task.perm_rulenames to permRules
	}
	
	/* Page content */
	Splitter {
		disposition:Horizontal
		Group {
			Edit {
				variable:campaignCode
				label:$bw_rm_startNLS.campaignuniquecode
				disabled:StringPredicate(campaignId) { when IsEmpty then False otherwise True }
				not-empty:True
			}
			Edit {
				variable:campaignTitle
				label:$bw_rm_startNLS.Campaigntitle
				disabled:StringPredicate(campaignId) { when IsEmpty then False otherwise True }
				not-empty:True
			}
			
			Edit {
				variable:campaignDescription
				label:$bw_rm_startNLS.campaigndescription
				not-empty:True
			}
		
			
			Edit {
				variable:campaignOwnerfullname
				disabled:True
				label:$bw_rm_startNLS.campaignowner
				commands:Command {icon:"16/audit/identity_16.png" actions:Dialog identityPicker ( campaignOwneruid from outUid, campaignOwnerfullname from outDisplayname ) }
			}

			Combo {
				label:Label {
					value:$bw_rm_startNLS.campaignfrequency
				}
				variable:campaignFrequency
				options:Static {
					Option {text:$bw_rm_startNLS.adhoc value:""}
					Option {text:$bw_rm_startNLS.daily value:"d"}
					Option {text:$bw_rm_startNLS.weekly value:"w"}
					Option {text:$bw_rm_startNLS.monthly value:"m"}
					Option {text:$bw_rm_startNLS.quarterly value:"q"}
					Option {text:$bw_rm_startNLS.semesterly value:"s"}
					Option {text:$bw_rm_startNLS.yearly value:"y"}
				}
			}
			
			DateTime {
				variable:campaignStartingDate
				label:$bw_rm_startNLS.campaignstartingdate
				disabled:StringPredicate(campaignFrequency) { when IsEmpty then True otherwise False }
				type:Date
			}		

			Edit {
				variable:campaignDuration
				label:$bw_rm_startNLS.campaignduration
				limit:3
				match:"^[0-9]*$"
				tooltip:$bw_rm_startNLS.indays
				not-empty:True
			}
			Combo {
				label: $bw_rm_startNLS.prioritylevel
				variable: task.prioritylevel
				options:
					Static { 
						Option { text: $bw_rm_startNLS.low value: "1" } 
						Option { text: $bw_rm_startNLS.medium value: "2" } 
						Option { text: $bw_rm_startNLS.high value: "3" }
					}
			}
			
			Table {
			  data: permRules
			  label: $bw_rm_startNLS.selectedPermRules 
			  layout: Layout { grab: horizontal True vertical False hint: height 130}
			  checkboxes: rulename to task.perm_rulenames
			  configurable: True
			  Column{
			    column: ruledisplayname
			    header: $bw_rm_startNLS.ruleDisplayname
			    width: 50%
			  }
			  Column{
			    column: rulenotes
			    header: $bw_rm_startNLS.ruleNotes
			    width: 50%
			  }	
			  Column {
			    column: rulename
			    header: $bw_rm_startNLS.ruleName
			    initially-masked: True
			  }		  
			}
			
			Table {
			  data: permInRules
			  show-count: True
			  label: $bw_rm_startNLS.permResult
			  layout: Layout { grab: horizontal True vertical True }
			  Column{
			    column: displayname
			    header: $bw_rm_startNLS.permHeader
			  }
			  Column{
			    column: app_displayname
			    header: $bw_rm_startNLS.appHeader
			  }			  
			}
	
		}
		Group {
			Table {
			   label: Label { value: $bw_rm_startNLS.selectedOrganisations break: True} 
				data:master
				layout:Layout{grab:horizontal True vertical True}
				checkboxes:uid to task.uid
				show-count:True
				show-filter:True
				configurable:True

				
				Column {
					column:uid
					hidden:True
					initially-masked:False
					width:100px			
					sortable:True
					filterable:True
				}
				
				Column {
					column:shortname
					header: $bw_rm_startNLS.orgShortName
					initially-masked:False
					width:100px		
					sortable:True
					filterable:True
				}
				
				Column {
					column:code
					header: $bw_rm_startNLS.orgCode
					initially-masked:True
					width:100px
					
					sortable:True
					filterable:True
				}
								
				Column {
					column:displayname
					header:$bw_rm_startNLS.orgHeader
					initially-masked:False
					width: 80%
					
					sortable:True
					filterable:True
				}
				
				Column {
					column:organisationtypedisplayname
					header:$bw_rm_startNLS.orgType
					initially-masked:False
					width: 50px
					
					sortable:True
					filterable:False
				}
				
				Column {
					column:people
					header:$bw_rm_startNLS.orgPeople
					initially-masked:False
					width: 75px
					
					sortable:True
					filterable:False
				}
			}
		}
	
	}
	
	
	Group {
		title: $bw_rm_startNLS.actionsection
		mixins: workflowActionsMixin
		
		ButtonGroup {
			align:Right
			
			Button {
				text: $bw_rm_startNLS.save
				image: "16/famfamfam_silk_icons_v013/disk.png"
				hidden:StringPredicate(campaignId) { when IsEmpty then False otherwise True}
				disabled:
					OrPredicate {
						IntPredicate(SizeOf task.uid) { when = 0 then True otherwise False}
						StringPredicate(campaignCode) { when IsEmpty then True otherwise False }
					}
				actions:
					Confirm $bw_rm_startNLS.saveconfirm,
					Set campaignCode to task.campaignid,
					Set campaignDuration to task.duration,
					CampaignSave task {
						code: campaignCode
						title:campaignTitle
						description: campaignDescription
						type: campaignType
						status-variable: campaignStatus
						owner:campaignOwneruid
						frequency: campaignFrequency
						duration:campaignDuration
						start-date:DateLDAP(campaignStartingDate)
						when-complete:
						    Flash Information $bw_rm_startNLS.saveflash,
						    GoTo Page br_campaignManager
						when-failed: Flash Error Concat("Error: ", campaignStatus)
					}
			}
			Button {
				text: $bw_rm_startNLS.update
				image: "16/famfamfam_silk_icons_v013/disk.png"
				hidden:StringPredicate(campaignId) { when IsEmpty then True otherwise False}
				disabled:
					OrPredicate {
						IntPredicate(SizeOf task.uid) { when = 0 then True otherwise False}
						StringPredicate(campaignCode) { when IsEmpty then True otherwise False }
					}
				actions:
					Confirm $bw_rm_startNLS.saveconfirm,
					Set campaignCode to task.campaignid,
					Set campaignDuration to task.duration,
					CampaignSave task {
						code: campaignCode
						title:campaignTitle
						description: campaignDescription
						type: campaignType
						status-variable: campaignStatus
						owner:campaignOwneruid
						frequency: campaignFrequency
						duration:campaignDuration
						start-date:DateLDAP(campaignStartingDate)
						when-complete:
							Flash Information $bw_rm_startNLS.saveflash,
						    GoTo Page br_campaignManager
						when-failed: Flash Error Concat("Error: ", campaignStatus)
					}
			}
		}

	}
}

