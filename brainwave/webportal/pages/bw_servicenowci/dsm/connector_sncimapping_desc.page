
ds_servicenow_ci_mapping_NLS = NLS {
  title [ en "ServiceNow - CMDB - Mapping" fr "ServiceNow - CMDB - Mapping" ]
  description [ 
    en "Optional companion connector for ServiceNow - CMDB to upload custom mappings between ServiceNow Configuration Items and Identity Analytics Resources."
    fr "Connecteur complémentaire et optionel au connecteur ServiceNow - CMDB afin de fournir un fichier de mapping entre les éléments de CMDB ServiceNow et les ressources d'Identity Analytics."]
}


ds_servicenow_ci_mapping = Page {
	title: $ds_servicenow_ci_mapping_NLS.title
