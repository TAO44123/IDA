	description: $ds_servicenow_ci_mapping_NLS.description
	icon: "bw_dsm/L/bw_genericapp.png"
	large-icon: "bw_dsm/XL/bw_genericapp.png"
	 metadata: ( 	 
	    fixedName -> "sncmdbcimapping"  ,  
	    category -> "infrastructure", 
	    destPathVar -> "bw_servicenowcimapping_sourcefolder",
		filePattern -> "*.csv",
	    hasMapping -> False,
	    multiFile -> False
	 )
}


