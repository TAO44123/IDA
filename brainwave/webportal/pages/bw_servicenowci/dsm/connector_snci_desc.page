    fr "Collecte les utilisateurs, les groupes, les rôles et tous les éléments de configuration afin de faciliter l'analyse et l'audit."]
  label_url [
  	en "URL"
  	fr "URL"
  ]
  label_url_TT [
  	en "ServiceNow URL (https://mytenant.service-now.com)"
  	fr "ServiceNow URL (https://mytenant.service-now.com)"
  ]
  label_login [ 
  	en "Login"
  	fr "Login"]
  label_login_TT [ 
  	en "ServiceNow user login." 
  	fr "Login de l'utilisateur ServiceNow"]
  label_token [ 
  	en "Token"
  	fr "Token"]
  label_token_TT [ 
  	en "ServiceNow token required to authenticate"
  	fr "Token ServiceNow requis pour l'authentification"]
  label_filterbyclass [
  	en "Filter by Class"
  	fr "Filtrer par classe"
