access360analytics_identity_applicationincommonNLS = NLS {
	title [en "Application in Common" fr "Applications en commun"]
	dyntitle [en "Applications with more than {0}% of Identities in Common" fr "Applications avec plus de {0}% d''identités en commun"]
	directrightsonly [en "Only Direct Rights" fr "seulement les droits directs"]
	description [
		en "This analytics highlight applications in common for the selected identities. Only active accounts are take into consideration. It is possible to modify the columns or to export the results."
		fr "Cette analyse met en évidence les applications en commun parmi les identités sélectionnées. Seuls les comptes actifs sont pris en compte. Il est possible de modifier les colonnes ou d'exporter les résultats"
	]
	multicombotooltip [en "Only identities who have access to at least one of those applications will be taken in consideration in the analysis" fr "Seules les identités qui ont accès à au moins une de ces applications seront prises en compte dans l'analyse"]
	sensitivitylevel [en "Group Sensitivity Level" fr "Niveau de sensibilité du groupe"]
	
	directonly [en "Direct Groups Only" fr "Seulement les groupes directs"]
	directonlytooltip [en "Only Display Direct Account-Group Links" fr "Affiche seulement les associations comptes-groupes directes"]
	
	ylabel [en "Included Identities (percentage)" fr "Identités incluses (pourcentage)"]

	lowthreshold [en "Low Threshold" fr "Seuil bas" ]
	lowthresholdtooltip [ 	en "Low threshold as a percentage of # of accounts in common for the group as compared with the total number of selected accounts"
							fr "Seuil bas en tant que pourcentage du nombre de comptes en commun par rapport au nombre de comptes sélectionnés au total"
						]
	hidechart [en "Hide Chart" fr "Masquer le graphique" ]
	hidecharttooltip [en "Hide Analytics Chart" fr "Masquer l'analyse graphique" ]
	
	identityapplications [en "Applications" fr "Applications"]
	filtering [en "Filtering" fr "Filtrage"]
	
	inspect [en "Inspect selected access right content\nthrough a detail section in the analytics\nwith both the included and excluded identity lists" fr "Inspecter le contenu du droits d'accès\nau travers d'une section détail dans l'analyse\nqui présente à la fois la liste des identités incluses et des identités exclues" ]
	originanalysis [
		en "This analytics presents the characteristics of an union of all the identities who have access to the selected applications in the list\nthanks to this analytics you can analyse the identities origin and identify if they have joint characteristics"
		fr "Cette analyse présente les caractéristiques de l'union des personnes qui ont accès aux applications sélectionnées dans la liste\nà l'aide de cette analyse vous pouvez identifier si ces personnes ont des traits en communs" 
	]
	grouprepository [en "Group Repository" fr "Référentiel du groupe"]

	nbincluded [en "Number of Included \nIdentities" fr "Nombre d'identités \nincluses" ]
	nbexcluded [en "Number of Excluded \nIdentities" fr "Nombre d'identités \nexclues" ]
	includedpercent [en "Included identities \n(percentage)" fr "Identités incluses \n(pourcentage)" ]

	nbincludedtitle [en "Included Identities" fr "Identités incluses" ]
	nbexcludedtitle [en "Excluded Identities" fr "Identités excluses" ]
	
	identitypermanalysis [en 'Identities with the Applications Analysis' fr 'Analyse des identités avec les applications']

	analysis [en "Analysis" fr "Analyse"]
	identities [en "Identities" fr "Identités"]
	
	details.tab1 [en "Identities with all Applications" fr "Identités avec toutes les applications"]
	details.tab2 [en "Identities with Missing Applications" fr "Identités avec des applications manquantes"]
	details.tab3 [en "Identities without any of those Applications" fr "Identités avec aucune des applications"]
	details.tab4 [en "Applications Venn Analysis" fr "Diagramme de Venn des applications"]
	details.tab5 [en "Identities with all Applications Origin Analysis" fr "Analyse de l'origine des identités"]
	
	details.venn.suffix1 [en "Identities" fr "identités"]
	details.venn.suffix2 [en "Identities in Common" fr "identités en commun"]

	subdetails.title [en "Details" fr "Details"]
	subdetails.identities [en "Identities" fr "Identités"]
	subdetails.permissions [en "Permissions" fr "Permissions"]
	subdetails.applications [en "Applications" fr "Applications"]
	
	analysisbutton [en "Selected Application Analysis" fr "Analyse des applications sélectionnées"]
	refineanalysisbutton [en "Permissions analysis" fr "Analyse des permissions"]
	refineanalysisbutton.tooltip [en "Refine this analysis by jumping to the permission in common analytics with the selected applications in the table" fr "Affiner l'analyse au niveau permissions en basculant sur l'analyse des permissions en commun avec les applications sélectionnées dans la liste"]
}

