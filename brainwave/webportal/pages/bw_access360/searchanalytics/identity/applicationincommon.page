						value: identityhrcode
						label: identityhrcode
						header: $identity.hrcode
					},
					Dim { 
						value: identitymail
						label: identitymail
						header: $identity.mail
					},
					Dim {
						value: identityinternal
						label: identityinternal
						header: $identity.internal
					},
					Dim {
						value: organisationcode
						label: organisationcode
						header: $porganisation.code
					},
					Dim {
						value: organisationshortname
						label: organisationshortname
						header: $porganisation.shortname
					},
					Dim {
						value: organisationdisplayname
						label: organisationdisplayname
						header: $organisation.concept
					},
					Dim {
						value: jobtitlecode
						label: jobtitlecode
						header: $identity.jobtitlecode
					},
					Dim {
						value: jobtitledisplayname
						label: jobtitledisplayname
						header: $identity.jobtitledisplayname
					}
				measures:
					Measure {
						value: identityuid
					}
			}
		}
	}
}

access360analytics_identity_applicationincommon= Page {
	title: $access360analytics_identity_applicationincommonNLS.title
	dynamic-title: $access360analytics_identity_applicationincommonNLS.dyntitle(lowthreshold)
	description: $access360analytics_identity_applicationincommonNLS.description
	feature:All(bwsa_identityapplicationsincommon, governance_license)
	tags: "identity", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: simpleReport
		
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_identity_applicationincommonNLS.filtering
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	
						applications inline,
						lowthreshold inline,
						hidechart inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_identity_FilterEdition(SerializeSearch search to identitySearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Identity Search with SerializeSearch search to identitySearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	applications = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$access360analytics_identity_applicationincommonNLS.identityapplications
		tooltip:$access360analytics_identity_applicationincommonNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:applicationlist
			text:Current displayname
			value:Current uid
		}		
	}
	lowthreshold = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:10
		label:$access360analytics_identity_applicationincommonNLS.lowthreshold
		tooltip:$access360analytics_identity_applicationincommonNLS.lowthresholdtooltip
		type:Integer
		constraint:Int{ min:0 max:100 }
	}
	hidechart = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:False
		label:$access360analytics_identity_applicationincommonNLS.hidechart
		tooltip:$access360analytics_identity_applicationincommonNLS.hidecharttooltip
		type:Boolean
	}
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}
		
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable
	outapplicationuid = Variable
	selectedidentitieswithpermission = Variable
	selectedidentitiesnotwithpermission = Variable
	selectedapplications = Variable  { multivalued: True }

	incanshowdetails = Variable { initial:True type:Boolean }	
	totalnbidentities = Variable
	
	/* Datasets and records here */
	applications = Dataset {
		search: Search {
			view:access360r_identityapplicationsincommon with applications to applications unless-empty, totalnbidentities to totalnbidentities, lowthreshold to lowthreshold
			definition:search
		}

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	// used to count the number of accounts
	counter = Dataset {
		search: Search {
			view:access360r_identitycountnbidentities with applications to applications unless-empty
			definition:search
		}
		count-variable:totalnbidentities
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	applicationlist = Dataset {
		search: Search {
			view:access360r_identityrightapplications
			definition:search
		}
	}

	goIdentityWithPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(selectedidentitieswithpermission to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowshares,
												True to inshowbusinessactivities,
												True to inshowoverallocated,
												True to inshowposition,
												True to inshowtheoretical
				)
			]
			when False then [
			
			]
		}
	)
	goIdentityNotWithPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(selectedidentitiesnotwithpermission to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowshares,
												True to inshowbusinessactivities,
												True to inshowoverallocated,
												True to inshowposition,
												True to inshowtheoretical
				)
			]
			when False then [
			
			]
		}
	)
	goApplicationDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outapplicationuid to inuid,
												True to inshowperjob,
												True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a }
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			height:180
			hidden:BooleanPredicate(hidechart)
			GridCell {
				IncludeHTMLWidget {
					//layout: Layout { hint: height 160 width 600 align: horizontal Center vertical Center }
					layout: Layout { grab: horizontal True vertical True }
					template: lineChart
					datasets: applications ( label, applicationcode, percent ) to chartdata ( label, code , count )
					hidden:BooleanPredicate(hidechart)
					bindings: 
						value-of False to maintainAspectRatio,
						value-of False to xAxesdisplay,
						value-of True to beginAtZero,
						value-of $access360analytics_identity_applicationincommonNLS.ylabel to ylabel,
						value-of 2 to pointRadius,
						value-of "start" to fill,
						value-of False to curvedLine
				}
			}
		} 
		GridRow {
			height:grow
			GridCell {
				ButtonGroup {
					Button {
						actions:Dialog access360analytics_identity_applicationincommonorgjob(selectedapplications to applicationsuid, SerializeSearch search to search, applications to applications)
						image:%collection_16.bulb
						text:$access360analytics_identity_applicationincommonNLS.analysisbutton
						tooltip:$access360analytics_identity_applicationincommonNLS.originanalysis
						disabled:
							OrPredicate {
								IntPredicate(SizeOf selectedapplications) { when >999 then True otherwise False }					
								StringPredicate(selectedapplications) { when IsEmpty then True otherwise False }
							}
					}
					Button {
						actions:GoTo Page access360analytics_identity_accessrightsincommon with selectedapplications to applications, SerializeSearch search to search
						image:%browsing_16.link
						text:$access360analytics_identity_applicationincommonNLS.refineanalysisbutton
						tooltip:$access360analytics_identity_applicationincommonNLS.refineanalysisbutton.tooltip
						disabled:
							OrPredicate {
								IntPredicate(SizeOf selectedapplications) { when >999 then True otherwise False }					
								StringPredicate(selectedapplications) { when IsEmpty then True otherwise False }
							}
					}
				}
				Table {
					data:applications
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					persist-configuration:True
					checkboxes:applicationuid to selectedapplications
					
					Column {
						column:applicationuid
						hidden:True
						selection:outapplicationuid
					}

					Column {
						column:applicationdisplayname
						header:$application.concept
						width:100%
						sortable:True
						filterable:True
						actions:ExecuteNamedAction goApplicationDetails
						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}


					Column {
						column:nbidentity
						header:$access360analytics_identity_applicationincommonNLS.nbincluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:nbexcludedidentities
						header:$access360analytics_identity_applicationincommonNLS.nbexcluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:percent
						text:Concat(Current percent,' %')
						header:$access360analytics_identity_applicationincommonNLS.includedpercent
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
				}
			}
		}	
	}
}
