access360analytics_identity_peoplewithallapplications = Dialog {
	title:$access360analytics_identity_applicationincommonNLS.subdetails.title
	buttons:OkButton
	width:1000
	height:600

	enter-event:
		MultivaluedAdd code1 to applicationsuid,
		MultivaluedAdd code2 to applicationsuid,
		MultivaluedAdd code3 to applicationsuid,
		MultivaluedAdd code4 to applicationsuid,
		MultivaluedAdd code5 to applicationsuid,
		MultivaluedAdd code6 to applicationsuid
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}

	code1 = Variable
	code2 = Variable
	code3 = Variable
	code4 = Variable
	code5 = Variable
	code6 = Variable
	applicationsuid = Variable { multivalued:True }

	selectedidentityuid = Variable
	selectedapplicationuid = Variable

	identitieswithpermission = Dataset {
		search: Search {
			view:access360r_identitylistappsincommon with applicationsuid to applicationuids
			definition:search
		}
		excludes:BooleanPredicate(False)
	}
	applications = Dataset {
		view:access360r_listapps_innerview with applicationsuid to uid
	}

	goIdentityDetails = NamedAction (
			Dialog bwf_identityDetailsDialog(selectedidentityuid to inuid,
											True to inshowaccounts,
											True to inshowapplications,
											True to inshowcontrols,
											True to inshowdecisionhistory,
											True to inshowshares,
											True to inshowbusinessactivities,
											True to inshowoverallocated,
											True to inshowposition,
											True to inshowtheoretical
			)
	)

	goApplicationDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog(selectedapplicationuid to inuid,
										True to inshowperjob,
										True to inshowperorg
		)
	)

	TabFolder {
		TabItem {
			text:$access360analytics_identity_applicationincommonNLS.subdetails.identities
		
			Table {
				data:identitieswithpermission
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goIdentityDetails
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					actions:ExecuteNamedAction goIdentityDetails
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
					filterable:True
					sortable:True
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_identity_applicationincommonNLS.subdetails.applications
	
			Table {
				data:applications
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:uid
					selection:selectedapplicationuid
					hidden:True
				}
				Column {
					column:code
					header:$application.code
					width:100%
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goApplicationDetails
				}
				Column {
					column:displayname
					header:$application.concept
					width:100%
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goApplicationDetails
				}
			}	
		}
	
	}
}

access360analytics_identity_applicationincommonorgjob = Dialog {
	title:$access360analytics_identity_applicationincommonNLS.identitypermanalysis
	buttons:OkButton
	width:1300
	height:700
	
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}

	applicationsuid = Variable { multivalued: True }
	selectedidentityuid = Variable
	
	activatedTab1 = Variable { initial:True type:Boolean }
	activatedTab2 = Variable { initial:False type:Boolean }
	activatedTab3 = Variable { initial:False type:Boolean }
	activatedTab4 = Variable { initial:False type:Boolean }
	activatedTab5 = Variable { initial:False type:Boolean }
	
	identitieswithapplication = Dataset {
		search: Search {
			view:access360r_identitylistappsincommon with applicationsuid to applicationuids
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:
		AndPredicate {
			Not BooleanPredicate(activatedTab1)
			Not BooleanPredicate(activatedTab5)
		}		
	}

	identitieswithoutapplication = Dataset {
		search: Search {
			view:access360r_identitylistnotappsincommon with applicationsuid to applicationuids
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab2)
	}
	
	identitieswithoutanyapplication = Dataset {
		search: Search {
			view:	access360r_identitylistnoappsatall with applicationsuid to applicationuids
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab3)
	}
	
	venndata = Dataset {
		search: Search {
			view:access360r_identitylistappsincommon_innerview with applicationsuid to uid
			definition:search
		}
		disabled:
		OrPredicate {
			IntPredicate(SizeOf applicationsuid) { when<2 then True otherwise False }
			IntPredicate(SizeOf applicationsuid) { when>10 then True otherwise False }
			Not BooleanPredicate(activatedTab4)
		}
	}
	
	goIdentityWithPermissionDetails = NamedAction (
			Dialog bwf_identityDetailsDialog(selectedidentityuid to inuid,
											True to inshowaccounts,
											True to inshowapplications,
											True to inshowcontrols,
											True to inshowdecisionhistory,
											True to inshowshares,
											True to inshowbusinessactivities,
											True to inshowoverallocated,
											True to inshowposition,
											True to inshowtheoretical
			)
	)

