			Table {
				data:identitieswithapplication
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					
					actions:ExecuteNamedAction goIdentityWithPermissionDetails
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
					filterable:True
					sortable:True
					
					actions:ExecuteNamedAction goIdentityWithPermissionDetails
					tooltip: $search_page.showdetails
				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		
		}
		TabItem {
			text:$access360analytics_identity_applicationincommonNLS.details.tab2
			hidden:IntPredicate(SizeOf applicationsuid) { when =1 then True otherwise False }
			activation-event:Set True to activatedTab2
			
			Table {
				data:identitieswithoutapplication
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					
