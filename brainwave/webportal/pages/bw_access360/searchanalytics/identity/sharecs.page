/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_fragments/share/resources.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ''
	otherwise current
}

access360analytics_identity_sharecsNLS = NLS {
	title [en "Shares analysis" fr "Analyse des partages"]
	directrightsonly [en "only direct rights" fr "seulement les droits directs"]
	description [
		en "This report analyses the identities shares in a form of a pivot table. Only active accounts are taken into account. It is possible to identify only changes that have occurred since a given date."
		fr "Ce rapport analyse les partages des identités sous la forme d'un tableau croisé. Seuls les comptes actifs sont pris en compte. Il est possible d'identifier uniquement les changements survenus depuis une date donnée."
	]
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
}

access360analytics_identity_sharecs= Page {
	title: $access360analytics_identity_sharecsNLS.title
	description: $access360analytics_identity_sharecsNLS.description
	tags: "identity", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwsa_identitysharecs)
	mixins: simpleReport	
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						selectedfamily inline,
						applications inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_identity_FilterEdition(SerializeSearch search to identitySearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Identity Search with SerializeSearch search to identitySearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	selectedfamily = Parameter {
		hidden:False
		mandatory:False
		label:$fragmentPShareNLS.family
		multivalued:False
		type:String
		constraint:Lookup {
			data:applicationfamily
			text:Current applicationapplicationfamily
			value:Current applicationapplicationfamily
		}
	}
	applications = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$fragmentPShareNLS.concept
		tooltip:$access360analytics_identity_sharecsNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:applicationlist
			text:Current applicationdisplayname
			value:Current applicationuid
		}		
	}
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}
		
	/* Variables here */
	outshareuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	applications = Dataset {
		search: Search {
			view:access360r_identityshares_bv with applications to applications unless-empty, selectedfamily to sharefamily unless-empty, comparisontimeslot to comparisontimeslot unless-empty, exclRemoved to excluderemoved, exclSimilar to excludesimilar
			definition:search
		}

		excludes:BooleanPredicate(False) /* Contournement de bug */

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	applicationlist = Dataset {
		search: Search {
			view:access360r_identitysharelist with selectedfamily to sharefamily unless-empty
			definition:search
		}
	}
	applicationfamily = Dataset {
		search: Search {
			view:access360r_identitysharefamily
			definition:search
		}
	}

	goShareDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outshareuid to inuid,
													True to inshowperjob,
													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid,
												True to inshowgroups,
												True to inshowshares
				)
			]
			when False then [
			
			]
		}
	)
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid, True to inshowaccounts, True to inshowshares)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:applications
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:32px  grab: horizontal True vertical True}
					columns:Dim { value:applicationapplicationfamily header:$fragmentShareNLS.pfamily }, Dim {value:applicationuid label:applicationdisplayname header:$application.concept header-click:outshareuid}
					rows:	Dim {value:orgdisplayname header:$organisation.concept width:160px},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:identityinternal label:identityinternal header:$identity.internal width:100px initially-masked:True},
							Dim {value:identityuid label:identityfullname tooltip:identityfullname header:$identity.fullname header-click:outidentityuid} 
					cell-content:CellContent {text: 'X' cluster-value:'X' align:Center tooltip:Current accountlogin styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 }}
					column-header-click:ExecuteNamedAction goShareDetails
					row-header-click:ExecuteNamedAction goIdentityDetails
				}
			}
		}	
	}
}
