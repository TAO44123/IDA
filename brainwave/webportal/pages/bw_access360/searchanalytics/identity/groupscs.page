/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/group/details/groupDetails.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ''
	otherwise current
}

access360analytics_identity_GroupscsNLS = NLS {
	title [en "Groups analysis" fr "Analyse des groupes"]
	directrightsonly [en "only direct rights" fr "seulement les droits directs"]
	description [
		en "This report analyse the identities groups in the form of a pivot table. Only active accounts are taken into account. Only the groups directly associated with individuals are taken into account. It is possible to identify only changes that have occurred since a given date."
		fr "Ce rapport analyse les groupes des identités sous la forme d'un tableau croisé. Seuls les comptes actifs sont pris en compte. Seuls les groupes directement associés aux personnes sont pris en comptes. Il est possible d'identifier uniquement les changements survenus depuis une date donnée."
	]
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
	sensitivitylevel [en "Group sensitivity level" fr "Niveau de sensibilité du groupe"]
}

access360analytics_identity_Groupscs= Page {
	title: $access360analytics_identity_GroupscsNLS.title
	description: $access360analytics_identity_GroupscsNLS.description
	tags: "identity", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwsa_identitygroupscs
	mixins: simpleReport	
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						repositories inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_identity_FilterEdition(SerializeSearch search to identitySearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Identity Search with SerializeSearch search to identitySearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	repositories = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$repository.concept
		tooltip:$access360analytics_identity_GroupscsNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:repositorylist
			text:Current repositorydisplayname
			value:Current repositoryuid
		}		
	}
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}
		
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable
	outgroupuid = Variable

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	groups = Dataset {
		search: Search {
			view:a360s_identitygroups_bv with repositories to repositories unless-empty, comparisontimeslot to comparisontimeslot unless-empty, exclRemoved to excluderemoved, exclSimilar to excludesimilar
			definition:search
		}

		excludes:BooleanPredicate(False) /* Contournement de bug */
	
		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	repositorylist = Dataset {
		search: Search {
			view:access360r_identityaccountgrouprepos
			definition:search
		}
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												True to inshowaccounts
				)
			]
			when False then [
			
			]
		}
	)
	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid,
												True to inshowgroups
				)
			]
			when False then [
			
			]
		}
	)
	goGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid,
												True to inshowapplications,
												True to inshowshares,
												True to inshowperjob,
												True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:groups
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:32px  grab: horizontal True vertical True }
					columns:Dim {value:repositorydisplayname header:$repository.concept},Dim {value:groupuid label:groupdisplayname header:$group.concept header-click:outgroupuid} 
					rows:	Dim {value:orgcode label:orgdisplayname header:$organisation.concept width:160px},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:identityinternal label:identityinternal header:$identity.internal width:100px initially-masked:True},
							Dim {value:identityuid label:identityfullname tooltip:identityfullname header:$identity.fullname header-click:outidentityuid} 
					cell-content:CellContent {text: 'X' cluster-value:'X' align:Center tooltip:Current accountlogin styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 }}
					column-header-click:ExecuteNamedAction goGroupDetails
					row-header-click:ExecuteNamedAction goIdentityDetails
				}
			}
		}	
	}
}
