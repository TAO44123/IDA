/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

/* Nationalized labels here */
access360analytics_identityaccountlistNLS = NLS {
	title [en "Active accounts list" fr "Liste des comptes actifs"]
	description [
		en "This report presents the active accounts list.You can configure the columns or export the data by right clicking on the table."
		fr "Ce rapport présente les comptes actifs. Vous pouvez configurer les colonnes ou exporter les données à l'aide d'un clic droit sur la table."
	]
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
}

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ''
	otherwise current
}

access360analytics_identityaccountlist = Page {
	title: $access360analytics_identityaccountlistNLS.title
	tags: "identity", "searchresults"
	description:$access360analytics_identityaccountlistNLS.description
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwsa_identityaccountslist
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						repositories inline
		}
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_identity_FilterEdition(SerializeSearch search to identitySearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Identity Search with SerializeSearch search to identitySearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	repositories = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$repository.concept
		tooltip:$access360analytics_identityaccountlistNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:repositories
			text:Current repositorydisplayname
			value:Current repositoryuid
		}		
	}
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}
	
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	data = Dataset {
		search: Search {
			view:a360s_identityaccounts_bv with repositories to repositories unless-empty, comparisontimeslot to comparisontimeslot unless-empty, exclRemoved to excluderemoved, exclSimilar to excludesimilar
			definition:search
		}

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	repositories = Dataset {
		search: Search {
			view:access360r_identityaccountrepos
			definition:search
		}
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid, True to inshowaccounts)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowgroups,
												True to inshowowner,
												True to inshowshares,
												True to inshowdecisionhistory,
												True to inshowusages
				)
			]
			when False then [
			
			]
		}
	)
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3

				PaginatedTable {
					data:data
					layout:Layout { grab: horizontal True vertical True }
					configurable:True
					page-size:1000
					//show-count:True
					show-filter:True
					double-click:ExecuteNamedAction goAccountDetails
					persist-configuration:True
					show-count-button: True
			
					Column {
						column:identityuid
						hidden:True
						selection:outidentityuid
					}
			
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 when 'Invalid' then tartimeline_highlightremoved360 } text:Transform Current status using tarmapping360 }
			
					Column {
						column:identityhrcode
						header:$identity.hrcode
						sortable:True
						filterable:True
						width:128px
						
						actions: ExecuteNamedAction goIdentityDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:identityfullname
						header:$identity.fullname
						sortable:True
						filterable:True
						width:160px
						
						actions: ExecuteNamedAction goIdentityDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:identitymail
						header:$identity.mail
						sortable:True
						filterable:True
						width:160px
						initially-masked:True
					}
					Column {
						column:identityinternal
						header:$identity.internal
						sortable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:identityarrivaldate
						header:$identity.arrivaldate
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:identitydeparturedate
						header:$identity.departuredate
						sortable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:organisationshortname
						header:$porganisation.shortname
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:organisationdisplayname
						header:$organisation.concept
						sortable:True
						width:160px
						initially-masked:True
					}
			
					Column {
						column:accountuid
						hidden:True
						selection:outaccountuid
					}
					Column {
						column:accountidentifier
						header:$account.identifier
						sortable:True
						filterable:True
						width:128px
						actions: ExecuteNamedAction goAccountDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						initially-masked:True
					}
					Column {
						column:accountlogin
						header:$account.login
						sortable:True
						filterable:True
						width:128px
						actions: ExecuteNamedAction goAccountDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column:accountusername
						header:$paccount.username
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
						actions: ExecuteNamedAction goAccountDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
					}
					Column {
						column:accountlastlogindate
						header:$account.lastlogindate
						sortable:True
						filterable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:accountdontexpirepassword
						header:$account.dontexpirepassword
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountlocked
						header:$account.locked
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountpasswordcantchange
						header:$account.passwordcantchange
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountpasswordexpired
						header:$account.passwordexpired
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountpasswordnotrequired
						header:$account.passwordnotrequired
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountprivilegedaccount
						header:$account.privilegedaccount
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountservice
						header:$account.service
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountsmartcardrequired
						header:$account.smartcardrequired
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountcreationdate
						header:$paccount.creationdate
						sortable:True
						width:128px
						initially-masked:True
					}
					Column {
						column:accountexpiredate
						header:$paccount.expiredate
						sortable:True
						width:128px
						initially-masked:True
					}
			
					Column {
						column:repositorydisplayname
						header:$repository.concept
						sortable:True
						filterable:True
						width:128px
					}
				}
			}
		}
	}
}
