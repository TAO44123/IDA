				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.details.tab4
			activation-event:Set True to activatedTab4
			hidden:
				OrPredicate { // hide Venn analysis if over limits...
					IntPredicate(SizeOf groupsuid) { when>10 then True otherwise False }
					IntPredicate(SizeOf groupsuid) { when<2 then True otherwise False }
					IntPredicate(Count venndata) { when>5000 then True otherwise False }
				}

			IncludeHTMLWidget {
				layout: Layout { hint: height 500 width 1000 align: horizontal Center vertical Center }
				template: vennDiagramChart
