access360analytics_identity_GroupsincommonNLS = NLS {
	title [en "Groups in Common" fr "Groupes en commun"]
	dyntitle [en "Groups with more than {0}% of Identities in Common" fr "Groupes avec plus de {0}% d''identités en commun"]
	directrightsonly [en "Only Direct Rights" fr "seulement les droits directs"]
	description [
		en "This analytics highlight the groups in common for the selected identities. Only active accounts are take into consideration. You can display perform the analysis on direct accounts groups or on all accounts groups. It is possible to modify the columns or to export the results."
		fr "Cette analyse met en évidence les groupes en commun parmi les identités sélectionnées. Seuls les comptes actifs sont concernés. Vous pouvez limiter l'analyse aux groupes directs ou à l'ensemble des groupes des comptes. Il est possible de modifier les colonnes ou d'exporter les résultats"
	]
	multicombotooltip [en "Click to Configure the Filter" fr "Cliquez pour configurer le filtre"]
	sensitivitylevel [en "Group Sensitivity Level" fr "Niveau de sensibilité du groupe"]
	
	directonly [en "Direct Groups Only" fr "Seulement les groupes directs"]
	directonlytooltip [en "Only Display Direct Account-Group Links" fr "Affiche seulement les associations comptes-groupes directes"]
	
	ylabel [en "Included Identities (percentage)" fr "Identités inclues (pourcentage)"]

	lowthreshold [en "Low threshold" fr "Seuil bas" ]
	lowthresholdtooltip [ 	en "Low threshold as a percentage of # of identities in common for the group as compared with the total number of selected identities"
							fr "Seuil bas en tant que pourcentage du nombre d'identités en commun par rapport au nombre d'identités sélectionnées au total"
						]
	hidechart [en "Hide Chart" fr "Masquer le graphique" ]
	hidecharttooltip [en "Hide Analytics Chart" fr "Masquer l'analyse graphique" ]
	
	accountrepository [en "Account Repository" fr "Référentiel du compte"]
	filtering [en "Filtering" fr "Filtrage"]
	
	inspect [en "Inspect selected group content\nthrough a detail section in the analytics\nwith both the included and excluded identity lists" fr "Inspecter le contenu du groupe\nau travers d'une section détail dans l'analyse\nqui présente à la fois la liste des identités incluses et des identités exclues" ]
	grouprepository [en "Group \nRepository" fr "Référentiel \ndu groupe"]

	nbincluded [en "Number of Included \nIdentities" fr "Nombre d'identités \nincluses" ]
	nbexcluded [en "Number of Excluded \nIdentities" fr "Nombre d'identités \nexclues" ]
	includedpercent [en "Included Identities \n(percentage)" fr "Identités incluses \n(pourcentage)" ]

	nbincludedtitle [en "Included Identities" fr "Identités incluses" ]
	nbexcludedtitle [en "Excluded Identities" fr "Identités exclues" ]

	identitypermanalysis [en 'Identities with the Group Analysis' fr 'Analyse des identités avec le groupe']

	originanalysis [
		en "This analytics presents the characteristics of an union of all the identities who have access to the selected groups in the list\nthanks to this analytics you can analyse the identities origin and identify if they have joint characteristics"
		fr "Cette analyse présente les caractéristiques de l'union des personnes qui ont accès aux groupes sélectionnés dans la liste\nà l'aide de cette analyse vous pouvez identifier si ces personnes ont des traits en communs" 
	]

	details.tab1 [en "Identities with all Groups" fr "Identités avec tous les groupes"]
	details.tab2 [en "Identities with Missing Groups" fr "Identités avec des groupes manquants"]
	details.tab3 [en "Identities without any of those Groups" fr "Identités avec aucun des groupes"]
	details.tab4 [en "Groups Venn Analysis" fr "Diagramme de Venn des groupes"]
	details.tab5 [en "Identities with all Group Origin Analysis" fr "Analyse de l'origine des identités"]

	subdetails.title [en "Details" fr "Details"]
	subdetails.identities [en "Identities" fr "Identités"]
	subdetails.groups [en "Groups" fr "Groupes"]

	analysisbutton [en "Selected Group Analysis" fr "Analyse des groupes sélectionnés"]

	details.venn.suffix1 [en "Identities" fr "identités"]
	details.venn.suffix2 [en "Identities in Common" fr "identités en commun"]
}

green1style = Style {
	background:Color RGB(0, 203, 178)
}
green2style = Style {
	background:Color RGB(0, 178, 140)
}
green3style = Style {
	background:Color RGB(0, 153, 102)
	foreground:white
}
green4style = Style {
	background:Color RGB(0, 128, 64)
	foreground:white
}

similarStyle = IntStylingTemplate {
	when >80 then green4style
	when >60 then green3style
	when >40 then green2style
	when >20 then green1style
}

access360analytics_identity_peoplewithallgroups = Dialog {
	title:$access360analytics_identity_GroupsincommonNLS.subdetails.title
	buttons:OkButton
	width:1000
	height:600

	enter-event:
		MultivaluedAdd code1 to groupsuid,
		MultivaluedAdd code2 to groupsuid,
		MultivaluedAdd code3 to groupsuid,
		MultivaluedAdd code4 to groupsuid,
		MultivaluedAdd code5 to groupsuid,
		MultivaluedAdd code6 to groupsuid
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}

	code1 = Variable
	code2 = Variable
	code3 = Variable
	code4 = Variable
	code5 = Variable
	code6 = Variable
	directonly = Variable { type:Boolean }
	groupsuid = Variable { multivalued:True }

	selectedidentityuid = Variable
	selectedgroupuid = Variable

	identitieswithgroup = Dataset {
		search: Search {
			view:access360r_identitylistgroupsincommon with groupsuid to groupuids, directonly to directonly
			definition:search
		}
		excludes:BooleanPredicate(False)
	}
	groups = Dataset {
		view:access360r_listgroups_innerview with groupsuid to uid
	}

	goIdentityDetails = NamedAction (
			Dialog bwf_identityDetailsDialog(selectedidentityuid to inuid,
											True to inshowaccounts,
											True to inshowapplications,
											True to inshowcontrols,
											True to inshowdecisionhistory,
											True to inshowshares,
											True to inshowbusinessactivities,
											True to inshowoverallocated,
											True to inshowposition,
											True to inshowtheoretical
			)
	)

	goGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedgroupuid to inuid,
										True to inshowperjob,
										True to inshowperorg
		)
	)

	TabFolder {
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.subdetails.identities
		
			Table {
				data:identitieswithgroup
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goIdentityDetails
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					actions:ExecuteNamedAction goIdentityDetails
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
					filterable:True
					sortable:True
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.subdetails.groups
	
			Table {
				data:groups
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:uid
					selection:selectedgroupuid
					hidden:True
				}
				Column {
					column:code
					header:$group.code
					width:160px
					filterable:True
					sortable:True
					align:Right
					initially-masked:True
					actions:ExecuteNamedAction goGroupDetails
				}
				Column {
					column:displayname
					header:$group.concept
					width:300px
					filterable:True
					sortable:True
					align:Right
					actions:ExecuteNamedAction goGroupDetails
				}
				Column {
					column:repositorydisplayname
					header:$repository.concept
					width:160px
					filterable:True
					sortable:True
					align:Right
				}
			}	
		}
	
	}
}

access360analytics_identity_Groupsincommonorgjob = Dialog {
	title:$access360analytics_identity_GroupsincommonNLS.identitypermanalysis
	buttons:OkButton
	width:1300
	height:700
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}

	directonly = Variable { type:Boolean }
	repositories = Variable { multivalued: True }
	groupsuid = Variable { multivalued: True }
	selectedidentityuid = Variable

	activatedTab1 = Variable { initial:True type:Boolean }
	activatedTab2 = Variable { initial:False type:Boolean }
	activatedTab3 = Variable { initial:False type:Boolean }
	activatedTab4 = Variable { initial:False type:Boolean }
	activatedTab5 = Variable { initial:False type:Boolean }

	identitieswithgroup = Dataset {
		search: Search {
			view:access360r_identitylistgroupsincommon with groupsuid to groupuids, directonly to directonly
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:
		AndPredicate {
			Not BooleanPredicate(activatedTab1)
			Not BooleanPredicate(activatedTab5)
		}		
	}

	identitieswithoutgroup = Dataset {
		search: Search {
			view:access360r_identitylistnotgroupsincommon with groupsuid to groupuids, directonly to directonly
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab2)
	}
	
	identitieswithoutanygroup = Dataset {
		search: Search {
			view:	access360r_identitylistnogroupsatall with groupsuid to groupuids, repositories to repositories unless-empty, directonly to directonly
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab3)
	}
	
	venndata = Dataset {
		search: Search {
			view:access360r_identitylistgroupsincommon_innerview with groupsuid to uid, directonly to directonly
			definition:search
		}
		disabled:
		OrPredicate {
			IntPredicate(SizeOf groupsuid) { when<2 then True otherwise False }
			IntPredicate(SizeOf groupsuid) { when>10 then True otherwise False }
			Not BooleanPredicate(activatedTab4)
		}
	}
	
	goIdentityWithGroupDetails = NamedAction (
			Dialog bwf_identityDetailsDialog(selectedidentityuid to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowshares,
												True to inshowbusinessactivities,
												True to inshowoverallocated,
												True to inshowposition,
												True to inshowtheoretical
			)
	)
	
	TabFolder {
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.details.tab1
			activation-event:Set True to activatedTab1

			Table {
				data:identitieswithgroup
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					
					actions:ExecuteNamedAction goIdentityWithGroupDetails
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
					filterable:True
					sortable:True
					
					actions:ExecuteNamedAction goIdentityWithGroupDetails
					tooltip: $search_page.showdetails
				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.details.tab2
			hidden:IntPredicate(SizeOf groupsuid) { when =1 then True otherwise False }
			activation-event:Set True to activatedTab2

			Table {
				data:identitieswithoutgroup
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					
