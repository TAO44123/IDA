					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.details.tab3
			activation-event:Set True to activatedTab3

			Table {
				data:identitieswithoutanygroup
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
