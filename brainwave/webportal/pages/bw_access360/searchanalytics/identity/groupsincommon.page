					when onclick then [
						Dialog access360analytics_identity_peoplewithallgroups(
							Current code1 to code1,
							Current code2 to code2,
							Current code3 to code3,
							Current code4 to code4,
							Current code5 to code5,
							Current code6 to code6,
							SerializeSearch search to search,
							directonly to directonly							
						)
					]
				}
			}
		}
		TabItem {
			text:$access360analytics_identity_GroupsincommonNLS.details.tab5
			activation-event:Set True to activatedTab5
			DynamicCrossTable {
				data:identitieswithgroup
				layout: Layout { grab: horizontal True vertical True row-headers-max-width:500px }	
				dimensions:
					Dim {
						value: identityfullname
						label: identityfullname
						header: $identity.fullname
					},	
					Dim {
						value: identityhrcode
						label: identityhrcode
						header: $identity.hrcode
					},
					Dim {
						value: identitymail
						label: identitymail
						header: $identity.mail
					},
					Dim {
						value: identityinternal
						label: identityinternal
						header: $identity.internal
					},
					Dim {
						value: organisationcode
						label: organisationcode
						header: $porganisation.code
					},
					Dim {
						value: organisationshortname
						label: organisationshortname
						header: $porganisation.shortname
					},
					Dim {
						value: organisationdisplayname
						label: organisationdisplayname
						header: $organisation.concept
					},
					Dim {
						value: jobtitlecode
						label: jobtitlecode
						header: $identity.jobtitlecode
					},
					Dim {
						value: jobtitledisplayname
						label: jobtitledisplayname
						header: $identity.jobtitledisplayname
					}
				measures:
					Measure {
						value: identityuid
					}
			}
		}
	}
}

access360analytics_identity_Groupsincommon= Page {
	title: $access360analytics_identity_GroupsincommonNLS.title
	dynamic-title: $access360analytics_identity_GroupsincommonNLS.dyntitle(lowthreshold)
	description: $access360analytics_identity_GroupsincommonNLS.description
	feature:All(bwsa_identitygroupsincommon, Any(governance_license, compliance_license))
	tags: "identity", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: simpleReport
		
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_identity_GroupsincommonNLS.filtering
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	
						repositories inline,
						directonly inline,
						lowthreshold inline,
						hidechart inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_account_FilterEdition(SerializeSearch search to identitySearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Identity Search with SerializeSearch search to identitySearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	repositories = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$access360analytics_identity_GroupsincommonNLS.accountrepository
		tooltip:$access360analytics_identity_GroupsincommonNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:repositorylist
			text:Current repositorydisplayname
			value:Current repositoryuid
		}		
	}
	directonly = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:True
		label:$access360analytics_identity_GroupsincommonNLS.directonly
		tooltip:$access360analytics_identity_GroupsincommonNLS.directonlytooltip
		type:Boolean
	}
	lowthreshold = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:10
		label:$access360analytics_identity_GroupsincommonNLS.lowthreshold
		tooltip:$access360analytics_identity_GroupsincommonNLS.lowthresholdtooltip
		type:Integer
		constraint:Int{ min:0 max:100 }
	}
	hidechart = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:False
		label:$access360analytics_identity_GroupsincommonNLS.hidechart
		tooltip:$access360analytics_identity_GroupsincommonNLS.hidecharttooltip
		type:Boolean
	}
	
	search = SearchDefinition {
		entity: Identity
		simple-mode-rule: br_identity_simple_search
	}
		
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable
	outgroupuid = Variable
	selectedidentitieswithgroup = Variable
	selectedidentitiesnotwithgroup = Variable
	selectedgroups = Variable { multivalued:True }

	incanshowdetails = Variable { initial:True type:Boolean }	
	totalnbidentities = Variable
	
	/* Datasets and records here */
	groups = Dataset {
		search: Search {
			view:access360r_identitygroupsincommon with repositories to repositories unless-empty, directonly to directonly, totalnbidentities to totalnbidentities, lowthreshold to lowthreshold
			definition:search
		}

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	// used to count the number of accounts
	counter = Dataset {
		search: Search {
			view:access360r_identitycountnbidentities with repositories to repositories unless-empty
			definition:search
		}
		count-variable:totalnbidentities
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	repositorylist = Dataset {
		search: Search {
			view:access360r_identitygrouprepos
			definition:search
		}
	}

	goGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid,
												True to inshowperjob,
												True to inshowperorg
												)
			]
			when False then [
			
			]
		}
	)
	goIdentityWithGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(selectedidentitieswithgroup to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowshares,
												True to inshowbusinessactivities,
												True to inshowoverallocated,
												True to inshowposition,
												True to inshowtheoretical
				)
			]
			when False then [
			
			]
		}
	)
	goIdentityNotWithGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(selectedidentitiesnotwithgroup to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowshares,
												True to inshowbusinessactivities,
												True to inshowoverallocated,
												True to inshowposition,
												True to inshowtheoretical
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a }
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			height:160
			hidden:BooleanPredicate(hidechart)
			GridCell {
				span:1
				

				IncludeHTMLWidget {
					//layout: Layout { hint: height 160 width 600 align: horizontal Center vertical Center }
					layout: Layout { grab: horizontal True vertical True }
					template: lineChart
					datasets: groups ( groupdisplayname, groupuid, percent ) to chartdata ( label, code , count )
					hidden:BooleanPredicate(hidechart)
					bindings: 
						value-of False to maintainAspectRatio,
						value-of False to xAxesdisplay,
						value-of True to beginAtZero,
						value-of $access360analytics_identity_GroupsincommonNLS.ylabel to ylabel,
						value-of 2 to pointRadius,
						value-of "start" to fill,
						value-of False to curvedLine
				}
			}
		} 
		GridRow {
			height:grow
			GridCell {
				span:1
			
				ButtonGroup {
					Button {
						actions:Dialog access360analytics_identity_Groupsincommonorgjob(selectedgroups to groupsuid, directonly to directonly, SerializeSearch search to search, repositories to repositories unless-empty, directonly to directonly unless-empty)
						image:%collection_16.bulb
						tooltip:$access360analytics_identity_GroupsincommonNLS.originanalysis
						disabled:
							OrPredicate {
								StringPredicate(selectedgroups) { when IsEmpty then True otherwise False }
								IntPredicate(SizeOf selectedgroups) { when >999 then True otherwise False }
							}					
						text:$access360analytics_identity_GroupsincommonNLS.analysisbutton
					}
				}
				Table {
					data:groups
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					persist-configuration:True
					checkboxes:groupuid to selectedgroups
					
					Column {
						column:groupuid
						hidden:True
						selection:outgroupuid
					}
					Column {
						column:groupdisplayname
						header:$group.concept
						width:100%
						sortable:True
						filterable:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
						
						actions: ExecuteNamedAction goGroupDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:groupcode
						header:$pgroup.code
						width:160px
						sortable:True
						filterable:True
						initially-masked:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
						
						actions: ExecuteNamedAction goGroupDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails
					}
					Column {
						column:groupbwa_groupmetadata_descr
						header:$pgroup.comment
						width:140px
						sortable:True
						filterable:True
						initially-masked:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:groupbwa_groupmetadata_sensitivitylevel
						header:$access360analytics_identity_GroupsincommonNLS.sensitivitylevel
						width:140px
						sortable:True
						initially-masked:True
					}

					Column {
						column:grouprepositorydisplayname
						header:$access360analytics_identity_GroupsincommonNLS.grouprepository
						width:140px
						sortable:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}


					Column {
						column:nbidentity
						header:$access360analytics_identity_GroupsincommonNLS.nbincluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:nbexcludedaccounts
						header:$access360analytics_identity_GroupsincommonNLS.nbexcluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:percent
						text:Concat(Current percent,' %')
						header:$access360analytics_identity_GroupsincommonNLS.includedpercent
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
				}
			}
		}	
	}
}
