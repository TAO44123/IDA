/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ""
	otherwise current
}

access360analytics_account_ApplicationscsNLS = NLS {
	title [en "Applications analysis" fr "Analyse des applications"]
	directrightsonly [en "only direct rights" fr "seulement les droits directs"]
	description [
		en "This report presents the accounts applications as a pivot table. Only active accounts are taken into account. Only the rights of type 'Application profile' are taken into account. It is possible to identify only changes that have occurred since a given date. It is possible to modify the columns or to export the results."
		fr "Ce rapport présente les applications des comptes sous la forme d'un tableau croisé. Seuls les comptes actifs sont pris en compte. Seuls les droits directement associés aux comptes sont affichés. Il est possible d'identifier uniquement les changements survenus depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats"
	]
}

access360analytics_account_Applicationscs= Page {
	title: $access360analytics_account_ApplicationscsNLS.title
	description: $access360analytics_account_ApplicationscsNLS.description
	tags: "account", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwsa_accountapplicationscs
	mixins: simpleReport	
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						applications inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_account_FilterEdition(SerializeSearch search to accountSearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Account Search with SerializeSearch search to accountSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	applications = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$application.concept
		tooltip:$access360analytics_resourcesNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:applicationlist
			text:Current applicationdisplayname
			value:Current applicationuid
		}		
	}

	search = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}
	
		
	/* Variables here */
	inpermissiontypes = Variable { multivalued:True initial:NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") }

	outapplicationuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable

//	applications = Variable { multivalued:True }

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	applist = Dataset {
		search: Search {
			view:access360r_accountapplications_bv with comparisontimeslot to comparisontimeslot unless-empty, applications to applications unless-empty, True to withjoborglink, exclRemoved to excluderemoved, exclSimilar to excludesimilar
			definition:search
		}

		excludes:BooleanPredicate(False) /* Contournement de bug */

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	applicationlist = Dataset {
		search: Search {
			view:access360r_accountrightsapplications
			definition:search
		}
	}

	goApplicationDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outapplicationuid to inuid,
													True to inshowperjob,
													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)
	
	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid,
													False to inshowaccounts,
													True to inshowperjob,
													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
												True to inshowgroups,
												True to inshowapplications,
												True to inshowshares,
												True to inshowowner,
												True to inshowcontrols
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:applist
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:32px  grab: horizontal True vertical True}
					columns:Dim {value:applicationdisplayname header:$application.concept} 
					rows:	Dim {value:orgcode label:orgdisplayname header:$organisation.concept width:160px tooltip:orgdisplayname},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:identityinternal label:identityinternal header:$identity.internal width:100px initially-masked:True},
							Dim {value:identityuid label:identityfullname header:$identity.fullname width:160px tooltip:identityfullname},
							Dim {value:accountuid label:accountlogin header:$account.login header-click:outaccountuid tooltip:accountlabel width:200px} 
					cell-content:CellContent {text: 'X' cluster-value:'X' align:Center tooltip:Current accountlabel styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 }}
					row-header-click:ExecuteNamedAction goAccountDetails
					column-header-click:ExecuteNamedAction goPermissionDetails
				}
			}
		}	
	}
}
