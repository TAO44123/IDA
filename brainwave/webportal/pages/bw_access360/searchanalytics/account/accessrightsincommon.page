access360analytics_identity_peoplewithallpermissions = Dialog {
	title:$access360analytics_account_accessrightsincommonNLS.subdetails.title
	buttons:OkButton
	width:1000
	height:600

	enter-event:
		MultivaluedAdd code1 to permissionsuid,
		MultivaluedAdd code2 to permissionsuid,
		MultivaluedAdd code3 to permissionsuid,
		MultivaluedAdd code4 to permissionsuid,
		MultivaluedAdd code5 to permissionsuid,
		MultivaluedAdd code6 to permissionsuid
	
	search = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}

	code1 = Variable
	code2 = Variable
	code3 = Variable
	code4 = Variable
	code5 = Variable
	code6 = Variable
	permissionsuid = Variable { multivalued:True }

	selectedidentityuid = Variable
	selectedaccountuid = Variable
	selectedpermissionuid = Variable

	identitieswithpermission = Dataset {
		search: Search {
			view:access360r_accountlistpermsincommon with permissionsuid to permissionuids
			definition:search
		}
		excludes:BooleanPredicate(False)
	}
	permissions = Dataset {
		view:access360r_listperms_innerview with permissionsuid to uid
	}

	goIdentityDetails = NamedAction (
			Dialog bwf_identityDetailsDialog(selectedidentityuid to inuid,
											True to inshowposition
			)
	)

	goAccountDetails = NamedAction (
			Dialog bwf_accountDetailsDialog(selectedaccountuid to inuid,
											True to inshowapplications,
											True to inshowcontrols,
											True to inshowgroups,
											True to inshowowner,
											True to inshowshares,
											True to inshowdecisionhistory
			)
	)

	goPermissionDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog(selectedpermissionuid to inuid,
										True to inshowperjob,
										True to inshowperorg
		)
	)

	TabFolder {
		TabItem {
			text:$access360analytics_account_accessrightsincommonNLS.subdetails.accounts
		
			Table {
				data:identitieswithpermission
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:identityuid
					hidden:True
					selection:selectedidentityuid
				}
				Column {
					column:accountuid
					hidden:True
					selection:selectedaccountuid
				}
				Column {
					column:accountlogin
					header:$account.login
					initially-masked:False
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goAccountDetails
				}
				Column {
					column:accountusername
					header:$paccount.username
					initially-masked:False
					width:160px
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goAccountDetails
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goIdentityDetails
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					actions:ExecuteNamedAction goIdentityDetails
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
					filterable:True
					sortable:True
					
					tooltip: $search_page.showdetails
				}
				Column {
					column:identityinternal
					header:$identity.internal
					sortable:True
				}
				Column {
					column:jobtitledisplayname
					header:$identity.jobtitledisplayname
					sortable:True
					filterable:True
					width:200px
				}
				Column {
					column:organisationdisplayname
					header:$organisation.concept
					sortable:True
					filterable:True
					width:200px
				}
			}		
		}
		TabItem {
			text:$access360analytics_account_accessrightsincommonNLS.subdetails.permissions
	
			Table {
				data:permissions
				layout: Layout { grab: horizontal True vertical True }
				show-count:True
				show-filter:True
				configurable:True
				
				Column {
					column:uid
					selection:selectedpermissionuid
					hidden:True
				}
				Column {
					column:code
					header:$permission.code
					width:160px
					filterable:True
					sortable:True
					align:Right
					initially-masked:True
					actions:ExecuteNamedAction goPermissionDetails
				}
				Column {
					column:displayname
					header:$permission.concept
					width:300px
					filterable:True
					sortable:True
					align:Right
					actions:ExecuteNamedAction goPermissionDetails
				}
				Column {
					column:applicationdisplayname
					header:$application.concept
					width:160px
					filterable:True
					sortable:True
					align:Right
				}
			}	
		}
	
	}
}

access360analytics_account_accessrightsincommonorgjob = Dialog {
	title:$access360analytics_account_accessrightsincommonNLS.accountpermanalysis
	buttons:OkButton
	width:1300
	height:700
	
	
	search = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}

	applications = Variable { multivalued: True }
	permissionsuid = Variable { multivalued: True }
	selectedidentityuid = Variable
	selectedaccountuid = Variable
	
	activatedTab1 = Variable { initial:True type:Boolean }
	activatedTab2 = Variable { initial:False type:Boolean }
	activatedTab3 = Variable { initial:False type:Boolean }
	activatedTab4 = Variable { initial:False type:Boolean }
	activatedTab5 = Variable { initial:False type:Boolean }
	
	identitieswithpermission = Dataset {
		search: Search {
			view:access360r_accountlistpermsincommon with permissionsuid to permissionuids
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:
		AndPredicate {
			Not BooleanPredicate(activatedTab1)
			Not BooleanPredicate(activatedTab5)
		}		
	}

	identitieswithoutpermission = Dataset {
		search: Search {
			view:access360r_accountlistnotpermsincommon with permissionsuid to permissionuids
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab2)
	}
	
	identitieswithoutanypermission = Dataset {
		search: Search {
			view:	access360r_accountlistnopermsatall with permissionsuid to permissionuids, applications to applications unless-empty
			definition:search
		}
		excludes:BooleanPredicate(False)
		disabled:Not BooleanPredicate(activatedTab3)
	}
	
	venndata = Dataset {
		search: Search {
			view:access360r_accountlistpermsincommon_innerview with permissionsuid to uid
			definition:search
		}
		disabled:
		OrPredicate {
			IntPredicate(SizeOf permissionsuid) { when<2 then True otherwise False }
