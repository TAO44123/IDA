access360analytics_account_accessrightsincommon= Page {
	title: $access360analytics_account_accessrightsincommonNLS.title
	dynamic-title: $access360analytics_account_accessrightsincommonNLS.dyntitle(lowthreshold)
	description: $access360analytics_account_accessrightsincommonNLS.description
	feature:All(bwsa_accountaccessrightsincommon, Any(governance_license, compliance_license))
	tags: "account", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: simpleReport
		
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_account_accessrightsincommonNLS.filtering
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	
						applications inline,
						lowthreshold inline,
						hidechart inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_account_FilterEdition(SerializeSearch search to accountSearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Account Search with SerializeSearch search to accountSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	applications = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$access360analytics_account_accessrightsincommonNLS.accountapplication
		tooltip:$access360analytics_account_accessrightsincommonNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:applicationlist
			text:Current displayname
			value:Current uid
		}		
	}
	lowthreshold = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:10
		label:$access360analytics_account_accessrightsincommonNLS.lowthreshold
		tooltip:$access360analytics_account_accessrightsincommonNLS.lowthresholdtooltip
		type:Integer
		constraint:Int{ min:0 max:100 }
	}
	hidechart = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:False
		label:$access360analytics_account_accessrightsincommonNLS.hidechart
		tooltip:$access360analytics_account_accessrightsincommonNLS.hidecharttooltip
		type:Boolean
	}
	
	search = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}
		
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable
	outpermissionuid = Variable
	selectedpermissions = Variable  { multivalued: True }
	selectedaccountingroup = Variable
	selectedaccountnotingroup = Variable


	incanshowdetails = Variable { initial:True type:Boolean }	
	totalnbaccounts = Variable
	
	/* Datasets and records here */
	accessrights = Dataset {
		search: Search {
			view:access360r_accountaccessrightsincommon with applications to applications unless-empty, totalnbaccounts to totalnbaccounts, lowthreshold to lowthreshold
			definition:search
		}

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	// used to count the number of accounts
	counter = Dataset {
		search: Search {
			view:access360r_accountnbaccounts with applications to applications unless-empty
			definition:search
		}
		count-variable:totalnbaccounts
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	applicationlist = Dataset {
		search: Search {
			view:access360r_accountapplications
			definition:search
		}
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												True to inshowaccounts
												)
			]
			when False then [
			
			]
		}
	)
	goAccountInGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedaccountingroup to inuid,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowowner,
												True to inshowshares
				)
			]
			when False then [
			
			]
		}
	)
	goAccountNotInGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedaccountnotingroup to inuid,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowowner,
												True to inshowshares
				)
			]
			when False then [
			
			]
		}
	)
	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid,
												True to inshowperjob,
												True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a }
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			height:160
			hidden:BooleanPredicate(hidechart)
			GridCell {
				span:1

				IncludeHTMLWidget {
					//layout: Layout { hint: height 160 width 600 align: horizontal Center vertical Center }
					layout: Layout { grab: horizontal True vertical True }
					template: lineChart
					datasets: accessrights ( label, permissionuid, percent ) to chartdata ( label, code , count )
					hidden:BooleanPredicate(hidechart)
					bindings: 
						value-of False to maintainAspectRatio,
						value-of False to xAxesdisplay,
						value-of True to beginAtZero,
						value-of $access360analytics_account_accessrightsincommonNLS.ylabel to ylabel,
						value-of 2 to pointRadius,
						value-of "start" to fill,
						value-of False to curvedLine
				}
			}
		} 
		GridRow {
			height:grow
			GridCell {
				span:1
			
				ButtonGroup {
					Button {
						actions:Dialog access360analytics_account_accessrightsincommonorgjob(selectedpermissions to permissionsuid, applications to applications, SerializeSearch search to search)
						image:%collection_16.bulb
						text:$access360analytics_account_accessrightsincommonNLS.analysisbutton
						tooltip:$access360analytics_account_accessrightsincommonNLS.originanalysis
						disabled:
							OrPredicate {
								StringPredicate(selectedpermissions) { when IsEmpty then True otherwise False }
								IntPredicate(SizeOf selectedpermissions) { when >999 then True otherwise False }
							}					
					}
				}
				Table {
					data:accessrights
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					persist-configuration:True
					checkboxes:permissionuid to selectedpermissions
					
					Column {
						column:applicationdisplayname
						header:$application.concept
						width:160px
						sortable:True
						filterable:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:permissionuid
						hidden:True
						selection:outpermissionuid
					}
					Column {
						column:permissioncode
						header:$ppermission.code
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
						
						actions: ExecuteNamedAction goPermissionDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:permissiondisplayname
						header:$permission.concept
						width:100%
						sortable:True
						filterable:True
						
						actions: ExecuteNamedAction goPermissionDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:permissionbwa_permissionmetadata_descr
						header:$ppermission.description
						width:140px
						sortable:True
						filterable:True
						initially-masked:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:permissionbwa_permissionmetadata_sensitivitylevel
						header:$access360analytics_account_accessrightsincommonNLS.sensitivitylevel
						width:140px
						sortable:True
						initially-masked:True
					}

					Column {
						column:nbaccount
						header:$access360analytics_account_accessrightsincommonNLS.nbincluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:nbexcludedaccounts
						header:$access360analytics_account_accessrightsincommonNLS.nbexcluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:percent
						text:Concat(Current percent,' %')
						header:$access360analytics_account_accessrightsincommonNLS.includedpercent
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
				}
			}
		}	
	}
}
