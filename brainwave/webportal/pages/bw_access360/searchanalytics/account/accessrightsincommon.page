access360analytics_account_accessrightsincommonNLS = NLS {
	title [en "Access Rights in Common" fr "Droits d'accès en commun"]
	dyntitle [en "Access Rights with more than {0}% of Accounts in Common" fr "Droits d''accès avec plus de {0}% de comptes en commun"]
	directrightsonly [en "Only Direct Rights" fr "seulement les droits directs"]
	description [
		en "This analytics highlight the access rights in common for the selected accounts. Only direct rights are displayed, only application type 'Profile' is considered. It is possible to modify the columns or to export the results."
		fr "Cette analyse met en évidence les droits d'accès en commun parmi les comptes sélectionnés. Seuls les droits d'accès directs sont affichés, seules les applications de type 'Profile' sont considérées. Il est possible de modifier les colonnes ou d'exporter les résultats"
	]
	multicombotooltip [en "Click to Configure the Filter" fr "Cliquez pour configurer le filtre"]
	sensitivitylevel [en "Group Sensitivity Level" fr "Niveau de sensibilité du groupe"]
	
	directonly [en "Direct Groups Only" fr "Seulement les groupes directs"]
	directonlytooltip [en "Only Display Direct Account-Group Links" fr "Affiche seulement les associations comptes-groupes directes"]
	
	ylabel [en "Included Accounts (percentage)" fr "Comptes inclus (pourcentage)"]

	lowthreshold [en "Low Threshold" fr "Seuil bas" ]
	lowthresholdtooltip [ 	en "Low threshold as a percentage of # of accounts in common for the group as compared with the total number of selected accounts"
							fr "Seuil bas en tant que pourcentage du nombre de comptes en commun par rapport au nombre de comptes sélectionnés au total"
						]
	hidechart [en "Hide chart" fr "Masquer le graphique" ]
	hidecharttooltip [en "Hide Analytics Chart" fr "Masquer l'analyse graphique" ]
	
	accountapplication [en "Account Application" fr "Application du compte"]
	filtering [en "Filtering" fr "Filtrage"]
	
	inspect [en "Inspect selected group content\nthrough a detail section in the analytics\nwith both the included and excluded accounts lists" fr "Inspecter le contenu du groupe\nau travers d'une section détail dans l'analyse\nqui présente à la fois la liste des comptes inclus et des comptes exclus" ]
	grouprepository [en "Group Repository" fr "Référentiel du groupe"]
	originanalysis [
		en "This analytics presents the characteristics of an union of all the accounts who have access to the selected permissions in the list\nthanks to this analytics you can analyse the accounts origin and identify if they have joint characteristics"
		fr "Cette analyse présente les caractéristiques de l'union des comptes qui ont accès aux permissions sélectionnées dans la liste\nà l'aide de cette analyse vous pouvez identifier si ces comptes ont des traits en communs" 
	]

	nbincluded [en "Number of Included \nAccounts" fr "Nombre de comptes \ninclus" ]
	nbexcluded [en "Number of Excluded \nAccounts" fr "Nombre de comptes \nexclus" ]
	includedpercent [en "Included Accounts \n(percentage)" fr "Comptes inclus \n(pourcentage)" ]

	nbincludedtitle [en "Included Accounts" fr "Comptes inclus" ]
	nbexcludedtitle [en "Excluded Accounts" fr "Comptes exclus" ]

	accountpermanalysis [en 'Accounts with the permissions analysis' fr 'Analyse des comptes avec les permissions']

	details.tab1 [en "Accounts with all Permissions" fr "Comptes avec toutes les permissions"]
	details.tab2 [en "Accounts with Missing Permissions" fr "Comptes avec des permissions manquantes"]
	details.tab3 [en "Accounts without any of those Permissions" fr "Comptes avec aucune des permissions"]
	details.tab4 [en "Permissions Venn Analysis" fr "Diagramme de Venn des permissions"]
	details.tab5 [en "Accounts with all Permissions Origin Analysis" fr "Analyse de l'origine des comptes"]
	
	details.venn.suffix1 [en "Accounts" fr "comptes"]
	details.venn.suffix2 [en "Accounts in Common" fr "comptes en commun"]

	subdetails.title [en "Details" fr "Details"]
	subdetails.accounts [en "Accounts" fr "Comptes"]
	subdetails.permissions [en "Permissions" fr "Permissions"]
	
	analysisbutton [en "Selected Permissions Analysis" fr "Analyse des permissions sélectionnées"]
}

green1style = Style {
	background:Color RGB(0, 203, 178)
}
green2style = Style {
	background:Color RGB(0, 178, 140)
}
green3style = Style {
	background:Color RGB(0, 153, 102)
	foreground:white
}
green4style = Style {
	background:Color RGB(0, 128, 64)
