				Column {
					column:accountusername
					header:$paccount.username
					initially-masked:False
					width:160px
					filterable:True
					sortable:True
					actions:ExecuteNamedAction goAccountDetails
				}
				Column {
					column:identityhrcode
					header:$identity.hrcode
					initially-masked:True
					filterable:True
					sortable:True
				}
				Column {
					column:identityfullname
					header:$identity.fullname
					filterable:True
					sortable:True
					width:160px
					
					actions:ExecuteNamedAction goIdentityDetails
					tooltip: $search_page.showdetails
				}
				Column {
					column:identitymail
					header:$identity.mail
					initially-masked:True
