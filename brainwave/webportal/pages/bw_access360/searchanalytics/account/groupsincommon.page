access360analytics_account_Groupsincommon= Page {
	title: $access360analytics_account_GroupsincommonNLS.title
	dynamic-title: $access360analytics_account_GroupsincommonNLS.dyntitle(lowthreshold)
	description: $access360analytics_account_GroupsincommonNLS.description
	feature:All(bwsa_accountgroupsincommon, Any(governance_license, compliance_license))
	tags: "account", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: simpleReport
		
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_account_GroupsincommonNLS.filtering
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	
						repositories inline,
						directonly inline,
						lowthreshold inline,
						hidechart inline
		}
		
		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_account_FilterEdition(SerializeSearch search to accountSearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Account Search with SerializeSearch search to accountSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	repositories = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		label:$access360analytics_account_GroupsincommonNLS.accountrepository
		tooltip:$access360analytics_account_GroupsincommonNLS.multicombotooltip
		type:String
		constraint:Lookup {
			data:repositorylist
			text:Current repositorydisplayname
			value:Current repositoryuid
		}		
	}
	directonly = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:True
		label:$access360analytics_account_GroupsincommonNLS.directonly
		tooltip:$access360analytics_account_GroupsincommonNLS.directonlytooltip
		type:Boolean
	}
	lowthreshold = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:10
		label:$access360analytics_account_GroupsincommonNLS.lowthreshold
		tooltip:$access360analytics_account_GroupsincommonNLS.lowthresholdtooltip
		type:Integer
		constraint:Int{ min:0 max:100 }
	}
	hidechart = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		default:False
		label:$access360analytics_account_GroupsincommonNLS.hidechart
		tooltip:$access360analytics_account_GroupsincommonNLS.hidecharttooltip
		type:Boolean
	}
	
	search = SearchDefinition {
		entity: Account
		simple-mode-rule: br_account_simple_search
	}
		
	/* Variables here */
	outidentityuid = Variable
	outaccountuid = Variable
	outgroupuid = Variable
	selectedaccountingroup = Variable
	selectedaccountnotingroup = Variable
	selectedgroups = Variable { multivalued:True }


	incanshowdetails = Variable { initial:True type:Boolean }	
	totalnbaccounts = Variable
	
	/* Datasets and records here */
	groups = Dataset {
		search: Search {
			view:access360r_accountgroupsincommon with repositories to repositories unless-empty, directonly to directonly, totalnbaccounts to totalnbaccounts, lowthreshold to lowthreshold
			definition:search
		}

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	// used to count the number of accounts
	counter = Dataset {
		search: Search {
			view:access360r_accountnbaccounts with repositories to repositories unless-empty
			definition:search
		}
		count-variable:totalnbaccounts
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	repositorylist = Dataset {
		search: Search {
			view:access360r_accountgrouprepos
			definition:search
		}
	}

	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												True to inshowaccounts
												)
			]
			when False then [
			
			]
		}
	)
	goAccountInGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedaccountingroup to inuid,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowowner,
												True to inshowshares
				)
			]
			when False then [
			
			]
		}
	)
	goAccountNotInGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_accountDetailsDialog(selectedaccountnotingroup to inuid,
												True to inshowgroups,
												True to inshowapplications,
												True to inshowcontrols,
												True to inshowdecisionhistory,
												True to inshowowner,
												True to inshowshares
				)
			]
			when False then [
			
			]
		}
	)
	goGroupDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_groupDetailsDialog(outgroupuid to inuid,
												True to inshowapplications,
												True to inshowshares,
												True to inshowperjob,
												True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a }
		layout:Layout { grab:horizontal True vertical True }
		GridRow {
			height:160
			hidden:BooleanPredicate(hidechart)
			GridCell {
				span:1
				

				IncludeHTMLWidget {
					//layout: Layout { hint: height 160 width 600 align: horizontal Center vertical Center }
					layout: Layout { grab: horizontal True vertical True }
					template: lineChart
					datasets: groups ( groupdisplayname, groupuid, percent ) to chartdata ( label, code , count )
					hidden:BooleanPredicate(hidechart)
					bindings: 
						value-of False to maintainAspectRatio,
						value-of False to xAxesdisplay,
						value-of True to beginAtZero,
						value-of $access360analytics_account_GroupsincommonNLS.ylabel to ylabel,
						value-of 2 to pointRadius,
						value-of "start" to fill,
						value-of False to curvedLine
				}
			}
		} 
		GridRow {
			height:grow
			GridCell {
				span:1
			
				ButtonGroup {
					Button {
						actions:Dialog access360analytics_account_Groupsincommonorgjob(selectedgroups to groupsuid, repositories to repositories, SerializeSearch search to search, directonly to directonly)
						image:%collection_16.bulb
						text:$access360analytics_account_GroupsincommonNLS.analysisbutton
						tooltip:$access360analytics_account_GroupsincommonNLS.originanalysis
						disabled:
							OrPredicate {
								IntPredicate(SizeOf selectedgroups) { when >999 then True otherwise False }					
								StringPredicate(selectedgroups) { when IsEmpty then True otherwise False }
							}
					}
				}
				Table {
					data:groups
					layout:Layout {grab: horizontal True vertical True}
					configurable:True
					show-count:True
					show-filter:True
					persist-configuration:True
					checkboxes:groupuid to selectedgroups
					
					Column {
						column:groupdisplayname
						header:$group.concept
						width:100%
						sortable:True
						filterable:True
						
						actions: ExecuteNamedAction goGroupDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:groupcode
						header:$pgroup.code
						width:160px
						sortable:True
						filterable:True
						initially-masked:True
						
						actions: ExecuteNamedAction goGroupDetails
						actions-disabled: Not BooleanPredicate(incanshowdetails)
						tooltip: $search_page.showdetails

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:groupbwa_groupmetadata_descr
						header:$pgroup.comment
						width:140px
						sortable:True
						filterable:True
						initially-masked:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:groupbwa_groupmetadata_sensitivitylevel
						header:$access360analytics_account_GroupsincommonNLS.sensitivitylevel
						width:140px
						sortable:True
						initially-masked:True
					}

					Column {
						column:grouprepositorydisplayname
						header:$access360analytics_account_GroupsincommonNLS.grouprepository
						width:140px
						sortable:True

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}


					Column {
						column:nbaccount
						header:$access360analytics_account_GroupsincommonNLS.nbincluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:nbexcludedaccounts
						header:$access360analytics_account_GroupsincommonNLS.nbexcluded
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:percent
						text:Concat(Current percent,' %')
						header:$access360analytics_account_GroupsincommonNLS.includedpercent
						width:160px
						sortable:True
						align:Right

						styling:StylingTemplateSelection (Current percent) using similarStyle 
					}
					Column {
						column:groupuid
						hidden:True
						selection:outgroupuid
					}
				}
			}
		}	
	}
}
