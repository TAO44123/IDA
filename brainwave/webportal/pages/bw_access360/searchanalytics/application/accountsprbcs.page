/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/identity/details/identityDetails.page"
import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/control/details/controlDetails.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_fragments/lib/nls.page"

import "/webportal/pages/bw_access360/searchanalytics/resources.page"

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	when IsNull then ""
	otherwise current
}

access360analytics_application_AccountsprbcsNLS = NLS {
	title [en "Active accounts analysis with controls defects" fr "Analyse des comptes actifs ayant des défauts de contrôle"]
	directrightsonly [en "only direct rights" fr "seulement les droits directs"]
	description [
		en "This report analyses the application accounts with controls defects with a pivot table. Only active accounts are taken into account. Only one login is considered per cell. It is possible to identify only changes that have occurred since a given date."
		fr "Ce rapport analyse les comptes ayant des défauts de contrôle des applications avec un tableau croisé. Seuls les comptes actifs sont pris en compte. Seul un login est affiché par cellule. Il est possible d'identifier uniquement les changements survenus depuis une date donnée."
	]
	multicombotooltip [en "Click to configure the filter" fr "Cliquez pour configurer le filtre"]
	empty [ en "You must pick at least one control in the list" fr "Vous devez sélectionner au moins un contrôle dans la liste"]

	risklevel [en "Risk level" fr "Niveau de risque"]
	riskinfo [en "Risk info" fr "Informations sur le risque"]
	suggestedmitigation [en "Suggested mitigation" fr "Remédation suggérée"]

	controlscope [en "Control scope" fr "Portée du controle"]
	minimumrisklevel [en "Minimum risk level" fr "Niveau de risque minimum"]
}

access360analytics_application_Accountsprbcs= Page {
	title: $access360analytics_application_AccountsprbcsNLS.title
	description: $access360analytics_application_AccountsprbcsNLS.description
	feature:bwsa_applicationaccountsprbcs
	tags: "application", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	mixins: simpleReport	
	dock-left:Dock {
		width:200
		collapsible:True
		collapsed:False
		
		Header {
			value:$access360analytics_resourcesNLS.localfiltertitle
			styling:bold
			tooltip:$access360analytics_resourcesNLS.localfiltertooltip
		}
		Separator {
			width:1
		}
		ParametersEdition {
			allow-reset:True
			parameters:	comparisontimeslot inline,		
						exclRemoved inline,
						exclSimilar inline,
						minimumrisklevel inline,
						controlscope inline,
						controls inline
		}

		Spacer {
			height:Fill
		}
		
		Button {
			actions:Dialog access360analytics_application_FilterEdition(SerializeSearch search to applicationSearch)
			text:$access360analytics_resourcesNLS.displayfilterbutton
			tooltip:$access360analytics_resourcesNLS.displayfiltertooltip
		}
		Button {
			actions:GoTo Activity Application Search with SerializeSearch search to applicationSearch
			text:$access360analytics_resourcesNLS.back
			tooltip:$access360analytics_resourcesNLS.back_tooltip
			layout:Layout { grab:horizontal True vertical False }
		}
	}

	/* Parameters here */
	comparisontimeslot = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:String
		label:$session_comparisonTimeslotTeam360NLS.label
		tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
		constraint:Lookup {
			data:session_comparisontimeslots
			text:Current commitdate
			value:Current uid
		}
	}
	exclRemoved = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:True
		label:$session_exclRemovedNLS.label
		tooltip:$session_exclRemovedNLS.tooltip
	}
	exclSimilar = Parameter {
		hidden:False
		mandatory:False
		multivalued:False
		type:Boolean
		default:False
		label:$session_exclSimilarNLS.label
		tooltip:$session_exclSimilarNLS.tooltip
	}
	controls = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		type:String
		label:$pcontrolresult.controldisplayname
		constraint:Lookup {
			data:controlslist
			text:Current controldisplayname
			value:Current controlcode
		}
	}
	controlscope = Parameter {
		hidden:False
		mandatory:False
		multivalued:True
		type:String
		label:$access360analytics_application_AccountsprbcsNLS.controlscope
		constraint: Choice {
			values:["Account","Identity"]
		}
	}
	minimumrisklevel = Parameter {
		label:$access360analytics_application_AccountsprbcsNLS.minimumrisklevel
		hidden:False
		mandatory:False
		multivalued:False
		type:Integer
		constraint: Choice {
			values:[
				'':' ',
				4:$bwf_ControlLevel_NLS._4,
				3:$bwf_ControlLevel_NLS._3,
				2:$bwf_ControlLevel_NLS._2,
				1:$bwf_ControlLevel_NLS._1,
				0:$bwf_ControlLevel_NLS._0
			]
		}
	}

	search = SearchDefinition {
		entity: Application
		simple-mode-rule: br_application_simple_search
	}
	
		
	/* Variables here */
	inpermissiontypes = Variable { multivalued:True initial:NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") }

	outapplicationuid = Variable
	outpermissionuid = Variable
	outidentityuid = Variable
	outaccountuid = Variable
	outcontrolcode = Variable

//	applications = Variable { multivalued:True }

	incanshowdetails = Variable { initial:True type:Boolean }	
	
	/* Datasets and records here */
	accounts = Dataset {
		search: Search {
			view:access360r_applicationaccountsctrl_bv with comparisontimeslot to comparisontimeslot unless-empty, controlscope to controlscope unless-empty, minimumrisklevel to minimumrisklevel unless-empty, controls to controls, exclRemoved to excluderemoved, exclSimilar to excludesimilar
			definition:search
		}
		
		excludes:BooleanPredicate(False) /* Contournement de bug produit */

		timeout-configuration:TimeoutConfiguration [
			{
				short-timeout:30
				long-timeout:300
			}
		]
	}
	
	controlslist = Dataset {
		view:access360r_applicationctrllist
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	goApplicationDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_applicationDetailsDialog(outapplicationuid to inuid,
													True to inshowperjob,
													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)
	
	goPermissionDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_permissionDetailsDialog(outpermissionuid to inuid,
													True to inshowaccounts,
													True to inshowperjob,
													True to inshowperorg
				)
			]
			when False then [
			
			]
		}
	)
	
	goIdentityDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_identityDetailsDialog(outidentityuid to inuid,
												outapplicationuid to inapplicationuids,
												True to inshowapplications				
				)
			]
			when False then [
			
			]
		}
	)

	goControlDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				Dialog bwf_controlDetailsDialog(outcontrolcode to incontrolcode, outaccountuid to inaccountuid, outidentityuid to inidentityuid)
			]
			when False then [
			
			]
		}
	)

	goAccountDetails = NamedAction (
		BooleanCase(incanshowdetails) {
			when True then [
				StringCase(outaccountuid) {
					when Not IsEmpty then [
						Dialog bwf_accountDetailsDialog(outaccountuid to inuid, 
														True to inshowgroups,
														True to inshowapplications,
														True to inshowshares,
														True to inshowowner,
														True to inshowcontrols
						)
					]
				}
			]
			when False then [
			
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:accounts
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:32px  row-headers-max-width:480px grab: horizontal True vertical True}
					columns:Dim { value:controlcode label:controldisplayname header:$controlresult.controldisplayname },  Dim {value:applicationuid label:applicationdisplayname header:$application.concept header-click:outapplicationuid}  
					rows:	Dim {value:orgcode label:orgdisplayname header:$organisation.concept width:160px},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:identityinternal label:identityinternal header:$identity.internal width:100px initially-masked:True},
							Dim {value:identityuid label:identityfullname header:$identity.fullname width:160px},
							Dim {value:accountuid label:accountlogin header:$account.login header-click:outaccountuid}  
					cell-content:CellContent {text: 'X' cluster-value:'X' align:Center styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 }}
					row-header-click:ExecuteNamedAction goAccountDetails
					column-header-click:ExecuteNamedAction goApplicationDetails
				}
			}
		}	
	}
}
