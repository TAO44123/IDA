/* Import other pages here */

/*Tab for GDPR fragment */
tabsStyle = Mixin {
	Grid {
		fill: Both
		gap:0
		insets:0
	}
	
	ButtonGroup {
	  margins: Left 0 Bottom 1
	   spacing: 1
	   uniform: False	   
	}
	
	Button {
		presentation: Link
		align: Left
		layout: Layout { grab: horizontal True vertical True align: horizontal Beginning vertical Center}
		styling: tab			
	}
	
}


tab = Style(uiBase) {
    //size: 16px
	foreground: RGB(80, 80, 80)
	bold: False
}

uiBase = Style {
     //size: 12px
     size: 14px
}

managerenduserMyself = Style {
	bold:True
}