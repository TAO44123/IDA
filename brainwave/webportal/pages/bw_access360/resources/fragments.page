import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_fragments/identity/accounts.page"
import "/webportal/pages/bw_fragments/identity/rights.page"
import "/webportal/pages/bw_fragments/identity/cacredentials.page"
import "/webportal/pages/bw_fragments/identity/data.page"
import "/webportal/pages/bw_fragments/identity/managedresources.page"
import "/webportal/pages/bw_fragments/identity/tasks.page"
import "/webportal/pages/bw_fragments/identity/batchedreports.page"
import "/webportal/pages/bw_fragments/identity/team.page"
import "/webportal/pages/bw_fragments/identity/entriestorevoke.page"
