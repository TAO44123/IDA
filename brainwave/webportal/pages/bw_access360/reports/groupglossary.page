groupglossary360 = Page {
	title: $groupglossary360NLS.title
	dynamic-title: $groupglossary360NLS.dyntitle(identity.fullname)
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	description:$groupglossary360NLS.description
	feature:bwa360_groupglossary
	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	selectedgroups = Variable { multivalued:True }
	selectedgroup = Variable
	selectedgroupsensitivitylevel = Variable
	selectedgroupsensitivityreason = Variable
	selectedgroupdescription = Variable
	ismanaged = Variable { type:Boolean }
	
	/* Datasets and records here */
	identity = Record {
		view:bwf_identityDetail with uid to uid
	}
	repository = Record {
		view:bwf_repositoryDetail with UserVariable session_selectedRepositoriesTeam360 to uid
	}
	
	managedrepositories = Dataset {
		view:enduser360_managedrepositories with uid to uid
	}
	groups = Dataset {
		view:access360_repositorygroups with UserVariable session_selectedRepositoriesTeam360 to uid
	}
	
//	editgroup = NamedAction (
//		Dialog bwfGroupDetailsMetadata_Dialog(	selectedgroup to paramGroupUid,
//													selectedgroupsensitivitylevel to sensitivitylevel,
//													selectedgroupsensitivityreason to sensitivityreason,
//													selectedgroupdescription to description,
//													ismanaged to ismanaged), 
//												ReloadData (groups)	
//	)
//	
//	batcheditgroup = NamedAction (
//		Dialog bwfGroupDetailsBatchMetadata_Dialog (selectedgroups to groups), 
//												ReloadData (groups)	
//	)
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 40 } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 200 }
					variable:UserVariable session_selectedRepositoriesTeam360
					options:Dynamic {
						data:managedrepositories
						text:Current resourcename
						value:Current resourceuid
					}
					label:$session_selectedGroupsTeam360NLS.label
					tooltip:$session_selectedGroupsTeam360NLS.tooltip
