	)
	
	/* Page content */

	Flow {
		disposition:Horizontal
		layout: Layout { grab: horizontal True vertical False hint: height 110 }
		Group {
			Text {
				label:$repository.code
				value:repository.code
				compact:True
			}
			Text {
				label:$repository.displayname
				value:repository.displayname
				compact:True
			}
			Text {
				label:$repository.repositoryfamily
				value: Transform repository.repositoryfamily using bwfRepoFamilyType
				compact:True
			}
		}
		Group {
			Text {
				label:$fragmentRepositoryDetailsNLS.category
				value:repository.category
				compact:True
			}
			Text {
				label:$repository.sensitivityreason
				value:repository.sensitivityreason
				compact:True
			}
			Text {
				label:$repository.sensitivitylevel
				value:Transform repository.sensitivitylevel using bwfGroupSensitivityLevelMapping
				compact:True
			}
			Text {
				label:$repository.description
				tooltip:repository.description
				value:repository.description
				compact:True
					commands:Commands { position: After orientation: Horizontal 
									Command{	actions:Dialog bwfRepositoryDetailsMetadata_Dialog(repositoryuid to paramRepositoryUid, repository.sensitivitylevel to sensitivitylevel, 
																									repository.sensitivityreason to sensitivityreason, 
																									repository.description to description, 
																									repository.category to category,
																									repository.repositorytype to repositorytype), 
														ReloadData (repository)
					                        	icon:%collection_16.pencil
					                        	tooltip:$fragmentRepositoryDetailsNLS.updatemetadata
					                       }
					                  }
			}
		}
	}


	Separator {
		width:1
	}

	Grid {
		columns:GridColumn { fill:True width: grow }, GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 38 }
		GridRow {
			GridCell {
				ButtonGroup {
					Button {
						actions:ExecuteNamedAction batcheditgroup
						text:$repoglossary360FragmentNLS.bulk
			            image:%collection_16.pencil
			            disabled:StringPredicate(selectedgroups) { when IsEmpty then True otherwise False }
					}
//					Batch add managers is too time consuming
