access360analytics_repository_groupglossary360= Page {
	title: $access360analytics_repository_groupglossary360NLS.title
	description: $access360analytics_repository_groupglossary360NLS.description
	tags: "group", "searchresults"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"

	/* Parameters here */
	search = SearchDefinition {
		entity: Group
		simple-mode-rule: br_group_simple_search
	}
	

	selectedgroups = Variable { multivalued:True }
	selectedgroup = Variable
	selectedgroupsensitivitylevel = Variable
	selectedgroupsensitivityreason = Variable
	selectedgroupdescription = Variable
	ismanaged = Variable { type:Boolean }
	
	onlyemptydescription = Variable { initial:False type:Boolean }
	onlywithoutowner = Variable { initial:False type:Boolean }
	
	/* Datasets and records here */
	groups = Dataset {
		search:Search {
			view:access360_repositorygroups with onlyemptydescription to withoutdescriptiononly, onlywithoutowner to withoutowneronly
			definition:search
		}
	}
	
	editgroup = NamedAction (
		Dialog bwfGroupDetailsMetadata_Dialog(	selectedgroup to paramPermissionUid,
													selectedgroupsensitivitylevel to sensitivitylevel,
													selectedgroupsensitivityreason to sensitivityreason,
													selectedgroupdescription to description,
													ismanaged to ismanaged), 
												ReloadData (groups)	
	)
	
	batcheditgroup = NamedAction (
		Dialog bwfGroupDetailsBatchMetadata_Dialog(selectedgroups to groups), 
											ReloadData (groups)	
	)	
	
	batcheditmanager = NamedAction (
		Dialog bwfGroupDetailsBatchAddManager_Dialog(selectedgroups to groups),
											ReloadData (groups)					
	)

	showGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedgroup to inuid, 
										True to inshowapplications,
										True to inshowshares,
										True to inshowperjob,
										True to inshowperorg,
										True to incanupdateowners,
										True to incanupdatemetadata,										
										False to inshowaccounts,
										False to inshowcontrols,
										False to inshowdecisionhistory
										)
	)
	
	/* Page content */
	Grid {
		columns:GridColumn { fill:True width: grow }, GridColumn
		layout: Layout { grab: horizontal True vertical False hint:height 38 }
		GridRow {
			GridCell {
				ButtonGroup {
					Button {
						actions:ExecuteNamedAction batcheditgroup, 
								Unset selectedgroups
						text:$repoglossary360FragmentNLS.bulk
			            image:%collection_16.pencil
			            disabled:StringPredicate(selectedgroups) { when IsEmpty then True otherwise False }
					}
//					Batch add managers is too time consuming
//					Button {
//						actions:ExecuteNamedAction batcheditmanager, 
//								Unset selectedgroups
//						text:$repoglossary360FragmentNLS.managerbulk
//			            image:%collection_16.pencil
//			            disabled:StringPredicate(selectedgroups) { when IsEmpty then True otherwise False }
//					}					
				}			
			}
			GridCell {
				Checkbox {
					variable:onlyemptydescription
					modify-event: Unset selectedgroups
					text:$access360r_group_glossary360NLS.onlyempty
				}
			}
//			GridCell {
//				Checkbox {
//					variable:onlywithoutowner
//					modify-event: Unset selectedgroups
//					text:$access360r_group_glossary360NLS.onlywithoutowner
//				}
//			}			
		}
	}
	Table {
		data:groups
		layout: Layout { grab: horizontal True vertical True }
		show-count:True
		show-filter:True
		configurable:True
		label:Label { break:True value:$permission.concept }
		checkboxes:groupuid to selectedgroups
		
		Column {
			column:repositorydisplayname
			tooltip:Current repositorydisplayname
			header:$repository.concept
			width:160px
			filterable:True
			sortable:True
			align:Right
		}
		Column {
			column:groupcode
			header:$group.code
			width:220px
			filterable:True
			sortable:True
			align:Right
			actions:ExecuteNamedAction showGroupDetails
		}
		Column {
			column:groupdisplayname
			tooltip:Current groupdisplayname
			header:$group.displayname
			width:260px
			filterable:True
			sortable:True
			align:Right
			actions:ExecuteNamedAction showGroupDetails
		}
		Column {
			column:groupsensitivitylevel
			text:Transform Current groupsensitivitylevel using bwfGroupSensitivityLevelMapping
			header:$group.sensitivitylevel
			width:160px
			filterable:True
			sortable:True
			align:Right
			selection:selectedgroupsensitivitylevel
		}
		Column {
			column:groupsensitivityreason
			tooltip:Current groupsensitivityreason
			header:$group.sensitivityreason
			width:200px
			filterable:True
			sortable:True
			align:Right
			selection:selectedgroupsensitivityreason
			initially-masked:True
		}
		Column {
			column:groupdescription
			tooltip:Current groupdescription
			header:$group.description
			width:100%
			filterable:True
			sortable:True
			align:Left
			selection:selectedgroupdescription
		}
		Column {
			column:ismanaged
			text: Transform Current ismanaged using booleanDisplayMapping
			header:$bwfGroupDetailsMetadata_Dialog_NLS.managed
			width:100%
			filterable:True
			sortable:True
			align:Left
			selection:ismanaged
		}		
		Column {
			column: groupsid
			header: $group.sid
			width: 100%
			initially-masked: True
			sortable:True
		}
		Column {
			column: groupguid
			header: $group.guid
			width: 100%
			initially-masked: True
			sortable:True
		}	
		Column {
			column:groupcomment
			header:$group.comment
			width:160px
			filterable:True
			initially-masked: True
			sortable:True
			align:Right
		}			
		Column {
			column: groupgrouptype
			header: $group.grouptype
			width: 100%
			filterable:True
			initially-masked: True
			sortable:True
		}
		Column {
			column: groupdynamic
			header: $group.dynamic
			width: 100%
			initially-masked: True
			sortable:True
		}				
		Column {
			column:nbaccounts
			header:$search.group.nbaccount.header
			width: 160px
			initially-masked: True
			sortable:True
			align:Right
		}
		Column {
			column:nbidentities
			header:$search.group.nbidentity.header
			width: 160px
			initially-masked: True
			sortable:True
			align:Right
		}
		Column {
			column:nbdirectaccounts
			header:$search.group.nbdirectaccounts.header
			width: 160px
			initially-masked: True
			sortable:True
			align:Right
		}
		Column {
			column:nbdirectidentities
			header:$search.group.nbdirectidentity.header
			width: 160px
			initially-masked: True
			sortable:True
			align:Right
		}
		Column {
			column:nbshare
			header:$search.group.nbshare.header
			width: 100px
			initially-masked: True
			sortable:True
			align:Right
		}					
		Column {
			column:nbapplication
			header:$search.group.nbapplication.header
			width: 100px
			initially-masked: True
			sortable:True
			align:Right
		}				
		Column {
			column:groupuid
			hidden:True
			selection:selectedgroup
		}
	}
	Text {
		value:$repoglossary360FragmentNLS.limit
		compact:True
		styling:warningFieldStyle
		hidden:IntPredicate(Count groups) { when =1000 then False otherwise True }
	}
}
repoglossary360FragmentNLS = NLS {
	bulk [en "Update Description" fr "Mise à jour des descriptions"]
	managerbulk [en "Add a Manager" fr "Ajout d'un manager"]
	limit [
		en "Table limited to 1000 groups, please consider filtering the table to look for hidden groups."
		fr "Affichage limité à 1000 groups, veuillez utiliser les capacités de filtrage du tableau pour rechercher des groupes."
	]
}
repoglossary360Fragment = PageFragment {
	/* Parameters here */
    repositoryuid = Variable

	/* Variables here */
	selectedgroups = Variable { multivalued:True }
	selectedgroup = Variable
	selectedgroupsensitivitylevel = Variable
	selectedgroupsensitivityreason = Variable
	selectedgroupdescription = Variable
	ismanaged = Variable { type:Boolean }
		
	onlyemptydescription = Variable { initial:False type:Boolean }
	onlywithoutowner = Variable { initial:False type:Boolean }
	
	/* Datasets and records here */
	repository = Record {
		view:bwf_repositoryDetail with repositoryuid to uid
	}
	
	groups = Dataset {
		view:access360_repositorygroups with repositoryuid to uid, onlyemptydescription to withoutdescriptiononly, onlywithoutowner to withoutowneronly
		limit:1000
	}
	
	editgroup = NamedAction (
		Dialog bwfGroupDetailsMetadata_Dialog(	selectedgroup to paramGroupUid,
													selectedgroupsensitivitylevel to sensitivitylevel,
													selectedgroupsensitivityreason to sensitivityreason,
													selectedgroupdescription to description,
													ismanaged to ismanaged), 
												ReloadData (groups)	
	)
	
	batcheditgroup = NamedAction (
		Dialog bwfGroupDetailsBatchMetadata_Dialog (selectedgroups to groups), 
												ReloadData (groups)	
	)

	batcheditmanager = NamedAction (
		Dialog bwfGroupDetailsBatchAddManager_Dialog (selectedgroups to groups), 
												ReloadData (groups)	
	)

	showGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedgroup to inuid, 
										True to inshowapplications,
