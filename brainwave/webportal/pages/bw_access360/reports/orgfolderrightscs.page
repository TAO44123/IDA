/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/teamfolderrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
organisationfolderrightscs360NLS = NLS {
	title [en "Managed Organizations Folders Analysis" fr "Analyse des droits d'accès aux données des organisations gérées"]
	dyntitle [en "Managed Organizations Folders Analysis for {0}" fr "Analyse des droits d''accès aux données des organisations gérées par {0}"]
	description [
		en "This report lists the folders rights related to the managed organizations in a form of a pivot table. Only active accounts are taken into account. It is possible to choose direct members only or all members. It is possible to display only the differences since a given date. It is possible to modify the columns or export the results by right clicking on the table."
		fr "Ce rapport liste les droits d'accès aux données relatifs aux organisations gérées sous la forme d'un tableau croisé dynamique. Seuls les comptes actifs sont pris en compte. Il est possible de choisir les membres directs uniquement ou l'ensemble des membres. Il est possible de n'afficher que les différences depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats à l'aide d'un clic droit sur le tableau."
	]
}


organisationfolderrightscs360d = Page {
	title: $organisationfolderrightscs360NLS.title
	description: $organisationfolderrightscs360NLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "organisationmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa360_orgaccessrightscs)

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page organisationfolderrightscs360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

organisationfolderrightscs360hp = Page {
	title: $organisationfolderrightscs360NLS.title
	description: $organisationfolderrightscs360NLS.description
	tags: "myorg_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa360_orgaccessrightscs)

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page organisationfolderrightscs360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

organisationfolderrightscs360 = Page {
	title: $organisationfolderrightscs360NLS.title
	dynamic-title: $organisationfolderrightscs360NLS.dyntitle(identity.fullname)
	description: $organisationfolderrightscs360NLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa360_orgaccessrightscs)
	enter-event:IntCase(orgmanagernbidentity.nbtotalmembers) { when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [ Set False to UserVariable session_indirectTeam360, Set True to indirectTeam360_disabled  ] }
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	indirectTeam360_disabled = Variable { initial:False }
	
	/* Datasets and records here */
	identity = Record {
		view:bwf_identityDetail with uid to uid
	}

	orgmanagernbidentity = Record {
		view:enduser360_orgmanagernbidentity with uid to uid
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	teamrights = Dataset {
		view:enduser360_orgmanagerfolderrights with uid to uid, UserVariable session_indirectTeam360 to indirectteam,
								UserVariable session_folderDepth to depth,
								UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltiplimit(NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold))
					disabled:BooleanPredicate(indirectTeam360_disabled)
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Combo {
					variable:UserVariable session_folderDepth
					tooltip:$session_folderDepthNLS.tooltip
					label:$session_folderDepthNLS.label
					layout:Layout {grab:horizontal False vertical False hint:width 96}
					options:Static {
						Option { text:'<=1' value:'<1' }
						Option { text:'<=2' value:'<2' }
						Option { text:'<=3' value:'<3' }
						Option { text:'=1' value:'=1' }
						Option { text:'=2' value:'=2' }
						Option { text:'=3' value:'=3' }
					}
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamrights
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:36px  grab: horizontal True vertical True}
					columns:
						Dim {value:applicationdisplayname header:$teamfolderrights360NLS.share},
						Dim {value:permissioncode header:$teamfolderrights360NLS.folder tooltip:permissioncode} 
					rows:
						Dim {value:orguid  label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:orguid  label:orgdisplayname header:$organisation.concept},
						Dim {value:jobtitleuid label:jobtitledisplayname header:$identity.jobtitledisplayname initially-masked:True},
						Dim {value:internal label:internal header:$identity.internal initially-masked:True},
						Dim {value:uid label:fullname header:$identity.concept} 
					cell-content:CellContent {text: Current rights cluster-value:'X' styling:StringStyling(Current status) { when 'New' then tfrtimeline_highlightnew360 when 'Removed' then tfrtimeline_highlightremoved360 when 'Modified' then tfrtimeline_highlightmodified360}}
				}
			}
		}
	}
}
