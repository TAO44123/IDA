/**
 * Contains "session variables" for Access 360 add-on
 * 
 */

session_folderDepthNLS = NLS {
	label [en "Folder Depth" fr "Profondeur arborescence"]
	tooltip [en "Folder depth" fr "Profondeur d'analyse en nombre de répertoires"]
}
session_folderDepth = UserVariable {
	initial:'<2'
	multivalued:False
	type:String
}

session_exclRemovedNLS = NLS {
	label [en "Exclude removed entries" fr "Exclure les entrées supprimées"]
	tooltip [en "Exclude removed entries" fr "Exclure les entrées supprimées"]
}
session_exclRemoved = UserVariable {
	initial:True
	multivalued:False
	type:Boolean
}

session_exclSimilarNLS = NLS {
	label [en "Exclude identical entries" fr "Exclure les entrées identiques"]
	tooltip [en "Exclude identical entries" fr "Exclure les entrées identiques"]
}
session_exclSimilar = UserVariable {
	initial:False
	multivalued:False
	type:Boolean
}

 
 session_indirectTeam360NLS_threshold = Constant {
 	value:2000
 	type:Integer
 }
session_indirectTeam360NLS = NLS {
 	label [en "Whole team" fr "Toute l'équipe"]
 	tooltip [en "Shows the whole team: both direct and indirect reports" fr "Montre toute l'équipe, à la fois l'équipe directe et l'équipe indirecte"]
 	tooltiplimit [en "Shows the whole team: both direct and indirect reports\ndisabled when total team size is greater than {0} people" fr "Montre toute l''équipe, à la fois l''équipe directe et l''équipe indirecte\ndésactivé si la taille totale de l''équipe est supérieure à {0} personnes"]
}
session_indirectTeam360 = UserVariable {
	initial:False
	multivalued:False
	type:Boolean
}

