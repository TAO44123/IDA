/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
teamfolderrights360NLS = NLS {
	title [en "Team folders rights list" fr "Liste des droits d'accès aux données de l''équipe"]
	dyntitle [en "Team folders rights list for {0}" fr "Liste des droits d''accès aux données de l''équipe de {0}"]
	detailtitle [en "Team data rights details" fr "Détails des droits d'accès aux données de l'équipe"]
	detaildyntitle [en "Team data rights details for {0}" fr "Détails des droits d'accès aux données de l''équipe pour {0}"]
	folder [en "folder" fr "répertoire"]
	foldername [en "folder name" fr "nom répertoire"]
	description [en "description" fr "description"]
	share [en "share" fr "partage"]
	department [en "department" fr "département"]
	back [en "Back to team data access rights list" fr "Retour à la liste des droits d'accès aux données de l'équipe"]

	_description [
		en "This report lists the folders rights of the team members. Only active accounts are taken into account. It is possible to limit the display to the direct team or to display the whole team. It is possible to display only the differences from a given date. It is possible to modify the columns or to export the results by right clicking on the table."
		fr "Ce rapport liste les droits bureautiques des membres de l'équipe. Seuls les comptes actifs sont pris en compte. Il est possible de limiter l'affichage à l'équipe directe ou d'afficher l'ensemble de l'équipe. Il est possible d'afficher uniquement les différences par rapport à une date donnée. Il est posible de modifier les colonnes ou d'exporter les résultats à l'aide d'un clic droit sur le tableau"
	]
}

tfrtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tfrtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tfrtimeline_highlightmodified360 = Style {
	foreground:white
	background:Color RGB(255, 128, 0)
}

tfrmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}


teamfolderrights360d = Page {
	title: $teamfolderrights360NLS.title
	description:$teamfolderrights360NLS._description
	tags: "identityext" priority 200, "byuid" , "browsing", "operationalmanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_teamfolderrights)

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamfolderrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamfolderrights360hp = Page {
	title: $teamfolderrights360NLS.title
	description:$teamfolderrights360NLS._description
	tags: "myteam_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_teamfolderrights)

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamfolderrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamfolderrights360 = Page {
	title: $teamfolderrights360NLS.title
	dynamic-title: $teamfolderrights360NLS.dyntitle(identity.fullname)
	description:$teamfolderrights360NLS._description
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_teamfolderrights)
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	selectedFolderUid = Variable
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	teamrights = Dataset {
		view:enduser360_teamfolderrights with uid to uid, UserVariable session_indirectTeam360 to indirectteam,
									UserVariable session_folderDepth to depth,
									UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltip
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Combo {
					variable:UserVariable session_folderDepth
					tooltip:$session_folderDepthNLS.tooltip
					label:$session_folderDepthNLS.label
					layout:Layout {grab:horizontal False vertical False hint:width 96}
					options:Static {
						Option { text:'<=1' value:'<1' }
						Option { text:'<=2' value:'<2' }
						Option { text:'<=3' value:'<3' }
						Option { text:'=1' value:'=1' }
						Option { text:'=2' value:'=2' }
						Option { text:'=3' value:'=3' }
					}
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:teamrights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					enable-markup:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tfrtimeline_highlightnew360 when 'Removed' then tfrtimeline_highlightremoved360 when 'Modified' then tfrtimeline_highlightmodified360 when 'Invalid' then tfrtimeline_highlightremoved360 } text:Transform Current status using tfrmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitlecode
						header:$identity.jobtitlecode
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgshortname
						header:$porganisation.shortname
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$teamfolderrights360NLS.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:rights
						header:$right.concept
					}
					Column {
						column:permissionuid
						hidden:True
						selection:selectedFolderUid
					}
					Column {
						sortable:True
						filterable:True
						column:permissioncode
						header:$teamfolderrights360NLS.folder
						width:240px
						link:Page teamfolderrights360detail with uid to uid, org to org, Current permissionuid to folderuid
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$teamfolderrights360NLS.foldername
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondescription
						header:$teamfolderrights360NLS.description
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$teamfolderrights360NLS.share
						width:160px
					}
				}
			}
		}
	}
}

