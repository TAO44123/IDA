/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/permaccessrights.page"

/* Nationalized labels here */
permaccessrightscs360NLS = NLS {
	title [en "Managed permissions access rights analysis" fr "Analyse des droits d'accès des permissions gérées"]
	dyntitle [en "Managed permissions access rights analysis for {0}" fr "Analyse des droits d''accès des permissions gérées par {0}"]
	description [
		en "This report shows the permissions managed by the user as a pivot table. Only active accounts are taken into account. It is possible to filter the results so that only differences from a given date are shown. It is possible to modify the columns or to export the results by right clicking on the table."
		fr "Ce rapport présente les permissions gérées par l'utilisateur sous la forme d'un tableau croisé dynamique. Seuls les comptes actifs sont pris en compte. Il est possible de filtrer les résultats de manière à ne faire apparaitre que les différences par rapport à une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau."
	]
}

permaccessrights360csdetail = Page {
	title: $permaccessrightscs360NLS.title
	description:$permaccessrightscs360NLS.description
	tags: "identityext" priority 200, "byuid" , "analytics", "permissionmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_permaccessrightscs
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page permaccessrights360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

permaccessrights360cshp = Page {
	title: $permaccessrightscs360NLS.title
	description:$permaccessrights360NLS.description
	tags: "mypermission_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_permaccessrightscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page permaccessrights360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

permaccessrights360cs = Page {
	title: $permaccessrightscs360NLS.title
	dynamic-title:$permaccessrights360NLS.dyntitle(identity.fullname)
	description:$permaccessrights360NLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_permaccessrightscs
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	permrights = Dataset {
		view:enduser360_permrightscs with uid to uid, UserVariable session_selectedPermissionsTeam360 to permissionuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}

	managedperms = Dataset {
		view:enduser360_managedpermissions with uid to uid
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 400 }
					variable:UserVariable session_selectedPermissionsTeam360
					options:Dynamic {
						data:managedperms
						text:Concat(Current resourcename, '(', Current resourcecategory, ')')
						value:Current resourceuid
					}
					label:$session_selectedPermissionsTeam360NLS.label
					tooltip:$session_selectedPermissionsTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:permrights
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:64px  grab: horizontal True vertical True}
					columns:
						Dim {value:applicationuid label:applicationdisplayname header:$application.concept},
						Dim {value:permissionuid label:permissioncode header:$ppermission.code initially-masked:True}, 
						Dim {value:permissionuid label:permissiondisplayname header:$permission.concept} 
					rows:
						Dim {value:orguid label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:orguid label:orgdisplayname header:$organisation.concept},
						Dim {value:jobtitleuid label:jobtitledisplayname header:$identity.jobtitledisplayname initially-masked:True},
						Dim {value:ownerinternal label:ownerinternal header:$identity.internal initially-masked:True},
						Dim {value:owneruid label:ownerfullname header:$identity.concept},
						Dim {value:uid label:login header:$account.login}
					cell-content:CellContent {text: Current status cluster-value:'X' styling:StringStyling(Current status) { when 'New' then aartimeline_highlightnew360 when 'Removed' then aartimeline_highlightremoved360 }}
				
				}
			}
		}
	}
}
