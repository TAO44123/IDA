								filterable:True
								initially-masked: True					
							}												
							
							Column {
								column: campaignreviewtype
			//					text: Transform Current  campaignreviewtype using typeofreview
								header: $reviewedentries360csNLS.reviewtype
								width:200px
								sortable:True
								filterable:True
							}
							Column {
								column: campaignduedate
								header: $reviewedentries360csNLS.reviewduedate
