								tooltip: Current id
								width: 300px
							}				
							Column {
								column: reviewerhrcode
								header:$bwaccess360_accessreviewmanagementNLS.lmhrcode
								styling: StringStyling ( Current isheader ) { when '1' then groupedcolumn_style_header }
								width:200px
								sortable:True
								filterable:True
								initially-masked:True
							}
							Column {
								column: reviewerfullname
								header:$bwaccess360_accessreviewmanagementNLS.lmfullname
								styling: StringStyling ( Current isheader ) { when '1' then groupedcolumn_style_header }
								width:200px
								sortable:True
