/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
teamgroups360NLS = NLS {
	title [en "Team AD groups list" fr "Liste des  Groupes AD de l''équipe"]
	dyntitle [en "Team AD groups list for {0}" fr "Liste des groupes AD de l''équipe de {0}"]
	description [
		en "This report lists the Active Directory groups of team members. Only active accounts are taken into account. Only the groups directly associated with the accounts are taken into account. It is possible to filter the results to show only the differences compared to a given date. It is possible to modify the columns or to export the results by doing This report lists the Active Directory groups of the team members. Only active accounts are taken into account. Only the groups directly associated to the accounts are taken into account. It is possible to filter the results to show only the differences compared to a given date. It is possible to modify the columns or to export the results by right clicking on the tablea right click on the table"
		fr "Ce rapport liste les groupes Active Directory des membres de l'équipe. Seuls les comptes actifs sont pris en compte. Seuls les groupes directement asociés aux comptes sont pris en compte. Il est possible de filtrer les résultats pour ne faire apparaitre que les différences par rapport à une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau"
	]
}

tgtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tgtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tgtmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

teamgroups360detail = Page {
	title: $teamgroups360NLS.title
	description: $teamgroups360NLS.description
	tags: "identityext" priority 200, "byuid", "operationalmanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_teamgroups

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamgroups360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamgroups360hp = Page {
	title: $teamgroups360NLS.title
	description: $teamgroups360NLS.description
	tags: "browsing","myteam_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_teamgroups

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamgroups360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamgroups360 = Page {
	title: $teamgroups360NLS.title
	description: $teamgroups360NLS.description
	dynamic-title: $teamgroups360NLS.dyntitle(identity.fullname)
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_teamgroups
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	teamgroups = Dataset {
		view:enduser360_teamgroups with uid to uid, UserVariable session_indirectTeam360 to indirectteam,UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltip
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:teamgroups
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tgtimeline_highlightnew360 when 'Removed' then tgtimeline_highlightremoved360 when 'Invalid' then tgtimeline_highlightremoved360 } text:Transform Current status using tgtmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						initially-masked:True
						column:jobtitlecode
						header:$identity.jobtitlecode
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						initially-masked:True
						column:orgshortname
						header:$porganisation.shortname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$organisation.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
					}
					Column {
						sortable:True
						filterable:True
						column:groupcode
						header:$pgroup.code
						width:300px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:groupdisplayname
						header:$pgroup.displayname
						width:260px
					}
					Column {
						sortable:True
						filterable:True
						column:groupcomment
						header:$pgroup.comment
						width:200px
					}
				}
			}
		}
	}
}
