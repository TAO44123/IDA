/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

/* Nationalized labels here */
groupsmembers360NLS = NLS {
	title [en "Managed groups members list" fr "Liste des membres des groupes gérés"]
	description [
		en "This report presents active accounts of the managed groups in the form of a table. All accounts that are members of the group(s) are displayed, whether or not they are direct members of the groups. You can restrict the display to a single group. it is possible to identify only the changes made since a given date. the columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport présente les comptes actifs des groupes gérés sous la forme d'un tableau. Tous les comptes membres du ou des groupes sont affichés, qu'ils soient directement membre des groupes ou non. Vous restreindre l'affichage à un seul groupe. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
		]
}

groupsmemberstimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
groupsmemberstimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

groupsmembersmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

groupsmembers360detail = Page {
	title: $groupsmembers360NLS.title
	tags: "identityext" priority 200, "byuid" , "browsing", "groupmanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	description:$groupsmembers360NLS.description
	feature:bwa360_groupsmembers
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page groupsmembers360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

groupsmembers360hp = Page {
	title: $groupsmembers360NLS.title
	tags: "mygroup_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	description:$groupsmembers360NLS.description
	feature:bwa360_groupsmembers

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page groupsmembers360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

groupsmembers360 = Page {
	title: $groupsmembers360NLS.title
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	description:$groupsmembers360NLS.description
	feature:bwa360_groupsmembers
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	apprights = Dataset {
		view:enduser360_mngtgroups with uid to uid, UserVariable session_selectedGroupsTeam360 to groupuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	managedgroups = Dataset {
		view:enduser360_managedgroups with uid to uid
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 400 }
					variable:UserVariable session_selectedGroupsTeam360
					options:Dynamic {
						data:managedgroups
						text:Concat(Current resourcename, '(', Current resourcecategory, ')')
						value:Current resourceuid
					}
					label:$session_selectedGroupsTeam360NLS.label
					tooltip:$session_selectedGroupsTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:apprights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then groupsmemberstimeline_highlightnew360 when 'Removed' then groupsmemberstimeline_highlightremoved360 when 'Invalid' then groupsmemberstimeline_highlightremoved360 } text:Transform Current status using groupsmembersmapping360 }
					Column {
						sortable:True
						filterable:True
						column:ownerhrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:ownerfullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownermail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownerinternal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:ownerarrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:ownerdeparturedate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$organisation.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:login
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:username
						header:$paccount.username
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:lastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:noownercode
						header:$preconciliation.noownercode
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:accountrepositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:groupcode
						header:$pgroup.code
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:groupdisplayname
						header:$pgroup.displayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:groupcomment
						header:$pgroup.comment
						initially-masked:True
						width:160px
					}
				}
			}
		}	
	}
}
