/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
permaccessrights360NLS = NLS {
	title [en "Managed permissions access rights list" fr "Liste des droits d'accès des permissions gérées"]
	dyntitle [en "Managed permissions access rights list for {0}" fr "Liste des droits d''accès des permissions gérées par {0}"]
	description [
		en "This report shows the permissions managed by the user. Only active accounts are taken into account. It is possible to filter the results so that only differences from a given date are shown. It is possible to modify the columns or to export the results by right clicking on the table."
		fr "Ce rapport présente les permissions gérées par l'utilisateur. Seuls les comptes actifs sont pris en compte. Il est possible de filtrer les résultats de manière à ne faire apparaitre que les différences par rapport à une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau."
	]
}

permartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
permartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

permarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

permaccessrights360detail = Page {
	title: $permaccessrights360NLS.title
	description:$permaccessrights360NLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "permissionmanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_permaccessrights
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page permaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

permaccessrights360hp = Page {
	title: $permaccessrights360NLS.title
	description:$permaccessrights360NLS.description
	tags: "mypermission_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_permaccessrights

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page permaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

permaccessrights360 = Page {
	title: $permaccessrights360NLS.title
	dynamic-title:$permaccessrights360NLS.dyntitle(identity.fullname)
	description:$permaccessrights360NLS.description
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_permaccessrights
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	apprights = Dataset {
		view:enduser360_permrights with uid to uid, UserVariable session_selectedPermissionsTeam360 to permissionuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	managedperms = Dataset {
		view:enduser360_managedpermissions with uid to uid
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 400 }
					variable:UserVariable session_selectedPermissionsTeam360
					options:Dynamic {
						data:managedperms
						text:Concat(Current resourcename, '(', Current resourcecategory, ')')
						value:Current resourceuid
					}
					label:$session_selectedPermissionsTeam360NLS.label
					tooltip:$session_selectedPermissionsTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:apprights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then permartimeline_highlightnew360 when 'Removed' then permartimeline_highlightremoved360 when 'Invalid' then permartimeline_highlightremoved360 } text:Transform Current status using permarmapping360 }
					Column {
						sortable:True
						filterable:True
						column:ownerhrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:ownerfullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownermail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownerinternal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:ownerarrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:ownerdeparturedate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$organisation.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:login
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:username
						header:$paccount.username
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:lastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:noownercode
						header:$preconciliation.noownercode
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:permissionpermissiontype
						header:$ppermission.permissiontype
					}
					Column {
						sortable:True
						filterable:True
						column:permissioncode
						header:$ppermission.code
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$ppermission.displayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondescription
						header:'description'
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$application.concept
						width:160px
					}
				}
			}
		}	
	}
}
