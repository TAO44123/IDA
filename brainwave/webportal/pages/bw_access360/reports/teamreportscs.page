/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/teamaccounts.page"

/* Nationalized labels here */
teamreports360csNLS = NLS {
	title [en "Team analysis" fr "Analyse de l'équipe"]
	dyntitle [en "Team analysis for {0}" fr "Analyse de l''équipe de {0}"]
	description [
		en "This report lists the active members of the team as a pivot table. It is possible to restrict the display to the direct team or to display the whole team.  It is possible to filter the results to show only the differences since a given date. It is possible to modify the columns or to export the results by right clicking on the table."
		fr "Ce rapport liste les membres actifs de l'équipe sous la forme d'un tableau croisé dynamique. Il est possible de restreindre l'affichage à l'équipe directe ou d'afficher toute l'équipe.  Il est possible de filtrer les résultats pour ne faire apparaitre que les différences depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau"
	]
}

teamreports360csdetail = Page {
	title: $teamreports360csNLS.title
	description:$teamreports360csNLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "operationalmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_teamreportscs
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamreports360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamreports360cshp = Page {
	title: $teamreports360csNLS.title
	description:$teamreports360csNLS.description
	tags: "myteam_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_teamreportscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamreports360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamreports360cs = Page {
	title: $teamreports360csNLS.title
	dynamic-title: $teamreports360csNLS.dyntitle(identity.fullname)
	description:$teamreports360csNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_teamreportscs
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	teamreports = Dataset {
		view:enduser360_teamreportscs with uid to uid, UserVariable session_indirectTeam360 to indirectteam,UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltip
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamreports
					multi-selection:True
					cluster-sortable:True
					swappable:True
					user-configurable:True
					layout:Layout {grab: horizontal True vertical True}
					rows:
						Dim {value:orguid label:orgdisplayname header:$organisation.concept},
						Dim {value:orguid label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:jobtitleuid label:jobtitledisplayname  header:$identity.jobtitledisplayname} 
					columns:
						Dim {value:internal header:$pidentity.internal},
						Dim {label:fullname value:uid header:$identity.concept} 
					cell-content:CellContent {text: 'X' align:Center styling:StringStyling(Current status) { when 'New' then tactimeline_highlightnew360 when 'Removed' then tactimeline_highlightremoved360}}
				
				}
			}
		}	
	}
}
