/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
appaccessrights360NLS = NLS {
	title [en "Managed applications access rights list" fr "Liste des droits d'accès des applications gérées"]
	dyntitle [en "Managed applications access rights list for {0}" fr "Liste des droits d''accès des applications gérées par {0}"]
	description [
		en "This report lists the access rights of managed applications. Only active accounts are taken into account. Only the rights directly associated with the accounts and of type 'application profile' are taken into account. It is possible to identify only changes that have occurred since a given date. It is possible to modify the columns or export the data by right-clicking on the table."
		fr "Ce rapport liste les droits d'accès des applications gérées. Seuls les comptes actifs sont pris en comptes. Seuls les droits directement associés aux comptes et de type 'profil applicatifs' sont pris en compte. Il est possible d'identifier uniquement les changements survenus depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les données en faisant un clic droit sur le tableau."
	]
}

aartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
aartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

aartimeline_highlightmodified360 = Style {
	foreground:white
	background:Color RGB(255, 128, 0)
}

aarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

appaccessrights360detail = Page {
	title: $appaccessrights360NLS.title
	description:$appaccessrights360NLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "applicationmanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_appacessrights
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page appaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

appaccessrights360hp = Page {
	title: $appaccessrights360NLS.title
	description:$appaccessrights360NLS.description
	tags: "myapp_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa360_appacessrights
	

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page appaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

appaccessrights360 = Page {
	title: $appaccessrights360NLS.title
	dynamic-title: $appaccessrights360NLS.dyntitle(identity.fullname)
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	description:$appaccessrights360NLS.description
	feature:bwa360_appacessrights
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:bwf_identityDetail with uid to uid
	}
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	apprights = Dataset {
		view:enduser360_apprights with uid to uid, UserVariable session_selectedApplicationsTeam360 to applicationuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	managedapps = Dataset {
		view:enduser360_managedapplications with uid to uid
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 200 }
					variable:UserVariable session_selectedApplicationsTeam360
					options:Dynamic {
						data:managedapps
						text:Current resourcename
						value:Current resourceuid
					}
					label:$session_selectedApplicationsTeam360NLS.label
					tooltip:$session_selectedApplicationsTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:apprights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then aartimeline_highlightnew360 when 'Removed' then aartimeline_highlightremoved360 when 'Invalid' then aartimeline_highlightremoved360 } text:Transform Current status using aarmapping360 }
					Column {
						sortable:True
						filterable:True
						column:ownerhrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:ownerfullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownermail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:ownerinternal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:ownerarrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:ownerdeparturedate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$organisation.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:login
						header:$account.login
					}
					Column {
						sortable:True
						filterable:True
						column:username
						header:$paccount.username
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:lastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:noownercode
						header:$preconciliation.noownercode
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:permissionpermissiontype
						header:$ppermission.permissiontype
					}
					Column {
						sortable:True
						filterable:True
						column:permissioncode
						header:$ppermission.code
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$ppermission.displayname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondescription
						header:'description'
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$application.concept
						width:160px
					}
				}
			}
		}	
	}
}
