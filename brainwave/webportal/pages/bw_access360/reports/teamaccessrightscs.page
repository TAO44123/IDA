/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/teamaccessrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
teamaccessrightscs360NLS = NLS {
	title [en "Team access rights analysis" fr "Anayse des droits d'accès de l'équipe"]
	dyntitle [en "Team access rights analysis for {0}" fr "Analyse des droits d''accès de l''équipe de {0}"]
	description [
		en "This report lists the access rights of team members in a form of a pivot table. Only active accounts are taken into account. Only rights directly assigned to users are displayed. Only the rights of type 'Application profile' are taken into account. It is possible to choose to display only the direct team or the whole team. It is possible to filter the results to display only the differences compared to a given date. It is possible to modify the columns or export the results by right clicking on the table."
		fr "Ce rapport liste les droits d'accès des membres de l'équipe sous la forme d'un tableau croisé dynamique. Seuls les comptes actifs sont pris en compte. Seuls les droits directement affectés aux utilisateurs sont affichés. Seuls les droits de type 'Profil applicatif' sont pris en compte. Il est possible de choisir d'afficher seulement l'équipe directe ou toute l'équipe. Il est possible de filtrer les résultats pour n'afficher que les différences par rapport à une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau."
	]
}


teamaccessrights360csdetail = Page {
	title: $teamaccessrightscs360NLS.title
	description:$teamaccessrightscs360NLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "operationalmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_teamaccessrightscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamaccessrights360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamaccessrights360cshp = Page {
	title: $teamaccessrightscs360NLS.title
	description:$teamaccessrightscs360NLS.description
	tags: "myteam_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_teamaccessrightscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page teamaccessrights360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

teamaccessrights360cs = Page {
	title: $teamaccessrightscs360NLS.title
	dynamic-title: $teamaccessrightscs360NLS.dyntitle(identity.fullname)
	description:$teamaccessrightscs360NLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	enter-event:IntCase(teamsize.count) { when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [ Set False to UserVariable session_indirectTeam360, Set True to indirectTeam360_disabled  ] }
	feature:bwa360_teamaccessrightscs
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	indirectTeam360_disabled = Variable { initial:False }
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid
	}
	
	teamsize = Record {
		view:enduser360_teamsize with uid to uid
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	teamrights = Dataset {
		view:enduser360_teamrights with uid to uid, UserVariable session_indirectTeam360 to indirectteam,UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltiplimit(NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold))
					disabled:BooleanPredicate(indirectTeam360_disabled)
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamrights
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:64px  grab: horizontal True vertical True}
					rows:
						Dim {value:applicationuid label:applicationdisplayname header:$application.concept},
						Dim {value:permissionuid label:permissioncode header:$ppermission.code initially-masked:True}, 
						Dim {value:permissionuid label:permissiondisplayname header:$permission.concept} 
					columns:
						Dim {value:orguid label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:orguid label:orgdisplayname header:$organisation.concept},
						Dim {value:jobtitleuid label:jobtitledisplayname header:$identity.jobtitledisplayname initially-masked:True},
						Dim {value:internal label:internal header:$identity.internal initially-masked:True},
						Dim {value:uid label:fullname header:$identity.concept} 
					cell-content:CellContent {text: Current status cluster-value:'X' styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 }}
				
				}
			}
		}
	}
}
