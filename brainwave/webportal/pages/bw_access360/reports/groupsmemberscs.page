/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"

/* Nationalized labels here */
groupsmemberscs360NLS = NLS {
	title [en "Managed groups analysis" fr "Analyse des groupes gérés"]
	description [
		en "This report presents active accounts of the managed groups in the form of a pivot table. All accounts that are members of the group(s) are displayed, whether or not they are direct members of the groups. You can restrict the display to a single group. it is possible to identify only the changes made since a given date. the columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport présente les comptes actifs des groupes gérés sous la forme d'un tableau croisé dynamique. Tous les comptes membres du ou des groupes sont affichés, qu'ils soient directement membre des groupes ou non. Vous restreindre l'affichage à un seul groupe. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
		]
}

groupsmembers360csdetail = Page {
	title: $groupsmemberscs360NLS.title
	tags: "identityext" priority 200, "byuid" , "analytics", "groupmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	description:$groupsmemberscs360NLS.description
	feature:bwa360_groupsmemberscs
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page groupsmembers360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

groupsmembers360cshp = Page {
	title: $groupsmemberscs360NLS.title
	tags: "mygroup_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	description:$groupsmemberscs360NLS.description
	feature:bwa360_groupsmemberscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page groupsmembers360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

groupsmembers360cs = Page {
	title: $groupsmemberscs360NLS.title
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	description:$groupsmemberscs360NLS.description
	feature:bwa360_groupsmemberscs
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	groupsmembers = Dataset {
		view:enduser360_mngtgroupscs with uid to uid, UserVariable session_selectedGroupsTeam360 to groupuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}

	managedgroups = Dataset {
		view:enduser360_managedgroups with uid to uid
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 400 }
					variable:UserVariable session_selectedGroupsTeam360
					options:Dynamic {
						data:managedgroups
						text:Concat(Current resourcename, '(', Current resourcecategory, ')')
						value:Current resourceuid
					}
					label:$session_selectedGroupsTeam360NLS.label
					tooltip:$session_selectedGroupsTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:groupsmembers
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:64px  grab: horizontal True vertical True}
					columns:
						Dim {value:repositoryuid label:repositorydisplayname header:$repository.concept},
						Dim {value:groupuid label:groupcode header:$pgroup.code tooltip:groupcode initially-masked:True}, 
						Dim {value:groupuid label:groupdisplayname header:$group.concept tooltip:groupdisplayname} 
					rows:
						Dim {value:orguid label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:orguid label:orgdisplayname header:$organisation.concept},
						Dim {value:jobtitleuid label:jobtitledisplayname header:$identity.jobtitledisplayname initially-masked:True},
						Dim {value:ownerinternal label:ownerinternal header:$identity.internal initially-masked:True},
						Dim {value:owneruid label:ownerfullname header:$identity.concept},
						Dim {value:uid label:login header:$account.login}
					cell-content:CellContent {text: Current status cluster-value:'X' styling:StringStyling(Current status) { when 'New' then aartimeline_highlightnew360 when 'Removed' then aartimeline_highlightremoved360 }}
				
				}
			}
		}
	}
}
