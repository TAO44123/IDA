/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
folderaccessrights360NLS = NLS {
	title [en "Managed folders access rights list" fr "Liste des droits d'accès des répertoires gérés"]
	dyntitle [en "Managed folders access rights list for {0}" fr "Liste des droits d''accès des répertoires gérés par {0}"]
	folder [en "folder" fr "répertoire"]
	foldername [en "folder name" fr "nom répertoire"]
	description [en "description" fr "description"]
	share [en "share" fr "partage"]
	department [en "department" fr "département"]
	_description [
		en "This report lists permissions for managed directories. It is possible to filter the results to highlight changes. It is possible to modify the displayed columns or export the results, right click on the table to do so."
		fr "Ce rapport liste les droits pour les répertoires  gérés. Il est possible de filtrer les résultats pour mettre en évidence les changements. Il est possible de modifier les colonnes affichées ou d'exporter les résultats, faites un clic droit sur le tableau pour cela."
	]
}

foldar_highlightnew360 = Style {
	foreground:white
	background:Color green
}
foldar_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

foldar_highlightmodified360 = Style {
	foreground:white
	background:Color RGB(255, 128, 0)
}

foldar_mapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

folderaccessrights360detail = Page {
	title: $folderaccessrights360NLS.title
	description:$folderaccessrights360NLS._description
	tags: "identityext" priority 200, "byuid" , "browsing", "foldermanager"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_folderaccessrights)
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page folderaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

folderaccessrights360hp = Page {
	title: $folderaccessrights360NLS.title
	description:$folderaccessrights360NLS._description
	tags: "myfolder_access360" priority 1
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_folderaccessrights)

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page folderaccessrights360 with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

folderaccessrights360 = Page {
	title: $folderaccessrights360NLS.title
	dynamic-title:$folderaccessrights360NLS.dyntitle(identity.fullname)
	description:$folderaccessrights360NLS._description
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa360_folderaccessrights)
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	
	/* Datasets and records here */
	identity = Record {
		view:bwf_identityDetail with uid to uid
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	folderrights = Dataset {
		view:enduser360_folderrights with uid to uid, UserVariable session_selectedFoldersTeam360 to folderuids, UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	managedfolders = Dataset {
		view:enduser360_managedfolders with uid to uid
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					layout:Layout { hint: width 400 }
					variable:UserVariable session_selectedFoldersTeam360
					options:Dynamic {
						data:managedfolders
						text:Concat(Current resourcename, ' (', Current resourcecategory, ')')
						value:Current resourceuid
					}
					label:$session_selectedFoldersTeam360NLS.label
					tooltip:$session_selectedFoldersTeam360NLS.tooltip
					allow-none:True
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				Table {
					data:folderrights
					layout:Layout {grab: horizontal True vertical True }
					show-count:True
					show-filter:True
					configurable:True
					enable-markup:True
					persist-configuration:True
					persist-configuration-key:uid
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then foldar_highlightnew360 when 'Removed' then foldar_highlightremoved360 when 'Modified' then foldar_highlightmodified360 when 'Invalid' then foldar_highlightremoved360 } text:Transform Current status using foldar_mapping360 }
					Column {
						sortable:True
						filterable:True
						column:identityhrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:identityfullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:identitymail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:identityinternal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:identityarrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:identitydeparturedate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:jobtitledisplayname
						header:$identity.jobtitledisplayname
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:orgdisplayname
						header:$folderaccessrights360NLS.department
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:rights
						header:$right.concept
					}
					Column {
						column:uid
						hidden:True
					}
					Column {
						sortable:True
						filterable:True
						column:code
						header:$folderaccessrights360NLS.folder
						width:240px
					}
					Column {
						sortable:True
						filterable:True
						column:displayname
						header:$folderaccessrights360NLS.foldername
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:description
						header:$folderaccessrights360NLS.description
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:share_displayname
						header:$folderaccessrights360NLS.share
						width:160px
					}
				}
			}
		}	
	}
}
