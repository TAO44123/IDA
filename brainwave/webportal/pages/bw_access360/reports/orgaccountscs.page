/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/teamaccounts.page"

/* Nationalized labels here */
organisationaccounts360csNLS = NLS {
	title [en "Managed Organizations Accounts Analysis" fr "Analyse des comptes d''accès des organisations gérées"]
	dyntitle [en "Managed Organizations Accounts Analysis for {0}" fr "Analyse des comptes d''accès des organisations gérées par {0}"]
	privileged [en "Privileged" fr "privilégié"]
	department [en "Department" fr "département"]
	lastlogintooltip [en "Last Login: {0}" fr "Dernière connexion: {0}"]
	unknown [en "Unknown" fr "Non renseigné"]
	description [
		en "This report lists active accounts of the managed organizations in a pivot table format. It is possible to choose either the direct members of the organizations or all members. It is possible to configure the columns or to export the results by right-clicking."
		fr "Ce rapport liste les comptes actifs des organisations gérées sous la forme d'un tableau croisé dynamique. Il est possible de choisir soit les membres directs des organisations soit l'ensemble des membres. Il est possible de paramétrer les colonnes ou d'exporter les résultats en faisant un clic droit."
	]
}

organisationaccounts360csLL = StringMapping {
	when IsEmpty then $organisationaccounts360csNLS.unknown
	otherwise current

}

organisationaccounts360csdetail = Page {
	title: $organisationaccounts360csNLS.title
	description:$organisationaccounts360csNLS.description
	tags: "identityext" priority 200, "byuid" , "browsing", "organisationmanager"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_orgaccountscs
	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page organisationccounts360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

organisationaccounts360cshp = Page {
	title: $organisationaccounts360csNLS.title
	description:$organisationaccounts360csNLS.description
	tags: "myorg_access360" priority 2
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_orgaccountscs

	conditional-redirect: ConditionalRedirect {
		condition:BooleanPredicate(True)
		target:Page organisationccounts360cs with-current-parameters
	}

    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
}

organisationccounts360cs = Page {
	title: $organisationaccounts360csNLS.title
	dynamic-title:$organisationaccounts360csNLS.dyntitle(identity.fullname)
	description:$organisationaccounts360csNLS.description
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa360_orgaccountscs
	enter-event:IntCase(orgmanagernbidentity.nbtotalmembers) { when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [ Set False to UserVariable session_indirectTeam360, Set True to indirectTeam360_disabled  ] }
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	indirectTeam360_disabled = Variable { initial:False }
	
	/* Datasets and records here */
	identity = Record {
		view:bwf_identityDetail with uid to uid
	}
	
	orgmanagernbidentity = Record {
		view:enduser360_orgmanagernbidentity with uid to uid
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	teamaccounts = Dataset {
		view:enduser360_orgmanageraccountscs with uid to uid, UserVariable session_indirectTeam360 to indirectteam,UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Invalid' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:UserVariable session_indirectTeam360
					label:$session_indirectTeam360NLS.label
					tooltip:$session_indirectTeam360NLS.tooltiplimit(NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold))
					disabled:BooleanPredicate(indirectTeam360_disabled)
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamaccounts
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:200px  grab: horizontal True vertical True}
					columns:
						Dim {value:repositorydisplayname header:$repository.concept} 
					rows:
						Dim {value:orguid label:orgshortname header:$porganisation.shortname initially-masked:True},
						Dim {value:orguid label:orgdisplayname header:$organisation.concept},
						Dim {value:jobtitleuid label:jobtitledisplayname header:$identity.jobtitledisplayname initially-masked:True},
						Dim {value:internal label:internal header:$identity.internal initially-masked:True},
						Dim {value:uid label:fullname header:$identity.concept} 
					cell-content:CellContent {text:Current accountlogin cluster-value:'X' tooltip:$organisationaccounts360csNLS.lastlogintooltip(Transform Current accountlastlogindate using organisationaccounts360csLL) styling:StringStyling(Current status) { when 'New' then tactimeline_highlightnew360 when 'Removed' then tactimeline_highlightremoved360}}
				
				}
			}
		}	
	}
}
