/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_htmlwidgets/tree.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"

/* Nationalized labels here */
access360r_accountpermissions360NLS = NLS {
	title [en "360° view of the account permissions" fr "Vue à 360° des permissions du compte"]
	dyntitle [en "{0} 360° view of the permissions" fr "Vue à 360° des permissions de {0}"]
	filteredon [en "Filtered on {0}" fr "Filtré sur {0}"]
	tooltipsuffix [en "\nDouble-clic for details" fr "\nDouble-cliquez pour les détails"]
	
	directonly [en "Show direct permissions only" fr "Afficher seulement les permissions directes"]
	
	description [
		en "This report presents all account permissions in the form of a network graph. The direction of the arrow means 'contains'. It is possible to restrict the display to direct permissions only. It is possible to display the details of the permissions."
		fr "Ce rapport présente l'ensemble des permissions du compte sous la forme d'un graphique de type réseau. Le sens de la flêche signifie 'contient'. Il est possible de restreindre l'affichage aux permissions directes uniquement. Il est possible d'afficher le détail des permissions."
	]

	zoommode [en "Zoom mode" fr "Mode zoom"]
	zoommode.tooltip [	en "In zoom mode a click on an application or a direct permission allows you to filter the graph in order to limit the display to the selected path. To come back to the complete graph you must either click on the account or uncheck the zoom mode." 
						fr "En mode zoom un clic sur une application ou une permission permet de filter le graphique afin de limiter l'affichage au chemin sélectionné\nPour revenir sur le graphique complet il faut soit cliquer sur le compte soit décocher le mode zoom."]
	detailmode [en "Detail mode" fr "Mode détail"]
	detailmode.tooltip [
						en "In detail mode, a click on an item displays the detail of this item in a dialog box. The detail mode has priority over the zoom mode." 
						fr "En mode détail, un clic sur un élément permet d'afficher le détail de cet élement dans une boite de dialogue. Le mode détail est prioritaire par rapport au mode zoom."]

	stopphysics [en "Freeze animation" fr "Geler l'animation"]
	hierarchy [en "Hierarchy layout" fr "Affichage hiérarchique"]
}

tgtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tgtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tgtmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

access360r_accountpermissions360 = Page {
	title: $access360r_accountpermissions360NLS.title
	description: $access360r_accountpermissions360NLS.description
	dynamic-title: $access360r_accountpermissions360NLS.dyntitle(account.login)
	tags: "account" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwa_accountpermissions360
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	selectedUID = Variable

	selectedApplication  = Variable
	selectedApplicationName = Variable
	selectedPermission  = Variable
	selectedPermissionName = Variable

	onselectPermission  = Variable
	
	directonly = Variable { initial:True type:Boolean }
	detailMode = Variable { initial:False type:Boolean }
	stopPhysics = Variable { initial:False type:Boolean }
	hierarchical = Variable { initial:True type:Boolean }
	zoomMode = Variable { initial:False type:Boolean }
		
	/* Datasets and records here */
	account = Record {
		view:br_accountDetail with uid to uid 
	}

	accountgroups = Dataset {
		view:bwa_a360_accountpermission360 with uid to uid, directonly to directonly, '' to tooltipsuffix, selectedApplication to selectedApplication, selectedPermission to selectedPermission
	}

	isaccountdirectpermission = Dataset {
		view:bwa_a360_accountisdirectperm with uid to uid, onselectPermission to permissionuid
	}
	
	onAccountDetails = NamedAction (
		Dialog bwf_accountDetailsDialog(selectedUID to inuid,
										True to inshowgroups,
										True to inshowapplications,
										True to inshowshares,
										True to inshowcontrols,
										True to inshowdecisionhistory,
										True to inshowowner,
										True to inshowusages
		)
	)
	onApplicationDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog(selectedUID to inuid,
										True to inshowperjob,
										True to inshowperorg
		)
	)
	onPermissionDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog(selectedUID to inuid,
										True to inshowperjob,
										True to inshowperorg
		)
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a },  GridColumn  { group:a },  GridColumn  { group:a }
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:directonly
					text:$access360r_accountpermissions360NLS.directonly
				}
				Checkbox {
					variable:hierarchical
					text:$access360r_accountpermissions360NLS.hierarchy
				}
				Checkbox {
					variable:stopPhysics
					text:$access360r_accountpermissions360NLS.stopphysics
					disabled:BooleanPredicate(hierarchical)
				}
			}
			GridCell {
				Checkbox {
					variable:zoomMode
					text:$access360r_accountpermissions360NLS.zoommode
					tooltip:$access360r_accountpermissions360NLS.zoommode.tooltip
					modify-event:
						BooleanCase(zoomMode) {
							when True then [
								Set False to detailMode
							]
							when False then [
								Set '' to selectedApplication,
								Set '' to selectedApplicationName,
								Set '' to selectedPermission,
								Set '' to selectedPermissionName
							]
						}
				}
				Checkbox {
					variable:detailMode
					text:$access360r_accountpermissions360NLS.detailmode
					tooltip:$access360r_accountpermissions360NLS.detailmode.tooltip
					modify-event:
						BooleanCase(Eval "detailMode.get() && selectedApplication.isEmpty() && selectedPermission.isEmpty()") {
							when  True then [
								Set False to zoomMode
							]
							when False then [
							]
						}
				}
			}
			GridCell {
				Header {
					value: $access360r_accountpermissions360NLS.filteredon(selectedPermissionName)
					hidden:StringPredicate(selectedPermission) { when IsEmpty then True } 
				}
				Header {
					value: $access360r_accountpermissions360NLS.filteredon(selectedApplicationName)
					hidden:StringPredicate(selectedApplication) { when IsEmpty then True } 
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				IncludeHTMLWidget {
					layout: Layout { grab:horizontal True vertical True /* hint:height 500 */ }
					template: network
					datasets:accountgroups(id, name, parentid, group, description, attrs) to chartdata(code, label, parentcode, group, description, nodeattributes)
					bindings:
						value-of True to arrows_middle,
						value-of hierarchical to hierarchical,
						value-of 'box' to shape,
						value-of 2000 to textboxsize,
						value-of stopPhysics to stopPhysics,
						value-of True to computegroupfontcolor,
						value-of True to navigationButtons
					widget-events: {
						when onclick then [
							BooleanCase(Eval "zoomMode.get() && !detailMode.get()") {
								when True then [
									StringCase(Current group) {
										when "account" then [
											Set '' to selectedApplication,
											Set '' to selectedApplicationName,
											Set '' to selectedPermission,
											Set '' to selectedPermissionName
										]
										when "application" then [
											Set Current code to selectedApplication,
											Set Current label to selectedApplicationName,
											Set '' to selectedPermission,
											Set '' to selectedPermissionName
										]
										when "permission" then [
											Set Current code to onselectPermission,
											IntCase(Count isaccountdirectpermission) {
												when =1 then [
													Set '' to selectedApplication,
													Set '' to selectedApplicationName,
													Set Current code to selectedPermission,
													Set Current label to selectedPermissionName
												]
											}
										]
									}							
								]
								when False then [
								]
							},
							BooleanCase(Eval "detailMode.get()") {
								when True then [
									Set Current code to selectedUID,
									StringCase(Current group) {
										when "account" then [
											ExecuteNamedAction onAccountDetails								
										]
										when "application" then [
											ExecuteNamedAction onApplicationDetails								
										]
										when "permission" then [
											ExecuteNamedAction onPermissionDetails								
										]
									}							
								]
								when False then [
								]
							}
						]
					}
				}

			}
		}
	}
}
