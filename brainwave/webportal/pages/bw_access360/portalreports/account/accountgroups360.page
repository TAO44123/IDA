/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/bw_htmlwidgets/tree.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

/* Nationalized labels here */
access360r_accountgroups360NLS = NLS {
	title [en "360° view of the account groups" fr "Vue à 360° des groupes du compte"]
	dyntitle [en "{0} 360° view of the groups" fr "Vue à 360° des groupes de {0}"]
	filteredon [en "Filtered on {0}" fr "Filtré sur {0}"]
	tooltipsuffix [en "\nDouble-clic for details" fr "\nDouble-cliquez pour les détails"]
	
	directonly [en "Show direct account groups only" fr "Afficher seulement les groupes directs du compte"]
	
	description [
		en "This report presents all groups in the account in the form of a network graph. The direction of the arrow means 'is in'. It is possible to restrict the display to direct groups only. It is possible to display the details of the groups."
		fr "Ce rapport présente l'ensemble des groupes du compte sous la forme d'un graphique de type réseau. Le sens de la flêche signifie 'est dans'. Il est possible de restreindre l'affichage aux groupes directs uniquement. Il est possible d'afficher le détail des groupes."
	]

	detailmode [en "Detail mode" fr "Mode détail"]
	detailmode.tooltip [
						en "In detail mode, a click on an item displays the detail of this item in a dialog box. The detail mode has priority over the zoom mode." 
						fr "En mode détail, un clic sur un élément permet d'afficher le détail de cet élement dans une boite de dialogue. Le mode détail est prioritaire par rapport au mode zoom."]

	stopphysics [en "Freeze animation" fr "Geler l'animation"]
	hierarchy [en "Hierarchy layout" fr "Affichage hiérarchique"]
}

tgtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tgtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tgtmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

access360r_accountgroups360 = Page {
	title: $access360r_accountgroups360NLS.title
	description: $access360r_accountgroups360NLS.description
	dynamic-title: $access360r_accountgroups360NLS.dyntitle(account.login)
	tags: "account" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwa_accountgroups360
	
	mixins: simpleReport	
	/* Parameters here */
    org = Parameter { type: String hidden: True }
    uid = Parameter { type: String hidden: True }
	
	/* Parameters here */
	
	/* Variables here */
	selectedUID = Variable
	
	directonly = Variable { initial:True type:Boolean }
	detailMode = Variable { initial:False type:Boolean }
	stopPhysics = Variable { initial:False type:Boolean }
	hierarchical = Variable { initial:False type:Boolean }
	
	/* Datasets and records here */
	account = Record {
		view:br_accountDetail with uid to uid 
	}

	accountgroups = Dataset {
		view:bwa_accountgroup360 with uid to uid, directonly to directonly, '' to tooltipsuffix
	}

	groupExists = Dataset {
		view:bwf_groupDetail with selectedUID to uid
	}

	onGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedUID to inuid,
										True to inshowapplications,
										True to inshowshares,
										True to inshowperjob,
										True to inshowperorg
		)
	)

	/* Page content */
	Grid {
		columns:GridColumn { group:a },  GridColumn { group:a },  GridColumn { group:a }
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:directonly
					text:$access360r_accountgroups360NLS.directonly
				}
			}
			GridCell {
				Checkbox {
					variable:detailMode
					text:$access360r_accountgroups360NLS.detailmode
					tooltip:$access360r_accountgroups360NLS.detailmode.tooltip
				}
				Checkbox {
					variable:hierarchical
					text:$access360r_accountgroups360NLS.hierarchy
				}
				Checkbox {
					variable:stopPhysics
					text:$access360r_accountgroups360NLS.stopphysics
					disabled:BooleanPredicate(hierarchical)
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				IncludeHTMLWidget {
					layout: Layout { grab:horizontal True vertical True /* hint:height 500 */ }
					template: network
					datasets:accountgroups(id, name, parentid, group, description, attrs) to chartdata(code, label, parentcode, group, description, nodeattributes)
					bindings:
						value-of True to arrows_middle,
						value-of hierarchical to hierarchical,
						value-of 'box' to shape,
						value-of 2000 to textboxsize,
						value-of stopPhysics to stopPhysics,
						value-of True to computegroupfontcolor,
						value-of True to navigationButtons
					widget-events: {
						when onclick then [
							BooleanCase(detailMode) {
								when True then [
									Set Current code to selectedUID,
									IntCase(Count groupExists) {
										when >0 then [
											ExecuteNamedAction onGroupDetails								
										]
									}							
								]
								when False then [
								]
							}
						]
					}
				}

			}
		}
	}
}
