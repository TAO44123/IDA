/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/permission/details/permissionDetails.page"
import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"

/* Nationalized labels here */
access360r_identity_accessrightsNLS = NLS {
	title [en "Access rights list" fr "Liste des droits d'accès aux applications"]
	dyntitle [en "{0} access rights list" fr "Liste des droits d''accès pour {0}"]
	description [
		en "This report lists the user's application access rights. Only the 'application profile' type rights directly associated with the user are taken into account. Only the user's active accounts are taken into account. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported; right-click on the table to do so."
		fr "Ce rapport liste les droits d'accès applicatifs de l'utilisateur. Seuls les droits de type 'profil applicatif' directement associés à l'utilisateur sont pris en compte. Seuls les comptes actifs de l'utilsateur sont pris en compte. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
	]
}

tartimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tartimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tarmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}

access360r_identity_accessrights = Page {
	title: $access360r_identity_accessrightsNLS.title
	dynamic-title: $access360r_identity_accessrightsNLS.dyntitle(identity.fullname)
	description:$access360r_identity_accessrightsNLS.description
	tags: "identity" priority 100, "byuid" , "browsing"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:bwa_identityaccessrights
		
	mixins: simpleReport

	/* Parameters here */
	uid = Parameter {
		label:"Concept Uid"
		type:String
	}
	
	/* Variables here */
	outaccountuid = Variable
	outpermissionuid = Variable
	outapplicationuid = Variable
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid 
	}
	
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	idtrights = Dataset {
		view: bwa360report_accessrightsbv with
			uid to uid,
			UserVariable session_comparisonTimeslotTeam360 to dummy,
			UserVariable session_comparisonTimeslotTeam360 to comparisontimeslot unless-empty,
			UserVariable session_exclRemoved to excluderemoved,
			UserVariable session_exclSimilar to excludesimilar
	}
	
	/* Page content */

	showAccountDetails = NamedAction (
		Dialog bwf_accountDetailsDialog(
			outaccountuid to inuid,
			True to inshowowner,
			True to inshowapplications,
			True to inshowcontrols,
			True to inshowdecisionhistory,
			True to inshowgroups,
			True to inshowshares,
			True to inshowusages
		)
	)

	showPermissionDetails = NamedAction (
		Dialog bwf_permissionDetailsDialog(
			outpermissionuid to inuid,
			True to inshowperjob,
			True to inshowperorg
		)
	)

	showApplicationDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog(
			outapplicationuid to inuid,
			True to inshowperjob,
			True to inshowperorg
		)
	)

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				PaginatedTable {
					data: idtrights
					layout:Layout {grab: horizontal True vertical True }
					page-size:1000
					//show-count:True
					show-filter:True
					configurable:True
					persist-configuration:True
					persist-configuration-key:uid
					show-count-button: True
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tartimeline_highlightnew360 when 'Removed' then tartimeline_highlightremoved360 when 'Invalid' then tartimeline_highlightremoved360 } text:Transform Current status using tarmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
						actions:ExecuteNamedAction showAccountDetails
					}
					Column {
						sortable:True
						filterable:True
						column:accountusername
						header:$account.username
						actions:ExecuteNamedAction showAccountDetails
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:permissionpermissiontype
						header:$ppermission.permissiontype
					}
					Column {
						sortable:True
						filterable:True
						column:permissioncode
						header:$ppermission.code
						width:160px
						actions:ExecuteNamedAction showPermissionDetails
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$ppermission.displayname
						width:160px
						actions:ExecuteNamedAction showPermissionDetails
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondescription
						header:'description'
						width:160px
						initially-masked:True
						actions:ExecuteNamedAction showPermissionDetails
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$application.concept
						width:160px
						actions:ExecuteNamedAction showApplicationDetails
					}
					Column {
						column:accountuid
						selection:outaccountuid
						hidden:True
					}
					Column {
						column:permissionuid
						selection:outpermissionuid
						hidden:True
					}
					Column {
						column:applicationuid
						selection:outapplicationuid
						hidden:True
					}
				}
			}
		}	
	}
}
