/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

import "/webportal/pages/bw_access360/reports/teamnls.page"

/* Nationalized labels here */
access360r_identity_folderrightsNLS = NLS {
	title [en "folders rights list" fr "Liste des droits d'accès aux données"]
	dyntitle [en "{0} folders rights list" fr "Liste des droits d''accès aux données pour {0}"]
	folder [en "folder" fr "répertoire"]
	foldername [en "folder name" fr "nom répertoire"]
	description [en "description" fr "description"]
	share [en "share" fr "partage"]
	family [en "family" fr "famille"]
	_description [
		en "This report lists the user's desktop access rights only the user's active accounts are taken into account. It is possible to filter the results by tree depth. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right click on the table to do so"
		fr "Ce rapport liste les droits d'accès bureautique de l'utilisateur. Seuls les comptes actifs de l'utilsateur sont pris en compte. il est possible de filtrer les résultats par profondeur d'arborescence. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
	]
}

tfrtimeline_highlightnew360 = Style {
	foreground:white
	background:Color green
}
tfrtimeline_highlightremoved360 = Style {
	foreground:white
	background:Color red
}

tfrtimeline_highlightmodified360 = Style {
	foreground:white
	background:Color RGB(255, 128, 0)
}

tfrmapping360 = StringMapping {
	when 'Invalid' then 'Removed'
	otherwise current
}


access360r_identity_folderrights = Page {
	title: $access360r_identity_folderrightsNLS.title
	dynamic-title: $access360r_identity_folderrightsNLS.dyntitle(identity.fullname)
	description:$access360r_identity_folderrightsNLS._description
	tags: "identity" priority 200, "byuid" , "browsing"
	icon: "16/details/browsing_16.png" large-icon: "48/details/browsing_48.png"
	feature:All(unstructureddata_license, bwa_identityfolderrights)
	
	mixins: simpleReport

	/* Parameters here */
	uid = Parameter {
		label:"Concept Uid"
		type:String
	}
	
	/* Parameters here */
	
	/* Variables here */
	selectedFolderUid = Variable
	
	/* Datasets and records here */
	identity = Record {
		view:br_identityDetail with uid to uid 
	}

	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	teamrights = Dataset {
		view:bwa360report_folderrights_bv with uid to uid, UserVariable session_indirectTeam360 to indirectteam,
									UserVariable session_folderDepth to depth,
									UserVariable session_comparisonTimeslotTeam360 to dummy, UserVariable session_comparisonTimeslotTeam360 to comparisontimeslot unless-empty, UserVariable session_exclRemoved to excluderemoved, UserVariable session_exclSimilar to excludesimilar
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Combo {
					variable:UserVariable session_folderDepth
					tooltip:$session_folderDepthNLS.tooltip
					label:$session_folderDepthNLS.label
					layout:Layout {grab:horizontal False vertical False hint:width 96}
					options:Static {
						Option { text:'<=1' value:'<1' }
						Option { text:'<=2' value:'<2' }
						Option { text:'<=3' value:'<3' }
						Option { text:'<=4' value:'<4' }
						Option { text:'<=5' value:'<5' }
						Option { text:'<=6' value:'<6' }
						Option { text:'<=7' value:'<7' }
						Option { text:'<=8' value:'<8' }
						Option { text:'<=9' value:'<9' }
						Option { text:'=1' value:'=1' }
						Option { text:'=2' value:'=2' }
						Option { text:'=3' value:'=3' }
						Option { text:'=4' value:'=4' }
						Option { text:'=5' value:'=5' }
						Option { text:'=6' value:'=6' }
						Option { text:'=7' value:'=7' }
						Option { text:'=8' value:'=8' }
						Option { text:'=9' value:'=9' }
					}
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				PaginatedTable {
					data:teamrights
					layout:Layout {grab: horizontal True vertical True }
					page-size:1000
					//show-count:True
					show-filter:True
					configurable:True
					enable-markup:True
					persist-configuration:True
					persist-configuration-key:uid
					show-count-button: True
					
					Column {sortable:True header:'' column:status styling:StringStyling(Current status) { when 'New' then tfrtimeline_highlightnew360 when 'Removed' then tfrtimeline_highlightremoved360 when 'Modified' then tfrtimeline_highlightmodified360 when 'Invalid' then tfrtimeline_highlightremoved360 } text:Transform Current status using tfrmapping360 }
					Column {
						sortable:True
						filterable:True
						column:hrcode
						header:$identity.hrcode
					}
					Column {
						sortable:True
						filterable:True
						column:fullname
						header:$identity.fullname
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:mail
						header:$identity.mail
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:internal
						header:$identity.internal
					}
					Column {
						sortable:True
						filterable:True
						column:arrivaldate
						header:$identity.arrivaldate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:departuredate
						header:$identity.departuredate
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlogin
						header:$account.login
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:accountlastlogindate
						header:$account.lastlogindate
					}
					Column {
						sortable:True
						filterable:True
						column:repositorydisplayname
						header:$repository.concept
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:rights
						header:$right.concept
					}
					Column {
						column:permissionuid
						hidden:True
						selection:selectedFolderUid
					}
					Column {
						sortable:True
						filterable:True
						column:permissioncode
						header:$access360r_identity_folderrightsNLS.folder
						width:240px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondisplayname
						header:$access360r_identity_folderrightsNLS.foldername
						initially-masked:True
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:permissiondescription
						header:$access360r_identity_folderrightsNLS.description
						width:160px
						initially-masked:True
					}
					Column {
						sortable:True
						filterable:True
						column:applicationdisplayname
						header:$access360r_identity_folderrightsNLS.share
						width:160px
					}
					Column {
						sortable:True
						filterable:True
						column:applicationapplicationfamily
						header:$access360r_identity_folderrightsNLS.family
						width:160px
					}
				}
			}
		}
	}
}
