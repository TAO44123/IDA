/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/resources/pages_nls.page"
import "/webportal/pages/bw_fragments/share/resources.page"

/* Nationalized labels here */
access360r_share_analytics360NLS = NLS {
	title [en "Self-service analytics" fr "Analytics en self-service"]
	dyntitle [en "{0} self-service analytics" fr "Analytics en self-service pour {0}"]
	empty [en "{0} does not contain any rights" fr "{0} ne contient pas de droits"]
	description [
		en "This report presents the access rights of the share in the form of a dynamic pivot table where it is possible to select the analysis dimensions. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport présente les droits d'accès du partage sous la forme d'un tableau croisé dynamique où il est possible de sélectionner les dimensions d'analyse. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée. Les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela."
		]
}

access360r_share_analytics = Page {
	title: $access360r_share_analytics360NLS.title
	dynamic-title: $access360r_share_analytics360NLS.dyntitle(application.displayname)
	description: $access360r_share_analytics360NLS.description
	tags: "share" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa_shareanalytics)
	
	mixins: simpleReport	

	/* Parameters here */
	uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	nbResults = Variable { type: Integer initial: 0 }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view: bw360_prevtimeslot with
			PortalTimeslot.UID to currentuid
	}
	
	application = Record {
		view: bwf_shareDetail with
			uid to uid
	}

	rights = Dataset {
		view: bwaccess360r_share_rightsanalytics with
			uid to uid,
			UserVariable session_comparisonTimeslotTeam360 to dummy,
			UserVariable session_folderDepth to depth
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		count-variable: nbResults
		excludes:
			OrPredicate {
				AndPredicate {
					StringPredicate(Current status) { when 'Removed' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Invalid' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Identical' then True }
					BooleanPredicate(UserVariable session_exclSimilar)
				}
		}
	}

	managedapps = Dataset {
		view: enduser360_managedapplications with
			uid to uid
	}
	
	/* Page content */
	ConditionalGroup {
		IntCondition( nbResults ) {
			when >0 then [
				Grid {
					columns:GridColumn, GridColumn, GridColumn
					layout:Layout { grab:horizontal True vertical True } 
					GridRow {
						height:64
						GridCell {
							Checkbox {
								variable:UserVariable session_indirectTeam360
								label:$session_indirectTeam360NLS.label
								tooltip:$session_indirectTeam360NLS.tooltip
							}
							Combo {
								variable:UserVariable session_comparisonTimeslotTeam360
								layout:Layout { hint: width 200 }
								label:$session_comparisonTimeslotTeam360NLS.label
								tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
								options:Dynamic {
									data:session_comparisontimeslots
									text:Current commitdate
									value:Current uid
								}
							}
						}
						GridCell {
							Checkbox {
								variable:UserVariable session_exclRemoved
								text:$session_exclRemovedNLS.label
								tooltip:$session_exclRemovedNLS.tooltip
							}
							Checkbox {
								variable:UserVariable session_exclSimilar
								text:$session_exclSimilarNLS.label
								tooltip:$session_exclSimilarNLS.tooltip
							}
						}
						GridCell {
							Combo {
								variable:UserVariable session_folderDepth
								tooltip:$session_folderDepthNLS.tooltip
								label:$session_folderDepthNLS.label
								layout:Layout {grab:horizontal False vertical False hint:width 96}
								options:Static {
									Option { text:'<=1' value:'<1' }
									Option { text:'<=2' value:'<2' }
									Option { text:'<=3' value:'<3' }
									Option { text:'=1' value:'=1' }
									Option { text:'=2' value:'=2' }
									Option { text:'=3' value:'=3' }
								}
							}
						}
					}
					GridRow {
						height:grow
						GridCell {
							span:3
							DynamicCrossTable {
								data:rights
								layout:Layout {cell-width:64px  grab: horizontal True vertical True}
								dimensions:
									Dim {
										value: permissioncode
										label: permissioncode
										header: $fragmentPFolderNLS.code
									},
									Dim {
										value: permissionuid
										label: permissiondisplayname
										header: $fragmentPFolderNLS.displayname
									},
									Dim {
										value: permissionsensitivitylevel
										label: permissionsensitivitylevel
										header: $fragmentPFolderNLS.sensitivitylevel
									},
									Dim {
										value: accountuid
										label: accountlogin
										header: $account.login
									},
									Dim {
										value: accountusername
										label: accountusername
										header: $account.username
									},
									Dim {
										value: noownercode
										label: noownercode
										header: $reconciliation.noownercode
									},
									Dim {
										value: identityhrcode
										label: identityhrcode
										header: $identity.hrcode
									},
									Dim {
										value: identityuid
										label: identityfullname
										header: $identity.fullname
									},
									Dim {
										value: identitymail
										label: identitymail
										header: $identity.mail
									},
									Dim {
										value: identityactive
										label: identityactive
										header: $pidentity.active
									},
									Dim {
										value: identityinternal
										label: identityinternal
										header: $pidentity.internal
									},
									Dim {
										value: jobtitledisplayname
										label: jobtitledisplayname
										header: $identity.jobtitledisplayname
									},
									Dim {
										value: organisationcode
										label: organisationcode
										header: $porganisation.code
									},
									Dim {
										value: organisationshortname
										label: organisationshortname
										header: $porganisation.shortname
									},
									Dim {
										value: organisationuid
										label: organisationdisplayname
										header: $organisation.concept
									},
									Dim {
										value: rights
										label: rights
										header: $right.concept
									},
									Dim {
										value: status
										label: status
										header: $global.status
									}
								measures:
									Measure {
										value: val
										header: $global.contain
									}
							}
						}
					}
				}
			] otherwise [
				Header {
					value: $access360r_share_analytics360NLS.empty( application.displayname )
				}
			]
		}
	}
}
