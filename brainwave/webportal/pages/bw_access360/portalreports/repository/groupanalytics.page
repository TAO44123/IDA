/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
access360r_repository_groupanalytics360NLS = NLS {
	title [en "Self-Service Group Analytics" fr "Analyse des groupes en self-service"]
	dyntitle [en "{0} Self-Service Group Analytics" fr "Analyse des groupes en self-service pour {0}"]
	empty [en "{0} does not contain any group members" fr "{0} ne contient pas de membres de groupes"]
	description [
		en "This report presents the accounts in the form of a dynamic pivot table where it is possible to select the analysis dimensions. Only active accounts are taken into consideration. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport présente les groupes sous la forme d'un tableau croisé dynamique où il est possible de sélectionner les dimensions d'analyse. Seuls les comptes actifs sont pris en compte. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée. Les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela."
		]
	filter [en "Filter" fr "Filtrer"]
	filter_tooltip [en "Filter by Group Code or Group Name" fr "Filtrer par code groupe ou nom du groupe"]
	limited [
		en "Self-service analytics is limited to {0} groups, please refine your search criterias"
		fr "L''analyse en self-service est limitée à {0} groupes, veuillez affiner vos critères de recherche"
	]
}

access360r_repository_groupanalytics_threshold = Constant {
	value:1000
	type:Integer
}

access360r_repository_groupanalytics = Page {
	title: $access360r_repository_groupanalytics360NLS.title
	description: $access360r_repository_groupanalytics360NLS.description
	dynamic-title: $access360r_repository_groupanalytics360NLS.dyntitle(repository.displayname)
	tags: "server", "repository" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa_repositorygroupanalytics
	
	mixins: simpleReport	

	/* Parameters here */
	uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	group_count = Variable { type: Integer initial: 0 }
	nbResults = Variable { type: Integer initial: 0 }
	codeFilter = Variable { type: String }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view: bw360_prevtimeslot with
			PortalTimeslot.UID to currentuid
	}
	
	repository = Record {
		view: bwf_repositoryDetail with
			uid to uid
	}

	group_count_dataset = Dataset {
		view: bwaccess360r_repository_similargroupnb with
			uid to uid,
			codeFilter to codefilter
		count-variable: group_count
	}

	rights = Dataset {
		view: bwaccess360r_repository_accountsandgroupsanalytics with
			uid to uid,
			UserVariable session_comparisonTimeslotTeam360 to dummy,
			codeFilter to codefilter
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:False
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		count-variable: nbResults
		disabled:
			IntPredicate(group_count) {
				when >Constant access360r_repository_groupanalytics_threshold then True
			}
		excludes:
			OrPredicate {
				AndPredicate {
					StringPredicate(Current status) { when 'Identical' then True }
					BooleanPredicate(UserVariable session_exclSimilar)
				}
			}
	}
	
	/* Page content */
	ConditionalGroup {
		IntCondition(nbResults) {
			when >0 then [
				Grid {
					columns:GridColumn, GridColumn, GridColumn
					layout:Layout { grab:horizontal True vertical True } 
					GridRow {
						height:64
						GridCell {
							Combo {
								variable:UserVariable session_comparisonTimeslotTeam360
								layout:Layout { hint: width 200 }
								label:$session_comparisonTimeslotTeam360NLS.label
								tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
								options:Dynamic {
									data:session_comparisontimeslots
									text:Current commitdate
									value:Current uid
								}
							}
							Edit {
								variable:codeFilter
								label:$access360r_repository_groupanalytics360NLS.filter
								tooltip:$access360r_repository_groupanalytics360NLS.filter_tooltip
							}
						}
						GridCell {
							Checkbox {
								variable:UserVariable session_exclSimilar
								text:$session_exclSimilarNLS.label
								tooltip:$session_exclSimilarNLS.tooltip
							}
						}
						GridCell {
						}
					}
					GridRow {
						height:grow
						GridCell {
							span:3
							Header {
								value:$access360r_repository_groupanalytics360NLS.limited(Constant access360r_repository_groupanalytics_threshold)
								styling:errorStyle
								hidden:IntPredicate(group_count) { when <=Constant access360r_repository_groupanalytics_threshold then True otherwise False }
							}
							DynamicCrossTable {
								data:rights
								layout:Layout {cell-width:64px  grab: horizontal True vertical True}
								dimensions:
									Dim {
										value: repositoryuid
										label: repositorydisplayname
										header: $repository.concept
									},
									Dim {
										value: groupuid
										label: groupdisplayname
										header: $group.concept
									},
									Dim {
										value: orguid
										label: orgdisplayname
										header: $organisation.concept
									},
									Dim {
										value: jobtitleuid
										label: jobtitledisplayname
										header: $allocation.jobtitledisplayname
									},
									Dim {
										value: uid
										label: login
										header: $account.login
									},
									Dim {
										value: service
										label: service
										header: $account.service
									},
									Dim {
										value: ownerhrcode
										label: ownerhrcode
										header: $identity.hrcode
									},
									Dim {
										value: owneruid
										label: ownerfullname
										header: $identity.fullname
									},
									Dim {
										value: ownerinternal
										label: ownerinternal
										header: $pidentity.internal
									},
									Dim {
										value: owneractive
										label: owneractive
										header: $pidentity.active
									}
								measures:
									Measure {
										value: val
										header: "#"
									}
							}
						}
					}
				}
			] otherwise [
				Header {
					value: $access360r_repository_groupanalytics360NLS.empty( repository.displayname )
				}
			]
		} 
	}
}
