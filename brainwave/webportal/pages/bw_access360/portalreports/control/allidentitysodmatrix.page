/* Nationalized labels here */
bwa360_allidentitysodmatrixNLS = NLS {
	title [en "SoD Defects Analysis" fr "Analyse des écarts de SoD"]
	activity [en "Activity" fr "Activité"]
	
	empty [
		fr "Aucun problème de SoD trouvé"
		en "No SoD Problems Found"
	]

	analytics.title [en "SoD Defects Analysis" fr "Analyse des écarts de SoD"]
	identitydefectdetails [en "SoD defects - User level" fr "Ecarts Sod - Niveau Utilisateur"]

	organisation.analytics.description [
		en "This report provides a summary of the segregation of duties (SOD) control deviations found for this organization. The gaps are presented in the form of a SOD matrix. This analysis includes both the organization and the sub-organizations. The background color represents the level of risk associated with the control. It is possible to analyze the permissions involved by clicking on the relevant activities (rows or columns)."
		fr "Ce rapport présente la synthèse des écarts de contrôle de séparation des tâches (SOD) trouvés pour cette organisation. Les écarts sont présentés sous la forme d'une matrice de SOD. Cette analyse inclus à la fois l'organisation courante et les sous organisations. La couleur de fond représente le niveau de risque associé au contrôle. Il est possible d'analyser les permissions en cause en cliquant sur les activités concernées (lignes ou colonnes)."
	]
	identity.analytics.description [
		en "This report provides a summary of the segregation of duties (SOD) control deviations found for this identity. The gaps are presented in the form of a SOD matrix. This analysis includes both the organization and the sub-organizations. The background color represents the level of risk associated with the control. It is possible to analyze the permissions involved by clicking on the relevant activities (rows or columns)."
		fr "Ce rapport présente la synthèse des écarts de contrôle de séparation des tâches (SOD) trouvés pour cette personne. Les écarts sont présentés sous la forme d'une matrice de SOD. Cette analyse inclus à la fois l'organisation courante et les sous organisations. La couleur de fond représente le niveau de risque associé au contrôle. Il est possible d'analyser les permissions en cause en cliquant sur les activités concernées (lignes ou colonnes)."
	]

	risklevel [en "Risk Level" fr "Niveau de risque"]
	controlcode [en "Control Code" fr "Code contrôle"]
	control [en "Control" fr "Contrôle"]
	controldescription [en "Control Description" fr "Description Contrôle"]
	risk [en "Risk" fr "Risque"]
	matrix [en "Matrix" fr "Matrice"]
	details [en "Details" fr "Détails"]
	selectcontrol [en "Select a Control" fr "Selectionner un contrôle"]
	nbidentitiesprb [en "(Shows the Number of Identities with the Problem)" fr "(Affiche le nombre d'identités avec le problème)"]
	rootcause [en "Root Cause Analysis" fr "Analyse de la cause"]
	minrisklevel [en "Minimum Risk Level" fr "Niveau de risque minimum"]
	filtercontrol [en "Control filtering" fr "Filtrage sur le contrôle"]
	remediation [en "Suggested Remediation" fr "Remédiation suggérée"]
	firstactivitycode [en "First Activity Code" fr "Premier code activité"]
	firstactivity [en "First Activity" fr "Première activité"]
	secondactivitycode [en "Second Activity Code" fr "Deuxième code activité"]
	secondactivity [en "Second Activity" fr "Deuxième activité"]

	showall [en "Display as a list" fr "Afficher en liste"]
	showcontroldetails [en "Selected control details" fr "Détails du contrôle sélectionné"]
	showcontrolresults [en "Selected defect details" fr "Détails du défaut"]
	
	showalltooltip [en "Show all Results as a List" fr "Afficher tous les résultats dans un tableau"]
	showcontroldetailstooltip [en "Show Selected Control Detail" fr "Afficher le détail du contrôle sélectionné"]
	showcontrolresultstooltip [en "Show Selected Control Results as a List" fr "Afficher les résultats du contrôle sélectionné dans un tableau"]
	back [en "Back to the Matrix" fr "Retour à la matrice"]

	risklevelprefix [en "Risk Level: " fr "Niveau de risque : "]

	paretotitle [en "Pareto Analysis per SoD Control" fr "Analyse de pareto par contrôle de SoD"]
	nbofidentities [en "Number of Identities" fr "Nombre d'identités"]
	runningpercent [en "Running Percentage" fr "pourcentage cumulé"]
	
	exception.status [en "Exception \nstatus" fr "Statut \nde l'exception"]
	exception.reason_ [en "Exception \nreason" fr "Raison \nde l'exception"]
	exception.comment [en "Exception \ncomment" fr "Commentaire \nde l'exception"]
	exception.setter_fullname [en "Exception \nsetter" fr "Responsable \nde l'exception"]
	exception.setter_hrcode [en "Exception \nsetter hrcode" fr "Code responsable \nde l'exception"]
	exception.expiration_date [en "Exception \nexpiration date" fr "Date d'expiration \nde l'exception"]
	setexceptiontooltip [en "Set an exception on selected identities for a specific control" fr "Appliquer une exception sur les identités en écart sur un contrôle"]
	defectfiltering [en "Defect filtering" fr "Filtrage sur l'écart"]
	defectfiltering.all_ [en "All" fr "Tout"]
	defectfiltering.role [en "Role" fr "Rôle"]
	defectfiltering.direct [en "Direct permission" fr "Permission directe"]
