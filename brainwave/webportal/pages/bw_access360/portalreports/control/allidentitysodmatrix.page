bwa360_allidentitysodmatrix_controlpicker = Dialog {
	title:$bwa360_allidentitysodmatrixNLS.selectcontrol
	width:1024
	height:600
	buttons:[
		OkButton { disabled:StringPredicate(outControlCode) { when IsEmpty then True otherwise False } }
		CancelButton
		] 

	controlcodes = Variable { multivalued:True }
	
	outControlCode = Variable
	outControlName = Variable
	
	controls = Dataset {
		view:bwa360_identitysodcontrols with controlcodes to controlcode
	}

	Table {
		data:controls
		layout: Layout { grab: horizontal True vertical True }
		configurable:True
		show-filter:True
		
		Column {
			column:risklevel
			text:Transform Current risklevel using bwf_ControlLevelMapping
			header:$bwa360_allidentitysodmatrixNLS.risklevel
			width:128px
			sortable:True
			filterable:True
			image:TemplateImageSelection(Current risklevel) using bwf_controllevel
		}	
		Column {
			column:controlcode
			tooltip:Current controlcode
			header:$bwa360_allidentitysodmatrixNLS.controlcode
			initially-masked:True
			selection:outControlCode
			sortable:True
			filterable:True
		}	
		Column {
			column:controldisplayname
			tooltip:Current controldisplayname
			header:$bwa360_allidentitysodmatrixNLS.control
			selection:outControlName
			sortable:True
			filterable:True
			width:100%
		}	
		Column {
			column:controldescription
			tooltip:Current controldescription
			header:$bwa360_allidentitysodmatrixNLS.controldescription
			initially-masked:True
			sortable:True
			filterable:True
			width:100%
		}	
		Column {
			column:riskinfo
			tooltip:Current riskinfo
			header:$bwa360_allidentitysodmatrixNLS.risk
			initially-masked:True
			sortable:True
			filterable:True
			width:100%
		}	
	}
}

/*
 * Organisation analytics page 
 * 
 */
bwa360_identitysodmatrix = Page {
	title: $bwa360_allidentitysodmatrixNLS.analytics.title
	description: $bwa360_allidentitysodmatrixNLS.identity.analytics.description
	feature:All(sod_license, bwa_controlallidentitysodmatrix, compliance_license)
	tags: "identity" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	conditional-redirect:ConditionalRedirect{ condition:True target:Page bwa360_allidentitysodmatrix_inner with uid to identityuid }
	
	/* Parameters here */
    uid = Parameter { type: String hidden: True }
}

