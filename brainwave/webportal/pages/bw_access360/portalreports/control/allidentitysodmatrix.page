/*
 * Menu page 
 * 
 */
bwa360_allidentitysodmatrix = Page {
	title: $bwa360_allidentitysodmatrixNLS.title
	feature: All ( sod_license, bwa_controlallidentitysodmatrix, compliance_license)
	conditional-redirect:
		ConditionalRedirect {
			condition: True
			target:
				Page bwa360_allidentitysodmatrix_inner with inmatrixuid to inmatrixuid unless-empty
		}
	inmatrixuid = Parameter { type: String mandatory: False }
}

/*
 * Page 
 * 
 */
bwa360_allidentitysodmatrix_inner = Page {
	title: $bwa360_allidentitysodmatrixNLS.title
	feature: All ( sod_license, bwa_controlallidentitysodmatrix, compliance_license)
	enter-event: 
		ReloadData(sodrules), 
		ReloadData(sodrules_roles), 
		ReloadData(sodrules_permission),
		Set inmatrixuid to selectedsodmatrix
	
	/* Parameters here */
    organisationuid = Parameter { type: String hidden: True }
    identityuid = Parameter { type: String hidden: True }
	minimumRiskLevel = Parameter { type: Integer hidden: True }
	inmatrixuid = Parameter { type: String mandatory: False }
	
	
	/* Variables here */
	currentRiskID = Variable {multivalued:True}
	currentRiskLevel = Variable {multivalued:True}
	currentRiskInfo = Variable {multivalued:True}
	currentSuggestedMitigation = Variable {multivalued:True}
	
	selectedKey1uid = Variable
	selectedKey2uid = Variable

	selectedactivityuid = Variable
	selectedapplicationuid = Variable

	selectedMinimumRiskLevel = Variable { initial:minimumRiskLevel }
	
	selectedsodmatrix = Variable
	
	selectedDefectCauseType = Variable { type: String }
	
	/* Datasets and records here */
	sodrules = Dataset {
		view:bwa360_identitysodproblems with 
			organisationuid to organisationuid unless-empty, 
			identityuid to identityuid unless-empty, 
			selectedMinimumRiskLevel to minimumRiskLevel unless-empty,
			selectedsodmatrix to sodmatrixuid unless-empty,
			True to rejectExceptions
	}
	
	sodrules_roles = Dataset {
		view: bwa360_identitysodproblemsviarole with 
//			organisationuid to organisationuid unless-empty, 
			identityuid to identityuid unless-empty, 
			selectedMinimumRiskLevel to minimumRiskLevel unless-empty,
			selectedsodmatrix to sodmatrixuid unless-empty,
			True to rejectExceptions
	}
	
	sodrules_permission = Dataset {
		view: bwa360_identitysodproblems_direct with 
//			organisationuid to organisationuid unless-empty, 
			identityuid to identityuid unless-empty, 
			selectedMinimumRiskLevel to minimumRiskLevel unless-empty,
			selectedsodmatrix to sodmatrixuid unless-empty,
			True to rejectExceptions
	}
	
	matrixsoddiscrepancies = Dataset {
		view: identitysodproblemsmatrix_bv
	}

	selectedsodrule = Dataset {
		view:bwa360_matrixkeypair
		includes:AndPredicate {
			SameValuePredicate(selectedKey1uid, Current key1uid)
			SameValuePredicate(selectedKey2uid, Current key2uid)
		}
	}
	
	showApplicationDetail = NamedAction (
		Dialog bwf_applicationDetailsDialog(selectedapplicationuid to inuid,
												True to inshowperjob,
												True to inshowperorg
		)
	)
	showActivityDetail = NamedAction (
		Dialog bwf_businessActivityDetailsDialog(selectedactivityuid to inuid,
												True to inshowaccounts,
												True to inshowperjob,
												True to inshowperorg,
												True to inshowsoddefects,
												True to inshowsodmodeldefects,
												identityuid to inidentityuid
		)
	)

	showIdentityDetail = NamedAction (
		Dialog bwf_identityDetailsDialog(identityuid to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowbusinessactivities,
												True to inshowdecisionhistory,
												True to inshowcontrols,
												True to inshowposition,
												True to inshowtheoretical,
												True to inshowshares,
												True to inshowoverallocated
		)
	)
	
	showControlDetail = NamedAction (
		Dialog bwf_controlDetailsDialog(currentRiskID to incontrolcode,
										identityuid to inidentityuid
		)
	)

	showDetail = NamedAction (
		BooleanCase(Eval "!selectedapplicationuid.isEmpty() && selectedactivityuid.isEmpty()") {
			when True then [
				ExecuteNamedAction showApplicationDetail
			]
			when False then [
			]
		},
		BooleanCase(Eval "!selectedactivityuid.isEmpty()") {
			when True then [
				ExecuteNamedAction showActivityDetail
			]
			when False then [
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn,GridColumn, GridColumn {width:grow}, GridColumn
		layout: Layout { grab: horizontal True vertical False hint: height 36 }
		GridRow {
			GridCell {
				Combo {
					options:Dynamic {data:matrixsoddiscrepancies text:Current matrix_displayname value:Current matrix_uid}
					allow-none: True
					variable:selectedsodmatrix
					label:$bwa360_sodmatrixNLS.matrix
				}
			}
			GridCell {
				Combo {
					variable:selectedMinimumRiskLevel
					label: $bwa360_allidentitysodmatrixNLS.minrisklevel
					allow-none:True
					options:Static {
						Option { value:4 text:$bwf_ControlLevel_NLS._4 }
						Option { value:3 text:$bwf_ControlLevel_NLS._3 }
						Option { value:2 text:$bwf_ControlLevel_NLS._2 }
						Option { value:1 text:$bwf_ControlLevel_NLS._1 }
						Option { value:0 text:$bwf_ControlLevel_NLS._0 }
					}
				}
			}
			GridCell {
				Combo {
					variable: selectedDefectCauseType
					label: $bwa360_allidentitysodmatrixNLS.defectfiltering
					allow-none: False
					options:Static {
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.all_ value:"all" }
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.role value:"role" }
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.direct value:"direct" }
					}
				}
			}
			GridCell {
			}
			GridCell {
				ButtonGroup {
					align: Right
					uniform: True
					Button {
						actions:GoTo Page bwa360_allidentitysodmatrix_innerdetails with 
											organisationuid to organisationuid unless-empty, 
											identityuid to identityuid, 
											selectedMinimumRiskLevel to minimumRiskLevel, 
											selectedDefectCauseType to defectCauseType unless-empty,
											selectedsodmatrix to inmatrixuid unless-empty,
											currentRiskID to incontrolcode,
											True to cangoback unless-empty
											save-state
						text:$bwa360_allidentitysodmatrixNLS.showall
						image: %collection_16.dashboard
						disabled:IntPredicate(Count sodrules) { when =0 then True otherwise False }
					}
					Button {
						actions:ExecuteNamedAction showControlDetail 
						text:$bwa360_allidentitysodmatrixNLS.showcontroldetails
						image: %concept_16.control
						disabled:
						StringPredicate(currentRiskID) { when IsEmpty then True otherwise False }
					}
					Button {
						actions:GoTo Page bwa360_allidentitysodmatrix_innerdetails with 
											organisationuid to organisationuid unless-empty, 
											identityuid to identityuid unless-empty, 
											selectedKey1uid to activity1uidfilter unless-empty, 
											selectedKey2uid to activity2uidfilter unless-empty, 
											selectedDefectCauseType to defectCauseType unless-empty,
											selectedsodmatrix to inmatrixuid unless-empty,
											currentRiskID to incontrolcode,
											True to cangoback 
											save-state 
						text:$bwa360_allidentitysodmatrixNLS.showcontrolresults
						image: %collection_16.magnify
						disabled:
						StringPredicate(currentRiskID) { when IsEmpty then True otherwise False }
					}
				}
			}				
		}
	}
	ConditionalGroup {
		title: $bwa360_allidentitysodmatrixNLS.identitydefectdetails
		IntCondition(Count sodrules) {
			when =0 then [
				Header {
					value:$bwa360_allidentitysodmatrixNLS.empty
				}
			]
			otherwise [
				ConditionalGroup {
					StringCondition(selectedDefectCauseType) {
						when "role" then [
							CrossTable {
								data:sodrules_roles
								layout: Layout{
									cell-width: 30px 
									cell-height: 24px 
									row-headers-max-width: 80% 
									grab:horizontal True vertical True
								}
								multi-selection:False
								cluster-sortable:True
										selection-changed-event: 
												ReloadData(selectedsodrule),
												TransferData selectedsodrule(uid, risklevel, riskinfo, suggestedmitigation) to (currentRiskID, currentRiskLevel, currentRiskInfo, currentSuggestedMitigation)
								
								columns:
								Dim {
									value:app1uid 
									label:app1displayname 
									header:$application.concept 
									header-click:selectedapplicationuid
									width: 100px
								}, 
								Dim {
									value:key1uid 
									label:key1displayname 
									header: $bwa360_allidentitysodmatrixNLS.activity 
									selection:selectedKey1uid 
									header-click:selectedactivityuid
								}
								rows:
									Dim {
										value:app2uid 
										label:app2displayname 
										header:$application.concept 
										header-click:selectedapplicationuid
										width: 100px
									}, 
									Dim {
										value:key2uid 
										label:key2displayname 
										header:$bwa360_allidentitysodmatrixNLS.activity 
										selection:selectedKey2uid 
										header-click:selectedactivityuid
									}
								column-header-click:ExecuteNamedAction showDetail
								row-header-click:ExecuteNamedAction showDetail
								cell-content:
									CellContent { 
										text:Current nbidentity  
										tooltip:Concat(Current controlcode, '\n', Current controldisplayname, '\n', $bwa360_sodmatrixNLS.risklevelprefix, Transform Current risklevel using bwf_ControlLevelMapping, '\n', $bwa360_allidentitysodmatrixNLS.nbidentitiesprb) 
										cluster-value:'X' 
										align:Center 
										styling:IntStyling(Current risklevel) { 
											when =1 then bwsod_sodmatrix_risklevel1 
											when =2 then bwsod_sodmatrix_risklevel2 
											when =3 then bwsod_sodmatrix_risklevel3 
											when =4 then bwsod_sodmatrix_risklevel4 
											when =5 then bwsod_sodmatrix_risklevel5 
											when >5 then bwsod_sodmatrix_risklevel5 
										}
								}
							}
						]
						when "all" then [
							CrossTable {
								data:sodrules
								layout: Layout{
									cell-width: 30px 
									cell-height: 24px 
									row-headers-max-width: 80% 
									grab:horizontal True vertical True
								}
								multi-selection:False
								cluster-sortable:True
										selection-changed-event: 
												ReloadData(selectedsodrule),
												TransferData selectedsodrule(uid, risklevel, riskinfo, suggestedmitigation) to (currentRiskID, currentRiskLevel, currentRiskInfo, currentSuggestedMitigation)
								
								columns:
								Dim {
									value:app1uid 
									label:app1displayname 
									header:$application.concept 
									header-click:selectedapplicationuid
									width: 100px
								}, 
								Dim {
									value:key1uid 
									label:key1displayname 
									header: $bwa360_allidentitysodmatrixNLS.activity 
									selection:selectedKey1uid 
									header-click:selectedactivityuid
								}
								rows:
									Dim {
										value:app2uid 
										label:app2displayname 
										header:$application.concept 
										header-click:selectedapplicationuid
										width: 100px
									}, 
									Dim {
										value:key2uid 
										label:key2displayname 
										header:$bwa360_allidentitysodmatrixNLS.activity 
										selection:selectedKey2uid 
										header-click:selectedactivityuid
									}
								column-header-click:ExecuteNamedAction showDetail
								row-header-click:ExecuteNamedAction showDetail
								cell-content:
									CellContent { 
										text:Current nbidentity
										tooltip:Concat(Current controlcode, '\n', Current controldisplayname, '\n', $bwa360_sodmatrixNLS.risklevelprefix, Transform Current risklevel using bwf_ControlLevelMapping, '\n', $bwa360_allidentitysodmatrixNLS.nbidentitiesprb) 
										cluster-value:'X' 
										align:Center 
										styling:IntStyling(Current risklevel) { 
											when =1 then bwsod_sodmatrix_risklevel1 
											when =2 then bwsod_sodmatrix_risklevel2 
											when =3 then bwsod_sodmatrix_risklevel3 
											when =4 then bwsod_sodmatrix_risklevel4 
											when =5 then bwsod_sodmatrix_risklevel5 
											when >5 then bwsod_sodmatrix_risklevel5 
										}
								}
							}
						]
						when "direct" then [
							CrossTable {
								data:sodrules_permission
								layout: Layout{
									cell-width: 30px 
									cell-height: 24px 
									row-headers-max-width: 80% 
									grab:horizontal True vertical True
								}
								multi-selection:False
								cluster-sortable:True
										selection-changed-event: 
												ReloadData(selectedsodrule),
												TransferData selectedsodrule(uid, risklevel, riskinfo, suggestedmitigation) to (currentRiskID, currentRiskLevel, currentRiskInfo, currentSuggestedMitigation)
								
								columns:
									Dim {
										value:app1uid 
										label:app1displayname 
										header:$application.concept 
										header-click:selectedapplicationuid
										width: 100px
									}, 
									Dim {
										value:key1uid 
										label:key1displayname 
										header: $bwa360_allidentitysodmatrixNLS.activity 
										selection:selectedKey1uid 
										header-click:selectedactivityuid
									}
								rows:
									Dim {
										value:app2uid 
										label:app2displayname 
										header:$application.concept 
										header-click:selectedapplicationuid
										width: 100px
									}, 
									Dim {
										value:key2uid 
										label:key2displayname 
										header:$bwa360_allidentitysodmatrixNLS.activity 
										selection:selectedKey2uid 
										header-click:selectedactivityuid
									}
								column-header-click:ExecuteNamedAction showDetail
								row-header-click:ExecuteNamedAction showDetail
								cell-content:
									CellContent { 
										text:Current nbidentity  
										tooltip:Concat(Current controlcode, '\n', Current controldisplayname, '\n', $bwa360_sodmatrixNLS.risklevelprefix, Transform Current risklevel using bwf_ControlLevelMapping, '\n', $bwa360_allidentitysodmatrixNLS.nbidentitiesprb) 
										cluster-value:'X' 
										align:Center 
										styling:IntStyling(Current risklevel) { 
											when =1 then bwsod_sodmatrix_risklevel1 
											when =2 then bwsod_sodmatrix_risklevel2 
											when =3 then bwsod_sodmatrix_risklevel3 
											when =4 then bwsod_sodmatrix_risklevel4 
											when =5 then bwsod_sodmatrix_risklevel5 
											when >5 then bwsod_sodmatrix_risklevel5 
										}
								}
							}
						]
					}
				}
			]
		}	
	}
}

bwa360_allidentitysodmatrix_innerdetails = Page {
	title: $bwa360_allidentitysodmatrixNLS.title
	enter-event:
		Set minimumRiskLevel to selectedMinimumRiskLevel, 
		Set defectCauseType to selectedDefectCauseType,
		Set inmatrixuid to selectedsodmatrix
	feature:All(sod_license, compliance_license)
	
	
	/* Parameters here */
    organisationuid = Parameter { type: String hidden: True }
    identityuid = Parameter { type: String hidden: True }
	cangoback = Parameter { type: Boolean default:False hidden: True }
	activity1uidfilter = Parameter { type: String hidden: True }
	activity2uidfilter = Parameter { type: String hidden: True }
	minimumRiskLevel = Parameter { type: Integer hidden: True }
	inmatrixuid = Parameter { type: String mandatory: False }
	
	incontrolcode = Parameter { type: String }
	defectCauseType = Parameter { type: String }
	
	/* Variables here */
	currentRiskID = Variable {multivalued:True}
	currentRiskLevel = Variable {multivalued:True}
	currentRiskInfo = Variable {multivalued:True}
	currentSuggestedMitigation = Variable {multivalued:True}
	
	selectedKey1uid = Variable
	selectedKey2uid = Variable

	selectedactivityuid = Variable
	selectedapplicationuid = Variable

	selectedidentity = Variable
	selectedcontrol = Variable
	selectedcontroltagtype = Variable
	selectedcontroldisplayname = Variable
	
	selectedControlUid = Variable
	selectedControlName = Variable
	allcontrols = Variable { multivalued:True }
	
	selectedMinimumRiskLevel = Variable
	selectedsodmatrix = Variable
	selectedDefectCauseType = Variable
	
	selectedKeys = Variable { multivalued: True }
	selectedIdentities = Variable { multivalued: True }
	selectedControlCodes = Variable { multivalued: True }
	selectedControlResulttypes = Variable { multivalued: True }
	
	defectaccountUids = Variable { multivalued: True }
		
	/* Datasets and records here */
	sodrules = Dataset { // used by the chart
		view:bwa360_identitysodproblemspareto with 
			organisationuid to organisationuid unless-empty, 
			identityuid to identityuid unless-empty, 
			selectedMinimumRiskLevel to minimumRiskLevel, 
			$bwa360_allidentitysodmatrixNLS.runningpercent to runningpercentlabel,
			selectedsodmatrix to sodmatrixuid unless-empty,
			True to rejectExceptions
		disabled: StringPredicate(activity1uidfilter) { when IsEmpty then False otherwise True }
	}
	
	soddetails = Dataset {
		view:bwa360_identitysodproblemslist_bv with organisationuid to organisationuid unless-empty, 
													identityuid to identityuid unless-empty, 
													selectedControlUid to controlcode unless-empty, 
													selectedMinimumRiskLevel to minimumRiskLevel,
													activity1uidfilter to activity1uidfilter unless-empty, 
													activity2uidfilter to activity2uidfilter unless-empty,
													selectedsodmatrix to sodmatrixuid unless-empty,
													selectedDefectCauseType to defectcausetype unless-empty,
													True to rejectExceptions
	}

	selectedsodrule = Dataset {
		view:bwa360_matrixkeypair
		includes:AndPredicate {
			SameValuePredicate(selectedKey1uid, Current key1uid)
			SameValuePredicate(selectedKey2uid, Current key2uid)
		}
	}
	
	currentControl = Record {
		view: bwf_controldetails with
			incontrolcode to controlcode
		disabled:
			StringPredicate ( incontrolcode ) {
				when IsEmpty then True
			}
	}
	
	defectaccounts = Dataset {
		view: bwsod_identitysodproblemaccountlist_bv with
			selectedIdentities to identityuid, 
			currentControl.controlcode to controlcode, 
			currentControl.controltagtype to controltagtype
	}
	
	matrixsoddiscrepancies = Dataset {
		view: identitysodproblemsmatrix_bv
	}
	
	showApplicationDetail = NamedAction (
		Dialog bwf_applicationDetailsDialog(selectedapplicationuid to inuid,
												True to inshowperjob,
												True to inshowperorg
		)
	)
	showActivityDetail = NamedAction (
		Dialog bwf_businessActivityDetailsDialog(selectedactivityuid to inuid,
												True to inshowaccounts,
												True to inshowperjob,
												True to inshowperorg,
												True to inshowsoddefects,
												True to inshowsodmodeldefects,
												selectedidentity to inidentityuid
		)
	)

	showIdentityDetail = NamedAction (
		Dialog bwf_identityDetailsDialog(selectedidentity to inuid,
												True to inshowaccounts,
												True to inshowapplications,
												True to inshowbusinessactivities,
												True to inshowdecisionhistory,
												True to inshowcontrols,
												True to inshowposition,
												True to inshowtheoretical,
												True to inshowshares,
												True to inshowoverallocated
		)
	)
	
	showControlDetail = NamedAction (
		Dialog bwf_controlDetailsDialog(selectedcontrol to incontrolcode,
										selectedidentity to inidentityuid
		)
	)

	showDetail = NamedAction (
		BooleanCase(Eval "!selectedapplicationuid.isEmpty() && selectedactivityuid.isEmpty()") {
			when True then [
				ExecuteNamedAction showApplicationDetail
			]
			when False then [
			]
		},
		BooleanCase(Eval "!selectedactivityuid.isEmpty()") {
			when True then [
				ExecuteNamedAction showActivityDetail
			]
			when False then [
			]
		}
	)

	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn, GridColumn {width: 300px}, GridColumn {width:grow}
		layout: Layout { grab: horizontal True vertical False }
		GridRow {
			GridCell {
				Combo {
					options:Dynamic {data:matrixsoddiscrepancies text:Current matrix_displayname value:Current matrix_uid}
					allow-none: True
					hidden:StringPredicate(activity1uidfilter) { when IsEmpty then False otherwise True }
					variable:selectedsodmatrix
					label:$bwa360_sodmatrixNLS.matrix
				}
			}
			GridCell {
				Combo {
					variable:selectedMinimumRiskLevel
					label: $bwa360_allidentitysodmatrixNLS.minrisklevel 
					allow-none:True
					hidden:StringPredicate(activity1uidfilter) { when IsEmpty then False otherwise True }
					modify-event:Unset selectedControlUid, Unset selectedControlName
					options:Static {
						Option { value:4 text:$bwf_ControlLevel_NLS._4 }
						Option { value:3 text:$bwf_ControlLevel_NLS._3 }
						Option { value:2 text:$bwf_ControlLevel_NLS._2 }
						Option { value:1 text:$bwf_ControlLevel_NLS._1 }
						Option { value:0 text:$bwf_ControlLevel_NLS._0 }
					}
				}
			}
			GridCell {
				Combo {
					variable: selectedDefectCauseType
					label: $bwa360_allidentitysodmatrixNLS.defectfiltering
					allow-none: False
					options:Static {
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.all_ value:"all" }
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.role value:"role" }
						Option { text:$bwa360_allidentitysodmatrixNLS.defectfiltering.direct value:"direct" }
					}
				}
			}
			GridCell {
				Edit {
					label: $bwa360_allidentitysodmatrixNLS.filtercontrol
					variable:selectedControlName
					tooltip:selectedControlName
					disabled:True
					hidden:StringPredicate(activity1uidfilter) { when IsEmpty then False otherwise True }
					commands: Commands {
						Command {
							actions:
								IntCase(SizeOf allcontrols) {
									when =0 then [
										TransferData soddetails(controlcode) to (allcontrols),
										MultivaluedDistinct allcontrols
									]
								},
								Dialog bwa360_allidentitysodmatrix_controlpicker(allcontrols to controlcodes, selectedControlUid from outControlCode, selectedControlName from outControlName)
							icon:%concept_16.control
						}										
						Command {
							actions:
								Unset selectedControlUid,
								Unset selectedControlName
							icon:%collection_16.delete
						}										
					}
				}
			}
			GridCell {
			
			}
		}
	}

	IncludeHTMLWidget {
		layout: Layout { grab: horizontal True vertical False hint: height 150 }
		template: barChart
		datasets: sodrules ( controldisplayname, controlcode, nbidentity, description, color ) to chartdata ( label, code , count , description, color)
		hidden: StringPredicate(activity1uidfilter) { when IsEmpty then False otherwise True }
		bindings:
			value-of $bwa360_allidentitysodmatrixNLS.paretotitle to title, 
			value-of $bwa360_allidentitysodmatrixNLS.nbofidentities to ylabel,
			value-of False to showyAxesGrid,
			value-of False to maintainAspectRatio,
			value-of True to showyAxesGrid,
			value-of True to beginAtZero,
			value-of False to xAxesdisplay,
			value-of True to yAxesdisplay
		widget-events: {
			when onclick then [
				Set Current code to selectedControlUid,
				Set Current label to selectedControlName
			]
		}
	}
	
	Table {
		data:soddetails
		layout: Layout { grab: horizontal True vertical True }
		show-count:True
		show-filter:True
		configurable:True
		double-click:Dialog bwsod_identitysodproblemrootcauseanalysisDialog (selectedidentity to identityuid, selectedcontrol to controlcode, selectedcontroltagtype to controltagtype) 
		checkboxes: key to selectedKeys and ( identityuid to selectedIdentities, controlcode to selectedControlCodes, controlresulttype to selectedControlResulttypes)
		Column {
			column:identityuid
			hidden:True
			selection:selectedidentity
		}
		Column {
			column:identityhrcode
			header:$identity.hrcode
			sortable:True
			filterable:True
			width:100px
			actions:ExecuteNamedAction showIdentityDetail
		}
		Column {
			column:identityfullname
			header:$identity.fullname
			sortable:True
			filterable:True
			width:100%
			actions:ExecuteNamedAction showIdentityDetail
		}
		Column {
			column:identitymail
			header:$identity.mail
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
			actions:ExecuteNamedAction showIdentityDetail
		}
		Column {
			column:identityinternal
			header:$identity.internal
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
		}
		Column {
			column:identityjoborg
			header:$identity.joborg
			tooltip:Current identityjoborg
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
		}


		Column {
			column:risklevel
			text:Transform Current risklevel using bwf_ControlLevelMapping
			header:$bwa360_allidentitysodmatrixNLS.risklevel
			width:128px
			sortable:True
			filterable:True
			image:TemplateImageSelection(Current risklevel) using bwf_controllevel
		}
		Column {
			column:controlcode
			header:$bwa360_allidentitysodmatrixNLS.controlcode
			sortable:True
			filterable:True
			initially-masked:True
			selection:selectedcontrol
			actions:ExecuteNamedAction showControlDetail
			
		}
		Column {
			column:controltagtype
//			header:$bwa360_allidentitysodmatrixNLS.controltype
			sortable:True
			filterable:True
			initially-masked:True
			selection:selectedcontroltagtype
			actions:ExecuteNamedAction showControlDetail
		}
		Column {
			column: controlresulttype
			hidden: True
		}
		Column {
			column:controldisplayname
			tooltip:Current controldisplayname
			header:$bwa360_allidentitysodmatrixNLS.control
			sortable:True
			filterable:True
			width:100%
			selection:selectedcontroldisplayname
			actions:ExecuteNamedAction showControlDetail
		}
		Column {
			column:controldescription
			tooltip:Current controldescription
			header:$bwa360_allidentitysodmatrixNLS.controldescription
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
		}
		Column {
			column:riskinfo
			tooltip:Current riskinfo
			header:$bwa360_allidentitysodmatrixNLS.risk
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
		}
		Column {
			column:suggestedmitigation
			tooltip:Current suggestedmitigation
			header:$bwa360_allidentitysodmatrixNLS.remediation
			sortable:True
			filterable:True
			initially-masked:True
			width:100%
		}

		Column {
			column:key1code
			header:$bwa360_allidentitysodmatrixNLS.firstactivitycode
			sortable:True
			filterable:True
			initially-masked:True
			actions:Set Current key1uid to selectedactivityuid, ExecuteNamedAction showActivityDetail
		}
		Column {
			column:key1displayname
			tooltip:Current key1displayname
			header:$bwa360_allidentitysodmatrixNLS.firstactivity
			sortable:True
			filterable:True
			width:100%
			actions:Set Current key1uid to selectedactivityuid, ExecuteNamedAction showActivityDetail
		}

		Column {
			column:key2code
			header:$bwa360_allidentitysodmatrixNLS.secondactivitycode
			sortable:True
			filterable:True
			initially-masked:True
			actions:Set Current key2uid to selectedactivityuid, ExecuteNamedAction showActivityDetail
		}
		Column {
			column:key2displayname
			tooltip:Current key2displayname
			sortable:True
			filterable:True
			header:$bwa360_allidentitysodmatrixNLS.secondactivity
			width:100%
			actions:Set Current key2uid to selectedactivityuid, ExecuteNamedAction showActivityDetail
		}
		Column {
			column: defect_type 
			initially-masked: True
			sortable: True
			header: "Defect type"
			width: 100%
		}
	}
	Grid {
		columns: GridColumn, GridColumn {width: grow}, GridColumn
		layout: Layout {grab: horizontal True vertical False}
		GridRow {
			GridCell {
				ButtonGroup {
					uniform: True
					align: Left
					Button {
						actions:GoTo BackInHistoryTruncate  
						text:$bwa360_allidentitysodmatrixNLS.back
						image:%browsing_16.back
						hidden:Not BooleanPredicate(cangoback)			
					}
				}
			}
			GridCell {
			
			}
			GridCell {
				ButtonGroup {
					align: Right
					uniform: True
					Button {
						actions:
							ReloadData(defectaccounts),
							TransferData defectaccounts(accountuid) to (defectaccountUids),
							Dialog bw_iasremediation_accounts_create (
								defectaccountUids to accountUids,
								Concat("SoD defect on the account for the control ", currentControl.controldisplayname) to comment,
								"SoD-control" to type
							),
							Unset selectedKeys
						text: $detailspages.remediation
						tooltip: $detailspages.remediationTt
						image: %collection_16.gear
						feature: iasreview_license
						hidden:
							StringPredicate(activity1uidfilter) { 
								when Not IsEmpty then False otherwise True 
							}
						disabled:
							StringPredicate ( selectedIdentities ) {
								when IsEmpty then True
							}
					}
					Button {
						actions: 
							Dialog bwsod_identitysodexceptionscreateDialog(
								selectedIdentities to identityuids, 
								selectedControlCodes to controlcodes, 
								selectedControlResulttypes to controlresulttypes
							),
							Unset selectedKeys,
							ReloadData(soddetails),
							ReloadData(sodrules)
						text: $bwsod_identitysodexceptionsNLS.setexception
						tooltip: $bwa360_allidentitysodmatrixNLS.setexceptiontooltip
						image: %status_16.add 
						disabled:
							StringPredicate ( selectedIdentities ) {
								when IsEmpty then True
							}
					}
					Button {
						actions: Dialog bwsod_identitysodproblemrootcauseanalysisDialog(selectedidentity to identityuid, selectedcontrol to controlcode, selectedcontroltagtype to controltagtype) 
						text:$bwa360_allidentitysodmatrixNLS.rootcause
						image:%collection_16.bulb
						disabled:StringPredicate(selectedidentity) { when IsEmpty then True otherwise False }				
					}
				}
			}
		}
	}
}
