bwsod_designer_importfileService = EventService {
	javascript-file:"/webportal/pages/bw_access360/portalreports/control/soddesigner.javascript"
	javascript-method:parseFile
	
	filename = Input { mandatory: True }
	matrixcode = Output{ type:String multivalued:True }
	permission1 = Output{ type:String multivalued:True }
	application1 = Output{ type:String multivalued:True }
	permission2 = Output{ type:String multivalued:True }
	application2 = Output{ type:String multivalued:True }
	matrixenabled = Output { type:Boolean multivalued:True }
	risklevels = Output{ type:String multivalued:True }
}

bwsod_designer_importfileFragment = PageFragment {
	
	importedmatrixcode = Variable { type:String multivalued:True }
	permission1code = Variable { type:String multivalued:True }
	application1code = Variable { type:String multivalued:True }
	permission2code = Variable { type:String multivalued:True }
	application2code = Variable { type:String multivalued:True }
	importedmatrixenabled = Variable { type:Boolean multivalued:True }
	importedrisklevels = Variable { type:Integer multivalued:True }
	
	perm1uid = Variable { type:String multivalued:True }
	perm2uid = Variable { type:String multivalued:True }
	
	matrixCode = Variable { type:String multivalued:False }
	matrixEnabled = Variable { type:Boolean multivalued:False }
	toxicKeys = Variable { type:String multivalued:True }
	riskLevels = Variable { type:Integer multivalued:True }
	permissions = Variable { type:String multivalued:True }
	applications = Variable { type:String multivalued:True }
	applicationNames = Variable { type:String multivalued:True }
	
	uploadedFilename = Variable { type:String }
	uploadStatus = Variable { type:String }
	isUploadedMatrix = Variable { type:Boolean }
	disableDataset = Variable { type:Boolean initial:True }
	
	upload_dataset = Dataset {
		view: bwsod_designer_loaddataset with
			importedmatrixcode to matrixcode, 
			permission1code to permission1code, 
			application1code to application1code, 
			permission2code to permission2code, 
			application2code to application2code,
			importedmatrixenabled to matrixenabled,
			importedrisklevels to risklevels
		disabled: BooleanPredicate(disableDataset) 
	}
	
		
	applicationDetails = Dataset {
		view: bwsod_designer_applicationdetails with 
			application1code to applicationcode1 unless-empty,
			application2code to applicationcode2 unless-empty
		disabled: BooleanPredicate(disableDataset)
	}
	
	FileUpload {
		uploaded-filename: uploadedFilename
		hide-filename: True
		upload-status: uploadStatus
		label: $bwsod_designerNLS.importMatrix_long
		upload-complete-event:
			Call bwsod_designer_importfileService(
				uploadedFilename to filename,
				importedmatrixcode from matrixcode,
				permission1code from permission1,
				application1code from application1,
				permission2code from permission2,
				application2code from application2,
				importedmatrixenabled from matrixenabled,
				importedrisklevels from risklevels
			),
			Flash $bwsod_designerNLS.fileuploaded,
			Set False to disableDataset,
			ReloadData(upload_dataset),
			ReloadData(applicationDetails),
			TransferData upload_dataset(toxicKeys, risklevels, perm1_permissionuid, perm2_permissionuid) to (toxicKeys, riskLevels, perm1uid, perm2uid),
			MultivaluedAdd perm1uid to permissions,
			MultivaluedAdd perm2uid to permissions,
			MultivaluedDistinct permissions,
			TransferData applicationDetails(uid, displayname) to (applications, applicationNames),
			Set importedmatrixcode to matrixCode,
			Set importedmatrixenabled to matrixEnabled,
			Set True to isUploadedMatrix
		upload-failed-event:
			Flash $bwsod_designerNLS.problemoccured
	}
}

bwsod_designer_crosstableDialog = Dialog {
	title: $bwsod_designerNLS.crosstable
	height: 900
	width: 1200
	
	buttons: CancelButton
	
	toxicKeys = Variable { multivalued: True }
	riskLevels = Variable { multivalued: True }
	
	toxicKeys = Dataset {
		view: bwsod_designer_toxic_keys with toxicKeys to toxickeys, True to duplicatekeys, riskLevels to risklevels
	}
	
	CrossTable {
		data: toxicKeys
		multi-selection:True		
		cluster-sortable:True
		layout:Layout { grab:horizontal True vertical True cell-height:24px cell-width:24px}
		columns:
			Dim {
				value:perm1_applicationuid 
				label:perm1_applicationdisplayname 
				header:$application.concept 
			}, 
			Dim {
				value:perm1_permissionuid 
				label:perm1_permissiondisplayname
				header:$bwa360_sodmatrixNLS.activity 
			}
		rows:
			Dim {
				value:perm2_applicationuid 
				label:perm2_applicationdisplayname 
				header:$application.concept 
			}, 
			Dim {
				value:perm2_permissionuid 
				label:perm2_permissiondisplayname
				header:$bwa360_sodmatrixNLS.activity 
			}
		cell-content:
			CellContent {
				text: Current risklevels
				align:Center 
				styling:IntStyling(Current risklevels) {
					when =1 then bwsod_sodmatrix_risklevel1 
					when =2 then bwsod_sodmatrix_risklevel2 
					when =3 then bwsod_sodmatrix_risklevel3 
					when =4 then bwsod_sodmatrix_risklevel4 
					when =5 then bwsod_sodmatrix_risklevel5 
					when >5 then bwsod_sodmatrix_risklevel5 
			  	}
			}
	}
}

bwsod_designer_loadmatrixDialog = Dialog {
	title: $bwsod_designerNLS.loadmatrix
	height: 200
	width: 400
	
	buttons: [
		ActionButton {
			text: $bwsod_designerNLS.loadmatrix_short
			actions: 
				BooleanCase(isUploadedMatrix) {
					when True then [
					
					]
					when False then [
						TransferData matrixApplications(app1uid, app2uid) to (app1uid, app2uid),
						MultivaluedAdd app1uid to applications1,
						MultivaluedAdd app2uid to applications2,
						MultivaluedDistinct applications1,
						MultivaluedDistinct applications2,
						TransferData matrixFullDetails(toxicKeys, risklevels, permission1uid, permission2uid) to (toxicKeys, riskLevels, perm1uid, perm2uid),
						MultivaluedAdd perm1uid to permissions,
						MultivaluedAdd perm2uid to permissions,
						MultivaluedDistinct permissions,
						ReloadData(application1Details),
						ReloadData(application2Details),
						TransferData application1Details(displayname) to (application1Names),
						TransferData application2Details(displayname) to (application2Names),
						Set matrixDetails.matrix_enabled to matrixEnabled,
						Set matrixDetails.matrix_code to matrixCode
					]
				}
			close: True
		}
		CancelButton
	]
	
	selectedMatrixCode = Variable {type: String}
	
	matrixCode = Variable {type: String}
	matrixEnabled = Variable {type: Boolean}
	
	app1uid = Variable {type: String multivalued: True}
	app2uid = Variable {type: String multivalued: True}
	perm1uid = Variable {type: String multivalued: True}
	perm2uid = Variable {type: String multivalued: True}
	
	applications = Variable {type: String multivalued: True}
	applications1 = Variable {type: String multivalued: True}
	applications2 = Variable {type: String multivalued: True}
	applicationNames = Variable {type: String multivalued: True}
	application1Names = Variable {type: String multivalued: True}
	application2Names = Variable {type: String multivalued: True}
	permissions = Variable {type: String multivalued: True}
	toxicKeys = Variable {type: String multivalued: True}
	riskLevels = Variable {type: String multivalued: True}
	
	isUploadedMatrix = Variable { type: Boolean }
	
	buildin_matrix = Dataset {
		view: bwsod_designer_matrix
	}
	
	matrixApplications = Dataset {
		view: bwsod_designer_matrix_applications with selectedMatrixCode to matrix_code unless-empty
		disabled: StringPredicate(selectedMatrixCode) { when IsEmpty then True otherwise False}
	}
	
	matrixDetails = Record {
		view: bwsod_designer_matrix with selectedMatrixCode to matrix_code unless-empty
		disabled: StringPredicate(selectedMatrixCode) { when IsEmpty then True otherwise False}
	}
	
	matrixFullDetails = Dataset {
		view: bwsod_designer_matrix_fulldetails with selectedMatrixCode to matrix_code unless-empty
		disabled: StringPredicate(selectedMatrixCode) { when IsEmpty then True otherwise False}
	}
	
	application1Details = Dataset {
		view: bwsod_designer_applicationdetails with applications1 to applicationuids unless-empty
		disabled: StringPredicate(applications1){ when IsEmpty then True otherwise False }
	}
	
	application2Details = Dataset {
		view: bwsod_designer_applicationdetails with applications2 to applicationuids unless-empty
		disabled: StringPredicate(applications2){ when IsEmpty then True otherwise False }
	}
	
	Combo {
		label: $bwsod_designerNLS.loadmatrix_long
		variable: selectedMatrixCode
		allow-none: True
		disabled: BooleanPredicate(isUploadedMatrix)
		options: Dynamic {
			data: buildin_matrix
			text: Current matrix_code
			value: Current matrix_code
			sort: matrix_code
		}
	}
	
	IncludeFragment {
		fragment: bwsod_designer_importfileFragment with 
			isUploadedMatrix binds-to isUploadedMatrix,
			matrixCode binds-to matrixCode,
			matrixEnabled binds-to matrixEnabled,
			riskLevels binds-to riskLevels,
			toxicKeys binds-to toxicKeys,
			permissions binds-to permissions,
			applications binds-to applications,
			applicationNames binds-to applicationNames
	}
}

