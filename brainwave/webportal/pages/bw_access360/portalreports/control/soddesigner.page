bwsod_designer = Page {
	title: $bwsod_designerNLS.title
	feature:All(sod_license, bwa_controlsodmatrix)

	// Filter on application/permission via picker
	pickedApplications1 = Variable { type: String multivalued: True}
	pickedApplications2 = Variable { type: String multivalued: True}
	pickedApplicationsDisplayname1 = Variable { type: String multivalued: True}
	pickedApplicationsDisplayname2 = Variable { type: String multivalued: True}
	pickedApplicationContent1 = Variable { type: String }
	pickedApplicationContent2 = Variable { type: String }
	pickedPermissions1 = Variable { type: String multivalued: True}
	pickedPermissions2 = Variable { type: String multivalued: True}
	
	// Selected values in the page
	selectedPermissions1 =  Variable { type: String multivalued: True }
	selectedPermissions2 =  Variable { type: String multivalued: True }
	selectedRiskLevel =  Variable { type: Integer multivalued: False initial: 1 }
	selectedToxicKeys = Variable { type: String multivalued: True }
	matrixCode = Variable { type: String }
	matrixEnabled = Variable { type: Boolean }
	
	// Pair of variables representing the matrix
	toxicKeys = Variable { type: String multivalued: True } // Permission1 + "$$$" + Permission2
	riskLevels = Variable { type: String multivalued: True }
	
	permissions = Variable { type: String multivalued: True }
	iteratedPermission = Variable { type: String } // Used in the multivaluedIterate as an intermediate
	
	permissions1 = Dataset {
		view: bwsod_designer_pair_permissions with
			pickedApplications1 to applicationuids unless-empty, 
			pickedPermissions1 to permissionuids unless-empty
		disabled: StringPredicate(pickedApplications1) { when IsEmpty then True otherwise False }
	}
	
	permissions2 = Dataset {
		view: bwsod_designer_pair_permissions with
			pickedApplications2 to applicationuids unless-empty, 
			pickedPermissions2 to permissionuids unless-empty
		disabled: StringPredicate(pickedApplications2) { when IsEmpty then True otherwise False }
	}
	
	toxicKeys = Dataset {
		view: bwsod_designer_toxic_keys with toxicKeys to toxickeys, riskLevels to risklevels, False to duplicatekeys, permissions to permissions
		disabled: StringPredicate(toxicKeys) { when IsEmpty then True otherwise False }
	}
	
	addToxicPair = NamedAction(
		MultivaluedAdd selectedPermissions1 to permissions,
		MultivaluedAdd selectedPermissions2 to permissions,
		MultivaluedDistinct permissions,
		MultivaluedIterate(selectedPermissions1 as permission1) [
			Set Current permission1 to iteratedPermission,
			MultivaluedIterate (selectedPermissions2 as permission2) [
				BooleanCase using SameValuePredicate(Current permission2, iteratedPermission) in {
					when True then [
					
					]
					when False then [
//						Remove the toxic pair if it exists to replace it
						MultivaluedRemove all Concat(Current permission2, "$$$", iteratedPermission) from toxicKeys and (riskLevels),
						MultivaluedRemove all Concat(iteratedPermission, "$$$", Current permission2) from toxicKeys and (riskLevels),
//						Add the key in the list, as well as the risklevel
						MultivaluedAdd Concat(iteratedPermission, "$$$", Current permission2) to toxicKeys,
						MultivaluedAdd selectedRiskLevel to riskLevels
					]
				}
			]
		],
		ReloadData(toxicKeys)
	)
	
	removeToxicPair = NamedAction(
		MultivaluedRemove all selectedToxicKeys from toxicKeys and (riskLevels),
		Unset selectedToxicKeys,
		ReloadData(toxicKeys)
	)
	
	Splitter {
		disposition: Horizontal
		size: 50%
		Group {
			Grid {
				columns: GridColumn { width: grow }, GridColumn { width: grow }
				layout: Layout { grab: horizontal True vertical True }
				GridRow {
					height: grow
					GridCell {
						Group {
							title: $bwsod_designerNLS.permissions1
							Group {
								layout: Layout { grab: horizontal True vertical False }
								Text {
									value: pickedApplicationContent1
									label: $bwsod_designerNLS.applicationpicker
									tooltip: pickedApplicationContent1
									layout: Layout { grab: horizontal True vertical False }
									compact: False
									commands:
										Commands {
											Command {
												actions:
													Dialog applicationMultiPickerWithPermission( 
														pickedApplications1 to outUid unless-empty,
														pickedApplicationsDisplayname1 to outDisplayname unless-empty, 
														pickedPermissions1 to outUidPermission unless-empty,
														pickedApplications1 from outUid, 
														pickedApplicationsDisplayname1 from outDisplayname, 
														pickedPermissions1 from outUidPermission),
													Set Join pickedApplicationsDisplayname1 using ", " to pickedApplicationContent1,
													ReloadData(permissions1)
												icon:%concept_16.application
											}
											Command {
												actions:
													Unset pickedApplications1,
													Unset pickedApplicationsDisplayname1,
													Unset pickedApplicationContent1
												icon:%collection_16.delete
											}										
										}
								}
							}
							Table {
								data: permissions1
								layout: Layout { grab: horizontal True vertical True }
								checkboxes: permissionuid to selectedPermissions1
								configurable: True
								show-filter: True
								show-count: True
								commands: Commands {
									orientation: Horizontal
									position: Above
									presentation: Link
									Command {
										actions: Unset selectedPermissions1
										text: $bwsod_designerNLS.uncheckall
										icon: %collection_16.refresh_round
									}
								}
								Column {
									column: permissionuid
									hidden: True
								}
								Column {
									column: permissioncode
									header: $permission.concept
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: applicationcode
									header: $application.concept
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: nbaccount
									header: $fragmentApplicationPermissionsNLS.nbaccount
									sortable: True
									filterable: True
									width: 100%
									initially-masked: True
								}
							}
						}
					}
					GridCell {
						Group {
							title: $bwsod_designerNLS.permissions2
							Group {
								layout: Layout { grab: horizontal True vertical False }
								Text {
									value: pickedApplicationContent2
									label: $bwsod_designerNLS.applicationpicker
									tooltip: pickedApplicationContent2
									layout: Layout { grab: horizontal True vertical False }
									compact: False
									commands:
										Commands {
											Command {
												actions:
													Dialog applicationMultiPickerWithPermission( 
														pickedApplications2 to outUid unless-empty,
														pickedApplicationsDisplayname2 to outDisplayname unless-empty, 
														pickedPermissions2 to outUidPermission unless-empty,
														pickedApplications2 from outUid, 
														pickedApplicationsDisplayname2 from outDisplayname, 
														pickedPermissions2 from outUidPermission),
													Set Join pickedApplicationsDisplayname2 using ", " to pickedApplicationContent2,
													ReloadData(permissions2)
												icon:%concept_16.application
											}
											Command {
												actions:
													Unset pickedApplications2,
													Unset pickedApplicationsDisplayname2,
													Unset pickedApplicationContent2
												icon:%collection_16.delete
											}										
										}
								}
							}
							Table {
								data: permissions2
								layout: Layout { grab: horizontal True vertical True }
								checkboxes: permissionuid to selectedPermissions2
								configurable: True
								show-filter: True
								show-count: True
								commands: Commands {
									orientation: Horizontal
									position: Above
									presentation: Link
									Command {
										actions: Unset selectedPermissions2
										text: $bwsod_designerNLS.uncheckall
										icon: %collection_16.refresh_round
									}
								}
								Column {
									column: permissionuid
									hidden: True
								}
								Column {
									column: permissioncode
									header: $permission.concept
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: applicationcode
									header: $application.concept
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: nbaccount
									header: $fragmentApplicationPermissionsNLS.nbaccount
									sortable: True
									filterable: True
									width: 100%
									initially-masked: True
								}
							}
						}
					}
				}
				GridRow {
					GridCell {
						span: 2
						Combo {
							variable: selectedRiskLevel
							label: $bwsod_designerNLS.risklevel
							options: Static {
								Option { text: $bwf_ControlLevel_NLS._1 value: 1 }
								Option { text: $bwf_ControlLevel_NLS._2 value: 2 }
								Option { text: $bwf_ControlLevel_NLS._3 value: 3 }
								Option { text: $bwf_ControlLevel_NLS._4 value: 4 }
							}
						}
						Button {
							actions: ExecuteNamedAction addToxicPair
							text: $bwsod_designerNLS.addpairs
							image: %collection_16.plus
						}
					}
				}
			}
		}
		Group {
			Grid {
				columns: GridColumn { width: grow }
				layout: Layout { grab: horizontal True vertical True }
				GridRow {
					GridCell {
						Edit {
							label: $bwsod_designerNLS.matrixname
							variable: matrixCode
							not-empty: True
						}
						Checkbox {
							label: $bwsod_designerNLS.matrixenabled
							variable: matrixEnabled
						}
					}
				}
				GridRow {
					height: grow
					GridCell {
						Group {
							title: $bwsod_designerNLS.toxicpairs
							Table {
								data: toxicKeys
								layout: Layout { grab: horizontal True vertical True }
								checkboxes: toxicKey to selectedToxicKeys
								configurable: True
								show-filter: False
								show-count: True
								Column {
									column:risklevels
									text:Transform Current risklevels using bwf_ControlLevelMapping
									header: $bwsod_designerNLS.risklevel
									width: 100%
									sortable:True
									filterable:True
									image:TemplateImageSelection(Current risklevels) using bwf_controllevel
								}
								Column {
									column: perm1_permissioncode
									header: Concat($permission.concept, " 1")
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: perm2_permissioncode
									header: Concat($permission.concept, " 2")
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: perm1_applicationcode
									header: Concat($application.concept, " 1")
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: perm2_applicationcode
									header: Concat($application.concept, " 2")
									sortable: True
									filterable: True
									width: 100%
								}
								Column {
									column: toxicKey
									initially-masked: True
									sortable: True
									filterable: True
									width: 100%
								}
							}
						}
					}
				}
				GridRow {
					GridCell {
						Button {
							actions: ExecuteNamedAction removeToxicPair
							text: $bwsod_designerNLS.removepairs
							image: %collection_16.minus
						}
					}
				}
			}
		}
	}
	ButtonGroup {
		layout: Layout { grab: horizontal True vertical False }
		align: Right
		uniform: True
		Button {
			text: $bwsod_designerNLS.crosstable
			tooltip: $bwsod_designerNLS.crosstable_tooltip
			image: %report_16.pivot_table
			actions: Dialog bwsod_designer_crosstableDialog(
				toxicKeys to toxicKeys,
				riskLevels to riskLevels 
			)
		}
		Button {
			text: $bwsod_designerNLS.loadmatrix
			image: %report_16.download
			actions: Dialog bwsod_designer_loadmatrixDialog(
				matrixCode from matrixCode,
				matrixEnabled from matrixEnabled,
				pickedApplications1 from applications1, 
				pickedApplicationsDisplayname1 from application1Names,
				pickedApplications2 from applications2, 
				pickedApplicationsDisplayname2 from application2Names,
				permissions from permissions,
				toxicKeys from toxicKeys,
				riskLevels from riskLevels),
				Set Join pickedApplicationsDisplayname1 using ", " to pickedApplicationContent1,
				Set Join pickedApplicationsDisplayname2 using ", " to pickedApplicationContent2
		}
		Button {
			text: $bwsod_designerNLS.savematrix
			image: %collection_16.checked
			actions: Dialog bwsod_designer_savematrixDialog(
				pickedApplications1 to applications,
				toxicKeys to toxicKeys, 
				riskLevels to riskLevels,
				matrixCode to matrixCode, 
				matrixEnabled to matrixEnabled)
			disabled: StringPredicate(matrixCode) { when IsEmpty then True otherwise False }
		}
		Button {
			text: $bwsod_designerNLS.exportmatrix
			image: %report_16.upload
			actions: Dialog bwsod_designer_exportmatrixDialog
		}
		Button {
			text: $bwsod_designerNLS.deletematrix
			image: %collection_16.delete
			actions: Dialog bwsod_designer_deletematrixDialog
		}
	}
}