/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
access360r_cmdbci_accountgrouprepositoryanalytics360NLS = NLS {
	title [en "Repositories and Servers Direct Group Membership Self-service analytics" fr "Analytics en self-service des membres de groupes directs sur les référentiels et les serveurs"]
	dyntitle [en "{0} Repositories and Servers Accounts Group Membership self-service analytics" fr "Analytics en self-service des membres de groupes directs sur les référentiels et les serveurs pour {0}"]
	empty [en "{0} does not contain any group membership" fr "{0} ne contient pas de membres de groupes"]
	description [
		en "This report presents the direct accounts groups memberships of the CI element repositories and servers resources in the form of a dynamic pivot table where it is possible to select the analysis dimensions. Only the active accounts are taken into account. It is possible to identify only the changes made since a given date."
		fr "Ce rapport présente les membres de groupes directs sur les référentiels et les serveurs de l''élément CI sous la forme d'un tableau croisé dynamique où il est possible de sélectionner les dimensions d'analyse. Seuls les comptes actifs sont pris en compte. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée."
		]
	access [en "Direct Group Membership" fr "Membre de groupe direct"]
	directonly [en "Direct Group Membership Only" fr "Membres de groupes directs seulement"]
}

access360r_cmdbci_accountgrouprepositoryanalytics = Page {
	title: $access360r_cmdbci_accountgrouprepositoryanalytics360NLS.title
	dynamic-title: $access360r_cmdbci_accountgrouprepositoryanalytics360NLS.dyntitle(cmdbci.displayname)
	description:$access360r_cmdbci_accountgrouprepositoryanalytics360NLS.description
	tags: "cmdbci" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwa_cmdbciaccountgrouprepositoryanalytics
	
	mixins: simpleReport	

	/* Parameters here */
	uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	nbResults = Variable { type: Integer initial: 0 }
	inonlydirectselection = Variable { multivalued: False initial: True }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view: bw360_prevtimeslot with
			PortalTimeslot.UID to currentuid
	}
	
	cmdbci = Record {
		view: bwa_cmdbci with
			uid to uid
	}

	accounts = Dataset {
		view: bwaccess360r_cmdbci_accountgrouprepositoryanalytics with
			uid to uid,
			inonlydirectselection to onlydirect,
			UserVariable session_comparisonTimeslotTeam360 to dummy
		trend:
			Trend {
				exclude-new: False
				exclude-same: False
				include-removed: True
				join-column: key
				value-column: val
				status-column-name: status		
				timeslot: UserVariable session_comparisonTimeslotTeam360
			}
		count-variable: nbResults
		excludes:
			OrPredicate {
				AndPredicate {
					StringPredicate(Current status) { when 'Removed' then True }
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Invalid' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Identical' then True }
					BooleanPredicate(UserVariable session_exclSimilar)
				}
			}
	}

	managedapps = Dataset {
		view: enduser360_managedapplications with
			uid to uid
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical False hint:height 64 } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					label:$access360r_cmdbci_accountgrouprepositoryanalytics360NLS.directonly
					variable:inonlydirectselection
				}
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
			}
		}
	}
	ConditionalGroup {
		IntCondition(nbResults) {
			when >0 then [
					DynamicCrossTable {
						data: accounts
						layout:
							Layout {
								grab: horizontal True vertical True
								row-headers-max-width: 70%
							}
						dimensions:
							Dim {
								value: orguid
								label: orgdisplayname
								header: $organisation.concept
							},
							Dim {
								value: orgcode
								label: orgshortname
								header: $porganisation.shortname
							},
							Dim {
								value: jobtitleuid
								label: jobtitledisplayname
								header: $allocation.jobtitledisplayname
							},
							Dim {
								value: groupcode
								label: groupcode
								header: $pgroup.code
							},
							Dim {
								value: groupdisplayname
								label: groupdisplayname
								header: $pgroup.displayname
							},
							Dim {
								value: accountlogin
								label: accountlogin
								header: $account.login
							},
							Dim {
								value: repositoryuid
								label: repositorydisplayname
								header: $repository.concept
							},
							Dim {
								value: repositoryrepositorytype
								label: repositoryrepositorytype
								header: $prepository.repositorytype
							},
							Dim {
								value: noownercode
								label: noownercode
								header: $reconciliation.noownercode
							},
							Dim {
								value: identityhrcode
								label: identityhrcode
								header: $pidentity.hrcode
							},
							Dim {
								value: identityfullname
								label: identityfullname
								header: $pidentity.fullname
							},
							Dim {
								value: identityinternal
								label: identityinternal
								header: $pidentity.internal
							}
						measures:
							Measure {
								value: key
								header: $access360r_cmdbci_accountgrouprepositoryanalytics360NLS.access
							},
							Measure {
								value: accountuid
								header: $account.concept
							},
							Measure {
								value: identityuid
								header: $identity.concept
							},
							Measure {
								value: applicationuid
								header: $application.concept
							},
							Measure {
								value: orguid
								header: $organisation.concept
							},
							Measure {
								value: jobtitleuid
								header: $identity.jobtitledisplayname
							}
					}
			] otherwise [
				Header {
					value: $access360r_cmdbci_accountgrouprepositoryanalytics360NLS.empty( cmdbci.displayname )
				}
			]
		}
	}
}
