/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"

/* Nationalized labels here */
access360r_application_accessrightscs360NLS = NLS {
	title [en "Access Analysis" fr "Analyse des droits d'accès"]
	dyntitle [en "{0} Access Analysis" fr "Analyse des droits d''accès pour {0}"]
	directrightsonly [en "Only Direct Rights" fr "seulement les droits directs"]
	description [
		en "This report presents the access rights of the application in a pivot table. Only the 'application profile' type rights directly associated with active accounts are taken into account. it is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right click on the table to do so."
		fr "Ce rapport présente les droits d'accès de l'application sous la forme d'un tableau croisé dynamique. Seuls les droits de type 'profil applicatif' directement associés aux comptes actifs sont pris en compte. il est possible d'identifier uniquement les changements réalisés depuis une date donnée. les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela"
		]
	}

access360r_application_accessrights360cs = Page {
	title: $access360r_application_accessrightscs360NLS.title
	dynamic-title: $access360r_application_accessrightscs360NLS.dyntitle(application.displayname)
	description:$access360r_application_accessrightscs360NLS.description
	tags: "application" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature: bwa_applicationaccessrightscs
	
	mixins: simpleReport	

	/* Parameters here */
    uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	onlydirectrights = Variable { initial:True type:Boolean }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	application = Record {
		view:bwf_applicationDetail with uid to uid
	}

	rights = Dataset {
		view:bwaccess360r_application_rights_bv with uid to uid, UserVariable session_comparisonTimeslotTeam360 to dummy, onlydirectrights to directrightsonly, UserVariable session_comparisonTimeslotTeam360 to comparisontimeslot unless-empty, UserVariable session_exclRemoved to excluderemoved, UserVariable session_exclSimilar to excludesimilar
	}

	managedapps = Dataset {
		view:enduser360_managedapplications with uid to uid
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Checkbox {
					variable:onlydirectrights
					label:$access360r_application_accessrightscs360NLS.directrightsonly
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:rights
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:64px  grab: horizontal True vertical True}
					columns:Dim {value:applicationuid label:applicationdisplayname header:$application.concept},Dim {value:permissionuid label:permissiondisplayname header:$permission.concept} 
					rows:	Dim {value:orguid label:orgdisplayname header:$organisation.concept},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:ownerinternal label:ownerinternal header:$identity.internal width:100px initially-masked:True},
							Dim {value:owneruid label:ownerfullname header:$identity.fullname},
							Dim {value:uid label:login header:$account.login}
					cell-content:CellContent {text: Current status cluster-value:'X' styling:StringStyling(Current status) { when 'New' then aartimeline_highlightnew360 when 'Removed' then aartimeline_highlightremoved360 }}
				
				}
			}
		}
	}
}
