/* Import other pages here */
import "/webportal/pages/styles/styles.page"

import "/webportal/pages/bw_fragments/application/details/applicationDetails.page"

import "/webportal/pages/bw_htmlwidgets/charts.page"

/* Nationalized labels here */
access360r_organisation_sharemapNLS = NLS {
	title [en "Shares Map" fr "Carte des partages"]
	dyntitle [en "{0} Shares Map" fr "Carte des partages pour {0}"]
	directonly [en "Only this Organization" fr "seulement cette organisation"]
	unknown [en 'Unknown' fr 'inconnue']
	size [en "Blocs Size" fr "Taille des blocs"]
	size_prop [en "Proportional to the Number of Accounts" fr "Proportionnel au nombre de comptes"]
	size_iprop [en "Inversely Proportional to the Number of Accounts" fr "Inversement proportionnel au nombre de comptes"]
	size_same [en "Identical" fr "Identique"]
	family [en "Family" fr "Famille"]
description [
		en "This report presents the applications accessible by the members of the organization in the form of a treemap. The size of the blocks can either be proportional to the number of accounts, inversely proportional to the number of accounts or identical. Only active accounts are taken into account. It is possible to restrict the display to direct members or to display all members. It is finally possible to display application details by clicking on the blocks."
		fr "Ce rapport présente les applications accessibles par les membres de l'organisation sous la forme d'une carte. La taille des blocs peut être au choix proportionnel au nombre de comptes, inversement proportionnel au nombre de comptes ou identique. Seuls les comptes actifs sont pris en compte. Il est possible de restreindre l'affichage aux membres directs ou d'afficher tous les membres. Il est enfin possible d'afficher le détail des applications en cliquant sur les blocs."
	]
}

access360r_organisation_sharemap = Page {
	title: $access360r_organisation_sharemapNLS.title
	description: $access360r_organisation_sharemapNLS.description
	dynamic-title: $access360r_organisation_sharemapNLS.dyntitle(organisation.displayname)
	tags: "organisation" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa_organisationsharemap)
	
	mixins: simpleReport	
	/* Parameters here */
    uid = Parameter { type: String hidden: True }
	inonlydirectselection = Parameter { multivalued:False default:True }
	
	/* Variables here */
	onlydirectselection = Variable { multivalued:False initial:inonlydirectselection }
	folderfamily = Variable
	
	selectedApplication = Variable
	
	sizeStrg = Variable
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	organisation = Record {
		view:br_organisationDetail with uid to uid 
	}

	teamapps = Dataset {
		view:bwaccess360r_organisation_sharesnbaccount with uid to uid, onlydirectselection to directonly, folderfamily to family
	}
	
	folders_family = Dataset {
		view:bwf_org_folders_family with uid to uid, onlydirectselection to directonly
	}
	
	showDetails = NamedAction (
		Dialog bwf_applicationDetailsDialog(	selectedApplication to inuid, 
												uid to inorganisationuid, 
												onlydirectselection to inonlydirectselection, 
												True to inshowaccountsfororganisation, 
												True to inshowperjob,
												True to inshowperorg
												)
	
	
	)
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:onlydirectselection
					label:$access360r_organisation_sharemapNLS.directonly
				}
			}
			GridCell {
				Combo {
					variable:sizeStrg
					label:$access360r_organisation_sharemapNLS.size
					layout:Layout {hint: width 350 align:horizontal Beginning vertical Center}
					options:Static {
						Option {text:$access360r_organisation_sharemapNLS.size_prop value:"count"}
						Option {text:$access360r_organisation_sharemapNLS.size_iprop value:"reversecount"}
						Option {text:$access360r_organisation_sharemapNLS.size_same value:"same"}
					}
				}
			}
			GridCell {
				Combo {
					variable:folderfamily
					label:$access360r_organisation_sharemapNLS.family
					layout:Layout {hint: width 200 align:horizontal Beginning vertical Center}
					allow-none:True
					options:Dynamic {
						data:folders_family
						value:Current applicationfamily
						text:Current applicationfamily
					}
				}
			}			
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				IncludeHTMLWidget {
					layout: Layout { hint: height 500 width 1050 align: horizontal Center vertical Center }
					template: treemapChart
					datasets: teamapps (applicationdisplayname, applicationuid, nb, description) to chartdata ( label, code , count, description )
					bindings: 
						sizeStrg binds-to sizeStrategy
					widget-events: {
						when onclick then [
							Set Current code to selectedApplication,
							ExecuteNamedAction showDetails
						]
					}
				}


			}
		}
	}
}
