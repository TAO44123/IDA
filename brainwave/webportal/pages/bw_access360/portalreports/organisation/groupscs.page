/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/teamaccounts.page"

import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

/* Nationalized labels here */
access360r_organisation_groups360csNLS = NLS {
	title [en "Groups Analysis" fr "Analyse des groupes"]
	dyntitle [en "{0} Groups Analysis" fr "Analyse des groupes pour {0}"]
	privileged [en "Privileged" fr "privilégié"]
	directonly [en "Only this Organization" fr "seulement cette organisation"]
	directgrouponly [en "Only Direct Groups" fr "seulement les groupes directs"]

	description [
		en "This report lists the membership groups of the organization in the form of a pivot table. Only active accounts are taken into account. It is possible to list only direct groups or all groups. It is possible to limit the results to direct members or to display all members. It is possible to filter the results to show only the differences since a given date. It is possible to modify the columns or to export the results by right clicking on the table."
		fr "Ce rapport liste les groupes des membres de l'organisation sous la forme d'un tableau croisé dynamique. Seuls les comptes actifs sont pris en compte. Il est possible de lister seulement les groupes directs ou tous les groupes. Il est possible de limiter les résultats aux membres directs ou d'afficher tous les membres. Il est possible de filtrer les résultats pour ne faire apparaitre que les différences depuis une date donnée. Il est possible de modifier les colonnes ou d'exporter les résultats en faisant un clic droit sur le tableau"
	]
}

access360r_organisation_groups360cs = Page {
	title: $access360r_organisation_groups360csNLS.title
	description: $access360r_organisation_groups360csNLS.description
	dynamic-title: $access360r_organisation_groups360csNLS.dyntitle(organisation.displayname)
	tags: "organisation" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwa_organisationgroupscs
	enter-event:IntCase(organisation.bwa_organisationanalytics_nbtotalmembers) { when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [ Set True to onlydirectselection, Set True to onlydirectselection_disabled  ] }
	
	mixins: simpleReport	
	/* Parameters here */
    uid = Parameter { type: String hidden: True }
	inonlydirectselection = Parameter { multivalued:False default:True }
	
	/* Parameters here */
	
	/* Variables here */
	onlydirectselection = Variable { multivalued:False initial:inonlydirectselection }
	onlydirectselection_disabled = Variable { initial:False type:Boolean }
	repositoryfilter = Variable
	onlydirectgroup = Variable { initial:True type:Boolean }
	selectedgroup = Variable
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}
	
	organisation = Record {
		view:bwf_organisationDetail with uid to uid 
	}

	repolist = Dataset {
		view:bwaccess360r_organisationrepositorypicker with uid to uid
	}

	teamgroups = Dataset {
		view:bwaccess360r_organisationgroups_bv with uid to uid, onlydirectselection to directonly,UserVariable session_comparisonTimeslotTeam360 to dummy, repositoryfilter to repository unless-empty, onlydirectgroup to directgrouponly, UserVariable session_comparisonTimeslotTeam360 to comparisontimeslot unless-empty, UserVariable session_exclRemoved to excluderemoved, UserVariable session_exclSimilar to excludesimilar
	}

	goDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(selectedgroup to inuid, 
										True to inshowapplications,
										True to inshowshares,
										True to inshowperjob,
										True to inshowperorg,
										False to inshowaccounts,
										False to inshowcontrols,
										False to inshowdecisionhistory
										)
	)
	
	/* Page content */

	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:onlydirectselection
					label:$access360r_organisation_groups360csNLS.directonly
					disabled:BooleanPredicate(onlydirectselection_disabled)
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Checkbox {
					variable:onlydirectgroup
					label:$access360r_organisation_groups360csNLS.directgrouponly
				}
				Combo {
					variable:repositoryfilter
					allow-none:True
					layout:Layout { hint: width 200 }
					label:$repository.concept
					options:Dynamic {
						data:repolist
						text:Current repositorydisplayname
						value:Current repositoryuid
					}
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamgroups
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:32px  grab: horizontal True vertical True}
					rows:Dim {value:repositorydisplayname header:$repository.concept}, Dim {value:groupuid label:groupdisplayname tooltip:groupdisplayname header:$group.concept header-click:selectedgroup} 
					columns:	Dim {value:orgdisplayname header:$organisation.concept},
								Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
								Dim {value:internal label:internal header:$identity.internal width:100px initially-masked:True},
								Dim {value:fullname tooltip:fullname width:160px header:$identity.concept}  
					cell-content:CellContent {text: 'X' tooltip:Current accountlogin cluster-value:'X' align:Center styling:StringStyling(Current status) { when 'New' then tactimeline_highlightnew360 when 'Removed' then tactimeline_highlightremoved360}}
					row-header-click:ExecuteNamedAction goDetails
				}
			}
		}	
	}
}
