/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/teamfolderrights.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
access360r_organisation_folderrightscs360NLS = NLS {
	title [en "Data Access Analysis" fr "Analyse des accès aux données"]
	dyntitle [en "{0} Data Access Analysis" fr "Analyse des accès aux données pour {0}"]
	directonly [en "Only This Organization" fr "seulement cette organisation"]
	description [
		en "This report lists the folder access rights of the organization's members in the form of a pivot table. Only active accounts are taken into account. It is possible to restrict the display to direct members or to display all members. It is possible to display only the differences with respect to a given date. It is possible to modify the columns or to export the data by right clicking on the table."
		fr "Ce rapport liste les droits d'accès bureautique des membres de l'organisation sous la forme d'un tableau croisé dynamique. Seuls les comptes actifs sont pris en compte. Il est possible de restreindre l'affichage aux membres directs ou d'afficher l'ensemble des membres. Il est possible de n'afficher que les différences par rapport à une date donnée. Il est possible de modifier les colonnes ou d'exporter les donées en faisant un clic droit sur le tableau"
	]
}

access360r_organisation_folderrightscs360 = Page {
	title: $access360r_organisation_folderrightscs360NLS.title
	description: $access360r_organisation_folderrightscs360NLS.description
	dynamic-title: $access360r_organisation_folderrightscs360NLS.dyntitle(organisation.displayname)
	tags: "organisation" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:All(unstructureddata_license, bwa_organisationfolderrightscs)
	enter-event:IntCase(organisation.bwa_organisationanalytics_nbtotalmembers) { when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [ Set True to onlydirectselection, Set True to onlydirectselection_disabled  ] }
	
	mixins: simpleReport	
	/* Parameters here */
    uid = Parameter { type: String hidden: True }
	inonlydirectselection = Parameter { multivalued:False default:True }
	
	/* Variables here */
	onlydirectselection = Variable { multivalued:False initial:inonlydirectselection }
	onlydirectselection_disabled = Variable { initial:False type:Boolean }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view:bw360_prevtimeslot with PortalTimeslot.UID to currentuid
	}

	organisation = Record {
		view:bwf_organisationDetail with uid to uid 
	}

	teamrights = Dataset {
		view:bwaccess360r_organisation_folderrights with uid to uid, onlydirectselection to directonly,
								UserVariable session_folderDepth to depth,
								UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
	
		excludes:
		OrPredicate {
			AndPredicate {
				StringPredicate(Current status) { when 'Removed' then True }
				BooleanPredicate(UserVariable session_exclRemoved)
			}
			AndPredicate {
				StringPredicate(Current status) { when 'Identical' then True }
				BooleanPredicate(UserVariable session_exclSimilar)
			}
		}
	}
	
	/* Page content */
	Grid {
		columns:GridColumn, GridColumn, GridColumn
		layout:Layout { grab:horizontal True vertical True } 
		GridRow {
			height:64
			GridCell {
				Checkbox {
					variable:onlydirectselection
					label:$access360r_organisation_folderrightscs360NLS.directonly
					disabled:BooleanPredicate(onlydirectselection_disabled)
				}
				
				Combo {
					variable:UserVariable session_comparisonTimeslotTeam360
					layout:Layout { hint: width 200 }
					label:$session_comparisonTimeslotTeam360NLS.label
					tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
					options:Dynamic {
						data:session_comparisontimeslots
						text:Current commitdate
						value:Current uid
					}
				}
			}
			GridCell {
				Checkbox {
					variable:UserVariable session_exclRemoved
					text:$session_exclRemovedNLS.label
					tooltip:$session_exclRemovedNLS.tooltip
				}
				Checkbox {
					variable:UserVariable session_exclSimilar
					text:$session_exclSimilarNLS.label
					tooltip:$session_exclSimilarNLS.tooltip
				}
			}
			GridCell {
				Combo {
					variable:UserVariable session_folderDepth
					tooltip:$session_folderDepthNLS.tooltip
					label:$session_folderDepthNLS.label
					layout:Layout {grab:horizontal False vertical False hint:width 96}
					options:Static {
						Option { text:'<=1' value:'<1' }
						Option { text:'<=2' value:'<2' }
						Option { text:'<=3' value:'<3' }
						Option { text:'=1' value:'=1' }
						Option { text:'=2' value:'=2' }
						Option { text:'=3' value:'=3' }
					}
				}
			}
		}
		GridRow {
			height:grow
			GridCell {
				span:3
			
				CrossTable {
					data:teamrights
					cluster-sortable:True
					multi-selection:True
					swappable:True
					user-configurable:True
					layout:Layout {cell-width:40px  grab: horizontal True vertical True}
					columns:Dim {value:applicationdisplayname tooltip:applicationdisplayname header:$teamfolderrights360NLS.share},Dim {value:permissioncode tooltip:permissioncode header:$teamfolderrights360NLS.folder} 
					rows:	Dim {value:orgdisplayname header:$teamfolderrights360NLS.department},
							Dim {value:jobtitledisplayname label:jobtitledisplayname header:$identity.jobtitledisplayname width:160px tooltip:jobtitledisplayname initially-masked:True},
							Dim {value:internal label:internal header:$identity.internal width:100px initially-masked:True},
							Dim {value:fullname header:$identity.concept} 
					cell-content:CellContent {text: Current rights cluster-value:'X' styling:StringStyling(Current status) { when 'New' then tfrtimeline_highlightnew360 when 'Removed' then tfrtimeline_highlightremoved360 when 'Modified' then tfrtimeline_highlightmodified360}}
				
				}
			}
		}
	}
}
