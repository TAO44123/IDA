/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"

/* Nationalized labels here */
access360r_organisation_analytics360NLS = NLS {
	title [en "Self-service analytics" fr "Analytics en self-service"]
	dyntitle [en "{0} self-service analytics" fr "Analytics en self-service pour {0}"]
	empty [en "{0} does not contain any right" fr "{0} ne contient pas de droits"]
	directonly [en "Only this Organization" fr "seulement cette organisation"]
	description [
		en "This report presents the access rights of the organisation in the form of a dynamic pivot table where it is possible to select the analysis dimensions. Only the 'application profile' type rights directly associated with the active accounts are taken into account. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport présente les droits d'accès de l'organisation sous la forme d'un tableau croisé dynamique où il est possible de sélectionner les dimensions d'analyse. Seuls les droits de type 'profil applicatif' directement associés aux comptes actifs sont pris en compte. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée. Les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela."
		]
	access [en "Access right" fr "Droit d'accès"]
	applicationaccess [en "Application right" fr "Accès à l'application"]
}

access360r_organisation_analytics = Page {
	title: $access360r_organisation_analytics360NLS.title
	dynamic-title: $access360r_organisation_analytics360NLS.dyntitle(organisation.displayname)
	description:$access360r_organisation_analytics360NLS.description
	tags: "organisation" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	enter-event:
		IntCase(organisation.bwa_organisationanalytics_nbtotalmembers) {
			when > NonEmpty(ConfigurationVariable "access360_crosstabteamlimit", Constant session_indirectTeam360NLS_threshold) then [
				Set True to onlydirectselection,
				Set True to onlydirectselection_disabled
			]
		}
	feature: bwa_organisationanalytics
	
	mixins: simpleReport	

	/* Parameters here */
	uid = Parameter { type: String hidden: True }
	inonlydirectselection = Parameter { multivalued: False default: True }
	
	/* Variables here */
	onlydirectselection = Variable { multivalued: False initial: inonlydirectselection }
	onlydirectselection_disabled = Variable { initial: False type: Boolean }
	nbResults = Variable { type: Integer initial: 0 }
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view: bw360_prevtimeslot with
			PortalTimeslot.UID to currentuid
	}
	
	organisation = Record {
		view: bwf_organisationDetail with
			uid to uid
	}

	rights = Dataset {
		view: bwaccess360r_organisation_rightsanalytics with
			uid to uid,
			NonEmpty(ConfigurationVariable "ias_permissionroletype", "Role") to permissiontype,
			onlydirectselection to directonly,
			UserVariable session_comparisonTimeslotTeam360 to dummy
		trend:
			Trend {
				exclude-new: False
				exclude-same: False
				include-removed: True
				join-column: key
				value-column: val
				status-column-name: status		
				timeslot: UserVariable session_comparisonTimeslotTeam360
			}
		count-variable: nbResults
		excludes:
			OrPredicate {
				AndPredicate {
					StringPredicate(Current status) { when 'Removed' then True }
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Invalid' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Identical' then True }
					BooleanPredicate(UserVariable session_exclSimilar)
				}
			}
	}

	managedapps = Dataset {
		view: enduser360_managedapplications with
			uid to uid
	}
	
	/* Page content */
	ConditionalGroup {
		IntCondition(nbResults) {
			when >0 then [
				Grid {
					columns:GridColumn, GridColumn, GridColumn
					layout:Layout { grab:horizontal True vertical True } 
					GridRow {
						height:64
						GridCell {
							Checkbox {
								variable:onlydirectselection
								label:$access360r_organisation_analytics360NLS.directonly
								disabled:BooleanPredicate(onlydirectselection_disabled)
							}
							Combo {
								variable:UserVariable session_comparisonTimeslotTeam360
								layout:Layout { hint: width 200 }
								label:$session_comparisonTimeslotTeam360NLS.label
								tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
								options:Dynamic {
									data:session_comparisontimeslots
									text:Current commitdate
									value:Current uid
								}
							}
						}
						GridCell {
							Checkbox {
								variable:UserVariable session_exclSimilar
								text:$session_exclSimilarNLS.label
								tooltip:$session_exclSimilarNLS.tooltip
							}
						}
						GridCell {
						}
					}
					GridRow {
						height: grow
						GridCell {
							span: 3
							DynamicCrossTable {
								data: rights
								layout:
									Layout {
										grab: horizontal True vertical True
										row-headers-max-width: 70%
									}
								dimensions:
									Dim {
										value: applicationuid
										label: applicationdisplayname
										header: $application.concept
									},
									Dim {
										value: permissioncode
										label: permissioncode
										header: $ppermission.code
									},
									Dim {
										value: permissionuid
										label: permissiondisplayname
										header: $permission.concept
									},
									Dim {
										value: orguid
										label: orgdisplayname
										header: $organisation.concept
									},
									Dim {
										value: orgcode
										label: orgshortname
										header: $porganisation.shortname
									},
									Dim {
										value: jobtitleuid
										label: jobtitledisplayname
										header: $allocation.jobtitledisplayname
									},
									Dim {
										value: accountuid
										label: accountlogin
										header: $account.login
									},
									Dim {
										value: repositoryuid
										label: repositorydisplayname
										header: $repository.concept
									},
									Dim {
										value: identityhrcode
										label: identityhrcode
										header: $identity.hrcode
									},
									Dim {
										value: identityuid
										label: identityfullname
										header: $identity.fullname
									},
									Dim {
										value: identityinternal
										label: identityinternal
										header: $identity.internal
									}
								measures:
									Measure {
										value: key
										header: $access360r_organisation_analytics360NLS.access
									},
									Measure {
										value: applicationkey
										header: $access360r_organisation_analytics360NLS.applicationaccess
									},
									Measure {
										value: accountuid
										header: $account.concept
									},
									Measure {
										value: identityuid
										header: $identity.concept
									},
									Measure {
										value: applicationuid
										header: $application.concept
									},
									Measure {
										value: orguid
										header: $organisation.concept
									},
									Measure {
										value: jobtitleuid
										header: $identity.jobtitledisplayname
									}
							}
						}
					}
				}
			] otherwise [
				Header {
					value: $access360r_organisation_analytics360NLS.empty( organisation.displayname )
				}
			]
		}
	}
}
