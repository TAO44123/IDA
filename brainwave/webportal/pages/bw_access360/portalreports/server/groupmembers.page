/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/bw_access360/reports/indirectVariables.page"
import "/webportal/pages/bw_access360/reports/appaccessrights.page"

import "/webportal/pages/bw_fragments/lib/icons.page"

import "/webportal/pages/bw_fragments/account/details/accountDetails.page"
import "/webportal/pages/bw_fragments/group/details/groupDetails.page"

/* Nationalized labels here */
access360r_server_groupmembers360NLS = NLS {
	title [en "Server local groups members" fr "Membres des groupes locaux du serveur"]
	dyntitle [en "{0} server local groups members" fr "Membres des groupes locaux du serveur {0}"]
	empty [en "This server does not contain any local group members" fr "Ce serveur ne contient pas de membres de groupes locaux"]
	description [
		en "This report lists the server local groups active accounts. Only active accounts are taken into consideration. Both direct and indirect accounts (through subgtroups) are presented. It is possible to identify only the changes made since a given date. The columns displayed are configurable and the results can be exported, right-click on the table to do so."
		fr "Ce rapport liste les comptes actifs des groupes locaux du serveur. Seuls les comptes actifs sont pris en compte. A la fois les membres directs et les membres indirects (au travers de sous groupes) sont affichés. Il est possible d'identifier uniquement les changements réalisés depuis une date donnée. Les colonnes affichées sont configurables et les résultats exportables, faites un clic droit sur le tableau pour cela."
		]
}

access360r_server_groupmembers = Page {
	title: $access360r_server_groupmembers360NLS.title
	description: $access360r_server_groupmembers360NLS.description
	dynamic-title: $access360r_server_groupmembers360NLS.dyntitle(repository.displayname)
	tags: "server" priority 200, "byuid" , "analytics"
	icon: %concept_16.server large-icon: %concept_48.server
	feature:All(pam_license, bwa_servergroupmembers, Any(governance_license, compliance_license))

	mixins: simpleReport	

	/* Parameters here */
	uid = Parameter { type: String hidden: True }
	
	/* Variables here */
	selectedAccount = Variable
	selectedGroup = Variable
	
	/* Datasets and records here */
	session_comparisontimeslots = Dataset {
		view: bw360_prevtimeslot with
			PortalTimeslot.UID to currentuid
	}
	
	repository = Record {
		view: bwf_repositoryDetail with
			uid to uid
	}

	rights = Dataset {
		view: bwaccess360r_server_localgroupsmembers with
			uid to uid,
			UserVariable session_comparisonTimeslotTeam360 to dummy
		trend: Trend {
			exclude-new:False
			exclude-same:False
			include-removed:True
			join-column:key
			value-column:val
			status-column-name:status		
			timeslot:UserVariable session_comparisonTimeslotTeam360
		}
		excludes:
			OrPredicate {
				AndPredicate {
					StringPredicate(Current status) { when 'Removed' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Invalid' then True }
					BooleanPredicate(UserVariable session_exclRemoved)
				}
				AndPredicate {
					StringPredicate(Current status) { when 'Identical' then True }
					BooleanPredicate(UserVariable session_exclSimilar)
				}
			}
	}
	
	showAccountDetails = NamedAction (
		Dialog bwf_accountDetailsDialog(
			selectedAccount to inuid,
			True to inshowowner,
			True to inshowgroups
		)
	)

	showGroupDetails = NamedAction (
		Dialog bwf_groupDetailsDialog(
			selectedGroup to inuid,
			True to inshowaccounts,
			True to inshowperjob,
			True to inshowperorg
		)
	)
	
	/* Page content */
	ConditionalGroup {
		IntCondition(repository.bwa_repositoryanalytics_nbgroup) {
			when >0 then [
				Grid {
					columns:GridColumn, GridColumn, GridColumn
					layout:Layout { grab:horizontal True vertical True } 
					GridRow {
						height:64
						GridCell {
							Combo {
								variable:UserVariable session_comparisonTimeslotTeam360
								layout:Layout { hint: width 200 }
								label:$session_comparisonTimeslotTeam360NLS.label
								tooltip:$session_comparisonTimeslotTeam360NLS.tooltip
								options:Dynamic {
									data:session_comparisontimeslots
									text:Current commitdate
									value:Current uid
								}
							}
						}
						GridCell {
							Checkbox {
								variable:UserVariable session_exclRemoved
								text:$session_exclRemovedNLS.label
								tooltip:$session_exclRemovedNLS.tooltip
							}
							Checkbox {
								variable:UserVariable session_exclSimilar
								text:$session_exclSimilarNLS.label
								tooltip:$session_exclSimilarNLS.tooltip
							}
						}
						GridCell {
						}
					}
					GridRow {
						height:grow
						GridCell {
							span:3
							Table {
								data:rights
								layout:Layout { grab:horizontal True vertical True }
								show-count:True
								show-filter:True
								configurable:True
								persist-configuration:True
								persist-configuration-key:uid
								Column {
									sortable:True
									header:''
									column:status
									styling:
										StringStyling(Current status) {
											when 'New' then aartimeline_highlightnew360
											when 'Removed' then aartimeline_highlightremoved360
											when 'Invalid' then aartimeline_highlightremoved360
										}
									text:Transform Current status using aarmapping360
								}
								Column {
									column:uid
									hidden:True
									selection:selectedGroup
								}
								Column {
									column:accountuid
									hidden:True
									selection:selectedAccount
								}
								Column {
									column:code
									header:$group.code
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
									actions:ExecuteNamedAction showGroupDetails
								}
								Column {
									column:displayname
									header:$group.concept
									sortable:True
									filterable:True
									width:160px
									actions:ExecuteNamedAction showGroupDetails
								}
								Column {
									column:bwa_groupmetadata_descr
									header:$group.comment
									sortable:True
									filterable:True
									initially-masked:True
								}
								Column {
									column:bwa_groupmetadata_sensitivitylevel
									header:$group.sensitivitylevel
									sortable:True
									filterable:True
									initially-masked:True
								}
								Column {
									column:accountidentifier
									header:$paccount.identifier
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
									actions:ExecuteNamedAction showAccountDetails
								}
								Column {
									column:accountlogin
									header:$paccount.login
									sortable:True
									filterable:True
									width:160px
									actions:ExecuteNamedAction showAccountDetails
								}
								Column {
									column:accountusername
									header:$paccount.username
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
									actions:ExecuteNamedAction showAccountDetails
								}
								Column {
									column:accountlastlogindate
									header:$paccount.lastlogindate
									sortable:True
									initially-masked:True
									width:160px
								}
								Column {
									column:repositorydisplayname
									header:$repository.concept
									sortable:True
									filterable:True
									width:160px
								}
								Column {
									column:noownercode
									header:$reconciliation.noownercode
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
								}
								Column {
									column:leavedate
									header:$reconciliation.leavedate
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
								}
								Column {
									column:identityhrcode
									header:$pidentity.hrcode
									sortable:True
									filterable:True
									initially-masked:True
								}
								Column {
									column:identityfullname
									header:$pidentity.fullname
									sortable:True
									filterable:True
									width:160px
								}
								Column {
									column:identitymail
									header:$pidentity.mail
									sortable:True
									filterable:True
									initially-masked:True
									width:160px
								}
								Column {
									column:identityinternal
									header:$pidentity.internal
									sortable:True
									filterable:True
									initially-masked:True
								}
								Column {
									column:identityactive
									header:$pidentity.active
									sortable:True
									filterable:True
									initially-masked:True
								}
								Column {
									column:identitybwa_identityanalyticsdata_joborg
									header:$pidentity.joborg
									sortable:True
									filterable:True
									initially-masked:True
									width:200px
								}
							}
						}
					}
				}
			]		
			otherwise [
				Header {
					value:$access360r_server_groupmembers360NLS.empty 
				}			
			]
		} 
	}
}
