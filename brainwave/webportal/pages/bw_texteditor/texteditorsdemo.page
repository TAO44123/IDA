import "/webportal/pages/bw_texteditor/texteditors.page"


textEditorsDemo = Page {
	title:"Text Editors Demo"
	tags:"demo"
	feature:bwed_showcase

	val = Variable {initial:"hello world"}
//	val = Variable {initial:"<h1>HELLO WORLD</h1>\n"}
	Splitter {
		disposition:Horizontal
		Group {
			IncludeHTMLWidget {
				template:textEditorArea
				layout:Layout {grab:horizontal True vertical True}
				bindings:
				val binds-to content,
				value-of False to readonly
			}
		}
		Group {
			Edit {
				variable:val
			}
			IncludeHTMLWidget {
				template:textEditorArea
				layout:Layout {grab:horizontal True vertical True}
				bindings:
				val binds-to content,
				value-of True to readonly
			}
		}
	}

}