/**
 * <span style="white-space: pre-line">
 * A WYSIWYG text editor
 * The content is edited through a dynamic interface, the produced content is in HTML format.
 * Keep in mind that the minimum width for this component is 500px
 * 
 * <u>Binding:</u>
 * <b>content (String)</b> the content, must be binded to a in/out variable, if the content is edited within the component, the variable value is updated accordingly, if the variable is updated, the editor content is updated accordingly.
 * 
 * <u>Parameters:</u><ul>
 * <li><b>readonly (Boolean)</b> true to switch the text editor to a read only mode, in this case only the 'print' toolbar option is visible</li>
 * </ul>
 * </span>
 */
textEditorArea = HTMLWidgetTemplate {
	source-file: "static/bw_texteditor/texteditor.html"
	bindings:
		content as in out String, /* bi-directional */
		readonly as in Boolean /* False */
}
