//		}
//	}

	cmdbaccounts = Dataset {
		view:bwt_cmdbrepositoryaccounts with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:nbdirectgroups
			timeslot:refTimeslot
			status-column-name:status
			difference-column-name:diff
		}
		
		disabled:IntPredicate(currentTab) { when !=1 then True otherwise False}

		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffaccounts)
		}
	}

	cmdbaccountsandgroups = Dataset {
		view:bwt_cmdbrepositoryaccountsandgroups with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:key
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
			difference-column-name:diff
		}
		
		disabled:IntPredicate(currentTab) { when !=2 then True otherwise False}

		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffrights)
		}
	}

	applicationaccountsandprofiles = Dataset {
		view:bwt_cmdbapplicationaccountsandprofiles with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:key
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
			difference-column-name:diff
		}
		
		disabled:IntPredicate(currentTab) { when !=3 then True otherwise False}

		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffrights)
		}
	}

	timeline = Dataset {
		view:bwt_cmdbcomputechanges with uid to uid
	}

