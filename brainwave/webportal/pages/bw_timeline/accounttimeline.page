/* Import other pages here */
import "/webportal/pages/styles/styles.page"
import "/webportal/pages/resources/concepts_nls.page"
import "/webportal/pages/resources/mappings.page"
import "/webportal/pages/resources/pages_nls.page"

import "/webportal/pages/bw_timeline/timelinenls.page"

import "/webportal/pages/bw_timelinewidget/timeline.page"

/* Nationalized labels here */
accounttimelineNLS = NLS {
	title [en "Account timeline" fr "Evolutions du compte"]
	dyntitle [en "{0} timeline" fr "Evolutions de {0}"]
	joborg [en "{0} in {1}" fr "{0} chez {1}"]
	share [en "Share" fr "Partage"]
	folder [en "Data" fr "Données"]
	grouptooltip [en "Groups directly assigned to this account" fr "Groups directement associés à ce compte"]

	description [
		en "This report presents the evolutions that have occurred over time. The timeline presents the different timeslots as well as the major events that occurred at each loading. It is possible to select a date to display the details of the identified changes. It is also possible to select a time range by pressing the Ctrl key and clicking on two dates in the timeline."
		fr "Ce rapport présente les évolutions survenues au fil du temps. la timeline présente les différents points de chargement ainsi que les evenements majeurs survenus à chaque chargement. Il est posible de sélectionner une date pour afficher le détail des changements identifiés. Il est aussi posible de sélectionner une page de temps en appuyant sur la touche Ctrl et en cliquant sur deux dates dans la timeline."
	]	
}

accounttimeline_highlightnew = Style {
	foreground:white
	background:Color green
}
accounttimeline_highlightremoved = Style {
	foreground:white
	background:Color red
}

accounttimelinepicker = Dialog {
	title:$timelineNLS.selecttimeslot
	width:640
	height:200
	buttons:[OkButton CancelButton]
	
	selectedTimeslot = Variable
	
	timeslots = Dataset {
		view:bwt_timeslots
	}

	Combo {
		variable:selectedTimeslot
		
		options:Dynamic {
			data:timeslots
			text:Concat (Current displayname, ' (', Current commitdate, ')')
			value:Current uid
		}
	}

}

accounttimeline = Page {
	title: $accounttimelineNLS.title
	dynamic-title: $accounttimelineNLS.dyntitle(account.login)
	description:$accounttimelineNLS.description
	tags: "account" priority 200, "byuid" , "analytics"
	icon: "16/details/analytics_16.png" large-icon: "48/details/analytics_48.png"
	feature:bwt_accounttimeline
	
	uid = Parameter {
		label:"Concept Uid"
		type:String
		hidden:True
		mandatory:True
	}
	initialTimeslot = Parameter { default:PortalTimeslot.UID }

	/* Parameters here */
	currentTimeslot = Variable
	refTimeslot = Variable
	
	selectedRepository = Variable
	selectedApplication = Variable
	selectedShare = Variable
	
	showonlydiffgroups = Variable {initial:True}
	showonlydiffapplications = Variable {initial:True}
	showonlydiffpermissions = Variable {initial:True}
	showonlydiffshares = Variable {initial:True}
	showonlydiffdata = Variable {initial:True}
	
	
	currentTab = Variable {initial:0}
	
	/* Variables here */
	
	/* Datasets and records here */
	timeslots = Dataset {
		view:bwt_timeslots
	}
	previoustimeslot = Record {
		view:bwt_previoustimeslot with currentTimeslot to uid
	}
	reftimeslot = Record {
		view:bwt_timeslot with refTimeslot to uid
	}
		
	account = Record {
		view:br_accountDetail with uid to uid
		timeslot:currentTimeslot
	}
	
	accountgroups = Dataset {
		view:bwt_accountgroups with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
		}

		disabled:IntPredicate(currentTab) { when !=0 then True otherwise False}
		
		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffgroups)
		}
	}
	
	accountapplications = Dataset {
		view:bwt_accountapplications with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
		}

		disabled:IntPredicate(currentTab) { when !=1 then True otherwise False}
		
		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffapplications)
		}
	}
	
	accountpermissions = Dataset {
		view:bwt_accountpermissions with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
		}

		disabled:IntPredicate(currentTab) { when !=2 then True otherwise False}
		
		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffpermissions)
		}
	}
	
	accountshares = Dataset {
		view:bwt_accountshares with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
		}

		disabled:IntPredicate(currentTab) { when !=3 then True otherwise False}
		
		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffshares)
		}
	}
	
	accountdata = Dataset {
		view:bwt_accountdata with uid to uid, refTimeslot to dummy
		timeslot:currentTimeslot
		trend:Trend {
			exclude-same:False
			exclude-new:False
			include-removed:True
			join-column:uid
			value-column:val
			timeslot:refTimeslot
			status-column-name:status
		}

		disabled:IntPredicate(currentTab) { when !=4 then True otherwise False}
		
		excludes:AndPredicate {
			StringPredicate(Current status) { when 'Identical' then True }
			BooleanPredicate(showonlydiffdata)
		}
	}

	timeline = Dataset {
		view:bwt_accountcomputechanges with uid to uid
	}
	
	/* Page content */
	IncludeHTMLWidget {
		layout: Layout { grab:horizontal True vertical False hint:height 130 }
		label:Label {break:True}
		template: timeline
		datasets:timeline(previoustimeslotuid, timeslotuid, previoustimeslotcommitdate, timeslotcommitdate, label, description, group) to chartdata(from_timeslotuid,  to_timeslotuid, from_ts, to_ts, label, description, group)
		bindings:
			value-of True to navigationButtons,
			value-of "background" to itemType
		widget-events: {
			when onclick then [
				Set Current to_timeslotuid to currentTimeslot, Set Current from_timeslotuid to refTimeslot  
			]
		}
	}
	ConditionalGroup {
		StringCondition(currentTimeslot) {
		when IsEmpty then [
			Header {
				value:$timelineNLS.help
			}
		]
		otherwise [
			TabFolder {
				TabItem {
					text:$account.concept
	
					Text {
						label:Label {break:False value:$account.identifier}
						compact:True
						value:account.identifier
					}
					Flow {
						disposition:Horizontal
						Group {
							Text {
								label:Label {break:False value:$account.login}
								compact:True
								value:account.login
							}
							Text {
								label:Label {break:False value:$account.givenname}
								compact:True
								value:account.givenname
							}
							Text {
								label:Label {break:False value:$account.surname}
								compact:True
								value:account.surname
							}
							Text {
								label:Label {break:False value:$account.username}
								compact:True
								value:account.username
							}
							Text {
								label:Label {break:False value:$account.mail}
								compact:True
								value:account.mail
							}
							Text {
								label:Label {break:False value:$account.creationdate}
								compact:True
								value:account.creationdate
							}
							Text {
								label:Label {break:False value:$account.lastlogindate}
								compact:True
								value:account.lastlogindate
							}
							Text {
								label:Label {break:False value:$account.expiredate}
								compact:True
								value:account.expiredate
							}
							Text {
								label:Label {break:False value:$account.service}
								compact:True
								value:account.service
							}
						}
						Group {
							Text {
								label:Label {break:False value:$account.disabled}
								compact:True
								value:account.disabled
							}
							Text {
								label:Label {break:False value:$account.locked}
								compact:True
								value:account.locked
							}
							Text {
								label:Label {break:False value:$account.passwordlastsetdate}
								compact:True
								value:account.passwordlastsetdate
							}
							Text {
								label:Label {break:False value:$account.passwordexpired}
								compact:True
								value:account.passwordexpired
							}
							Text {
								label:Label {break:False value:$account.nextpwdchangedate}
								compact:True
								value:account.nextpwdchangedate
							}
							Text {
								label:Label {break:False value:$account.passwordcantchange}
								compact:True
								value:account.passwordcantchange
							}
							Text {
								label:Label {break:False value:$account.passwordnotrequired}
								compact:True
								value:account.passwordnotrequired
							}
							Text {
								label:Label {break:False value:$account.smartcardrequired}
								compact:True
								value:account.smartcardrequired
							}
				
							Text {
								label:Label {break:False value:$reconciliation.noownercode}
								compact:True
								value:account.reconciliation_noownercode
							}
							Text {
								label:Label {break:False value:$identity.concept}
								compact:True
								value:account.identity_fullname
							}
						}
					}
				}
				TabItem {
					text:$group.concept
					tooltip:$accounttimelineNLS.grouptooltip
					activation-event:Set 0 to currentTab
	
				
					Checkbox {
						variable:showonlydiffgroups
						text:$timelineNLS.showdiffonly
					}	
						
					Spacer {
						height:16
					}
	
					Table {
						data:accountgroups
						layout:Layout {grab:horizontal True vertical True}
						show-count:True
						show-filter:True
						configurable:True
						
						Column {sortable:True header:'' column:status text:Transform Current status using timelineChangeMapping styling:StringStyling(Current status) { when 'New' then accounttimeline_highlightnew when 'Removed' then accounttimeline_highlightremoved } }
						Column {sortable:True initially-masked:True filterable:True width:320px header:$group.code column:code}
						Column {sortable:True filterable:True width:160px header:$group.displayname column:displayname}
						Column {sortable:True filterable:True width:160px header:$repository.concept column:repositorydisplayname}
						Column {filterable:True width:160px header:$group.comment column:comment}
						Column {initially-masked:True filterable:True width:160px header:$group.grouptype column:grouptype}
						Column {initially-masked:True filterable:True width:160px header:$group.creationdate column:creationdate}
						Column {initially-masked:True filterable:True width:160px header:$group.modificationdate column:modificationdate}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.modificationby column:lastmodifiedby}
					}			
				}
				TabItem {
					text:$application.concept
					activation-event:Set 1 to currentTab
	
				
					Checkbox {
						variable:showonlydiffapplications
						text:$timelineNLS.showdiffonly
					}	
						
					Spacer {
						height:16
					}
				
					Table {
						data:accountapplications
						layout:Layout {grab:horizontal True vertical True}
						show-count:True
						show-filter:True
						configurable:True
						
						Column {sortable:True header:'' column:status text:Transform Current status using timelineChangeMapping styling:StringStyling(Current status) { when 'New' then accounttimeline_highlightnew when 'Removed' then accounttimeline_highlightremoved } }
						Column {sortable:True initially-masked:True filterable:True width:320px header:$application.code column:code}
						Column {sortable:True filterable:True width:160px header:$application.displayname column:displayname}
						Column {initially-masked:True sortable:True filterable:True width:160px header:$timelineNLS.category column:category}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.description column:description}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.sensitivitylevel column:sensitivitylevel}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.sensitivityreason column:sensitivityreason}
					}			
				}
				TabItem {
					text:$permission.concept
					activation-event:Set 2 to currentTab
	
				
					Checkbox {
						variable:showonlydiffpermissions
						text:$timelineNLS.showdiffonly
					}	
						
					Spacer {
						height:16
					}
	
					Table {
						data:accountpermissions
						layout:Layout {grab:horizontal True vertical True}
						show-count:True
						show-filter:True
						configurable:True
						
						Column {sortable:True header:'' column:status text:Transform Current status using timelineChangeMapping styling:StringStyling(Current status) { when 'New' then accounttimeline_highlightnew when 'Removed' then accounttimeline_highlightremoved } }
						Column {initially-masked:True filterable:True width:320px header:$permission.code column:code}
						Column {filterable:True width:320px header:$permission.displayname column:displayname}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.description column:description}
						Column {filterable:True width:160px header:$application.concept column:applicationdisplayname}
					}
				}
				TabItem {
					text:$accounttimelineNLS.share
					activation-event:Set 3 to currentTab
					feature:unstructureddata_license
				
				
					Checkbox {
						variable:showonlydiffshares
						text:$timelineNLS.showdiffonly
					}	
						
					Spacer {
						height:16
					}
	
					Table {
						data:accountshares
						layout:Layout {grab:horizontal True vertical True}
						show-count:True
						show-filter:True
						configurable:True
						
						Column {sortable:True header:'' column:status text:Transform Current status using timelineChangeMapping styling:StringStyling(Current status) { when 'New' then accounttimeline_highlightnew when 'Removed' then accounttimeline_highlightremoved } }
						Column {sortable:True initially-masked:True filterable:True width:320px header:$application.code column:code}
						Column {sortable:True filterable:True width:160px header:$application.displayname column:displayname}
						Column {initially-masked:True sortable:True filterable:True width:160px header:$timelineNLS.category column:category}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.description column:description}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.sensitivitylevel column:sensitivitylevel}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.sensitivityreason column:sensitivityreason}
					}			
				}
				TabItem {
					text:$accounttimelineNLS.folder
					activation-event:Set 4 to currentTab
					feature:unstructureddata_license
	
				
					Checkbox {
						variable:showonlydiffdata
						text:$timelineNLS.showdiffonly
					}	
						
					Spacer {
						height:16
					}
	
					Table {
						data:accountdata
						layout:Layout {grab:horizontal True vertical True}
						show-count:True
						show-filter:True
						configurable:True
						label:Label { break:True  value:$accounttimelineNLS.folder }
						
						Column {sortable:True header:'' column:status text:Transform Current status using timelineChangeMapping styling:StringStyling(Current status) { when 'New' then accounttimeline_highlightnew when 'Removed' then accounttimeline_highlightremoved } }
						Column {sortable:True initially-masked:False width:100px header:$right.concept column:basic}
						Column {initially-masked:False filterable:True width:320px header:$accounttimelineNLS.folder column:code}
						Column {initially-masked:True filterable:True width:320px header:$permission.displayname column:displayname}
						Column {initially-masked:True filterable:True width:160px header:$timelineNLS.description column:description}
						Column {initially-masked:False filterable:True width:320px header:$accounttimelineNLS.share column:applicationdisplayname}
					}
				}
			}
		]
		}
	}
}

