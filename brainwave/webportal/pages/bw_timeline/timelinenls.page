/* Import other pages here */

/* Nationalized labels here */
timelineNLS = NLS {
	selecttimeslot [en "Select a timeslot" fr "Choisissez une photographie"]
	difftimeslot [en 'differences computed with timeslot:' fr 'comparaison avec la photographie:']
	difftimeslottooltip [en "Pick a custom timeslot for comparison" fr "Choisir une photographie spécifique pour la comparaison"]
	showdiffonly [en "Show only the differences with the comparison timeslot" fr "Montrer uniquement les différences avec la photographie de comparaison"]

	identical [en "identical" fr "identique"]
	new [en "new" fr "nouveau"]
	modified [en "modified" fr "modifié"]
	removed [en "removed" fr "supprimé"]
	
	description [en 'description' fr 'description']
	category [en 'category' fr 'categorie']
	sensitivitylevel [en 'sensitivity level' fr 'niveau de sensibilité']
	sensitivityreason [en 'sensitivity reason' fr 'raison de sensibilité']
	applicationfamily [en "application family" fr "famille de l'application"]
	modificationby [en 'modification by' fr 'modifié par']
	
	help [en "Select a timeslot or a timeslot range (with Ctrl key) in the timeline to see the details of the changes" fr "Sélectionnez un timeslot ou une page de timesots (avec la touche Ctrl) dans la timeline pour afficher les détails des changements"]
}


timelineChangeMapping = StringMapping {
	when "Identical" then $timelineNLS.identical
	when "New" then $timelineNLS.new
	when "Modified" then $timelineNLS.modified
	when "Removed" then $timelineNLS.removed
	otherwise current
}