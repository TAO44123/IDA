
ds_sailpointiiq_mapping_NLS = NLS {
  title [ en "SailPoint IdentityIQ - Mapping" fr "SailPoint IdentityIQ - Mapping" ]
  description [ 
    en "Optional companion connector for SailPoint IdentityIQ - CSV file to define the mapping between applications schemas attributes exposed by SailPoint and IDA attributes."
    fr "Connecteur complémentaire et optionel au connecteur SailPoint IdentityIQ - Fichier CSV afin de créer un mapping entre les attributs des schémas d'applications exposés par SailPoint et ceux d'Identity Analytics."]
}


ds_sailpointiiq_mapping = Page {
	title: $ds_sailpointiiq_mapping_NLS.title
	tags: "bwds_connector" , "file" , "csv"
	description: $ds_sailpointiiq_mapping_NLS.description
	icon: "bw_dsm/L/bw_genericapp.png"
	large-icon: "bw_dsm/XL/bw_genericapp.png"
	 metadata: ( 	 
	    fixedName -> "bw_sailpointiiq_mapper"  ,  
	    category -> "infrastructure", 
	    destPathVar -> "bw_sailpointiiq_mapper",
		filePattern -> "*.csv",
	    hasMapping -> False,
	    multiFile -> False
	 )
}


