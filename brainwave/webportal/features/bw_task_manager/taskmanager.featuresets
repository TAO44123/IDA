<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE FeatureSets PUBLIC "-//Brainwave//DTD FeatureSets 1.0//EN" "urn:brainwave:igrc:dtds/featuresets.dtd">
<FeatureSets description="Task Manager features set" name="taskmanager" version="1">
	<FeatureSet description="Can launch new processes, send emails in all tabs, assign tasks to candidates and access to completed tasks" featureset="tm_poweruser" name="I1388338299121" />
	<FeatureSet description="Can send emails to other candidates, cannot start new processes" featureset="tm_standarduser" name="I1388338316267" />
	<FeatureSet description="Access to all the task manager features. poweruser  + suspend, resume, stop processes; reassign a task to any individual" featureset="tm_all" name="I1388338330191" />
	<FeatureSet description="Limited to the minimum : cannot launch new processes, can only acquire tasks from the inbox" featureset="tm_limiteduser" name="I1388338342741" />
</FeatureSets>