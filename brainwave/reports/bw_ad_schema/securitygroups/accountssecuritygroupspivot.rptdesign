                </structure>
                <structure>
                    <property name="name">status_Orga/accountsandgroups_current::org_displayname_group/accountsandgroups_current::controldisplayname</property>
                    <expression name="expression">measure["status"]</expression>
                    <property name="dataType">decimal</property>
                    <simple-property-list name="aggregateOn">
                        <value>Orga/accountsandgroups_current::org_displayname</value>
                        <value>group/accountsandgroups_current::controldisplayname</value>
                    </simple-property-list>
                    <property name="aggregateFunction">SUM</property>
                </structure>
            </list-property>
        </extended-item>
        <label id="999">
            <text-property name="text">a X with a red background means that this group assignment is new</text-property>
        </label>
    </body>
