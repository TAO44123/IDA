                    <list-property name="highlightRules">
                        <structure>
                            <property name="operator">is-true</property>
                            <expression name="testExpr" type="javascript">row.__rownum%2==0</expression>
                            <property name="style">tableAltDetail</property>
                        </structure>
                    </list-property>
                    <cell id="1138">
                        <data id="1159">
                            <list-property name="highlightRules">
                                <structure>
                                    <property name="operator">eq</property>
                                    <property name="backgroundColor">#004000</property>
                                    <property name="color">#FFFFFF</property>
                                    <expression name="testExpr" type="javascript">row["reviewstatus"]</expression>
                                    <simple-property-list name="value1">
                                        <value type="javascript">"ok"</value>
                                    </simple-property-list>
                                </structure>
                                <structure>
                                    <property name="operator">eq</property>
