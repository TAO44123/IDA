                                    <property name="color">#FFFFFF</property>
                                    <expression name="testExpr" type="javascript">row["reviewstatus"]</expression>
                                    <simple-property-list name="value1">
                                        <value type="javascript">"revoke"</value>
                                    </simple-property-list>
                                </structure>
                                <structure>
                                    <property name="operator">eq</property>
                                    <property name="backgroundColor">#FF8040</property>
                                    <property name="color">#FFFFFF</property>
                                    <expression name="testExpr" type="javascript">row["reviewstatus"]</expression>
                                    <simple-property-list name="value1">
                                        <value type="javascript">"update"</value>
                                    </simple-property-list>
                                </structure>
                            </list-property>
                            <property name="resultSetColumn">reviewstatus</property>
                        </data>
                    </cell>
