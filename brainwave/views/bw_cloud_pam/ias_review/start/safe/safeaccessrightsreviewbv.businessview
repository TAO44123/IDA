		<Link name="L1670333559410" source="C1670333557491" target="C1665592033143" priority="3" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1670333945353" type="joinview" x="30" y="70" w="632" h="114" title="safe effective access rights review (filtered by account tag if needed)">
			<InnerView name="bwir_safeaccessrightsreview">
