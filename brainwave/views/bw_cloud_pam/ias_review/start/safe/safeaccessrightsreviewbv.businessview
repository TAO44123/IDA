		<Component name="C1670333557491" type="scriptview" x="30" y="290" w="299" h="114" title="filter Booking accounts" enable="{param.includebookingusers.get().equals(&apos;0&apos;)}">
			<FilterList>
				<Filter name="F1670333780972" expression="dataset.UserType.get().equalsIgnoreCase(&apos;Booking&apos;)" comment="Exclude Booking Accounts" type="Exclude"/>
