<?xml version="1.0" encoding="UTF-8"?>
<View family="businessview" name="bwir_safeaccessrightsreviewbv" displayname="safe access rights review">
	<Definition scriptfile="/views/bw_cloud_pam/ias_review/start/safe/safeaccessrightsreviewbv.javascript" name="D1665588440718">
		<Component type="innerview" x="30" y="10" w="589" h="64" name="C1665588440718" title="safe all access rights review (filtered by account tag if needed)">
			<InnerView name="bwir_safeallbookingaccessrightsreview">
				<Param name="F1665591582067" viewparam="filterbypermissiontag" viewparamvalue="{param.filterbypermissiontag}"/>
				<Param name="F1665591595561" viewparam="filterbyaccounttag" viewparamvalue="{param.filterbyaccounttag}"/>
				<Param name="F1665591606509" viewparam="safelist" viewparamvalue="{param.safelist}"/>
				<Param name="F1758636523779" viewparam="ruleuid" viewparamvalue="{param.ruleuid}"/>
			</InnerView>
			<FilterList>
				<Filter name="F1665591643396" expression="dataset.key.get()" comment="Remove duplicated lines in case of several line managers for a single individual" type="Deduplicate"/>
			</FilterList>
		</Component>
		<Component name="C1665592012685" type="scriptview" x="306" y="277" w="300" h="50" title="filter orphaned accounts" enable="{param.includeorphanaccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665594046405" expression="dataset.isEmpty(&apos;reconuid&apos;)" comment="remove orphaned users" type="Exclude"/>
			</FilterList>
		</Component>
		<Component name="C1665592033143" type="scriptview" x="30" y="400" w="302" h="114" title="filter EPV user accounts" enable="{param.includeuseraccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665593990044" expression="dataset.UserType.get().equalsIgnoreCase(&apos;EPVUser&apos;)" type="Exclude" comment="remove user accounts"/>
			</FilterList>
		</Component>
		<Link name="L1665592033868" source="C1665592033143" target="C1665592012685" priority="3" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1665592058800" type="scriptview" x="652" y="297" w="300" h="50" title="filter leaver accounts" enable="{param.includeleaveraccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665594080872" expression="!dataset.isEmpty(&apos;reconnoownercode&apos;) &amp;&amp; dataset.reconnoownercode.get().equalsIgnoreCase(&apos;leave&apos;)" comment="remove leaver users" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1665592059033" source="C1665592012685" target="C1665592058800" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1665593706976" type="scriptview" x="532" y="438" w="300" h="50" title="filter AIM accounts" enable="{param.includetechaccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665594114473" expression="dataset.UserType.get().equalsIgnoreCase(&apos;AIMAccount&apos;)" comment="filtrer tech users" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1665593707442" source="C1665592058800" target="C1665593706976" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1665593867739" type="joinview" x="715" y="478" w="300" h="50" title="add safe owner">
			<InnerView name="bwir_safeaccesssafeownerbv">
				<Param name="F1665648561498" viewparam="safelist" viewparamvalue="{param.safelist}"/>
			</InnerView>
			<Join jointype="left" key1="{dataset.safeuid.get()}" key2="{dataset.safeuid.get()}"/>
		</Component>
		<Component name="C1665593879361" type="scriptview" x="492" y="712" w="300" h="50" title="set reviewer">
			<Script onscriptread="setreviewer"/>
			<ExcludeList>
				<Exclude name="defaultreviewerfullname"/>
				<Exclude name="defaultreviewerhrcode"/>
				<Exclude name="defaultreviewermail"/>
				<Exclude name="defaultrevieweruid"/>
			</ExcludeList>
		</Component>
		<Component name="C1665593881863" type="scriptview" x="544" y="646" w="300" h="50" title="filter for one reviewer if needed" enable="{!param.isEmpty(&apos;filterbyreviewer&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665649108974" expression="!dataset.isEmpty(&apos;revieweruid&apos;) &amp;&amp; param.filterbyreviewer.get().equals(dataset.revieweruid.get())" type="Include" comment="Filter the results for one reviewer only"/>
			</FilterList>
		</Component>
		<Link name="L1665593882266" source="C1665593879361" target="C1665593881863" priority="5" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1665594878291" type="scriptview" x="645" y="715" w="300" h="50" title="do not take latest review status if identity position changed since then" enable="{param.includelatestreviewstatus.get().equals(&apos;1&apos;)}">
			<Script onscriptread="checkIdentityPosition"/>
		</Component>
		<Component name="C1665594885488" type="scriptview" x="471" y="731" w="300" h="50" title="filter if already reviewed" enable="{param.includelatestreviewstatus.get().equals(&apos;1&apos;) &amp;&amp; param.filterifalreadyreviewed.get().equals(&apos;1&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1665595012300" expression="!dataset.isEmpty(&apos;reviewstatus&apos;)" type="Exclude" comment="filter if the entry has already been reviewed in the timeframe"/>
			</FilterList>
		</Component>
		<Link name="L1665594886013" source="C1665594878291" target="C1665594885488" priority="2" errorlink="true" linecustom="true" color="255,0,0"/>
