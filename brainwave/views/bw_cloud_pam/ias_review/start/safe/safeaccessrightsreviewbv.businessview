			</InnerView>
			<Join jointype="full" key1="{dataset.key.get()}" key2="{dataset.key.get()}"/>
			<FilterList>
				<Filter name="F1670334520211" expression="dataset.key.get()" comment="Remove duplicated lines in case of several line managers for a single individual" type="Deduplicate"/>
			</FilterList>
			<ViewComputedAttribute name="UserType" displayname="User Type" type="String" expression="dataset.isEmpty(&apos;RawUserType&apos;)?&quot;Booking&quot;:dataset.RawUserType.get()"/>
			<ViewComputedAttribute name="rightlabel" displayname="Right Label" type="String" expression="dataset.accountlogin.get()+&apos; (&apos;+&apos;type: &apos;+(dataset.isEmpty(&apos;UserType&apos;)?&quot;Other&quot;:dataset.UserType.get())+(dataset.isEmpty(&apos;identityfullname&apos;)?&apos;)&apos;:(&apos;, id: &apos;+dataset.identityfullname.get()+&apos;)&apos;))+&apos; on safe &apos;+dataset.safedisplayname.get()+&apos; (&apos;+dataset.permissiondisplayname.get()+&apos;)&apos;+&apos; in vault &apos;+dataset.vaultdisplayname.get()"/>
		</Component>
		<Link name="L1670333948612" source="C1665588440718" target="C1670333945353" priority="2" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1670494665919" type="scriptview" x="486" y="170" w="300" h="50" title="filter Built-In accounts" enable="{param.includebuiltinusers.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
