<View family="businessview" name="bwpam_casafeusersctrl_bv" displayname="ca safe users controls">
	<Definition scriptfile="/views/bw_cloud_pam/searchanalytics/casaferightsbv.javascript" name="D1671557133063">
		<Component type="innerview" x="30" y="10" w="300" h="64" name="C1671557133063" title="safe users">
