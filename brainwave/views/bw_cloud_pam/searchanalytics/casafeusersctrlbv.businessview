				<Param name="F1671558376996" viewparam="minimumrisklevel" viewparamvalue="{param.minimumrisklevel.get()}"/>
			</InnerView>
			<Union primary_discriminator="prim" secondary_discriminator="sec" discriminatorcolumn="discr"/>
		</Component>
		<Component name="C1671558455057" type="trendview" x="847" y="384" w="300" h="50" title="trend" enable="{!param.isEmpty(&apos;comparisontimeslot&apos;)}">
			<Trend timeslot="{param.comparisontimeslot.get()}" key="{dataset.key.get()}" comparing_column="val" trend_column_name="status" include_removed="true"/>
			<FilterList>
				<Filter name="F1671558557340" expression="param.excluderemoved.get() &amp;&amp; &quot;Removed&quot;.equals(dataset.status.get())" comment="remove Removed" type="Exclude"/>
				<Filter name="F1671558572653" expression="param.excludesimilar.get() &amp;&amp; &quot;Identical&quot;.equals(dataset.status.get())" comment="remove Similar" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1671558455262" source="C1671558309395" target="C1671558455057" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1671646773791" type="joinview" x="1105" y="246" w="300" h="50" title="safe effective users">
			<Join jointype="full" key1="{dataset.key.get()}" key2="{dataset.key.get()}"/>
			<InnerView name="bwpam_safeeffectiveusersctrl">
				<Param name="F1671646820485" viewparam="includebuiltin" viewparamvalue="{param.includebuiltin.get()}"/>
				<Param name="F1671647760956" viewparam="controls" viewparamvalue="{param.controls}"/>
