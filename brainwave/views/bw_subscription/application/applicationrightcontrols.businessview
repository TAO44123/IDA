				<Param name="F1639070856527" viewparam="uid" viewparamvalue="{param.uid.get()}"/>
			</InnerView>
			<Join jointype="left" key1="{dataset.rightkey.get()}" key2="{dataset.control_rightkey.get()}"/>
			<ExcludeList>
			</ExcludeList>
		</Component>
		<Link name="L1640247094628" source="C1639070691329" target="C1639070816920" priority="2" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1640339564209" type="joinview" x="439" y="442" w="300" h="50" title="get identity controls flags">
			<InnerView name="bws_application_identitycontrolscolumns" prefix="control_">
				<Param name="F1640339602462" viewparam="uid" viewparamvalue="{param.uid.get()}"/>
			</InnerView>
			<Join jointype="left" key1="{dataset.identitykey.get()}" key2="{dataset.control_identitykey.get()}"/>
			<ExcludeList>
				<Exclude name="control_identitykey"/>
				<Exclude name="control_rightkey"/>
			</ExcludeList>
		</Component>
		<Link name="L1640339564456" source="C1639070816920" target="C1640339564209" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="N1640340466241" type="note" x="358" y="248" w="300" h="50" title="Account rights related controls"/>
		<Component name="N1640340479824" type="note" x="359" y="354" w="300" h="50" title="Identity rights related controls (overallocation)"/>
