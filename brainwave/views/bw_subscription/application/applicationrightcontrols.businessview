<View family="businessview" name="bws_applicationrightcontrols" displayname="applicationrightcontrols">
	<Definition scriptfile="/views/bw_subscription/application/applicationrightcontrols.javascript" name="D1639070558372">
		<Component type="innerview" x="30" y="10" w="300" h="64" name="C1639070558372" title="rights">
			<InnerView name="bws_application_rights">
				<Param name="F1639070595837" viewparam="uid" viewparamvalue="{param.uid.get()}"/>
			</InnerView>
		</Component>
		<Component name="C1639070691329" type="trendview" x="630" y="173" w="300" h="50" title="detect new rights">
			<Trend timeslot="-1" key="{dataset.key.get()}" comparing_column="val" trend_column_name="status" include_removed="false"/>
			<ExcludeList>
				<Exclude name="key"/>
			</ExcludeList>
		</Component>
		<Link name="L1639070691418" source="C1639070558372" target="C1639070691329" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1639070816920" type="joinview" x="422" y="322" w="300" h="50" title="get controls flags">
