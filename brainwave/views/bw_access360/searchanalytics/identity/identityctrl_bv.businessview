<View family="businessview" name="a360s_identityctrl_bv" displayname="identityctrl_bv">
	<Definition scriptfile="/views/bw_access360/searchanalytics/identity/identityaccounts_bv.javascript" name="D1612722433445">
		<Component type="innerview" x="30" y="10" w="300" h="64" name="C1612722433444" title="identity controls">
			<InnerView name="access360r_identityctrl">
				<Param name="F1617349050735" viewparam="controls" viewparamvalue="{param.controls}"/>
