<?xml version="1.0" encoding="UTF-8"?>
<View family="businessview" name="access360r_repositorygroupmembersreviewbv" displayname="repository group direct members review bv">
	<Definition scriptfile="/views/bw_access360/searchanalytics/repository/groupmembershipreview/repositorygroupmembersreviewbv.javascript" name="D1697218257563">
		<Component type="innerview" x="30" y="10" w="372" h="64" name="C1697218257562" title="repository group direct members review">
			<InnerView name="access360r_repositorygroupmembersreview">
				<Param name="F1697292813939" viewparam="filterbyaccounttag" viewparamvalue="{param.filterbyaccounttag}"/>
				<Param name="F1697292840100" viewparam="repositorylist" viewparamvalue="{param.repositorylist}"/>
				<Param name="F1697292855561" viewparam="filterbygrouptag" viewparamvalue="{param.filterbygrouptag}"/>
				<Param name="F1697292875933" viewparam="includegroupswithoutowner" viewparamvalue="{param.includegroupswithoutowner.get()}"/>
				<Param name="F1697377184536" viewparam="includedynamicgroups" viewparamvalue="{param.includedynamicgroups.get()}"/>
				<Param name="F1755523294178" viewparam="ruleuid" viewparamvalue="{param.ruleuid.get()}"/>
			</InnerView>
		</Component>
		<Component name="C1697218443810" type="scriptview" x="30" y="180" w="305" h="114" title="filter user accounts" enable="{param.includeuseraccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697375839707" expression="!dataset.isEmpty(&apos;identityuid&apos;)" comment="remove user accounts" type="Exclude"/>
			</FilterList>
		</Component>
		<Component name="C1697293027388" type="scriptview" x="30" y="290" w="309" h="114" title="filter orphaned accounts" enable="{param.includeorphanaccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697375875138" expression="dataset.isEmpty(&apos;reconuid&apos;)" comment="remove orphaned accounts" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1697293027816" source="C1697218443810" target="C1697293027388" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697293041286" type="scriptview" x="30" y="400" w="309" h="114" title="filter leaver accounts" enable="{param.includeleaveraccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697375905742" expression="!dataset.isEmpty(&apos;reconnoownercode&apos;) &amp;&amp; dataset.reconnoownercode.get().equalsIgnoreCase(&apos;leave&apos;)" comment="remove leaver accounts" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1697293041497" source="C1697293027388" target="C1697293041286" priority="5" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697293051052" type="scriptview" x="30" y="510" w="309" h="114" title="filter tech accounts" enable="{param.includetechaccounts.get().equals(&apos;0&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697375937815" expression="!dataset.isEmpty(&apos;reconnoownercode&apos;) &amp;&amp; !dataset.reconnoownercode.get().equalsIgnoreCase(&apos;leave&apos;)" comment="remove tech accounts" type="Exclude"/>
			</FilterList>
		</Component>
		<Link name="L1697293051246" source="C1697293041286" target="C1697293051052" priority="5" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697374627924" type="joinview" x="949" y="326" w="300" h="50" title="get latest review status">
			<InnerView name="bwaccess360r_repositorygroupmemberslastreview">
				<Param name="F1697374764529" viewparam="filterminimumreviewdate" viewparamvalue="{param.filterminimumreviewdate.get()}"/>
				<Param name="F1697374779022" viewparam="includelatestreviewstatus" viewparamvalue="{param.includelatestreviewstatus.get()}"/>
				<Param name="F1697374790312" viewparam="repositorylist" viewparamvalue="{param.repositorylist}"/>
			</InnerView>
			<Join jointype="left" key1="{dataset.key.get()}" key2="{dataset.key.get()}"/>
		</Component>
		<Link name="L1697374628115" source="C1697293051052" target="C1697374627924" priority="5" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697377243115" type="scriptview" x="30" y="620" w="416" h="114" title="do not take latest review status if identity position changed since then" enable="{param.includelatestreviewstatus.get().equals(&apos;1&apos;)}">
			<Script onscriptread="checkIdentityPosition"/>
		</Component>
		<Link name="L1697377244081" source="C1697374627924" target="C1697377243115" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697377702359" type="scriptview" x="30" y="730" w="416" h="114" title="filter if already reviewed" enable="{param.includelatestreviewstatus.get().equals(&apos;1&apos;) &amp;&amp; param.filterifalreadyreviewed.get().equals(&apos;1&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697377770922" expression="!dataset.isEmpty(&apos;reviewstatus&apos;)" type="Exclude" comment="filter if the entry has already been reviewed in the timeframe"/>
			</FilterList>
		</Component>
		<Link name="L1697377702583" source="C1697377243115" target="C1697377702359" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
