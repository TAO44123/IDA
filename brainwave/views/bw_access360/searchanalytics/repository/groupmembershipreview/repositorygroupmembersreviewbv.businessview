		<Link name="L1697379557759" source="C1625819976919_5" target="C1625833211998_2" priority="2" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697379736381" type="scriptview" x="793" y="1115" w="300" h="50" title="set reviewer">
			<Script onscriptread="setreviewer"/>
			<ExcludeList>
				<Exclude name="defaultreviewerfullname"/>
				<Exclude name="defaultreviewerhrcode"/>
				<Exclude name="defaultreviewermail"/>
				<Exclude name="defaultrevieweruid"/>
			</ExcludeList>
		</Component>
		<Link name="L1697379737422" source="C1625833211998_2" target="C1697379736381" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1697379871128" type="scriptview" x="703" y="1247" w="300" h="50" title="filter for one reviewer if needed" enable="{!param.isEmpty(&apos;filterbyreviewer&apos;)}">
			<Script onscriptread="read"/>
			<FilterList>
				<Filter name="F1697379953739" expression="!dataset.isEmpty(&apos;revieweruid&apos;) &amp;&amp; param.filterbyreviewer.get().equals(dataset.revieweruid.get())" type="Include" comment="Filter the results for one reviewer only"/>
			</FilterList>
