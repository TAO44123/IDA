			</InnerView>
			<Join jointype="left" key1="{dataset.groupuid.get()}" key2="{dataset.groupuid.get()}"/>
		</Component>
		<Link name="L1697379222119" source="C1625819976919_2" target="C1697379221660" priority="2" errorlink="true" linecustom="true" color="255,0,0"/>
		<Link name="L1697379222812" source="C1697379221660" target="C1625819976919_5" priority="3" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1625833211998_2" type="joinview" x="426" y="705" w="300" h="50" title="get default reviewer infos if needed">
			<InnerView name="bw_access360r_applicationdefaultreviewer">
				<Param name="F1625833335047" viewparam="uid" viewparamvalue="{param.defaultrevieweruid.get()}"/>
			</InnerView>
			<Join jointype="left" key2="{dataset.defkey.get()}" key1="{dataset.defkey.get()}"/>
