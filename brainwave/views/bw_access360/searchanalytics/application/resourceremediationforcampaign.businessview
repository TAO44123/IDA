<View family="businessview" name="bwaccess360_resourceremediationforcampaign" displayname="resourceremediationforcampaign">
	<Definition scriptfile="/views/bw_access360/searchanalytics/application/resourceremediationforcampaign.javascript" name="D1647879238160">
