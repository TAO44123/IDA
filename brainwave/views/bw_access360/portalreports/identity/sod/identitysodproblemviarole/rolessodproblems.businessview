		<Component name="C1757667285885" type="joinview" x="350" y="316" w="300" h="50" enable="{param.sodmatrixuid.get()!=null}" title="filter on sod matrix">
			<InnerView name="bwa360_rolesodproblemsmatrix">
				<Param name="F1757667735617" viewparam="uid" viewparamvalue="{param.sodmatrixuid.get()}"/>
			</InnerView>
			<Join jointype="left" key1="{dataset.controldisplayname.get()}" key2="{dataset.permission_pair_controldisplayname.get()}"/>
			<FilterList>
