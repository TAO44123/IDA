			<InnerView name="bwa360_identitysodexceptionsviarole_nb"/>
			<ViewComputedAttribute name="nbidentity" displayname="nb identity" type="Integer" expression="dataset.nbidentity_exception_role.get()!=null&amp;&amp;param.rejectExceptions.get()?dataset.nbidentity_all.get()-dataset.nbidentity_exception_role.get():dataset.nbidentity_all.get()"/>
			<Join jointype="left" key1="{dataset.controldisplayname.get()}" key2="{dataset.controldisplayname.get()}"/>
			<FilterList>
