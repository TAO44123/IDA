<?xml version="1.0" encoding="UTF-8"?>
<View name="bwiasr_processisactive" errorifempty="false" distinct="true" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" concept="ticketlog" displayname="initinprogress" notes="" begindate="" enddate="">
	<ViewParam name="tickettype" displayname="ticket type">
		<Value name="0" data="REMEDIATION_INITTICKETS"/>
	</ViewParam>
	<ViewParam name="delay" displayname="delay" type="Integer" defaultvalue="1"/>
	<ViewParam name="testday" displayname="testday" type="Integer" defaultvalue="{(new Date()).getTime()/(1000*3600*24)-param.delay.get()}"/>
	<ViewSort name="sort"/>
	<ViewAttribute name="A1655714255961_483" attribute="recorduid" alias="nb" displayname="nb" operator="or" aggregate="COUNT DISTINCT" removedfromprojection="false" globalfilter="false"/>
	<ViewAttribute name="A1655714264022_484" attribute="tickettype" operator="or" removedfromprojection="true" globalfilter="false">
		<ViewAttributeFilter name="F1655714381660_0" reference="tickettype" operation="eq" ignoreifempty="false"/>
	</ViewAttribute>
	<ViewAttribute name="A1655714355545_493" attribute="ticketopen" operator="or" removedfromprojection="true" globalfilter="false">
		<ViewAttributeFilter name="F1655714372591_0" operation="isTrue" ignoreifempty="false"/>
	</ViewAttribute>
	<ViewAttribute name="A1664272824061_803" attribute="submissionday" operator="or" removedfromprojection="true" globalfilter="false">
		<ViewAttributeFilter name="F1664273068730_0" reference="testday" operation="gt" ignoreifempty="false"/>
	</ViewAttribute>
	<ViewNote name="N1664273409746_836" displayname="Process launched more than DELAY days ago are ignored&#xA;(it can be the case if a process crashed)" x="343" y="23" width="520" height="150"/>
</View>
