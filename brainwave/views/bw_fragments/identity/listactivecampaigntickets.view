<?xml version="1.0" encoding="UTF-8"?>
<View name="bwf_identitylistactivecampaigntickets" errorifempty="false" distinct="true" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" concept="ticketlog" displayname="List of review tickets for an active campaign" notes="" begindate="" enddate="">
	<ViewParam name="revieweruid" displayname="Reviewer uid" type="String">
		<Value name="0" data="ID0000490_1709224115827_12698"/>
	</ViewParam>
	<ViewParam name="includedcampaign" displayname="Included campaign" type="String">
		<Value name="0" data="10034"/>
	</ViewParam>
	<ViewParam name="filteractivetasks" displayname="Filter on tickets to review only" type="Boolean" defaultvalue="false">
		<Value name="0" data="true"/>
	</ViewParam>
	<ViewSqlFilter name="F1659106470165" expression="dataset.revieweruid=param.revieweruid OR dataset.accountableuid=param.revieweruid"/>
	<ViewComputedAttribute name="_key" displayname="Key (campaign recorduid + review ticket record uid)" type="String" expression="param.includedcampaign.get() + &apos;-&apos; + dataset.recorduid.get()"/>
	<ViewSort name="sort"/>
	<ViewAttribute name="1645199648983_465" attribute="tickettype" operator="or" removedfromprojection="true" globalfilter="false">
		<ViewAttributeFilter name="F1628339918734_0" operation="eq" ignoreifempty="false">
			<Value name="0" data="ADHOC_UAR"/>
		</ViewAttributeFilter>
	</ViewAttribute>
	<ViewAttribute name="1645199708328_467" attribute="recorduid" operator="or" removedfromprojection="true" globalfilter="false">
		<ViewAttributeFilter name="F1630309887906_0" reference="includedcampaign" operation="eq" ignoreifempty="false"/>
	</ViewAttribute>
	<ViewJoin name="J1645199715551_468" kind="inner" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" join="ticketAction">
		<ViewJoin name="J1645199720118_469" kind="inner" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" join="ticketreview">
			<ViewJoin name="J1626348416358_424" prefix="reviewer" kind="inner" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" join="actor">
				<ViewAttribute name="1645199737478_472" attribute="uid" operator="or" removedfromprojection="true" globalfilter="false"/>
			</ViewJoin>
			<ViewJoin name="J1659106387225_1499" prefix="accountable" kind="inner" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" join="accountable">
				<ViewAttribute name="1659106404699_1502" attribute="uid" operator="or" removedfromprojection="true" globalfilter="false"/>
			</ViewJoin>
			<ViewAttribute name="A1717057799924_457" attribute="recorduid" operator="or" removedfromprojection="false" globalfilter="false"/>
			<ViewAttribute name="1717059797962_551" attribute="status" operator="or" removedfromprojection="true" globalfilter="false" enabled="param.filteractivetasks.get()">
				<ViewAttributeFilter name="F1680020801559_0" operation="eq" ignoreifempty="false">
					<Value name="0" data="to be reviewed"/>
				</ViewAttributeFilter>
			</ViewAttribute>
		</ViewJoin>
	</ViewJoin>
</View>
