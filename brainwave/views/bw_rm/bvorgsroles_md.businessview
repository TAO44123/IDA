			<InnerView name="bwpm_nbidentitieswithroleperorg_md"/>
			<ViewComputedAttribute name="nbidentities" displayname="nbidentities" type="Integer" expression="!dataset.isEmpty(&apos;nbidentities&apos;)?dataset.nbidentities.get():0"/>
