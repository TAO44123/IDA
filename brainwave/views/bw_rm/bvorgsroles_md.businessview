<View family="businessview" name="bwpm_bvorgsroles_1" displayname="bvorgsroles">
	<Definition scriptfile="views/bw_rm/bv.javascript" name="D1521966660062">
		<Component type="innerview" x="30" y="10" w="300" h="64" name="C1521966660061" title="orgs">
			<InnerView name="bwpm_orgs"/>
		</Component>
		<Component name="C1521966673539" type="joinview" x="391" y="212" w="300" h="50" title="nb roles per org">
			<InnerView name="bwpm_nbroleperorg_md"/>
			<Join jointype="left" key1="{dataset.uid.get()}" key2="{dataset.org_uid.get()}"/>
