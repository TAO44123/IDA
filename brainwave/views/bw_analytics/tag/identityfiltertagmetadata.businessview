<?xml version="1.0" encoding="UTF-8"?>
<View family="businessview" name="bwa_identityfiltertagmetadata" displayname="identityfiltertagmetadata">
	<Definition scriptfile="/views/bw_analytics/tag/identityfiltertagmetadata.javascript" name="D1608636145002">
		<Component type="innerview" x="30" y="10" w="300" h="64" name="C1608636145002" title="all identities with tag metadata">
			<InnerView name="bwa_identitytagmetadata">
				<Param name="F1608647891871" viewparam="tag" viewparamvalue="{param.tag.get()}"/>
			</InnerView>
			<FilterList>
				<Filter name="F1608636640673" expression="param.uids.indexOf(dataset.uid.get())==-1" comment="Exclude identities which are not part of the selection" type="Exclude"/>
			</FilterList>
		</Component>
		<Component name="N1608636648042" type="note" x="370" y="15" w="300" h="50" title="Tricky filter to get around the SQL multivalued parameter limit"/>
	</Definition>
	<ViewParam name="uids" displayname="uids">
