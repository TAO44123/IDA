		<Component name="C1595859296239" type="unionview" x="574" y="312" w="300" h="50" title="nb folder accounts">
			<InnerView name="bwa_foldernbaccounts"/>
			<Union primary_discriminator="right" secondary_discriminator="folder" discriminatorcolumn="discr"/>
