			<InnerView name="bwa_accountmaxfoldersensitivitylevel" prefix="folder_"/>
			<Join jointype="left" key1="{dataset.uid.get()}" key2="{dataset.folder_uid.get()}"/>
			<FilterList>
			</FilterList>
		</Component>
		<Link name="L1608139520683" source="C1608139399637" target="C1608139517096" priority="4" errorlink="true" linecustom="true" color="255,0,0"/>
		<Component name="C1608140103552" type="scriptview" x="681" y="543" w="300" h="50" title="max sensitivity level">
			<Script onscriptread="compute"/>
			<FilterList>
				<Filter name="F1608141948517" expression="dataset.isEmpty(&apos;maxsensitivitylevel&apos;)" comment="no max sensitivity level found" type="Exclude"/>
			</FilterList>
			<ExcludeList>
