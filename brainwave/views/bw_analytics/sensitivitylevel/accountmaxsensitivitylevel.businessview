<?xml version="1.0" encoding="UTF-8"?>
<View family="businessview" name="bwa_accountmaxsensitivitylevel" displayname="accountmaxsensitivitylevel">
	<Definition scriptfile="/views/bw_analytics/sensitivitylevel/accountmaxsensitivitylevel.javascript" name="D1608137787370">
