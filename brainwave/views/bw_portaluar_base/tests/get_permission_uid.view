<View name="get_permission_uid" errorifempty="false" distinct="true" identitysecure="false" applicationsecure="false" repositorysecure="false" searchpoint="false" concept="permission" displayname="get permission uid from others attributes" notes="permission codename and hrcode of identity are mandatory">
