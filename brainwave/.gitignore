# This file is a copy of .gitignore, to be used for the delivery of the .facet 
# It does not contain the react build output entry, so that the facet can be installed properly.
# https://support.brainwavegrc.com/jira/browse/BWIPUAR-1731

/.settings/
/configurations/*.configuration
/library/facets/*.facet
/webportal/mail.properties
/webportal/workflow.properties
/webportal/license.lic
/webportal/datasource.properties
/webportal/custom-web.xml
/webportal/data
/webportal/data/
/db/
/importfiles/
/facets_info/facets_output/
/importfiles/test/
/logs/
/scenario/
/IAS.audit


# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv
