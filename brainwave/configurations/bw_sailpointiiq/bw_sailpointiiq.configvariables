<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ConfigVariables PUBLIC "-//Brainwave//DTD ConfigVariables 1.0//EN" "urn:brainwave:igrc:dtds/configvariables.dtd">
<ConfigVariables name="bw_sailpointiiq" description="bw sailpointiiq">
	<ConfigVariable name="bw_sailpointiiq_sourcefolder" type="String" displayname="Sailpoint Identity IQ source folder" defaultvalue="{config.importfiles}/bw_sailpointiiq/"/>
	<ConfigVariable name="bw_sailpointiiq_extendschema" type="String" displayname="Boolean: true to activate preprocessing and extend schema with source schemas | false: to only ingest IIQ default schema attributes" defaultvalue="false"/>
	<ConfigVariable name="bw_sailpointiiq_mapper" type="String" displayname="Location of the IIQ mapping file" defaultvalue="{config.importfiles}/bw_sailpointiiq_mapper/"/>
</ConfigVariables>
