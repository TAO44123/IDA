		<Attribute name="A2720653729268931331" attribute="mail" column="mail" type="String" multivalued="true" persistent="false" description="This attribute specifies the list of e-mail addresses for a contact" hidden="false"/>
		<Attribute name="A2720653729268931333" attribute="managedby" column="managedby" type="String" multivalued="false" persistent="false" description="The distinguished name of the user that is assigned to manage this object" hint="groupmanageraccount" hidden="false"/>
		<Attribute name="A2720653729268931334" attribute="member" column="member" type="String" multivalued="true" persistent="false" description="The list of users that belong to the group" hint="groupemembers" hidden="true"/>
