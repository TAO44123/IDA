function getExchangeOnlineActionsDescription() {
	var exchangeonlineactions = {};
	exchangeonlineactions["A"] = "Allows the delegate to send messages as if they came directly from the mailbox or group. There's no indication that the message was sent by the delegate. ";
	exchangeonlineactions["B"] = "Allows the delegate to send messages from the mailbox or group. The From address of these messages clearly shows that the message was sent by the delegate (<Delegate> on behalf of <MailboxOrGroup>). However, replies to these messages are sent to the mailbox or group, not to the delegate. ";
	exchangeonlineactions["C"] = "Allows the delegate to open the mailbox, and view, add and remove the contents of the mailbox. Doesn't allow the delegate to send messages from the mailbox. ";
	exchangeonlineactions["D"] = "Allows to change the owner of a mailbox.";
	exchangeonlineactions["E"] = "Allows to change the permissions of a mailbox.";
	exchangeonlineactions["F"] = "Allows to delete items of a mailbox.";
	exchangeonlineactions["G"] = "Allows to read the permissions of a mailbox.";
	exchangeonlineactions["H"] = "Indicates that the delegate account is not part of the same domain.";
	exchangeonlineactions["I"] = "The user can read items within the specified folder.";
	exchangeonlineactions["J"] = "The user can create items within the specified folder.";
	exchangeonlineactions["K"] = "The user can only edit items that they created in the specified folder.";
	exchangeonlineactions["L"] = "The user can only delete items that they created from the specified folder.";
	exchangeonlineactions["M"] = "The user can edit all items in the specified folder.";
	exchangeonlineactions["N"] = "The user can delete all items in the specified folder.";
	exchangeonlineactions["O"] = "The user can create subfolders in the specified folder.";
	exchangeonlineactions["P"] = "The user is the owner of the specified folder. The user can view the folder, move the folder and create subfolders. The user can't read items, edit items, delete items or create items.";
	exchangeonlineactions["Q"] = "The user is the contact for the specified public folder.";
	exchangeonlineactions["R"] = "The user can view the specified folder, but can't read or edit items within the specified public folder.";
	exchangeonlineactions["S"] = "View only availability data.";
	exchangeonlineactions["T"] = "View availability data with subject and location.";
	return exchangeonlineactions;
}