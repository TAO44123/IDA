function getSharePointOnlineActionsDescription() {
	var sharepointactions = {};
	sharepointactions ["A"] =  "Create and change permission levels on the website and assign permissions to users and groups.";
	sharepointactions ["B"] =  "View reports on website usage. ";
	sharepointactions ["C"] =  "Create subsites such as team sites, Meeting Workspace sites, and Document Workspace sites. ";
	sharepointactions ["D"] =  "Perform all administration tasks for the website, which includes managing content. ";
	sharepointactions ["E"] =  "Add, change, or delete HTML pages or Web Part pages, and edit the website by using a Windows SharePoint Services-compatible editor. ";
	sharepointactions ["F"] =  "Apply a theme or borders to the whole website. ";
	sharepointactions ["G"] =  "Apply a style sheet (.css file) to the website. ";
	sharepointactions ["H"] =  "Create a group of users who can be used anywhere within the site collection. ";
	sharepointactions ["I"] =  "Enumerate files and folders in a website, by using an interface such as SharePoint Designer or web-based Distributed Authoring and Versioning (Web DAV). ";
	sharepointactions ["J"] =  "Create a website by using Self-Service Site Creation. ";
	sharepointactions ["K"] =  "View pages in a website. ";
	sharepointactions ["L"] =  "Enumerate permissions on the website, list, folder, document, or list item. ";
	sharepointactions ["M"] =  "View information about users of the website. ";
	sharepointactions ["N"] =  "Manage alerts for all users of the website ";
	sharepointactions ["O"] =  "Use Simple Object Access Protocol (SOAP), Web DAV, or SharePoint Designer interfaces to access the website. ";
	sharepointactions ["P"] =  "Use Client Integration Features";
	sharepointactions ["Q"] =  "Open a website, list, or folder to access items inside that container. ";
	sharepointactions ["R"] =  "Allow a user to change personal information, such as adding a picture. ";
	sharepointactions ["S"] =  "AnonymousSearchAccessWebLists";
	sharepointactions ["T"] =  "Create and delete lists, add or remove columns in a list, and add or remove public views of a list. ";
	sharepointactions ["U"] =  "Discard or check in a document that is checked out to another user. ";
	sharepointactions ["V"] =  "Add items to lists, add documents to document libraries, and add web discussion comments. ";
	sharepointactions ["W"] =  "Edit items in lists, edit documents in document libraries, edit web discussion comments in documents, and customize Web Part Pages in document libraries. ";
	sharepointactions ["X"] =  "Delete items from a list, documents from a document library, and web discussion comments in documents. ";
	sharepointactions ["Y"] =  "View items in lists, documents in document libraries, and web discussion comments. ";
	sharepointactions ["Z"] =  "Approve a minor version of a list item or document. ";
	sharepointactions ["0"] =  "View the source of documents that use server-side file handlers. ";
	sharepointactions ["1"] =  "View past versions of a list item or document. ";
	sharepointactions ["2"] =  "Delete past versions of a list item or document. ";
	sharepointactions ["3"] =  "Create e-mail alerts. ";
	sharepointactions ["4"] =  "View documents and views in a list or document library. ";
	sharepointactions ["5"] =  "AnonymousSearchAccessList";
	return sharepointactions;
}

