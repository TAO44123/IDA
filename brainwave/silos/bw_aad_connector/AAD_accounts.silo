<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="AAD_accounts" displayname="AAD accounts" parentsilo="AAD_everyone" collector="/collectors/bw_aad_connector/AD_LOAD_ACCOUNTS.collector" iterate="true" folder="{config.aad_sourceFolder}" recurse="true" filter="*_users.csv" overridensiloname="{config.siloIteratedFileShortname.split(&quot;_&quot;)[0].toString()}">
	<Repository name="repository" repositorycode="{config.siloName.toUpperCase()}" repositorydisplayname="{config.siloName.toUpperCase()}"/>
</Silo>
