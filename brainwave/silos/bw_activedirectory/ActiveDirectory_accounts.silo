<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="ActiveDirectory_accounts" displayname="AD accounts" iterate="true" folder="{config.ad_sourceFolder}" filter="*.ldif" collector="/collectors/bw_activedirectory/AD_LOAD_ACCOUNTS.collector" description="Silo loading AD accounts" overridensiloname="{config.siloIteratedFileShortname}" recurse="true" parentsilo="ActiveDirectory_everyone">
	<Connectors>
		<Connector name="C1445517029762" connector="ad_extract" configfile="{config.ad_sourceFolder}/ADCollect_Config.csv" configstatfile="{config.ad_sourceFolder}/ADCollect_Status.csv" outputfolder="{config.ad_sourceFolder}"/>
	</Connectors>
	<Repository name="repository" repositorycode="{config.siloName.toUpperCase()}" repositorydisplayname="{config.siloName.toUpperCase()}"/>
</Silo>
