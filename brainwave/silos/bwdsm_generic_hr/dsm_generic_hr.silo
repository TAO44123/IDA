<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="dsm_generic_hr" displayname="generic hr" type="hr" collector="/collectors/bwdsm_generic_hr/generic_hr_all.collector" iterate="true" recurse="true" filter="*.csv" overridensiloname="{config.siloIteratedFileShortname}" folder="{config.bw_generic_hr_sourceFolder}">
	<Repository name="repository" repositorycode="{config.siloName.toUpperCase()}" repositorydisplayname="{config.siloName.toUpperCase()}"/>
</Silo>
