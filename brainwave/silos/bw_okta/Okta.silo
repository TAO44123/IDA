<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="Okta" displayname="Okta" collector="/collectors/bw_okta/0000 load okta.collector" iterate="true" folder="{config.bw_okta_sourcefolder}" filter="users.csv" overridensiloname="xxx" recurse="true">
