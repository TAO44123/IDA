<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="bw_ias_cyberark" displayname="bw_ias_cyberark" parentsilo="bw_cyberark_identity_all" iterate="true" folder="{config.bw_cyberark_model_sourceFolder}" recurse="true" filter="*_export-mode.csv" overridensiloname="{config.siloIteratedFileShortname.replace(&apos;_export-mode&apos;,&apos;&apos;)}" collector="/collectors/bw_ias_cyberark/CyberArk/00_CA_launcher.collector" type="theoretical">
	<Repository name="repository" repositorycode="{config.siloName.toUpperCase()}" repositorydisplayname="{config.siloName.toUpperCase()}"/>
	<Application name="application" applicationcode="{config.siloName.toUpperCase()}" applicationdisplayname="{config.siloName.toUpperCase()}"/>
</Silo>
