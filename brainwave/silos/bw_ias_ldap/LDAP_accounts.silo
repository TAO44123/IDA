<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Silo PUBLIC "-//Brainwave//DTD Silo 1.0//EN" "urn:brainwave:igrc:dtds/silo.dtd">
<Silo version="1" name="LDAP_accounts" displayname="LDAP accounts" iterate="true" folder="{config.bw_ias_ldap_sourceFolder}" filter="*.ldif" collector="/collectors/bw_ias_ldap/load_accounts.collector" description="Silo loading LDAP accounts" overridensiloname="{config.siloIteratedFileShortname}" recurse="true" parentsilo="ActiveDirectory_members">
	<Repository name="repository" repositorycode="{config.siloName.toUpperCase()}" repositorydisplayname="{config.siloName.toUpperCase()}"/>
</Silo>
