<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Control PUBLIC "-//Brainwave//DTD Control Type 1 1.0//EN" "urn:brainwave:igrc:dtds/control_t9.dtd">
<Control type="9" version="10" code="BWPAM_CA_VAULT_ACCOUNT12" name="CA_VAULT_ACCOUNT12_disabled_accounts_access" displayname="Disabled user accounts giving access to a vault" risklevel="1" executionplan="true" notes="Disabled user accounts giving access to a CyberArk vault." riskinfo="Legacy user accounts can be removed if they are very old to improve repository quality." suggestedmitigation="Remove very old disabled accounts." activationexpression="config.isPamBoosterActive==&apos;true&apos; &amp;&amp; config.licenseFeatures.contains(&apos;pam&apos;)">
	<ControlType9 name="t9" permission="perm_vault_recorduid" entity="account_recorduid" type="Account">
		<ControlView name="view" view="safevault_access_accounts_disabled">
			<ControlViewParam name="type">
				<Value name="0" data="vault"/>
			</ControlViewParam>
		</ControlView>
	</ControlType9>
	<ControlMetrics name="metrics">
		<Metric name="count" enabled="true"/>
		<Metric name="ratio" enabled="false"/>
	</ControlMetrics>
	<ControlTags name="tags">
		<Tag name="custom9" content="CA_VAULT_ACCOUNT12"/>
		<Tag name="family" content="pam"/>
		<Tag name="scope" content="vault"/>
		<Tag name="type" content="quality"/>
	</ControlTags>
</Control>
