'use strict';

if (!window.brainwave) {
    window.brainwave = {};
}

// stylesheet is handled in the java side, using requireCSS
if (window.rap)
    rap.registerTypeHandler("brainwave.IndicatorGroup", {

        factory: function (properties) {
            return new brainwave.IndicatorGroupHandler(properties);
        },
        destructor: "destroy",
        properties: [ "editing"],
        methods: ["updateData"],
        events: ["render",  "edit"]
    });

brainwave.IndicatorGroupHandler = class IndicatorGroupHandler {
    constructor(properties) {
        bindAll(this, ["onResize", "onReady", "onRender"]);
        this.parent = rap.getObject(properties.parent);
        this.createControls(this.parent, properties);
        this.parent.addListener("Resize", this.onResize);
        rap.on("render", this.onRender);
        this.ready = false;
    }

    createControls(parent, properties) {
        // create root container
        const container = document.createElement("div");
        parent.append(container);
        this.container = container;
        //create child indicator with default options
        const self = this;
        this.indicatorGroup = new brainwave.IndicatorGroup(container, properties.config, properties.parent,(editInfo)=> { self.handleEdit(editInfo)} );
    }


    onReady() {
        this.ready = true;
        this.onResize();
        if (this._data) {
            this.setData(this._data);
        }
    }

    onRender() {
        if (this.container.parentNode) {
            rap.off("render", this.onRender);
            this.onReady();
            rap.on("send", this.onSend);
        }
    }

    onSend() {
    }

    onResize() {
        try {
            if (this.ready) {
                var area = this.parent.getClientArea();
                this.indicatorGroup.resize(area[2], area[3]);
            }
        } catch (e) {
            console.log(e);
        }
    }

    handleEdit(editInfo ) {
        const remoteObject = rap.getRemoteObject(this);
        remoteObject.notify("edit",  editInfo);
    }

    destroy() {
        //TODO check memory leak
        //nsole.debug("indicator.destroy()+ this.container=", this.container );
        rap.off("send", this.onSend);
        $(this.container).remove();
        this.indicatorGroup.destroy();
    }

    // data = { value,  valueString, prevValue, status  }
    updateData(data) {
        if (this.ready) {
            this.indicatorGroup.setData(data.index, data);
        } else {
            this._data = data;
        }
    }

    setEditing(editing) {
        this.indicatorGroup.setEditing(editing);
    }

}

var bind = function (context, method) {
    return function () {
        return method.apply(context, arguments);
    };
};

var bindAll = function (context, methodNames) {
    for (var i = 0; i < methodNames.length; i++) {
        var method = context[methodNames[i]];
        context[methodNames[i]] = bind(context, method);
    }
}


