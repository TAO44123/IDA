	<Definition label="CA Identity EntraID Users" scriptfile="collectors/bw_ias_cyberark/CyberArk_Identity/bw_cyberark_identity.javascript" name="P1756900699943_kCMQVF241xSBN8U1IBkxQ" startingpoint="C1727869837429_1">
