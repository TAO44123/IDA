				<Action name="U1635931409073" action="add" attribute="EVD_isExpired_computed" type="Boolean" multivalued="false" newvalue="{ (dataset.isEmpty(&apos;EVD_expirationdate_formated&apos;) ? false : ((dataset.EVD_expirationdate_formated.get().diff(new java.util.Date(),&quot;d&quot;) &gt; 0) ? false : true)) }" errorexist="false"/>
				<Action name="U1639157021506" action="add" attribute="ldap_expirationdate" type="String" multivalued="false" newvalue="{dataset.EVD_expirationdate_formated.get() != null ? dataset.EVD_expirationdate_formated.get().toLDAPString() : null }" errorexist="false"/>
