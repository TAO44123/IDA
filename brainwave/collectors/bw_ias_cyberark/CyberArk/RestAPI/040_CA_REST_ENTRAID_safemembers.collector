		<Link name="L1730382721099" source="C1617217653791_3" target="C1617040697402_2" priority="1"/>
		<Component name="N1733217985621" type="note" x="510" y="23" w="300" h="132" title="Add EntraID users in safes&#xA;Join 1 : join safe members with Identity users to get the directory service uuid&#xA;Join 2 : join safe members with EntraID users to get the EntraID internal name&#xA;Join 3 : join the directory service uuid in Join 1 to get the repository name of the user"/>
	</Definition>
	<Configuration default="noname">
		<Values name="noname" configuration="noname"/>
		<Variables>
			<Variable name="inputfilename"/>
			<Variable name="cyberark_path"/>
			<Variable name="identity_repo"/>
		</Variables>
