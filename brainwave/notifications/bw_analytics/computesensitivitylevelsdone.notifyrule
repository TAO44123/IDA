<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE NotifyRule PUBLIC "-//Brainwave//DTD Notify Rule 1.0//EN" "urn:brainwave:igrc:dtds/notifyrule.dtd">
<NotifyRule version="1" name="bwa_computesensitivitylevelsdone" displayname="compute sensitivity levels done" description="compute sensitivity levels done">
	<Mail recipientview="br_identity" sendername="{config.bwa_sendername}" sendermail="{config.bwa_senderemail}" recipientfullnameattribute="fullname" recipientmailattribute="mail" recipientuidattribute="uid" subject="Accounts and Identities sensitivity levels refreshed" body="{image.header}&#xA;&lt;pre&gt;&#xA;Dear {dataset.givenname.get()},&#xA;&#xA;This email to inform you that accounts and identities sensitivity levels have been properly refreshed.&#xA;You can now browse the data to discover the most sensitive accounts and identities.&#xA;&#xA;Regards,&#xA;&lt;/pre&gt;">
		<Embeddeds>
			<Embedded name="I1608197803997" embeddedimage="header" embeddedfile="/reports/icons/various/mailheader.png"/>
		</Embeddeds>
	</Mail>
</NotifyRule>
